#!/usr/bin/env bash
set -euo pipefail

ZERO_SHA="0000000000000000000000000000000000000000"
REPO_ROOT="$(git rev-parse --show-toplevel)"
REMOTE_NAME="${1:-origin}"
RUNTIME_FIDELITY_REGEX='^(plugins/[^/]+/(hooks|agents)/|plugins/[^/]+/\.claude-plugin/(hooks\.json|plugin\.json)$|plugins/opspal-core/scripts/|scripts/|\.github/workflows/|\.githooks/pre-push$|package(-lock)?\.json$)'
CHANGED_FILES_FILE="$(mktemp "${TMPDIR:-/tmp}/opspal-pre-push-files.XXXXXX")"
PUSH_REFS_FILE="$(mktemp "${TMPDIR:-/tmp}/opspal-pre-push-refs.XXXXXX")"

cleanup() {
  rm -f "$CHANGED_FILES_FILE" "$PUSH_REFS_FILE"
}

trap cleanup EXIT

cd "$REPO_ROOT"
cat > "$PUSH_REFS_FILE"

echo "Running commercial pre-push guardrails..."

npm run docs:ci >/dev/null
npm run verify:encrypted-assets >/dev/null

DEFAULT_BASE="HEAD"
if git rev-parse --verify "${REMOTE_NAME}/main" >/dev/null 2>&1; then
  DEFAULT_BASE="$(git merge-base HEAD "${REMOTE_NAME}/main")"
elif git rev-parse --verify HEAD^ >/dev/null 2>&1; then
  DEFAULT_BASE="$(git rev-parse HEAD^)"
fi

scan_commit_range_for_secrets() {
  local base_ref="$1"
  local head_ref="$2"
  local log_opts="$head_ref"

  if [ "$base_ref" != "$head_ref" ]; then
    log_opts="${base_ref}..${head_ref}"
  fi

  "$GITLEAKS" detect --source "$REPO_ROOT" --config "$REPO_ROOT/.gitleaks.toml" --log-opts "$log_opts" --exit-code 1 --no-banner 2>/dev/null || {
    echo ""
    echo "BLOCKED: Secrets detected in outgoing commits."
    echo "  Commit range: $log_opts"
    echo "  Run: gitleaks detect --source . --config .gitleaks.toml --log-opts \"$log_opts\" --verbose"
    echo "  Fix the issues, then retry the push."
    exit 1
  }
}

resolve_base_ref() {
  local remote_sha="$1"

  if [ -z "${remote_sha:-}" ] || [ "$remote_sha" = "$ZERO_SHA" ]; then
    printf '%s\n' "$DEFAULT_BASE"
    return
  fi

  printf '%s\n' "$remote_sha"
}

# Layer 1: Secret scanning (blocks push if secrets are detected in outgoing commits)
GITLEAKS="$(command -v gitleaks 2>/dev/null || echo "$HOME/.local/bin/gitleaks")"
if [ -x "$GITLEAKS" ]; then
  echo "Scanning outgoing commits for secrets..."
  ran_secret_scan="false"

  while read -r local_ref local_sha remote_ref remote_sha; do
    if [ -z "${local_sha:-}" ] || [ "$local_sha" = "$ZERO_SHA" ]; then
      continue
    fi

    base_ref="$(resolve_base_ref "$remote_sha")"
    scan_commit_range_for_secrets "$base_ref" "$local_sha"
    ran_secret_scan="true"
  done < "$PUSH_REFS_FILE"

  if [ "$ran_secret_scan" != "true" ]; then
    scan_commit_range_for_secrets "$DEFAULT_BASE" HEAD
  fi

  echo "Secret scan passed."
else
  echo "WARNING: gitleaks not found — skipping pre-push secret scan"
fi

ran_range_check="false"

record_changed_files() {
  local base_ref="$1"
  local head_ref="$2"

  git diff --name-only "$base_ref" "$head_ref" >> "$CHANGED_FILES_FILE"
}

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "${local_sha:-}" ] || [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  base_ref="$(resolve_base_ref "$remote_sha")"

  node scripts/lib/verify-plugin-version-bumps.js --base "$base_ref" --head "$local_sha" >/dev/null
  node scripts/lib/verify-commercial-repo-boundaries.js --base "$base_ref" --head "$local_sha" >/dev/null
  record_changed_files "$base_ref" "$local_sha"
  ran_range_check="true"
done < "$PUSH_REFS_FILE"

if [ "$ran_range_check" != "true" ]; then
  node scripts/lib/verify-plugin-version-bumps.js --base "$DEFAULT_BASE" --head HEAD >/dev/null
  node scripts/lib/verify-commercial-repo-boundaries.js --base "$DEFAULT_BASE" --head HEAD >/dev/null
  record_changed_files "$DEFAULT_BASE" HEAD
fi

if [ -s "$CHANGED_FILES_FILE" ] && sort -u "$CHANGED_FILES_FILE" | grep -Eq "$RUNTIME_FIDELITY_REGEX"; then
  echo "Detected runtime-sensitive changes; running runtime fidelity guardrails..."
  npm run verify:runtime-fidelity >/dev/null
fi

RTH_BIN="$REPO_ROOT/../dev-tools/recursive-test-harness/bin/rth.js"
if [ -f "$RTH_BIN" ] && sort -u "$CHANGED_FILES_FILE" | grep -qE '^plugins/'; then
  echo "Running RTH smoke test against commercial plugins..."
  # RTH L1+L2 tests are now enforced. L1 checks structure, L2 checks hook behavior.
  # All hooks must exit 0 or 2 on canonical and plugin-specific fixtures.
  node "$RTH_BIN" run --mode smoke --plugins-dir "$REPO_ROOT/plugins" --no-evidence || {
    echo ""
    echo "RTH smoke test FAILED. Fix hook exit codes before pushing."
    echo "To debug: node ../dev-tools/recursive-test-harness/bin/rth.js run --mode smoke --plugins-dir plugins --plugin <name>"
    exit 1
  }
fi

echo "Commercial pre-push guardrails passed."
