#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Resolve gitleaks binary
GITLEAKS="$(command -v gitleaks 2>/dev/null || echo "$HOME/.local/bin/gitleaks")"
if [ ! -x "$GITLEAKS" ]; then
  echo "WARNING: gitleaks not found — skipping pre-commit secret scan"
  echo "  Install: https://github.com/gitleaks/gitleaks#installing"
  exit 0
fi

echo "Scanning staged changes for secrets..."
"$GITLEAKS" protect --staged --config "$REPO_ROOT/.gitleaks.toml" --exit-code 1 --verbose

echo "Secret scan passed."
