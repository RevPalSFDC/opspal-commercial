{
  "name": "cross-platform-ops",
  "version": "1.0.0",
  "description": "Cross-platform data operations suite for Salesforce and HubSpot integration",
  "main": "mcp-server.js",
  "bin": {
    "xplat": "./cli/xplat-cli.js",
    "contact-hygiene": "./bin/contact-hygiene.js",
    "bulk-processor": "./bin/bulk-processor.js",
    "import-contacts": "./bin/import-contacts",
    "export-contacts": "./bin/export-contacts",
    "import-companies": "./bin/import-companies",
    "export-companies": "./bin/export-companies"
  },
  "scripts": {
    "start": "node mcp-server.js",
    "mcp:start": "node mcp-server.js",
    "mcp:debug": "NODE_ENV=debug node mcp-server.js",
    "cli": "node cli/xplat-cli.js",
    "xplat:map": "node cli/xplat-cli.js map",
    "xplat:dedupe": "node cli/xplat-cli.js dedupe",
    "xplat:sync": "node cli/xplat-cli.js sync",
    "xplat:analyze": "node cli/xplat-cli.js analyze",
    "xplat:config": "node cli/xplat-cli.js config",
    "test": "jest",
    "test:bulk": "jest test/hubspot-bulk.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "setup": "npm install && npm run config:init",
    "config:init": "node cli/xplat-cli.js config --init",
    "dedupe:sf": "node cli/xplat-cli.js dedupe -p salesforce",
    "dedupe:hs": "node cli/xplat-cli.js dedupe -p hubspot",
    "dedupe:cross": "node cli/xplat-cli.js dedupe --cross-platform",
    "sync:sf-to-hs": "node cli/xplat-cli.js sync -d sf-to-hs",
    "sync:hs-to-sf": "node cli/xplat-cli.js sync -d hs-to-sf",
    "sync:bidirectional": "node cli/xplat-cli.js sync -d bidirectional",
    "analyze:all": "node cli/xplat-cli.js analyze -p both",
    "map:auto": "node cli/xplat-cli.js map --auto-detect",
    "report:duplicates": "node scripts/generate-report.js duplicates",
    "report:sync": "node scripts/generate-report.js sync",
    "report:quality": "node scripts/generate-report.js quality",
    "sf:auth": "sf org login web",
    "sf:list": "sf org list",
    "hs:test": "node scripts/test-hubspot-connection.js",
    "validate": "node scripts/validate-config.js",
    "demo": "node scripts/demo.js",
    "rentable:connect": "node scripts/connect-rentable-existing-auth.js",
    "rentable:connect-interactive": "node scripts/connect-rentable-production.js",
    "rentable:switch": "bash scripts/switch-environment.sh switch rentable-production",
    "rentable:test": "bash scripts/switch-environment.sh test",
    "env:switch": "bash scripts/switch-environment.sh switch",
    "env:list": "bash scripts/switch-environment.sh list",
    "env:current": "bash scripts/switch-environment.sh current",
    "prod:analyze": "node cli/xplat-cli.js analyze -p both --sample-size 100",
    "prod:dedupe-preview": "node cli/xplat-cli.js dedupe --dry-run --threshold 0.9",
    "prod:sync-preview": "node cli/xplat-cli.js sync --dry-run --max-records 10",
    "prod:validate": "node cli/xplat-cli.js map --validate",
    "hygiene:dry": "node bin/contact-hygiene.js --mode all --dry-run",
    "hygiene:unprocessed": "node bin/contact-hygiene.js --mode unprocessed",
    "hygiene:all": "node bin/contact-hygiene.js --mode all",
    "hygiene:test": "mocha test/contactHygiene.test.js",
    "bulk:process": "node bin/bulk-processor.js process",
    "bulk:estimate": "node bin/bulk-processor.js estimate",
    "bulk:split": "node bin/bulk-processor.js split",
    "bulk:resume": "node bin/bulk-processor.js resume",
    "bulk:monitor": "node bin/bulk-processor.js monitor",
    "bulk:test": "node bin/bulk-processor.js process --dry-run",
    "bulk:migrate": "node scripts/migrate-to-bulk-v2.js",
    "agents:start": "node agents/AgentOrchestrator.js",
    "agents:start-api": "node agents/AgentOrchestrator.js --port 3000",
    "agents:start-daemon": "node agents/AgentOrchestrator.js --daemon",
    "agents:dedupe": "node agents/data/deduplication-engine.js",
    "agents:connect": "node agents/core/connection-manager.js",
    "agents:route": "node agents/orchestration/smart-router.js",
    "agents:status": "curl http://localhost:3000/status",
    "agents:list": "curl http://localhost:3000/agents"
  },
  "keywords": [
    "salesforce",
    "hubspot",
    "integration",
    "data-sync",
    "deduplication",
    "cross-platform",
    "mcp",
    "cli"
  ],
  "author": "RevPal Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@salesforce/cli": "^2.0.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.4",
    "inquirer": "^8.2.6",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "mocha": "^10.8.2",
    "nyc": "^15.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/revpal/cross-platform-ops.git"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "core/**/*.js",
      "modules/**/*.js",
      "cli/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "coverage",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/test/**/*.test.js"
    ]
  }
}
