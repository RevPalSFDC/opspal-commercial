{
  "name": "opspal-commercial",
  "version": "1.0.0",
  "description": "OpsPal commercial plugin marketplace for Claude Code — Salesforce, HubSpot, Marketo, and cross-platform RevOps plugins.",
  "type": "commonjs",
  "scripts": {
    "setup:githooks": "bash scripts/setup-githooks.sh",
    "prepare": "npm run setup:githooks",
    "docs:generate": "node scripts/generate-plugin-suite-docs.js",
    "docs:check": "node scripts/generate-plugin-suite-docs.js --check",
    "docs:lint": "node scripts/lib/docs-lint.js",
    "docs:lint:baseline": "node scripts/lib/docs-lint.js --update-baseline",
    "docs:verify-hook-path-isolation": "node scripts/lib/verify-hook-path-isolation.js",
    "docs:verify-routing-hook-coverage": "node scripts/lib/verify-routing-hook-coverage.js",
    "docs:verify-routing": "node scripts/lib/verify-routing.js",
    "docs:verify-route-coverage": "node scripts/lib/verify-route-coverage.js",
    "docs:verify-route-coverage:baseline": "node scripts/lib/verify-route-coverage.js --update-baseline",
    "docs:verify-commands": "node scripts/lib/verify-commands.js",
    "docs:verify-unused-assets": "node scripts/lib/verify-unused-assets.js",
    "docs:verify-unused-assets:baseline": "node scripts/lib/verify-unused-assets.js --update-baseline",
    "docs:verify-marketplace-catalog": "node scripts/lib/verify-marketplace-catalog.js",
    "docs:verify-version-bumps": "node scripts/lib/verify-plugin-version-bumps.js",
    "docs:verify-lifecycle-metadata": "node scripts/lib/verify-lifecycle-metadata.js",
    "docs:verify-lifecycle-metadata:baseline": "node scripts/lib/verify-lifecycle-metadata.js --update-baseline",
    "docs:verify-architecture-boundaries": "node scripts/lib/verify-architecture-boundaries.js",
    "docs:verify-architecture-boundaries:baseline": "node scripts/lib/verify-architecture-boundaries.js --update-baseline",
    "docs:verify-shell-safety": "node scripts/lib/verify-shell-safety.js",
    "docs:verify-shell-safety:baseline": "node scripts/lib/verify-shell-safety.js --update-baseline",
    "docs:verify-docs-metadata": "node scripts/lib/verify-docs-metadata.js",
    "docs:ci": "npm run docs:check && npm run docs:lint && npm run docs:verify-hook-path-isolation && npm run docs:verify-routing-hook-coverage && npm run docs:verify-routing && npm run docs:verify-route-coverage && npm run docs:verify-commands && npm run docs:verify-unused-assets && npm run docs:verify-marketplace-catalog && npm run docs:verify-version-bumps && npm run docs:verify-lifecycle-metadata && npm run docs:verify-architecture-boundaries && npm run docs:verify-shell-safety && npm run docs:verify-docs-metadata",
    "fix:agent-descriptions": "node scripts/normalize-agent-descriptions.js",
    "test:hooks": "node plugins/opspal-core/test/hooks/runner.js",
    "test:hook-critical-regressions": "bash scripts/test-hook-critical-regressions.sh",
    "verify:active-hook-contracts": "node scripts/validate-active-hook-contracts.js",
    "verify:agent-description-budget": "node scripts/validate-agent-description-budget.js",
    "verify:hook-fanout-budget": "node scripts/validate-hook-fanout-budget.js",
    "verify:hook-test-coverage": "node scripts/validate-active-hook-test-coverage.js",
    "verify:routing-integrity": "node plugins/opspal-core/scripts/lib/validate-routing-integrity.js",
    "verify:routing-runtime-integrity": "node scripts/verify-routing-runtime-integrity.js",
    "verify:runtime-replay": "node scripts/validate-runtime-incident-fixtures.js",
    "verify:version-bumps": "node scripts/lib/verify-plugin-version-bumps.js",
    "verify:encrypted-assets": "node scripts/lib/verify-encrypted-assets.js",
    "verify:repo-boundaries": "node scripts/lib/verify-commercial-repo-boundaries.js",
    "verify:hook-runtime": "npm run verify:routing-runtime-integrity && node scripts/validate-active-hook-contracts.js && node scripts/validate-active-hook-test-coverage.js && node scripts/validate-hook-fanout-budget.js && bash scripts/test-hook-critical-regressions.sh && bash scripts/test-claude-hooks-smoke.sh --skip-live",
    "verify:claude-installed-runtime": "bash scripts/test-claude-installed-runtime.sh",
    "verify:runtime-fidelity": "npm run verify:hook-runtime && npm run verify:claude-installed-runtime",
    "smoke:claude-hooks": "bash scripts/test-claude-hooks-smoke.sh",
    "smoke:claude-hooks:static": "bash scripts/test-claude-hooks-smoke.sh --skip-live",
    "smoke:marketplace": "bash scripts/smoke-commercial-marketplace.sh",
    "ci:hardening": "npm run docs:ci && npm run verify:runtime-fidelity && npm run verify:encrypted-assets && npm run verify:repo-boundaries && npm run smoke:marketplace"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RevPalSFDC/opspal-commercial.git"
  },
  "author": "RevPal Engineering <engineering@gorevpal.com>",
  "license": "Proprietary",
  "bugs": {
    "url": "https://github.com/RevPalSFDC/opspal-commercial/issues"
  },
  "homepage": "https://github.com/RevPalSFDC/opspal-commercial#readme",
  "dependencies": {
    "dotenv": "~17.2.3",
    "js-yaml": "~4.1.0",
    "playwright": "~1.57.0"
  }
}
