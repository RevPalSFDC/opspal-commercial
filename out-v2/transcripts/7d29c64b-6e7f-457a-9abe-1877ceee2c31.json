      "recording_id": "18fe5e65-3190-42d7-9386-31093d06fa97",
      "end_time": 151.22,
      "start_time": 145.46,
      "recording_attendee_id": "d347dd53-2c29-4ef0-a14a-2dc467ef2216",
      "order_number": 45,
      "text": "just to be completely transparent, we're not gonna roll anything new out until late in the second quarter."
    },
    {
      "id": "7d29c64b-6e7f-457a-9abe-1877ceee2c31",
      "recording_id": "18fe5e65-3190-42d7-9386-31093d06fa97",
