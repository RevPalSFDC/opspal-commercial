      "recording_id": "18fe5e65-3190-42d7-9386-31093d06fa97",
      "end_time": 135.02,
      "start_time": 128.2,
      "recording_attendee_id": "883881d1-ab2b-42d6-a382-55beaf95ec07",
      "order_number": 42,
      "text": "Um I'll go into our product and see where I think it could fit with what you're currently doing over there."
    },
