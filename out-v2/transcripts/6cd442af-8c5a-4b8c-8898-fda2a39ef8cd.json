      "start_time": 27.69,
      "recording_attendee_id": "9ac3be85-ae61-4fde-8cee-521503efca60",
      "order_number": 4,
      "text": "Well, I'm the manager here, Jamieson Area manager now. Um, is that something that can capture has contracted with you?"
