    {
      "id": "c6fa2789-9c9d-4ea3-88d1-f2e7c17e8f93",
      "recording_id": "e8d39184-761b-43e0-bca6-15cd0e024569",
      "end_time": 79.16,
      "start_time": 78.61,
      "recording_attendee_id": "5eae8038-04c5-4667-8bb1-ad6ab3f61654",
      "order_number": 8,
      "text": "switching."
