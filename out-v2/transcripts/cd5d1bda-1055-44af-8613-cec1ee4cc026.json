      "recording_id": "9a715a70-7e0a-4d98-9d3b-384b3b286c8e",
      "end_time": 96.68,
      "start_time": 80.66,
      "recording_attendee_id": "a1ef82a0-f5b6-490c-87a0-c70471d34508",
      "order_number": 12,
      "text": "I do appreciate your follow up call. I will tell you that we have not started our budgets yet. Um we also have a marketing team that handles all of our advertising, so as soon as we do get closer, if we do have any questions or need any other information from you, I will reach out"
    },
