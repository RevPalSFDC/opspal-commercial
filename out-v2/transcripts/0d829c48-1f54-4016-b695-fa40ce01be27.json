      "id": "0d829c48-1f54-4016-b695-fa40ce01be27",
      "recording_id": "cde71903-7dc0-4f3c-87cd-cb2770342aeb",
      "end_time": 140.98,
      "start_time": 134.98,
      "recording_attendee_id": "8b92cea8-e971-4d91-8404-eec00681773a",
      "order_number": 22,
      "text": "Okay, great. So would it be alright if I send you something tentative for next week and you can move it around just so it's there"
    },
