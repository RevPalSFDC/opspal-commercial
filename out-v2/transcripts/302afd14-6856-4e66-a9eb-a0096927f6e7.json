      "id": "302afd14-6856-4e66-a9eb-a0096927f6e7",
      "recording_id": "1e209cdb-9145-48d0-8a23-a12a49991f50",
      "end_time": 684.46,
      "start_time": 682.24,
      "recording_attendee_id": "0dda40d9-f785-49e2-9dcb-fad53c809d98",
      "order_number": 41,
      "text": "11, I have something at 1030."
