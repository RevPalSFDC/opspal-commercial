    {
      "id": "d1751998-7289-49d4-94ad-6968414d1709",
      "recording_id": "aa907076-d7e7-4bfe-9bc3-f35cb231b754",
      "end_time": 171.46,
      "start_time": 162.95,
      "recording_attendee_id": "8f714552-79cf-4713-a10a-d03d6a298bcc",
      "order_number": 21,
      "text": "Ah It's the earliest I could do would be nine a.m. Eastern. But I'm free all day that day. So I could do any time between nine and ah later."
    },
    {
      "id": "d1751998-7289-49d4-94ad-6968414d1709",
      "recording_id": "aa907076-d7e7-4bfe-9bc3-f35cb231b754",
      "end_time": 176.73,
      "start_time": 171.87,
      "recording_attendee_id": "912f0049-e21c-4aff-888d-9ba13fc2316e",
      "order_number": 22,
      "text": "Okay, how does uh How does eleven a.m. sounds"
    },
    {
      "id": "d1751998-7289-49d4-94ad-6968414d1709",
      "recording_id": "aa907076-d7e7-4bfe-9bc3-f35cb231b754",
      "end_time": 177.99,
      "start_time": 177.05,
      "recording_attendee_id": "8f714552-79cf-4713-a10a-d03d6a298bcc",
      "order_number": 23,
      "text": "Sounds perfect."
    },
    {
      "id": "d1751998-7289-49d4-94ad-6968414d1709",
      "recording_id": "aa907076-d7e7-4bfe-9bc3-f35cb231b754",
      "end_time": 192.84,
      "start_time": 178.23,
      "recording_attendee_id": "912f0049-e21c-4aff-888d-9ba13fc2316e",
      "order_number": 24,
      "text": "okay, perfect. I'm gonna send over a calendar invite and my my colleague can these are regional sales director uh will be on there as well but I'll get that over to you guys right now and we'll we'll see you on the first. Okay,"
    },
