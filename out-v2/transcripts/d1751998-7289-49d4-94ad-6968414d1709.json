      "order_number": 0,
      "text": "Good afternoon Philips Management Group, This is Brittany. How can I help you?"
    },
    {
      "id": "d1751998-7289-49d4-94ad-6968414d1709",
      "recording_id": "aa907076-d7e7-4bfe-9bc3-f35cb231b754",
