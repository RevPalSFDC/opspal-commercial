      "recording_id": "fec7aa44-d442-4adc-affe-de9341b291ea",
      "end_time": 419.49,
      "start_time": 418.57,
      "recording_attendee_id": "4f214303-6068-4c33-b997-beba66e6b0c1",
      "order_number": 122,
      "text": "He knows about Apartment IQ."
    },
    {
      "id": "30382990-af80-4c03-9293-584e17c82512",
      "recording_id": "fec7aa44-d442-4adc-affe-de9341b291ea",
      "end_time": 421.71,
      "start_time": 419.68,
      "recording_attendee_id": "4f214303-6068-4c33-b997-beba66e6b0c1",
      "order_number": 123,
      "text": "Before, and he said it was too much work or something."
    },
    {
      "id": "30382990-af80-4c03-9293-584e17c82512",
      "recording_id": "fec7aa44-d442-4adc-affe-de9341b291ea",
      "end_time": 422.45,
      "start_time": 421.9,
      "recording_attendee_id": "4f214303-6068-4c33-b997-beba66e6b0c1",
      "order_number": 124,
      "text": "I don't know"
    },
    {
      "id": "30382990-af80-4c03-9293-584e17c82512",
      "recording_id": "fec7aa44-d442-4adc-affe-de9341b291ea",
      "end_time": 422.87,
      "start_time": 422.66,
      "recording_attendee_id": "9bc8d78b-c060-4131-8855-db4277c30fdc",
      "order_number": 125,
      "text": "Don't."
    },
    {
      "id": "30382990-af80-4c03-9293-584e17c82512",
      "recording_id": "fec7aa44-d442-4adc-affe-de9341b291ea",
      "end_time": 423.3,
      "start_time": 423.09,
      "recording_attendee_id": "9bc8d78b-c060-4131-8855-db4277c30fdc",
      "order_number": 126,
      "text": "Hmm!"
    },
    {
      "id": "30382990-af80-4c03-9293-584e17c82512",
      "recording_id": "fec7aa44-d442-4adc-affe-de9341b291ea",
      "end_time": 424.8,
      "start_time": 424,
      "recording_attendee_id": "9bc8d78b-c060-4131-8855-db4277c30fdc",
      "order_number": 127,
      "text": "I don't know."
    },
    {
      "id": "30382990-af80-4c03-9293-584e17c82512",
      "recording_id": "fec7aa44-d442-4adc-affe-de9341b291ea",
      "end_time": 427.08,
