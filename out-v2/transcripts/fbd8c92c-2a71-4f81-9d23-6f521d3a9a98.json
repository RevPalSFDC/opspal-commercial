      "recording_id": "e7add522-8ea6-4e9d-9fd3-481a5cd4bbad",
      "end_time": 364.27,
      "start_time": 358.26,
      "recording_attendee_id": null,
      "order_number": 62,
      "text": "Uh You know, um I don't really know um to be honest with you, I don't think they do either."
