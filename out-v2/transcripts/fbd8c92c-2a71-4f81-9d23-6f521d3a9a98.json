      "recording_id": "e7add522-8ea6-4e9d-9fd3-481a5cd4bbad",
      "end_time": 324.85,
      "start_time": 323.25,
      "recording_attendee_id": null,
      "order_number": 48,
      "text": "Are they in the student housing space?"
