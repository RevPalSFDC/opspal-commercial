    {
      "id": "fbd8c92c-2a71-4f81-9d23-6f521d3a9a98",
      "recording_id": "e7add522-8ea6-4e9d-9fd3-481a5cd4bbad",
      "end_time": 265,
      "start_time": 261.15,
      "recording_attendee_id": null,
      "order_number": 37,
      "text": "Uh So see what that would look like and see if any of them are attracted to you."
    },
    {
      "id": "fbd8c92c-2a71-4f81-9d23-6f521d3a9a98",
      "recording_id": "e7add522-8ea6-4e9d-9fd3-481a5cd4bbad",
      "end_time": 266.2,
      "start_time": 265.01,
      "recording_attendee_id": null,
      "order_number": 38,
      "text": "Uh How about you?"
