    {
      "id": "fbd8c92c-2a71-4f81-9d23-6f521d3a9a98",
      "recording_id": "e7add522-8ea6-4e9d-9fd3-481a5cd4bbad",
      "end_time": 260.8,
      "start_time": 257.35,
      "recording_attendee_id": null,
      "order_number": 36,
      "text": "Of course, I've got a bunch of updates to show you in apartment IQ."
