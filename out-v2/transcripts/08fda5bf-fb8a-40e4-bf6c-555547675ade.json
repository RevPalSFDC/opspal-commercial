  "sentences": [
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 21.89,
      "start_time": 20.97,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 0,
      "text": "Good morning, Kelly."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 22.4,
      "start_time": 22.11,
      "recording_attendee_id": "423f4e1f-c0b9-4817-b42a-5b9635051e43",
      "order_number": 1,
      "text": "Hello."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 22.94,
      "start_time": 22.56,
      "recording_attendee_id": "423f4e1f-c0b9-4817-b42a-5b9635051e43",
      "order_number": 2,
      "text": "How"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 23.66,
      "start_time": 22.95,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 3,
      "text": "are you"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 24.37,
      "start_time": 24.07,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 4,
      "text": "doing?"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 25.38,
      "start_time": 24.38,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 5,
      "text": "Real well, how are you doing?"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 26.99,
      "start_time": 25.59,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 6,
      "text": "Doing good."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 28.63,
      "start_time": 28.07,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 7,
      "text": "Awesome."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 30.74,
      "start_time": 28.64,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 8,
      "text": "Your week off to a good start."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 31.98,
      "start_time": 31.08,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 9,
      "text": "It is."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 32.58,
      "start_time": 31.99,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 10,
      "text": "It's cold."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 36.53,
      "start_time": 32.59,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 11,
      "text": "It's, well, I don't know where you're from but it's cold here but it's not as cold as Becky."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 38.83,
      "start_time": 36.54,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 12,
      "text": "So I don't have a lot to complain"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 39.42,
      "start_time": 38.84,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 13,
      "text": "about."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 39.95,
      "start_time": 39.68,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 14,
      "text": "Yeah."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 42.47,
      "start_time": 39.96,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 15,
      "text": "What's, uh, are, are you based in?"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 44.2,
      "start_time": 43.05,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 16,
      "text": "I'm in Arizona."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 44.74,
      "start_time": 44.21,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 17,
      "text": "Ok."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 47,
      "start_time": 45.84,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 18,
      "text": "What's cold, I guess?"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 49.02,
      "start_time": 47.01,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 19,
      "text": "Is that like, fifties or sixties?"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 49.86,
      "start_time": 49.41,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 20,
      "text": "Yeah,"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 55.45,
      "start_time": 49.87,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 21,
      "text": "like in the morning it was like 44 and during the day it's warm, so I really have nothing to complain about."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 58.6,
      "start_time": 55.46,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 22,
      "text": "I'm just, my feet are cold right now and I'm just mad about it."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 59.94,
      "start_time": 59.68,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 23,
      "text": "Got you."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 61.82,
      "start_time": 60.72,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 24,
      "text": "Where are you from?"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 64.44,
      "start_time": 61.84,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 25,
      "text": "Um, I'm based in Madison, Wisconsin."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 65.85,
      "start_time": 64.45,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 26,
      "text": "So, uh, it was,"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 67.5,
      "start_time": 65.86,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 27,
      "text": "I have nothing to complain about."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 70.53,
      "start_time": 67.83,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 28,
      "text": "It was, it was negative 30 yesterday here."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 70.82,
      "start_time": 70.54,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 29,
      "text": "So,"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 72.37,
      "start_time": 70.83,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 30,
      "text": "oh, my gosh."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 77.11,
      "start_time": 73.03,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 31,
      "text": "I feel bad for, uh, my dog it hasn't been able to get its walks."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 78.54,
      "start_time": 77.12,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 32,
      "text": "So,"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 80.6,
      "start_time": 79.27,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 33,
      "text": "I don't know how you do it."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 85.01,
      "start_time": 81.09,
      "recording_attendee_id": "59a7da27-c910-46b5-8c5c-86723110b3f1",
      "order_number": 34,
      "text": "I, 40 degrees that I'm like, oh, my gosh, this is miserable."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 95,
      "start_time": 86.56,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 35,
      "text": "Yeah, it's, uh, it's not every year it gets harder and harder and I don't I don't know why I keep, uh, agreeing to live here, but kind of is what it is."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 98.83,
      "start_time": 96.97,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 36,
      "text": "Well, I appreciate you jumping on."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 100.55,
      "start_time": 98.84,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 37,
      "text": "Um, it's nice to meet you."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 106.07,
      "start_time": 100.72,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 38,
      "text": "Uh, my name's Austin and I've been working, um, with Jessie and then she let me know."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 108.73,
      "start_time": 106.08,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 39,
      "text": "I'd previously also been talking with Daniel."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 113.99,
      "start_time": 108.91,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 40,
      "text": "I know he sounds like he left the company but, um, nice to meet you and I appreciate your time."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 115.55,
      "start_time": 114,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 41,
      "text": "And Jesse, can you hear us,"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 125.6,
      "start_time": 125.18,
      "recording_attendee_id": "423f4e1f-c0b9-4817-b42a-5b9635051e43",
      "order_number": 42,
      "text": "Jessie?"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 126.11,
      "start_time": 125.61,
      "recording_attendee_id": "423f4e1f-c0b9-4817-b42a-5b9635051e43",
      "order_number": 43,
      "text": "Are you there?"
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 129.62,
      "start_time": 128.66,
      "recording_attendee_id": "423f4e1f-c0b9-4817-b42a-5b9635051e43",
      "order_number": 44,
      "text": "Let me text her."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 138.11,
      "start_time": 136.43,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 45,
      "text": "It looks like she's coming back."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 140.02,
      "start_time": 138.73,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
      "order_number": 46,
      "text": "Looks like maybe she called in."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 141.3,
      "start_time": 140.47,
      "recording_attendee_id": "423f4e1f-c0b9-4817-b42a-5b9635051e43",
      "order_number": 47,
      "text": "Oh, ok."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 142.16,
      "start_time": 141.31,
      "recording_attendee_id": "423f4e1f-c0b9-4817-b42a-5b9635051e43",
      "order_number": 48,
      "text": "Perfect."
    },
    {
      "id": "08fda5bf-fb8a-40e4-bf6c-555547675ade",
      "recording_id": "80482b87-becc-45ff-b84c-d78bbc5358ea",
      "end_time": 147.73,
      "start_time": 146.52,
      "recording_attendee_id": "9f5cd4cb-6481-4115-a606-7b14d98c560e",
