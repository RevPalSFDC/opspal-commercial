      "end_time": 56.99,
      "start_time": 54.54,
      "recording_attendee_id": "bea3b541-5fa6-4e00-88e5-2897e5f21e03",
      "order_number": 12,
      "text": "Um I think that's true."
    },
    {
      "id": "817de9c6-281f-4334-b602-0c1d38c072cf",
      "recording_id": "1e2d6b7b-06df-4e8f-9016-bd867c1c73b4",
