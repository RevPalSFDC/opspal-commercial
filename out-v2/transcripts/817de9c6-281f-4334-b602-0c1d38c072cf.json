      "id": "817de9c6-281f-4334-b602-0c1d38c072cf",
      "recording_id": "1e2d6b7b-06df-4e8f-9016-bd867c1c73b4",
      "end_time": 243.59,
      "start_time": 239.48,
      "recording_attendee_id": "120a62c2-58e6-4527-9ae2-49d7506125d4",
      "order_number": 41,
      "text": "Um Did we chat about that at all or do you have anything in place for listing management?"
