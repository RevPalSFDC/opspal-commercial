      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 143.48,
      "start_time": 143.07,
      "recording_attendee_id": "585eb8d7-ed2f-4eb2-9504-79eba2a48141",
      "order_number": 36,
      "text": "OK."
    },
    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 146.67,
      "start_time": 143.49,
      "recording_attendee_id": "585eb8d7-ed2f-4eb2-9504-79eba2a48141",
      "order_number": 37,
      "text": "The 30 that meaning put a bit and keep it in for 30 then rotate out."
