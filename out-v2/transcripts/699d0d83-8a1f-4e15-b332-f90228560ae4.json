    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 61.53,
      "start_time": 58.79,
      "recording_attendee_id": "585eb8d7-ed2f-4eb2-9504-79eba2a48141",
      "order_number": 18,
      "text": "yeah, so the, the first one which is like, you know, I guess"
    },
    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 68.42,
      "start_time": 63.72,
      "recording_attendee_id": "585eb8d7-ed2f-4eb2-9504-79eba2a48141",
      "order_number": 19,
      "text": "um like 1000 a month, I'm just waiting to get that approved cause I'm not having the agents pay it."
