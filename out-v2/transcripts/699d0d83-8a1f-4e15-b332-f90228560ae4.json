    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 103.95,
      "start_time": 90.84,
      "recording_attendee_id": "585eb8d7-ed2f-4eb2-9504-79eba2a48141",
      "order_number": 25,
      "text": "So, um, I'm gonna try to put together, I have four of my top agents but I may be able to get a couple more in there because if I'm gonna be paying for that up to 25 buildings, then I wanna get as much exposure as we can."
    },
    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 109.19,
      "start_time": 105.05,
      "recording_attendee_id": "585eb8d7-ed2f-4eb2-9504-79eba2a48141",
      "order_number": 26,
      "text": "Um, so I'm just waiting for a couple of agents to get back to me and let me know how many units they have."
    },
    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 111.65,
