    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 139.35,
      "start_time": 136.62,
      "recording_attendee_id": "72ed751b-e550-4405-8f17-5d79a06cb166",
      "order_number": 34,
      "text": "That's no problem to rotate out properties on here."
