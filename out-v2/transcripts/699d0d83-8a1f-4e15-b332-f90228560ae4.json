    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 49.29,
      "start_time": 45.78,
      "recording_attendee_id": "585eb8d7-ed2f-4eb2-9504-79eba2a48141",
      "order_number": 15,
      "text": "Um I think of the options that you guys have mentioned."
    },
    {
      "id": "699d0d83-8a1f-4e15-b332-f90228560ae4",
      "recording_id": "452457b9-680c-4756-8490-d422dbbc146b",
      "end_time": 51.05,
      "start_time": 49.3,
      "recording_attendee_id": "585eb8d7-ed2f-4eb2-9504-79eba2a48141",
      "order_number": 16,
      "text": "I mean the, the one for like"
