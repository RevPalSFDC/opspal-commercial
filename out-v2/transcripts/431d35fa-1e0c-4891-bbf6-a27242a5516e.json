      "recording_id": "57f6eb47-7442-4402-9421-90fc11bad451",
      "end_time": 113.71,
      "start_time": 104.65,
      "recording_attendee_id": "49941232-e6e4-464e-a0a5-cc784311db05",
      "order_number": 33,
      "text": "I know I've worked pretty extensively with, uh, with Cole and Trade I'm, I'm familiar with the uh uh I guess the context of the meeting but um wonderful to meet you."
