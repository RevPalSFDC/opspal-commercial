      "recording_attendee_id": "2717be3d-5326-49f5-b1fb-f10e2a6e8e1c",
      "order_number": 2,
      "text": "I saw as a property manager. Um he doesn't work here on site, he has his own office at corporate. Is there something I can help you with?"
