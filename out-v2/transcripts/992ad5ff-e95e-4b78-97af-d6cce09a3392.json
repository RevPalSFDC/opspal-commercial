      "start_time": 23.17,
      "recording_attendee_id": "2717be3d-5326-49f5-b1fb-f10e2a6e8e1c",
      "order_number": 4,
      "text": "It's all used to be the property manager, but he isn't the property manager here either. Uh any any longer? Um I'm the resident manager. My name's life. I've I've worked here for the last four years."
    },
    {
      "id": "992ad5ff-e95e-4b78-97af-d6cce09a3392",
