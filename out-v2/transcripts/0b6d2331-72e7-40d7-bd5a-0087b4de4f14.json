      "start_time": 18.32,
      "recording_attendee_id": "571e78fa-d0b2-4583-b4cb-e5e85c522a0e",
      "order_number": 5,
      "text": "Nope, that's alright, no reason to shut. I guess I didn't get you the best time here today."
