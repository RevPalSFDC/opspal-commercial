    {
      "id": "a80792a1-b92b-4c8a-824b-25c92236f53e",
      "recording_id": "3a4f99f6-47b9-4612-a52d-d6d904f0812d",
      "end_time": 114.17,
      "start_time": 100.56,
      "recording_attendee_id": "de5ab578-cc05-49ec-9f80-d2d4b7df4de4",
      "order_number": 25,
      "text": "Like a year from now. Yeah, right now, based on everything I'm hearing from experts in the field and kind of what we're seeing right now, it's gonna be this way for at least a year we"
    },
    {
      "id": "a80792a1-b92b-4c8a-824b-25c92236f53e",
      "recording_id": "3a4f99f6-47b9-4612-a52d-d6d904f0812d",
      "end_time": 114.17,
      "start_time": 114,
      "recording_attendee_id": "9ae12e63-c5d3-429b-abce-b62eba6ddad9",
      "order_number": 26,
      "text": "Don't"
