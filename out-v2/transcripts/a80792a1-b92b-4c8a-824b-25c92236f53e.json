      "id": "a80792a1-b92b-4c8a-824b-25c92236f53e",
      "recording_id": "3a4f99f6-47b9-4612-a52d-d6d904f0812d",
      "end_time": 97.98,
      "start_time": 94.62,
      "recording_attendee_id": "9ae12e63-c5d3-429b-abce-b62eba6ddad9",
      "order_number": 22,
      "text": "Which uh which election? The governor? The governor? And uh"
    },
    {
      "id": "a80792a1-b92b-4c8a-824b-25c92236f53e",
      "recording_id": "3a4f99f6-47b9-4612-a52d-d6d904f0812d",
      "end_time": 99.91,
      "start_time": 98.08,
      "recording_attendee_id": "de5ab578-cc05-49ec-9f80-d2d4b7df4de4",
