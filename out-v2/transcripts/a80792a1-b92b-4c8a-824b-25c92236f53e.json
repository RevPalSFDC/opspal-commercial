      "id": "a80792a1-b92b-4c8a-824b-25c92236f53e",
      "recording_id": "3a4f99f6-47b9-4612-a52d-d6d904f0812d",
      "end_time": 158.68,
      "start_time": 157.76,
      "recording_attendee_id": "de5ab578-cc05-49ec-9f80-d2d4b7df4de4",
      "order_number": 31,
      "text": "That's fine."
    },
    {
      "id": "a80792a1-b92b-4c8a-824b-25c92236f53e",
      "recording_id": "3a4f99f6-47b9-4612-a52d-d6d904f0812d",
      "end_time": 161.31,
