# AI Consult Plugin Configuration
# Copy this file to .env and customize values

# ============================================
# GEMINI API CONFIGURATION (Required)
# ============================================

# Google Gemini API Key
# Get from: https://aistudio.google.com/apikey
# Free tier: 60 requests/min, 1,000 requests/day
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use
# Options: gemini-2.5-pro (best), gemini-2.5-flash (faster), gemini-2.0-flash (legacy)
# Default: gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-pro

# Request timeout in milliseconds
# Default: 120000 (2 minutes)
GEMINI_TIMEOUT=120000

# ============================================
# AUTO-CONSULTATION TRIGGERS
# ============================================

# Enable automatic consultation suggestions (1=enabled, 0=disabled)
# When enabled, suggests Gemini consultation when agents struggle
# Default: 1
ENABLE_AUTO_CONSULTATION=1

# Enable verbose consultation logging (1=enabled, 0=disabled)
# Default: 0
CONSULTATION_VERBOSE=0

# ============================================
# SUPABASE CONFIGURATION (ACE Integration)
# ============================================

# Supabase project URL
# Get from: Supabase Dashboard > Settings > API > Project URL
# Required for ACE skill registry integration
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for client-side)
# Get from: Supabase Dashboard > Settings > API > anon/public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# ACE INTEGRATION OPTIONS
# ============================================

# Enable ACE skill registry logging (1=enabled, 0=disabled)
# Logs consultation outcomes to track effectiveness
# Default: 1
ENABLE_ACE_LOGGING=1

# ============================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================
# The following must be set for full functionality:
#   - GEMINI_API_KEY (required for consultation)
#   - SUPABASE_URL (optional, for ACE integration)
#   - SUPABASE_ANON_KEY (optional, for ACE integration)
