{
  "reportTypes": {
    "tabular": {
      "description": "Simple list format without groupings",
      "template": {
        "format": "Tabular",
        "showDetails": true,
        "sortColumn": "CREATED_DATE",
        "sortOrder": "Desc"
      },
      "limitations": [
        "Cannot be used in most dashboard components",
        "No groupings or subtotals",
        "Limited chart options"
      ],
      "bestFor": ["Data exports", "Detail lists", "Simple tables"]
    },
    
    "summary": {
      "description": "Grouped data with subtotals",
      "template": {
        "format": "Summary",
        "showDetails": true,
        "showGrandTotal": true,
        "showSubtotals": true,
        "sortColumn": "CREATED_DATE",
        "sortOrder": "Desc"
      },
      "features": [
        "Groupings up to 3 levels",
        "Subtotals and grand totals",
        "Compatible with all dashboard components"
      ],
      "bestFor": ["Dashboards", "Trend analysis", "Group comparisons"]
    },
    
    "matrix": {
      "description": "Cross-tab format with row and column groupings",
      "template": {
        "format": "Matrix",
        "showDetails": false,
        "showGrandTotal": true,
        "showSubtotals": true
      },
      "features": [
        "Row and column groupings",
        "Cross-tab analysis",
        "Heat map visualization"
      ],
      "bestFor": ["Comparative analysis", "Time-based trends", "Multi-dimensional data"]
    },
    
    "joined": {
      "description": "Multiple report blocks with shared groupings",
      "template": {
        "format": "Joined",
        "showDetails": false
      },
      "features": [
        "Multiple report types in one",
        "Shared groupings across blocks",
        "Complex data relationships"
      ],
      "bestFor": ["Cross-object reporting", "Complex KPIs", "Consolidated views"]
    }
  },
  
  "chartConfigurations": {
    "column": {
      "requiredFormat": ["Summary", "Matrix"],
      "template": {
        "chartType": "VerticalColumn",
        "chartSummary": ["Sum", "Average", "Maximum", "Minimum"],
        "enableHover": true,
        "expandOthers": false,
        "groupingColumn": "STAGE_NAME",
        "legendPosition": "Bottom",
        "showAxisLabels": true,
        "showPercentage": false,
        "showTotal": true,
        "showValues": true,
        "size": "Medium",
        "summaryAxisManualRangeEnd": null,
        "summaryAxisManualRangeStart": null,
        "summaryAxisRange": "Auto"
      }
    },
    
    "bar": {
      "requiredFormat": ["Summary", "Matrix"],
      "template": {
        "chartType": "HorizontalBar",
        "enableHover": true,
        "expandOthers": false,
        "groupingColumn": "OWNER_NAME",
        "legendPosition": "Right",
        "showAxisLabels": true,
        "showPercentage": false,
        "showTotal": true,
        "showValues": true,
        "size": "Medium"
      }
    },
    
    "line": {
      "requiredFormat": ["Summary", "Matrix"],
      "template": {
        "chartType": "Line",
        "enableHover": true,
        "expandOthers": false,
        "groupingColumn": "CLOSE_DATE",
        "legendPosition": "Bottom",
        "showAxisLabels": true,
        "showPercentage": false,
        "showTotal": false,
        "showValues": false,
        "size": "Medium",
        "summaryAxisManualRangeEnd": null,
        "summaryAxisManualRangeStart": 0,
        "summaryAxisRange": "Manual"
      }
    },
    
    "pie": {
      "requiredFormat": ["Summary", "Matrix"],
      "template": {
        "chartType": "Pie",
        "enableHover": true,
        "expandOthers": true,
        "legendPosition": "Right",
        "showPercentage": true,
        "showTotal": false,
        "showValues": true,
        "size": "Medium"
      }
    },
    
    "donut": {
      "requiredFormat": ["Summary", "Matrix"],
      "template": {
        "chartType": "Donut",
        "enableHover": true,
        "expandOthers": true,
        "legendPosition": "Right",
        "showPercentage": true,
        "showTotal": true,
        "showValues": true,
        "size": "Medium"
      }
    },
    
    "funnel": {
      "requiredFormat": ["Summary"],
      "template": {
        "chartType": "Funnel",
        "enableHover": true,
        "expandOthers": false,
        "legendPosition": "None",
        "showPercentage": true,
        "showTotal": false,
        "showValues": true,
        "size": "Medium"
      }
    }
  },
  
  "groupingTemplates": {
    "dateGrouping": {
      "template": {
        "dateGranularity": "Month",
        "field": "CLOSE_DATE",
        "sortOrder": "Asc"
      },
      "granularityOptions": ["Day", "Week", "Month", "Quarter", "Year", "FiscalQuarter", "FiscalYear"]
    },
    
    "picklistGrouping": {
      "template": {
        "field": "STAGE_NAME",
        "sortOrder": "Asc"
      }
    },
    
    "lookupGrouping": {
      "template": {
        "field": "ACCOUNT_NAME",
        "sortOrder": "Asc"
      }
    }
  },
  
  "filterTemplates": {
    "dateFilter": {
      "current_quarter": {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_QUARTER"
      },
      "last_30_days": {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "LAST_N_DAYS:30"
      },
      "next_90_days": {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "NEXT_N_DAYS:90"
      },
      "this_year": {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_YEAR"
      }
    },
    
    "standardFilter": {
      "isWon": {
        "column": "WON",
        "operator": "equals",
        "value": "true"
      },
      "isOpen": {
        "column": "CLOSED",
        "operator": "equals",
        "value": "false"
      },
      "highValue": {
        "column": "AMOUNT",
        "operator": "greaterThan",
        "value": "100000"
      }
    },
    
    "customFilter": {
      "template": {
        "booleanFilter": "1 AND 2",
        "criteriaItems": [
          {
            "column": "FIELD_NAME",
            "columnToColumn": false,
            "isUnlocked": false,
            "operator": "equals",
            "snapshot": null,
            "value": "VALUE"
          }
        ]
      }
    }
  },
  
  "aggregateTemplates": {
    "sum": {
      "acrossGroupingContext": "GRAND_SUMMARY",
      "calculatedFormula": "AMOUNT:SUM",
      "datatype": "currency",
      "description": "Total Amount",
      "developerName": "FORMULA1",
      "downGroupingContext": "GRAND_SUMMARY",
      "isActive": true,
      "isCrossBlock": false,
      "masterLabel": "Total",
      "reportType": "Opportunity",
      "scale": 2
    },
    
    "average": {
      "acrossGroupingContext": "GRAND_SUMMARY",
      "calculatedFormula": "AMOUNT:AVG",
      "datatype": "currency",
      "description": "Average Deal Size",
      "developerName": "FORMULA2",
      "downGroupingContext": "GRAND_SUMMARY",
      "isActive": true,
      "isCrossBlock": false,
      "masterLabel": "Avg Deal",
      "reportType": "Opportunity",
      "scale": 2
    },
    
    "count": {
      "acrossGroupingContext": "GRAND_SUMMARY",
      "calculatedFormula": "RowCount",
      "datatype": "number",
      "description": "Record Count",
      "developerName": "FORMULA3",
      "downGroupingContext": "GRAND_SUMMARY",
      "isActive": true,
      "isCrossBlock": false,
      "masterLabel": "Count",
      "reportType": "Opportunity",
      "scale": 0
    }
  },
  
  "dateIntervalMappings": {
    "friendly": {
      "TODAY": "INTERVAL_TODAY",
      "YESTERDAY": "INTERVAL_YESTERDAY",
      "THIS_WEEK": "INTERVAL_THISWEEK",
      "LAST_WEEK": "INTERVAL_LASTWEEK",
      "THIS_MONTH": "INTERVAL_THISMONTH",
      "LAST_MONTH": "INTERVAL_LASTMONTH",
      "THIS_QUARTER": "INTERVAL_CURRENTQ",
      "LAST_QUARTER": "INTERVAL_PREVQ",
      "THIS_YEAR": "INTERVAL_CURY",
      "LAST_YEAR": "INTERVAL_PREVY",
      "NEXT_90_DAYS": "INTERVAL_NEXT90",
      "LAST_30_DAYS": "INTERVAL_LAST30"
    },
    
    "custom": {
      "pattern": "LAST_N_DAYS:n",
      "examples": [
        "LAST_N_DAYS:7",
        "LAST_N_DAYS:30",
        "NEXT_N_DAYS:30",
        "LAST_N_MONTHS:3",
        "NEXT_N_QUARTERS:2"
      ]
    }
  },
  
  "validationRules": {
    "reportName": {
      "maxLength": 40,
      "pattern": "^[a-zA-Z0-9_]+$",
      "reserved": ["Report", "Dashboard", "System"]
    },
    
    "reportFolder": {
      "required": true,
      "pattern": "^[a-zA-Z0-9_/]+$"
    },
    
    "aggregateFormula": {
      "maxLength": 3900,
      "supportedFunctions": ["SUM", "AVG", "MIN", "MAX", "COUNT", "RowCount"]
    }
  },
  
  "bestPractices": {
    "performance": [
      "Limit reports to necessary columns only",
      "Use indexed fields in filters when possible",
      "Avoid cross-object formulas in reports",
      "Set appropriate date ranges to limit data",
      "Use summary reports instead of tabular for dashboards"
    ],
    
    "naming": [
      "Use descriptive names with object and purpose",
      "Include date range in name if specific",
      "Prefix with department or team code",
      "Avoid special characters except underscore"
    ],
    
    "organization": [
      "Create logical folder structure",
      "Group related reports together",
      "Archive unused reports regularly",
      "Document report purpose in description"
    ]
  }
}