    <!-- SYSTEM PERMISSIONS -->
    <!-- Standard user system permissions -->

    <!-- API Enabled: Allow API access -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>

    <!-- Run Reports: Allow running reports -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunReports</name>
    </userPermissions>

    <!-- Create Reports: Allow creating personal reports -->
    <userPermissions>
        <enabled>false</enabled>
        <name>CreateCustomizeReports</name>
    </userPermissions>

    <!-- View Setup: View setup pages (but not modify) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewSetup</name>
    </userPermissions>

    <!-- View All Data: Bypass sharing rules (typically false) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewAllData</name>
    </userPermissions>

    <!-- Modify All Data: Modify all records (typically false) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ModifyAllData</name>
    </userPermissions>

    <!-- Edit Read Only Fields: Edit readonly fields (typically false) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>EditReadOnlyFields</name>
    </userPermissions>

    <!-- APPLICATION VISIBILITY -->
    <!-- Grant access to relevant apps -->
    <!--
    <applicationVisibilities>
        <application>standard__Sales</application>
        <default>true</default>
        <visible>true</visible>
    </applicationVisibilities>
    -->

