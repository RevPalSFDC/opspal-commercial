<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <!--
    TEMPLATE: Standard User Permission Set
    CATEGORY: Basic
    DESCRIPTION: Provides standard CRED (Create, Read, Edit, Delete) access to core objects
    TIER: 1 (Foundational)

    USE CASES:
    - Typical users who need to create and edit records
    - Front-line employees (sales reps, support agents)
    - Standard contributors without administrative needs
    - Users who need full CRUD on assigned records

    OBJECTS INCLUDED:
    - Account (CRED)
    - Contact (CRED)
    - Opportunity (CRED)
    - Lead (CRED)
    - Task (CRED)
    - Event (CRED)

    FIELD ACCESS:
    - Standard fields: Read and Edit
    - Custom fields: Add as needed (read and edit)

    SYSTEM PERMISSIONS:
    - API Enabled: true
    - View All Data: false (respects sharing rules)
    - Modify All Data: false (respects sharing rules)

    CUSTOMIZATION CHECKLIST:
    □ 1. Replace {{PERMISSION_SET_NAME}} with your naming convention
    □ 2. Update {{LABEL}} with human-readable name
    □ 3. Update {{DESCRIPTION}} with specific use case
    □ 4. Add/remove objects as needed
    □ 5. Add field permissions for custom fields
    □ 6. Review and adjust CRUD permissions
    □ 7. Set app visibility
    □ 8. Configure tab settings
    □ 9. Test thoroughly before production

    NAMING CONVENTION:
    Standard_<Object>_Edit (e.g., Standard_Account_Edit)

    TWO-TIER ARCHITECTURE:
    This is a Tier 1 foundational set. Can be composed into Tier 2 role-based sets:
    - Sales_Representative (composes Account_Edit, Opportunity_Edit, Lead_Edit)
    - Support_Agent (composes Case_Edit, Contact_Edit, Account_Edit)
    - Marketing_User (composes Lead_Edit, Campaign_Edit)
    -->

    <description>{{DESCRIPTION}}</description>
    <label>{{LABEL}}</label>

    <!-- OBJECT PERMISSIONS -->
    <!-- Pattern: Full CRUD access (respects sharing rules) -->

    <!-- Account: Full CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Contact: Full CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Opportunity: Full CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Opportunity</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Lead: Full CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Lead</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Task: Full CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Task</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Event: Full CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Event</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- ADD MORE OBJECTS AS NEEDED -->

    <!-- FIELD PERMISSIONS -->
    <!-- Pattern: Read and edit access (readable=true, editable=true) -->
    <!-- Add field permissions for custom fields -->

    <!-- Example: Account custom fields -->
    <!--
    <fieldPermissions>
