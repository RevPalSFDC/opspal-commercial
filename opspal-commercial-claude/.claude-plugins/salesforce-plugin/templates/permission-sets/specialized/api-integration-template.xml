<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <!--
    TEMPLATE: API Integration User Permission Set
    CATEGORY: Specialized
    DESCRIPTION: Minimal permissions for API-only integration users (no UI access)
    TIER: 1 (Foundational)

    USE CASES:
    - Third-party system integrations (ERP, marketing automation, data warehouse)
    - ETL/data sync tools (Informatica, Talend, MuleSoft)
    - Middleware and iPaaS solutions (Boomi, Jitterbit, Workato)
    - Custom API integrations
    - Automated data backups

    OBJECTS INCLUDED:
    - Specify objects based on integration requirements
    - Typically: Account, Contact, Opportunity, Lead, Custom Objects

    FIELD ACCESS:
    - Only fields required for integration
    - Minimize sensitive field access
    - Document field usage in integration spec

    SYSTEM PERMISSIONS:
    - API Enabled: true (REQUIRED)
    - View All Data: false (use unless integration needs org-wide data)
    - Modify All Data: false (use only if absolutely required)

    SECURITY CONSIDERATIONS:
    - Use dedicated integration user (not shared)
    - Rotate password/security token regularly
    - Monitor API usage and audit logs
    - Implement IP restrictions if possible
    - Use OAuth 2.0 instead of password auth when possible

    CUSTOMIZATION CHECKLIST:
    □ 1. Replace {{PERMISSION_SET_NAME}} with integration name
    □ 2. Update {{LABEL}} and {{DESCRIPTION}}
    □ 3. Add only objects needed by integration
    □ 4. Grant minimum CRUD permissions required
    □ 5. Add only fields accessed by integration
    □ 6. Document integration purpose
    □ 7. Configure ViewAllData only if needed
    □ 8. Set up Connected App (OAuth) if applicable
    □ 9. Configure IP restrictions
    □ 10. Test with integration before production

    NAMING CONVENTION:
    API_<System>_Integration (e.g., API_Marketo_Integration, API_NetSuite_Integration)
    -->

    <description>{{DESCRIPTION}}</description>
    <label>{{LABEL}}</label>

    <!-- OBJECT PERMISSIONS -->
    <!-- Add only objects required by integration -->
    <!-- Pattern: Minimum permissions (R, CR, CRE, or CRED as needed) -->

    <!-- Example: Account read-only for reporting integration -->
    <!--
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    -->

    <!-- Example: Lead CR for marketing automation sync -->
    <!--
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Lead</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    -->

    <!-- Example: Custom Object CRED for bidirectional sync -->
    <!--
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>CustomObject__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    -->

    <!-- FIELD PERMISSIONS -->
    <!-- Add only fields accessed by integration -->
    <!-- Pattern: Minimum access (R or RE as needed) -->

    <!-- Example: Account fields for data warehouse sync -->
    <!--
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.Name</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.Industry</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.AnnualRevenue</field>
        <readable>true</readable>
    </fieldPermissions>
    -->

    <!-- Example: Lead fields for marketing automation bidirectional sync -->
    <!--
    <fieldPermissions>
        <editable>true</editable>
        <field>Lead.Email</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Lead.Company</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Lead.LeadSource</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Lead.Status</field>
        <readable>true</readable>
    </fieldPermissions>
    -->

    <!-- SYSTEM PERMISSIONS -->
    <!-- API-specific system permissions -->

    <!-- API Enabled: REQUIRED for API access -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>

    <!-- Bulk API: Enable if integration uses Bulk API -->
    <!--
    <userPermissions>
        <enabled>true</enabled>
        <name>BulkApiHardDelete</name>
    </userPermissions>
    -->

    <!-- View All Data: Enable ONLY if integration needs org-wide data access -->
    <!-- WARNING: Bypasses sharing rules, grants access to all records -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewAllData</name>
    </userPermissions>

    <!-- Modify All Data: Enable ONLY if integration needs to modify all records -->
    <!-- WARNING: Bypasses sharing rules, allows modification of all records -->
    <!-- CRITICAL: Requires security team approval -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ModifyAllData</name>
    </userPermissions>

    <!-- NO UI ACCESS -->
    <!-- API users should NOT have UI access -->
    <!-- Do NOT add application visibilities or tab settings -->

    <!--
    INTEGRATION USER SETUP:
    1. Create dedicated integration user
       - Username: integration.<system>@company.com
       - Profile: Minimum Access - Salesforce (or custom API-only profile)
       - License: Salesforce Integration

    2. Security settings:
       - Set strong password
       - Generate security token
       - Store credentials in secure vault (LastPass, AWS Secrets Manager)
       - Configure IP restrictions (if possible)

    3. OAuth 2.0 Setup (RECOMMENDED):
       - Create Connected App
       - Enable OAuth 2.0 flows (JWT Bearer, Username-Password)
       - Set OAuth scopes (api, refresh_token)
       - Configure callback URL
       - Use refresh tokens instead of password auth

    TESTING CHECKLIST:
    □ 1. Create integration user
    □ 2. Assign permission set
    □ 3. Test API authentication (REST, SOAP, or Bulk)
    □ 4. Test data retrieval (query objects/fields)
    □ 5. Test data creation (if applicable)
    □ 6. Test data update (if applicable)
    □ 7. Test data deletion (if applicable)
    □ 8. Verify sharing rules respected (if ViewAllData=false)
    □ 9. Test error handling
    □ 10. Monitor API limits during test
    □ 11. Verify audit logs show integration activity
    □ 12. Test failure scenarios (invalid data, limits exceeded)

    SECURITY BEST PRACTICES:
    1. Principle of Least Privilege:
       - Grant only objects/fields needed
       - Use read-only when possible
       - Avoid ViewAllData/ModifyAllData unless required

    2. Credential Management:
       - Store credentials in secure vault
       - Never commit credentials to source control
       - Rotate credentials quarterly
       - Use OAuth 2.0 instead of password when possible

    3. Monitoring:
       - Set up API usage alerts (approaching limits)
       - Monitor audit logs for suspicious activity
       - Track integration errors and failures
       - Review permission set quarterly

    4. Network Security:
       - Configure IP restrictions (Session Settings)
       - Use HTTPS for all API calls
       - Implement certificate pinning (mobile/desktop apps)
       - Consider VPN or private connectivity (AWS PrivateLink)

    API GOVERNOR LIMITS:
    Monitor these limits for integration users:
    - API Requests per 24 hours: Varies by license (5,000 - 100,000+)
    - Concurrent API Requests: 25 (can be increased)
    - Bulk API Batch Size: 10,000 records per batch
    - REST API Request Size: 50MB
    - SOQL Query Rows: 50,000 per query

    INTEGRATION PATTERNS:
    1. Real-time (REST API):
       - Low latency requirements
       - Trigger-based updates
       - Webhook callbacks

    2. Batch (Bulk API):
       - High volume data loads
       - Scheduled ETL jobs
       - Data warehouse syncs

    3. Event-Driven (Platform Events):
       - Publish-subscribe pattern
       - Asynchronous processing
       - Decoupled systems

    TROUBLESHOOTING:
    - Authentication failures: Check password, token, OAuth config
    - Permission errors: Verify object/field permissions
    - API limit errors: Check API usage, implement queuing
    - Invalid field errors: Verify field API names
    - Sharing rule errors: Check ViewAllData setting

    COMPLIANCE:
    - Document integration in security review
    - Include in SOX/SOC audit scope
    - Maintain integration specification document
    - Track data flow for GDPR/privacy compliance

    MAINTENANCE:
    - Review quarterly for unused permissions
    - Audit API usage patterns
    - Update as integration evolves
    - Rotate credentials per security policy
    - Monitor for deprecation warnings (API versions)
    -->
</PermissionSet>
