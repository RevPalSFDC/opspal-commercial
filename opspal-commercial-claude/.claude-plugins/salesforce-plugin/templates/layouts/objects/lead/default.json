{
  "object": "Lead",
  "template": "default",
  "label": "Standard Lead Layout",
  "description": "Default Lead layout for lead qualification and conversion",
  "targetPersonas": ["sales-rep", "sales-manager"],
  "sections": [
    {
      "label": "Lead Information",
      "order": 1,
      "fields": [
        "Name",
        "Company",
        "Title",
        "Email",
        "Phone",
        "MobilePhone",
        "LeadSource",
        "Status",
        "Rating",
        "OwnerId"
      ],
      "columns": 2
    },
    {
      "label": "Address Information",
      "order": 2,
      "fields": [
        "Street",
        "City",
        "State",
        "PostalCode",
        "Country"
      ],
      "columns": 2
    },
    {
      "label": "Additional Information",
      "order": 3,
      "fields": [
        "Industry",
        "NumberOfEmployees",
        "AnnualRevenue",
        "Description"
      ],
      "columns": 2
    }
  ],
  "compactLayoutFields": ["Name", "Company", "Email", "Status"],
  "components": {
    "header": [
      {"type": "force:highlightsPanelDesktop", "order": 1},
      {"type": "runtime_sales_pathassistant:pathAssistant", "order": 2}
    ],
    "main": [
      {"type": "force:recordFieldSection", "sections": ["Lead Information", "Additional Information"], "order": 1},
      {"type": "force:activityComposer", "order": 2}
    ],
    "sidebar": [
      {"type": "force:relatedListSingleContainer", "relatedObject": "Task", "order": 1},
      {"type": "force:relatedListSingleContainer", "relatedObject": "CampaignMember", "order": 2}
    ]
  },
  "relatedLists": [
    "Open Activities",
    "Activity History",
    "Campaign History",
    "Notes & Attachments"
  ]
}
