{
  "persona": "marketing",
  "label": "Marketing User",
  "description": "Marketing team member focused on campaign management, lead nurturing, and marketing attribution",
  "role": "Individual Contributor",
  "decisionScope": "Campaign effectiveness, lead quality, marketing attribution, engagement tracking",
  "keyQuestions": [
    "Which campaigns are driving the most qualified leads?",
    "What's the engagement history of this contact?",
    "How are contacts progressing through the funnel?",
    "Which touches converted this lead to an opportunity?"
  ],
  "layoutCharacteristics": {
    "fieldCount": {
      "optimal": 45,
      "max": 75,
      "priority": "Marketing attribution and engagement over operational details"
    },
    "sectionCount": {
      "optimal": 5,
      "max": 7,
      "recommended": ["Contact Essentials", "Marketing Status", "Campaign Attribution", "Funnel Milestones", "Marketing Preferences"]
    },
    "components": {
      "required": ["Highlights Panel", "Campaign Members"],
      "recommended": ["Related List - Campaigns", "Related List - Activities", "Related List - Opportunities"],
      "avoid": ["Quotes", "Orders", "Cases"]
    },
    "relatedLists": {
      "max": 5,
      "priority": ["Campaign Members", "Activities", "History", "Opportunities", "Notes"]
    }
  },
  "fieldPriorities": {
    "contact": {
      "criticalFields": [
        "Name",
        "Email",
        "Marketing_Stage__c",
        "Last_Touch_Campaign__c",
        "LeadSource",
        "AccountId",
        "OwnerId"
      ],
      "importantFields": [
        "Prospect_Status__c",
        "Qualification_Status__c",
        "First_Touch_Campaign__c",
        "Recent_MQL_Date__c",
        "Last_Engagement_Date__c",
        "Title",
        "Department"
      ],
      "contextualFields": [
        "Original_MQL_Date__c",
        "SQL_Date_Stamp__c",
        "First_Touch_Date__c",
        "Last_Touch_Date__c",
        "Contact_Source_Detail__c",
        "Recent_MQL_Type__c",
        "First_MQL_Type__c"
      ],
      "lowPriorityFields": [
        "Customer_Date_Stamp__c",
        "SQO_Date_Stamp__c",
        "Disqualified_Date_Stamp__c",
        "Last_Unresponsive_Marketing__c",
        "Last_Prospect_Status_Change__c"
      ]
    },
    "lead": {
      "criticalFields": [
        "Name",
        "Company",
        "Email",
        "Status",
        "LeadSource",
        "Rating",
        "OwnerId"
      ],
      "importantFields": [
        "Campaign__c",
        "Lead_Score__c",
        "Last_Campaign_Touch__c",
        "MQL_Date__c",
        "Phone",
        "Title"
      ],
      "contextualFields": [
        "Industry",
        "NumberOfEmployees",
        "AnnualRevenue",
        "Description"
      ]
    },
    "campaign": {
      "criticalFields": [
        "Name",
        "Status",
        "Type",
        "StartDate",
        "EndDate",
        "BudgetedCost",
        "ActualCost"
      ],
      "importantFields": [
        "NumberOfLeads",
        "NumberOfConvertedLeads",
        "NumberOfContacts",
        "NumberOfOpportunities",
        "AmountAllOpportunities",
        "AmountWonOpportunities"
      ]
    }
  },
  "sections": {
    "contact": [
      {
        "label": "Contact Essentials",
        "order": 1,
        "fields": ["Name", "Email", "Phone", "LeadSource", "AccountId", "Title", "Department", "OwnerId"]
      },
      {
        "label": "Marketing Status & Progression",
        "order": 2,
        "fields": ["Marketing_Stage__c", "Prospect_Status__c", "Qualification_Status__c", "Recent_MQL_Date__c", "Recent_MQL_Type__c", "First_MQL_Type__c"]
      },
      {
        "label": "Campaign Attribution",
        "order": 3,
        "fields": ["First_Touch_Campaign__c", "First_Touch_Date__c", "Contact_Source_Detail__c", "Last_Touch_Campaign__c", "Last_Touch_Date__c", "Last_Engagement_Date__c"]
      },
      {
        "label": "Funnel Milestones",
        "order": 4,
        "fields": ["Original_MQL_Date__c", "SQL_Date_Stamp__c", "Customer_Date_Stamp__c", "SQO_Date_Stamp__c", "Disqualified_Date_Stamp__c"]
      },
      {
        "label": "Marketing Preferences & Compliance",
        "order": 5,
        "fields": ["HasOptedOutOfEmail", "DoNotCall", "Last_Unresponsive_Marketing__c", "Last_Prospect_Status_Change__c"]
      }
    ],
    "lead": [
      {
        "label": "Lead Information",
        "order": 1,
        "fields": ["Name", "Company", "Email", "Phone", "Status", "LeadSource", "Rating", "OwnerId"]
      },
      {
        "label": "Marketing Details",
        "order": 2,
        "fields": ["Campaign__c", "Lead_Score__c", "Last_Campaign_Touch__c", "MQL_Date__c", "First_Touch_Date__c"]
      },
      {
        "label": "Qualification Information",
        "order": 3,
        "fields": ["Title", "Industry", "NumberOfEmployees", "AnnualRevenue", "Description"]
      }
    ],
    "campaign": [
      {
        "label": "Campaign Information",
        "order": 1,
        "fields": ["Name", "Status", "Type", "StartDate", "EndDate", "IsActive", "Description"]
      },
      {
        "label": "Budget & Cost",
        "order": 2,
        "fields": ["BudgetedCost", "ActualCost", "ExpectedRevenue", "ExpectedResponse"]
      },
      {
        "label": "Performance Metrics",
        "order": 3,
        "fields": ["NumberOfLeads", "NumberOfConvertedLeads", "NumberOfContacts", "NumberOfOpportunities", "AmountAllOpportunities", "AmountWonOpportunities"]
      }
    ]
  },
  "compactLayoutFields": {
    "contact": ["Email", "Marketing_Stage__c", "Last_Touch_Campaign__c", "Recent_MQL_Date__c"],
    "lead": ["Email", "Status", "LeadSource", "Campaign__c"],
    "campaign": ["Status", "Type", "NumberOfLeads", "ActualCost"]
  },
  "conditionalVisibility": {
    "rules": [
      {
        "name": "MQL Fields",
        "condition": "Marketing_Stage__c = 'MQL'",
        "action": "Show section 'MQL Details'"
      },
      {
        "name": "Disqualified Reason",
        "condition": "Prospect_Status__c = 'Disqualified'",
        "action": "Show field 'Disqualification_Reason__c'"
      },
      {
        "name": "Email Preferences",
        "condition": "HasOptedOutOfEmail = true",
        "action": "Highlight 'Email Opt Out Status'"
      }
    ]
  },
  "mobile": {
    "optimized": true,
    "maxFieldsFirstScreen": 12,
    "priority": "Email, marketing stage, last campaign touch, engagement date"
  },
  "bestPractices": {
    "useDynamicForms": true,
    "useHighlightsPanel": true,
    "usePathComponent": false,
    "maxComponentsPerPage": 12,
    "filterRelatedListsToRelevant": true
  },
  "objectGuidance": {
    "Account": {
      "sections": [
        {"name": "Account Information", "fields": ["Name", "Type", "Industry", "Website"]},
        {"name": "Marketing Context", "fields": ["AccountSource", "Marketing_Segment__c", "ABM_Tier__c"]},
        {"name": "Engagement", "fields": ["Last_Marketing_Touch__c", "Marketing_Qualified__c"]}
      ],
      "compactFields": ["Type", "Industry", "AccountSource", "OwnerId"],
      "relatedLists": ["Contacts", "CampaignMembers", "Opportunities"],
      "defaultTab": "Related",
      "rationale": "Marketing users access accounts to see contacts and campaign engagement - Related tab shows marketing relationships"
    },
    "Contact": {
      "sections": [
        {"name": "Contact Essentials", "fields": ["Name", "Email", "AccountId", "Title", "Department"]},
        {"name": "Marketing Status", "fields": ["Marketing_Stage__c", "Prospect_Status__c", "Qualification_Status__c"]},
        {"name": "Campaign Attribution", "fields": ["First_Touch_Campaign__c", "Last_Touch_Campaign__c", "LeadSource"]},
        {"name": "Funnel Dates", "fields": ["Recent_MQL_Date__c", "SQL_Date_Stamp__c"]},
        {"name": "Preferences", "fields": ["HasOptedOutOfEmail", "DoNotCall"]}
      ],
      "compactFields": ["Email", "Marketing_Stage__c", "Last_Touch_Campaign__c", "Recent_MQL_Date__c"],
      "relatedLists": ["CampaignMembers", "Activities", "Opportunities"],
      "defaultTab": "Details",
      "rationale": "Marketing users focus on funnel stage and attribution - Details tab shows marketing journey"
    },
    "Opportunity": {
      "sections": [
        {"name": "Opportunity Info", "fields": ["Name", "AccountId", "Amount", "StageName", "CloseDate"]},
        {"name": "Marketing Attribution", "fields": ["LeadSource", "CampaignId", "Primary_Campaign_Source__c"]},
        {"name": "Deal Context", "fields": ["Type", "ContactId"]}
      ],
      "compactFields": ["Amount", "StageName", "LeadSource", "CampaignId"],
      "relatedLists": ["CampaignInfluence", "Contacts"],
      "defaultTab": "Details",
      "rationale": "Marketing users view Opportunities for attribution - Details shows campaign influence"
    },
    "Quote": {
      "sections": [
        {"name": "Quote Overview", "fields": ["Name", "Status", "OpportunityId", "GrandTotal"]},
        {"name": "Timeline", "fields": ["ExpirationDate"]}
      ],
      "compactFields": ["Status", "GrandTotal", "OpportunityId", "ExpirationDate"],
      "relatedLists": ["QuoteLineItems"],
      "defaultTab": "Details",
      "rationale": "Marketing users rarely access Quotes - basic layout for context"
    },
    "QuoteLineItem": {
      "sections": [
        {"name": "Line Details", "fields": ["Product2Id", "Quantity", "TotalPrice"]}
      ],
      "compactFields": ["Product2Id", "Quantity", "TotalPrice"],
      "relatedLists": [],
      "defaultTab": "Details",
      "rationale": "Minimal layout - marketing users rarely access line items"
    }
  }
}
