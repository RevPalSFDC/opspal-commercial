{
  "templateMetadata": {
    "templateName": "Sales Manager Quota Attainment Dashboard",
    "templateVersion": "1.0",
    "description": "Team quota performance: individual and team attainment, pacing, forecast confidence",
    "audience": "Sales Managers, Team Leads",
    "useCase": "Track team quota performance, identify at-risk reps, forecast team results",
    "refreshFrequency": "Daily",
    "componentCount": 6
  },
  "dashboardLayout": {
    "components": [
      {
        "position": 1,
        "size": "half-width",
        "type": "Gauge",
        "title": "Team Quota Attainment (This Quarter)",
        "sourceReport": "team-quota-attainment",
        "metric": "SUM(Closed_Won_This_Quarter__c) / SUM(Quarterly_Quota__c)",
        "target": "100%",
        "greenZone": ">=100%",
        "yellowZone": "85-100%",
        "redZone": "<85%",
        "showDollarAmount": true
      },
      {
        "position": 2,
        "size": "half-width",
        "type": "Metric",
        "title": "Team Pacing (% of Quarter Elapsed)",
        "sourceReport": "team-pacing",
        "metric": "Team_Attainment__c / Days_Elapsed_Pct__c",
        "description": "On Pace = 100%, Behind = <100%, Ahead = >100%",
        "colorCode": {">=100": "green", ">=85": "yellow", "<85": "red"}
      },
      {
        "position": 3,
        "size": "full-width",
        "type": "Horizontal Bar Chart",
        "title": "Quota Attainment by Rep",
        "sourceReport": "quota-attainment-by-rep",
        "groupBy": "Rep Name",
        "metric": "Quota_Attainment__c",
        "sortBy": "Quota_Attainment__c DESC",
        "showTarget": "100%",
        "showDataLabels": true,
        "conditionalFormatting": {
          ">=100%": "green",
          "85-100%": "yellow",
          "70-85%": "orange",
          "<70%": "red"
        }
      },
      {
        "position": 4,
        "size": "half-width",
        "type": "Table",
        "title": "Rep Performance Detail",
        "sourceReport": "rep-performance-detail",
        "columns": [
          "Rep Name",
          "Quota",
          "Closed Won",
          "Attainment %",
          "Remaining Quota",
          "Open Pipeline",
          "Coverage",
          "Avg Deal Size",
          "Win Rate"
        ],
        "sortBy": "Attainment % DESC",
        "conditionalFormatting": {
          "Attainment__c": {">=1.0": "green", ">=0.85": "yellow", ">=0.70": "orange", "<0.70": "red"},
          "Pipeline_Coverage__c": {">=3": "green", ">=2": "yellow", "<2": "red"}
        }
      },
      {
        "position": 5,
        "size": "half-width",
        "type": "Scatter Chart",
        "title": "Attainment vs Pipeline Coverage",
        "sourceReport": "attainment-vs-coverage",
        "xAxis": "Quota Attainment %",
        "yAxis": "Pipeline Coverage Ratio",
        "dataPoints": "Individual Reps",
        "quadrants": {
          "topRight": "High Performers (high attainment + high pipeline)",
          "topLeft": "Building Pipeline (low attainment + high pipeline)",
          "bottomRight": "At Risk (high attainment but low pipeline)",
          "bottomLeft": "Need Intervention (low attainment + low pipeline)"
        }
      },
      {
        "position": 6,
        "size": "full-width",
        "type": "Table",
        "title": "At-Risk Reps (<70% Attainment)",
        "sourceReport": "at-risk-reps",
        "columns": [
          "Rep Name",
          "Quota",
          "Closed Won",
          "Attainment %",
          "Gap to 70%",
          "Open Pipeline",
          "Coverage",
          "Deals Needed (Est)",
          "Action Plan"
        ],
        "sortBy": "Attainment % ASC",
        "rowLimit": 10,
        "highlightRows": "All rows (this is the at-risk list)"
      }
    ]
  },
  "dashboardFilters": [
    {"field": "Time Period", "type": "Date Range", "default": "THIS_FISCAL_QUARTER"},
    {"field": "Rep", "type": "Picklist", "default": "All", "source": "User.Manager = $User.Id"}
  ],
  "sourceReportTemplates": [
    "team-quota-attainment.json",
    "team-pacing.json",
    "quota-attainment-by-rep.json",
    "rep-performance-detail.json",
    "attainment-vs-coverage.json",
    "at-risk-reps.json"
  ],
  "calculatedFieldsRequired": [
    {
      "fieldName": "Quota_Attainment__c",
      "fieldType": "Formula (Percent)",
      "formula": "Closed_Won_This_Quarter__c / Quarterly_Quota__c",
      "object": "User",
      "description": "Current quota attainment percentage"
    },
    {
      "fieldName": "Remaining_Quota__c",
      "fieldType": "Formula (Currency)",
      "formula": "Quarterly_Quota__c - Closed_Won_This_Quarter__c",
      "object": "User",
      "description": "Dollar amount still needed to hit quota"
    },
    {
      "fieldName": "Pipeline_Coverage__c",
      "fieldType": "Formula (Number)",
      "formula": "Open_Pipeline__c / Remaining_Quota__c",
      "object": "User",
      "description": "Pipeline coverage for remaining quota"
    },
    {
      "fieldName": "Deals_Needed__c",
      "fieldType": "Formula (Number)",
      "formula": "CEILING(Remaining_Quota__c / Average_Deal_Size__c)",
      "object": "User",
      "description": "Estimated deals needed to close quota gap"
    },
    {
      "fieldName": "Pacing__c",
      "fieldType": "Formula (Percent)",
      "formula": "Quota_Attainment__c / (Days_Elapsed_This_Quarter__c / 90)",
      "object": "User",
      "description": "Quota pacing vs time elapsed (100% = on pace)"
    }
  ],
  "deploymentInstructions": {
    "steps": [
      "1. Set up Quota object or User-level quota fields (Quarterly_Quota__c)",
      "2. Create rollup summaries or scheduled jobs to calculate Closed_Won_This_Quarter__c",
      "3. Create calculated fields (Quota_Attainment__c, Remaining_Quota__c, Pipeline_Coverage__c, etc.)",
      "4. Create all 6 source reports using templates",
      "5. Add report filter: User.Manager = $User.Id (dynamic filtering)",
      "6. Create dashboard in Dashboards folder (Manager)",
      "7. Add components in order specified",
      "8. Configure filters (Time Period, Rep)",
      "9. Set refresh schedule to daily at 6 AM",
      "10. Share with managers (view-only or editor)",
      "11. Create alerts: Team attainment <85%, At-risk reps >=3"
    ],
    "quotaManagement": {
      "option1StandardObject": "Use standard Quota object (requires Sales Cloud)",
      "option2CustomFields": "Add Quarterly_Quota__c to User object",
      "option3CustomObject": "Create custom Quota__c object with User lookup"
    }
  },
  "kpiDefinitions": {
    "quotaAttainment": {
      "formula": "Closed Won Revenue / Quota",
      "benchmark": "100% = on target, 80-90% = needs attention, <70% = at risk",
      "whyItMatters": "Primary measure of individual and team sales performance"
    },
    "pacing": {
      "formula": "Quota Attainment % / % of Quarter Elapsed",
      "benchmark": "100% = on pace, <100% = behind, >100% = ahead",
      "whyItMatters": "Leading indicator of whether team will hit quota by quarter end"
    },
    "pipelineCoverage": {
      "formula": "Open Pipeline / Remaining Quota",
      "benchmark": "3-4x for healthy coverage of remaining quota",
      "whyItMatters": "Indicates likelihood of closing quota gap"
    }
  },
  "usageScenarios": {
    "mondayMorning": {
      "focus": "Team quota attainment gauge, pacing metric",
      "questions": [
        "Are we on track to hit team quota?",
        "Do we need to adjust expectations or add resources?"
      ]
    },
    "midQuarter": {
      "focus": "Quota attainment by rep, at-risk reps table",
      "questions": [
        "Who's at risk of missing quota?",
        "What interventions are needed?"
      ]
    },
    "quarterEnd": {
      "focus": "Rep performance detail, attainment vs coverage scatter",
      "questions": [
        "Who exceeded quota? (rewards/recognition)",
        "Who missed quota? (coaching/PIP)",
        "Who has strong pipeline for next quarter?"
      ]
    }
  },
  "coachingInsights": {
    "performanceSegmentation": {
      "topPerformers": ">=120% attainment → Study and replicate their approach",
      "corePerformers": "85-120% attainment → Maintain momentum, provide resources",
      "developmentNeeded": "70-85% attainment → Coaching focus, skill gaps",
      "performanceImprovement": "<70% attainment → PIP, role change, or exit"
    },
    "redFlags": [
      "Attainment <70% at mid-quarter",
      "Pacing <85% (team won't hit quota at current rate)",
      "High attainment but low pipeline (borrowed from future quarters)",
      "Low attainment AND low pipeline (double trouble)"
    ],
    "actionItems": [
      "Attainment <70% mid-quarter → Formal coaching plan or PIP",
      "Pacing <85% → Increase prospecting, adjust forecast down, add resources",
      "Low pipeline → Lead redistribution, marketing support, prospecting sprint",
      "Consistently missing quota → Quota reset, role change, or performance exit"
    ]
  },
  "relatedTemplates": [
    "team-pipeline.json",
    "activity-metrics.json"
  ]
}
