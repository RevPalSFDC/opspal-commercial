{
  "templateMetadata": {
    "name": "Test Suite: TABULAR Basic",
    "version": "1.0.0",
    "description": "Tests basic TABULAR report creation"
  },
  "reportMetadata": {
    "name": "Open Opportunities List",
    "reportType": "Opportunity",
    "reportFormat": "TABULAR",
    "detailColumns": [
      "OPPORTUNITY_NAME",
      "ACCOUNT_NAME",
      "AMOUNT",
      "STAGE_NAME",
      "CLOSE_DATE",
      "OPPORTUNITY_OWNER",
      "PROBABILITY",
      "AGE"
    ],
    "reportFilters": [
      {
        "column": "STAGE_NAME",
        "operator": "notEqual",
        "value": "Closed Won"
      },
      {
        "column": "STAGE_NAME",
        "operator": "notEqual",
        "value": "Closed Lost"
      }
    ]
  },
  "fieldHints": {
    "OPPORTUNITY_OWNER": {
      "patterns": ["FULL_NAME", "OWNER_NAME"],
      "fallback": "FULL_NAME"
    }
  }
}
