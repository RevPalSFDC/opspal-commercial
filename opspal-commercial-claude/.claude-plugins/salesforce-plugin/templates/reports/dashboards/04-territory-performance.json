{
  "templateMetadata": {
    "templateName": "Territory Performance Report",
    "templateVersion": "1.0",
    "description": "Owner/territory pipeline performance for dashboard components.",
    "audience": "Sales Leaders, Regional Managers, RevOps",
    "useCase": "Territory health dashboards and owner performance comparisons.",
    "customizationPoints": [
      "Territory or owner segmentation",
      "Pipeline stage filters",
      "Date range for open pipeline"
    ],
    "prerequisites": [
      "Opportunity report type access",
      "Territory/owner assignments configured",
      "Consistent stage definitions"
    ]
  },
  "reportMetadata": {
    "reportName": "Territory Performance Report",
    "reportDescription": "Sales performance by owner and territory showing quota attainment, pipeline, and activity",
    "reportFormat": "SUMMARY",
    "scope": "organization",
    "showDetails": true,
    "groupings": [
      {
        "field": "FULL_NAME",
        "sortOrder": "Asc",
        "dateGranularity": "Day"
      }
    ],
    "columns": [
      {
        "field": "OPPORTUNITY_NAME",
        "label": "Opportunity Name"
      },
      {
        "field": "ACCOUNT_NAME",
        "label": "Account Name"
      },
      {
        "field": "AMOUNT",
        "label": "Amount"
      },
      {
        "field": "STAGE_NAME",
        "label": "Stage"
      },
      {
        "field": "CLOSE_DATE",
        "label": "Close Date"
      },
      {
        "field": "PROBABILITY",
        "label": "Probability (%)"
      }
    ],
    "filters": [
      {
        "column": "CLOSED",
        "operator": "equals",
        "value": "0"
      }
    ],
    "aggregates": [
      {
        "field": "AMOUNT",
        "aggregateType": "Sum",
        "label": "Total Pipeline by Owner"
      },
      {
        "field": "OPPORTUNITY_NAME",
        "aggregateType": "RowCount",
        "label": "Opp Count by Owner"
      },
      {
        "field": "AMOUNT",
        "aggregateType": "Average",
        "label": "Avg Deal Size by Owner"
      }
    ],
    "chart": {
      "chartType": "HorizontalBar",
      "groupingColumn": "FULL_NAME",
      "aggregateColumn": "s!AMOUNT",
      "title": "Pipeline by Rep",
      "showPercentages": false,
      "showValues": true
    },
    "reportType": "Opportunity"
  },
  "dashboardUsage": {
    "createDashboard": true,
    "dashboardName": "Territory Performance Dashboard",
    "description": "Rep and territory performance metrics: pipeline by owner, quota attainment, and activity levels",
    "components": [
      {
        "title": "Top Performer (Pipeline)",
        "componentType": "Metric",
        "section": "left",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "Highest Pipeline Value"
      },
      {
        "title": "Pipeline by Rep",
        "componentType": "Bar",
        "section": "left",
        "sortBy": "RowValueDescending",
        "legendPosition": "Bottom",
        "chartAxisRange": "Auto"
      },
      {
        "title": "Team Pipeline Value",
        "componentType": "Metric",
        "section": "middle",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "Total Team Pipeline"
      },
      {
        "title": "Average Pipeline per Rep",
        "componentType": "Metric",
        "section": "middle",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "Avg by Owner"
      },
      {
        "title": "Rep Performance Details",
        "componentType": "Table",
        "section": "right",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600"
      }
    ]
  }
}
