{
  "templateMetadata": {
    "templateName": "Win/Loss Analysis Report",
    "templateVersion": "1.0",
    "description": "Closed opportunity analysis for win rates, loss reasons, and competitive trends.",
    "audience": "Sales Leaders, Enablement, RevOps",
    "useCase": "Win/loss dashboards and competitive analysis.",
    "customizationPoints": [
      "Closed won/lost stage mappings",
      "Date range for analysis",
      "Loss reason or competitor fields"
    ],
    "prerequisites": [
      "Opportunity report type access",
      "Consistent closed stage definitions",
      "Loss reason/competitor fields populated"
    ]
  },
  "reportMetadata": {
    "reportName": "Win Loss Analysis Report",
    "reportDescription": "Closed opportunity analysis showing win rate, lost deals, and performance by competitor/reason",
    "reportFormat": "SUMMARY",
    "scope": "organization",
    "showDetails": true,
    "groupings": [
      {
        "field": "STAGE_NAME",
        "sortOrder": "Asc",
        "dateGranularity": "Day"
      }
    ],
    "columns": [
      {
        "field": "FULL_NAME",
        "label": "Opportunity Owner"
      },
      {
        "field": "OPPORTUNITY_NAME",
        "label": "Opportunity Name"
      },
      {
        "field": "ACCOUNT_NAME",
        "label": "Account Name"
      },
      {
        "field": "AMOUNT",
        "label": "Amount"
      },
      {
        "field": "CLOSE_DATE",
        "label": "Close Date"
      },
      {
        "field": "LEAD_SOURCE",
        "label": "Lead Source"
      }
    ],
    "filters": [
      {
        "column": "CLOSED",
        "operator": "equals",
        "value": "1"
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "LAST_FISCAL_QUARTER"
      }
    ],
    "aggregates": [
      {
        "field": "AMOUNT",
        "aggregateType": "Sum",
        "label": "Total Revenue"
      },
      {
        "field": "OPPORTUNITY_NAME",
        "aggregateType": "RowCount",
        "label": "Deal Count"
      },
      {
        "field": "AMOUNT",
        "aggregateType": "Average",
        "label": "Average Deal Size"
      }
    ],
    "chart": {
      "chartType": "Donut",
      "groupingColumn": "STAGE_NAME",
      "aggregateColumn": "s!AMOUNT",
      "title": "Wins vs Losses",
      "showPercentages": true,
      "showValues": true
    },
    "reportType": "Opportunity"
  },
  "dashboardUsage": {
    "createDashboard": true,
    "dashboardName": "Win Loss Analysis Dashboard",
    "description": "Performance analysis of closed deals: win rate, revenue breakdown, and key trends",
    "components": [
      {
        "title": "Win Rate",
        "componentType": "Metric",
        "section": "left",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "Closed Won %"
      },
      {
        "title": "Wins vs Losses",
        "componentType": "Donut",
        "section": "left",
        "legendPosition": "Right",
        "showPercentage": true
      },
      {
        "title": "Total Revenue (Won)",
        "componentType": "Metric",
        "section": "middle",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "Last Quarter"
      },
      {
        "title": "Average Deal Size",
        "componentType": "Metric",
        "section": "middle",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "Avg Won Deal"
      },
      {
        "title": "Recent Closed Deals",
        "componentType": "Table",
        "section": "right",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600"
      }
    ]
  }
}
