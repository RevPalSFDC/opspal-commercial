# Marketo Plugin Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Marketo API Credentials
# ============================================

# Client ID from Marketo LaunchPoint
# Found in: Admin → LaunchPoint → [Your Service] → View Details
MARKETO_CLIENT_ID=your-client-id-here

# Client Secret from Marketo LaunchPoint
# Found in: Admin → LaunchPoint → [Your Service] → View Details
MARKETO_CLIENT_SECRET=your-client-secret-here

# Base URL for Marketo REST API
# Format: https://{munchkin-id}.mktorest.com
# Example: https://123-ABC-456.mktorest.com
MARKETO_BASE_URL=https://XXX-XXX-XXX.mktorest.com

# ============================================
# OPTIONAL: Configuration
# ============================================

# Munchkin ID (auto-detected from BASE_URL if not set)
# Format: XXX-XXX-XXX (e.g., 123-ABC-456)
# MARKETO_MUNCHKIN_ID=123-ABC-456

# Default instance name (default: "default")
# Use for multi-instance configurations
# MARKETO_INSTANCE_NAME=production

# API request timeout in milliseconds (default: 30000)
# MARKETO_API_TIMEOUT=30000

# Rate limit (calls per 20 seconds, default: 100)
# MARKETO_RATE_LIMIT=100

# ============================================
# OPTIONAL: Feature Flags
# ============================================

# Skip authentication check on session start (default: 0)
# MARKETO_SKIP_AUTH_CHECK=0

# Skip quirks detection after authentication (default: 0)
# MARKETO_SKIP_QUIRKS_DETECTION=0

# ============================================
# HOW TO FIND YOUR CREDENTIALS
# ============================================
#
# 1. Log into Marketo as Admin
# 2. Go to Admin → LaunchPoint
# 3. Click "New" → "New Service"
# 4. Select "Custom" for Service Type
# 5. Give it a name (e.g., "Claude Code Integration")
# 6. Click "Create"
# 7. Click "View Details" to see Client ID and Client Secret
#
# Your Munchkin ID is in your Marketo URL:
#   https://app-{munchkin-id}.marketo.com
#   Example: https://app-123-abc-456.marketo.com → 123-ABC-456
#
# Your REST API Base URL is:
#   https://{munchkin-id}.mktorest.com
#   Example: https://123-ABC-456.mktorest.com
