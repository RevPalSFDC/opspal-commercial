# Developer Tools Plugin Environment Variables
#
# Copy this file to the project root as .env and fill in your values
# Location: /path/to/your/project/.env (NOT in the plugin directory)
#
# Usage: source .claude-plugins/developer-tools-plugin/scripts/lib/load-env.sh

# ============================================================================
# SUPABASE CONFIGURATION (Reflection Database)
# ============================================================================

# Supabase Project URL
# Find at: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (for read operations)
# Find at: https://app.supabase.com/project/_/settings/api
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (for write operations)
# ⚠️  WARNING: Keep this secret! Has admin access to database
# Find at: https://app.supabase.com/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# User Email (for attribution in database records)
USER_EMAIL=your.email@company.com

# ============================================================================
# ASANA CONFIGURATION (Task Management)
# ============================================================================

# Asana Personal Access Token
# Create at: https://app.asana.com/0/my-apps
# Required Scopes: default (full access to your workspaces)
ASANA_ACCESS_TOKEN=0/your-token-here

# Asana Workspace GID
# Find by running: curl -H "Authorization: Bearer $ASANA_ACCESS_TOKEN" https://app.asana.com/api/1.0/workspaces
ASANA_WORKSPACE_ID=your-workspace-gid
ASANA_WORKSPACE_GID=your-workspace-gid

# Asana Project GID (for reflection improvements)
# Find at: Project URL after /0/ and before /list
# Example: https://app.asana.com/0/1234567890/list → GID is 1234567890
ASANA_PROJECT_GID=your-project-gid
ASANA_REFLECTION_PROJECT_GID=your-project-gid

# Asana Read-Only Mode (set to true to prevent task creation)
ASANA_READ_ONLY_MODE=false

# ============================================================================
# ASANA ENHANCED FEATURES (Optional)
# ============================================================================

# Sprint Configuration
ASANA_SPRINT_ENABLED=true
ASANA_SPRINT_FORMAT="Sprint {number} ({start} - {end})"
ASANA_SPRINT_DURATION=14
ASANA_SPRINT_START_DATE=2024-01-01

# Task Matching (prevent duplicates)
ASANA_TASK_MATCHING_ENABLED=true
ASANA_SIMILARITY_THRESHOLD=0.8

# Environment Prefixes (for multi-environment task management)
ASANA_ENV_PREFIX_ENABLED=true
ASANA_PREFIX_PROD=[PROD]
ASANA_PREFIX_SANDBOX=[SB]

# Default Assignee
ASANA_ASSIGNEE=your.email@company.com

# ============================================================================
# SLACK CONFIGURATION (Notifications)
# ============================================================================

# Slack Incoming Webhook URL
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# NOTES
# ============================================================================
#
# Required for /processreflections command:
#   - SUPABASE_URL
#   - SUPABASE_SERVICE_ROLE_KEY (NOT anon key!)
#   - ASANA_ACCESS_TOKEN
#   - ASANA_WORKSPACE_ID
#   - ASANA_PROJECT_GID
#   - USER_EMAIL
#
# Optional Variables:
#   - SUPABASE_ANON_KEY (for read-only operations)
#   - ASANA_* feature flags (for customization)
#   - SLACK_WEBHOOK_URL (for notifications)
#
# Security:
#   - NEVER commit .env file to git
#   - Add .env to your .gitignore
#   - Keep SUPABASE_SERVICE_ROLE_KEY secret (has admin access)
#   - Keep ASANA_ACCESS_TOKEN secret (has full workspace access)
#   - Rotate tokens regularly
#
# Testing:
#   - Use ASANA_READ_ONLY_MODE=true to test without creating tasks
#   - Use separate Asana project for testing (ASANA_TEST_PROJECT_GID)
#
# Troubleshooting:
#   - Run: source .claude-plugins/developer-tools-plugin/scripts/lib/load-env.sh
#   - Verify with: echo $SUPABASE_URL
#   - Check: .claude-plugins/developer-tools-plugin/scripts/lib/load-env.sh --help
#
