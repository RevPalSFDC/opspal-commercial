# Automatic Agent Routing Configuration
# Copy this file to .env and customize values

# ============================================
# ROUTING SYSTEM
# ============================================

# Enable/disable auto-routing (1=enabled, 0=disabled)
# When enabled, prompts are automatically routed to appropriate agents
ENABLE_AUTO_ROUTING=1

# Confidence threshold for auto-routing (0.0-1.0)
# Agents with confidence >= this value will be auto-selected
# Default: 0.7 (70% confidence)
ROUTING_CONFIDENCE_THRESHOLD=0.7

# Complexity threshold for required routing (0.0-1.0)
# Tasks with complexity >= this value MUST use an agent
# Default: 0.7 (high complexity tasks require agents)
COMPLEXITY_THRESHOLD=0.7

# Semantic routing threshold (0.0-1.0)
# Minimum similarity score for semantic matches
# Default: 0.3 (30% similarity)
SEMANTIC_THRESHOLD=0.3

# Hook timeout in seconds
# Maximum time for routing analysis
# Default: 5 seconds
HOOK_TIMEOUT=5

# ============================================
# SUPABASE CONFIGURATION (ACE Skill Registry)
# ============================================

# Supabase project URL
# Get from: Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for client-side)
# Get from: Supabase Dashboard > Settings > API > anon/public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (server-side only, has admin access)
# Get from: Supabase Dashboard > Settings > API > service_role
# WARNING: Keep secret - has full database access
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# ACE FRAMEWORK ROUTING INTEGRATION
# ============================================

# Enable ACE skill-based confidence boost (1=enabled, 0=disabled)
# Uses agent's historical skill performance to boost/penalize routing confidence
# Default: 1 (enabled)
ENABLE_ACE_ROUTING=1

# Enable ACE tier override (1=enabled, 0=disabled)
# High performers (90%+ success) get downgraded from BLOCKED to RECOMMENDED
# Low performers (<50% success) get upgraded from AVAILABLE to RECOMMENDED
# Default: 1 (enabled)
ENABLE_ACE_TIER_OVERRIDE=1

# ACE cache TTL in seconds
# How long to cache skill performance data
# Default: 300 (5 minutes)
ACE_CACHE_TTL=300

# ============================================
# LOGGING & DEBUGGING
# ============================================

# Enable verbose logging (1=enabled, 0=disabled)
# Shows detailed routing decisions in logs
ROUTING_VERBOSE=0

# Log file location
# Where routing decisions are logged
ROUTING_LOG_FILE=/tmp/routing-hook.log

# Metrics file location
# Where routing metrics are stored
ROUTING_METRICS_FILE=/tmp/routing-metrics.jsonl

# ============================================
# ADVANCED FEATURES (Phase 6-7)
# ============================================

# Enable semantic routing (1=enabled, 0=disabled)
# Uses TF-IDF vectorization for semantic matching
# Default: 1 (enabled)
ENABLE_SEMANTIC_ROUTING=1

# Enable agent composition (1=enabled, 0=disabled)
# Automatically composes multi-agent workflows for complex tasks
# Default: 1 (enabled)
ENABLE_AGENT_COMPOSITION=1

# Composition threshold (0.0-1.0)
# Complexity threshold for automatic workflow composition
# Default: 0.8 (only very complex tasks)
COMPOSITION_THRESHOLD=0.8

# Enable adaptive thresholds (1=enabled, 0=disabled)
# Automatically adjusts thresholds based on performance
# Default: 0 (disabled - manual tuning recommended initially)
ENABLE_ADAPTIVE_THRESHOLDS=0

# Adaptive threshold adjustment window (days)
# Number of days to analyze for threshold adaptation
# Default: 7 days
ADAPTIVE_THRESHOLD_WINDOW=7

# ============================================
# API & DASHBOARD (Phase 7)
# ============================================

# Enable routing API (1=enabled, 0=disabled)
# REST API for external routing requests
# Default: 0 (disabled)
ENABLE_ROUTING_API=0

# API port
# Port for routing recommendation API
# Default: 3000
ROUTING_API_PORT=3000

# API authentication (optional)
# JWT secret for API authentication
# ROUTING_API_SECRET=your-secret-here

# Enable dashboard (1=enabled, 0=disabled)
# Web-based routing metrics dashboard
# Default: 0 (disabled)
ENABLE_ROUTING_DASHBOARD=0

# Dashboard port
# Port for routing dashboard
# Default: 3001
ROUTING_DASHBOARD_PORT=3001

# ============================================
# A/B TESTING (Phase 7)
# ============================================

# Enable A/B testing (1=enabled, 0=disabled)
# Test different routing strategies
# Default: 0 (disabled)
ENABLE_AB_TESTING=0

# A/B test experiment ID
# Current experiment being run
# AB_EXPERIMENT_ID=

# A/B test variant (A or B)
# Which variant this instance should use
# AB_TEST_VARIANT=A

# ============================================
# PERFORMANCE TUNING
# ============================================

# Vector cache location
# Where semantic routing vectors are cached
VECTOR_CACHE_PATH=/tmp/routing-vector-cache.json

# Metrics retention (days)
# How long to keep routing metrics
# Default: 30 days
METRICS_RETENTION_DAYS=30

# Learning data location
# Where routing learning insights are stored
LEARNING_DATA_FILE=/tmp/routing-learning.json
