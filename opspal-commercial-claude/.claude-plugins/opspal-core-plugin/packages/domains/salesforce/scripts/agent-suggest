#!/bin/bash

# Agent Suggest - Interactive CLI tool for agent discovery and recommendations
# Provides instant agent suggestions based on task descriptions

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# Configuration
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
AGENT_DIR="${AGENT_DIR:-${CLAUDE_PLUGIN_ROOT:-$PLUGIN_ROOT}/agents}"
AUTO_ROUTER="$SCRIPT_DIR/auto-agent-router.js"

# Function to display header
show_header() {
    echo -e "${CYAN}╔════════════════════════════════════════════════════════╗${RESET}"
    echo -e "${CYAN}║          ${BOLD}🤖 AGENT DISCOVERY & SUGGESTION TOOL 🤖${RESET}${CYAN}        ║${RESET}"
    echo -e "${CYAN}╚════════════════════════════════════════════════════════╝${RESET}"
    echo ""
}

# Function to list all available agents
list_agents() {
    echo -e "${YELLOW}Available Salesforce Agents:${RESET}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

    # Core orchestrators
    echo -e "\n${BOLD}🎯 Core Orchestrators${RESET}"
    echo -e "  ${PURPLE}sfdc-orchestrator${RESET} - Coordinates complex multi-step operations"
    echo -e "  ${PURPLE}sfdc-planner${RESET} - Analyzes requirements and creates plans"
    echo -e "  ${PURPLE}principal-engineer${RESET} - High-level technical decision making"

    # Metadata & Structure
    echo -e "\n${BOLD}📦 Metadata & Structure${RESET}"
    echo -e "  ${GREEN}sfdc-metadata-manager${RESET} - Objects, fields, validation rules"
    echo -e "  ${GREEN}sfdc-field-analyzer${RESET} - Field analysis and validation"
    echo -e "  ${GREEN}sfdc-dependency-analyzer${RESET} - Dependency mapping and sequencing"

    # Development
    echo -e "\n${BOLD}💻 Development${RESET}"
    echo -e "  ${BLUE}sfdc-apex-developer${RESET} - Apex classes, triggers, tests"
    echo -e "  ${BLUE}sfdc-lightning-developer${RESET} - LWC and Aura components"
    echo -e "  ${BLUE}sfdc-automation-builder${RESET} - Flows, workflows, process builder"

    # Data Operations
    echo -e "\n${BOLD}💾 Data Operations${RESET}"
    echo -e "  ${YELLOW}sfdc-data-operations${RESET} - Bulk operations, imports, exports"
    echo -e "  ${YELLOW}sfdc-query-specialist${RESET} - SOQL query optimization"
    echo -e "  ${YELLOW}sfdc-data-generator${RESET} - Mock data generation"

    # Deployment & Quality
    echo -e "\n${BOLD}🚀 Deployment & Quality${RESET}"
    echo -e "  ${RED}sfdc-deployment-manager${RESET} - Deployments with validation"
    echo -e "  ${RED}sfdc-conflict-resolver${RESET} - Conflict resolution"
    echo -e "  ${RED}sfdc-quality-auditor${RESET} - Quality checks and audits"

    # Security & Compliance
    echo -e "\n${BOLD}🔒 Security & Compliance${RESET}"
    echo -e "  ${CYAN}sfdc-security-admin${RESET} - Permissions and profiles"
    echo -e "  ${CYAN}sfdc-compliance-officer${RESET} - Compliance and regulations"

    # Analytics & Reporting
    echo -e "\n${BOLD}📊 Analytics & Reporting${RESET}"
    echo -e "  ${PURPLE}sfdc-reports-dashboards${RESET} - Reports and dashboards"
    echo -e "  ${PURPLE}sfdc-revops-auditor${RESET} - RevOps assessments"

    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BOLD}Total: 52 specialized agents available${RESET}"
}

# Function to suggest agent based on task
suggest_for_task() {
    local task="$1"

    echo -e "${YELLOW}Analyzing task...${RESET}"
    echo ""

    # Use auto-router for analysis
    if [ -f "$AUTO_ROUTER" ]; then
        node "$AUTO_ROUTER" route "$task"
    else
        # Fallback pattern matching
        echo -e "${BOLD}Task:${RESET} $task"
        echo ""

        # Simple pattern matching
        if echo "$task" | grep -iE "deploy|release|production" > /dev/null; then
            echo -e "${GREEN}Recommended Agent:${RESET} ${PURPLE}sfdc-deployment-manager${RESET}"
            echo -e "${CYAN}Why:${RESET} Handles deployments with validation and rollback"
        elif echo "$task" | grep -iE "conflict|error|failed" > /dev/null; then
            echo -e "${GREEN}Recommended Agent:${RESET} ${PURPLE}sfdc-conflict-resolver${RESET}"
            echo -e "${CYAN}Why:${RESET} Resolves conflicts and prevents failures"
        elif echo "$task" | grep -iE "plan|design|architect" > /dev/null; then
            echo -e "${GREEN}Recommended Agent:${RESET} ${PURPLE}sfdc-planner${RESET}"
            echo -e "${CYAN}Why:${RESET} Creates implementation plans"
        elif echo "$task" | grep -iE "field|object|metadata" > /dev/null; then
            echo -e "${GREEN}Recommended Agent:${RESET} ${PURPLE}sfdc-metadata-manager${RESET}"
            echo -e "${CYAN}Why:${RESET} Manages metadata with validation"
        elif echo "$task" | grep -iE "bulk|import|export|data" > /dev/null; then
            echo -e "${GREEN}Recommended Agent:${RESET} ${PURPLE}sfdc-data-operations${RESET}"
            echo -e "${CYAN}Why:${RESET} Handles large data operations"
        elif echo "$task" | grep -iE "apex|trigger|class" > /dev/null; then
            echo -e "${GREEN}Recommended Agent:${RESET} ${PURPLE}sfdc-apex-developer${RESET}"
            echo -e "${CYAN}Why:${RESET} Develops and tests Apex code"
        else
            echo -e "${YELLOW}Consider using:${RESET} ${PURPLE}sfdc-planner${RESET}"
            echo -e "${CYAN}Why:${RESET} Can analyze and plan any task"
        fi
    fi
}

# Function to compare manual vs agent approach
compare_approaches() {
    local task="$1"

    echo -e "${YELLOW}Task:${RESET} $task"
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

    # Manual approach
    echo -e "${RED}❌ Manual Approach:${RESET}"
    echo "  • Research documentation"
    echo "  • Write custom scripts"
    echo "  • Handle edge cases manually"
    echo "  • Debug failures yourself"
    echo "  • No rollback capability"
    echo -e "  ${BOLD}Time: 2-4 hours${RESET}"
    echo -e "  ${BOLD}Risk: High${RESET}"

    echo ""

    # Agent approach
    echo -e "${GREEN}✓ Agent Approach:${RESET}"
    echo "  • Pre-built expertise"
    echo "  • Automated validation"
    echo "  • Error prevention built-in"
    echo "  • Rollback on failure"
    echo "  • Best practices enforced"
    echo -e "  ${BOLD}Time: 15-30 minutes${RESET}"
    echo -e "  ${BOLD}Risk: Low${RESET}"

    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${GREEN}${BOLD}Efficiency Gain: 75-90% time saved${RESET}"
}

# Function to show agent details
show_agent_details() {
    local agent="$1"
    local agent_file="$AGENT_DIR/${agent}.md"

    if [ -f "$agent_file" ]; then
        echo -e "${YELLOW}Agent Details: ${PURPLE}$agent${RESET}"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

        # Extract description from agent file
        head -20 "$agent_file" | grep -E "^#|description:" | sed 's/^#*//g'

        echo ""
        echo -e "${GREEN}Capabilities:${RESET}"
        grep -E "^\- " "$agent_file" | head -5

        echo ""
        echo -e "${BOLD}To use this agent:${RESET}"
        echo "  Task tool with subagent_type='$agent'"
    else
        echo -e "${RED}Agent file not found: $agent${RESET}"
    fi
}

# Function for interactive mode
interactive_mode() {
    show_header

    while true; do
        echo ""
        echo -e "${BOLD}What would you like to do?${RESET}"
        echo "  1) Get agent suggestion for a task"
        echo "  2) List all available agents"
        echo "  3) Compare manual vs agent approach"
        echo "  4) Show agent details"
        echo "  5) View agent usage statistics"
        echo "  6) Exit"
        echo ""
        echo -n "Choice [1-6]: "
        read -r choice

        case "$choice" in
            1)
                echo ""
                echo -e "${YELLOW}Describe your task:${RESET}"
                read -r task
                echo ""
                suggest_for_task "$task"
                ;;
            2)
                echo ""
                list_agents
                ;;
            3)
                echo ""
                echo -e "${YELLOW}Describe your task:${RESET}"
                read -r task
                echo ""
                compare_approaches "$task"
                ;;
            4)
                echo ""
                echo -e "${YELLOW}Enter agent name (e.g., sfdc-planner):${RESET}"
                read -r agent
                echo ""
                show_agent_details "$agent"
                ;;
            5)
                echo ""
                if [ -f "$SCRIPT_DIR/../.claude/agent-analytics.js" ]; then
                    node "$SCRIPT_DIR/../.claude/agent-analytics.js" report
                else
                    echo -e "${RED}Analytics not available${RESET}"
                fi
                ;;
            6)
                echo -e "${GREEN}Goodbye!${RESET}"
                exit 0
                ;;
            *)
                echo -e "${RED}Invalid choice${RESET}"
                ;;
        esac
    done
}

# Main execution
case "${1:-}" in
    list|ls)
        show_header
        list_agents
        ;;
    suggest|find)
        shift
        show_header
        suggest_for_task "$*"
        ;;
    compare)
        shift
        show_header
        compare_approaches "$*"
        ;;
    details|info)
        shift
        show_header
        show_agent_details "$1"
        ;;
    why)
        show_header
        echo -e "${BOLD}Why Use Agents?${RESET}"
        echo ""
        echo -e "${GREEN}✓ Prevent Errors:${RESET} Agents validate before execution"
        echo -e "${GREEN}✓ Save Time:${RESET} Pre-built expertise and automation"
        echo -e "${GREEN}✓ Best Practices:${RESET} Follows Salesforce guidelines"
        echo -e "${GREEN}✓ Rollback:${RESET} Automatic recovery from failures"
        echo -e "${GREEN}✓ Documentation:${RESET} Self-documenting operations"
        echo ""
        echo -e "${YELLOW}Example Time Savings:${RESET}"
        echo "  • Field creation: 5 min vs 30 min"
        echo "  • Deployment: 15 min vs 2 hours"
        echo "  • Conflict resolution: 10 min vs 4 hours"
        echo "  • Data migration: 30 min vs 1 day"
        ;;
    interactive|i)
        interactive_mode
        ;;
    *)
        show_header
        echo "Usage: agent-suggest <command> [options]"
        echo ""
        echo "Commands:"
        echo "  list              - List all available agents"
        echo "  suggest <task>    - Get agent suggestion for task"
        echo "  compare <task>    - Compare manual vs agent approach"
        echo "  details <agent>   - Show agent details"
        echo "  why               - Why use agents?"
        echo "  interactive       - Interactive mode"
        echo ""
        echo "Examples:"
        echo "  agent-suggest suggest 'deploy custom fields to production'"
        echo "  agent-suggest compare 'bulk update 10000 accounts'"
        echo "  agent-suggest details sfdc-planner"
        echo ""
        echo -e "${BOLD}Tip:${RESET} Run 'agent-suggest interactive' for guided discovery"
        ;;
esac
