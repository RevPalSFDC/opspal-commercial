{
  "name": "@revpal-internal/data-hygiene-plugin",
  "version": "1.0.1",
  "description": "Cross-platform data deduplication and hygiene management for HubSpot and Salesforce",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "deduplication",
    "data-hygiene",
    "hubspot",
    "salesforce",
    "merge",
    "data-quality"
  ],
  "author": {
    "name": "RevPal Engineering",
    "email": "engineering@gorevpal.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/RevPalSFDC/opspal-plugin-internal-marketplace"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "verbose": true,
    "collectCoverageFrom": [
      "scripts/lib/**/*.js",
      "!scripts/lib/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 60,
        "branches": 50,
        "functions": 60,
        "lines": 60
      }
    },
    "moduleNameMapper": {
      "^.*/salesforce-plugin/scripts/lib/csv-schema-validator$": "<rootDir>/scripts/lib/__mocks__/csv-schema-validator.js"
    }
  }
}
