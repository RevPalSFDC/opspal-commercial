{
  "templateMetadata": {
    "id": "funnel-conversion",
    "name": "Sales Funnel Conversion Analysis",
    "version": "1.0.0",
    "description": "Analyze conversion rates at each funnel stage from lead to close with bottleneck identification",
    "category": "funnel",
    "targetAudience": ["sales-leadership", "marketing", "sales-ops"],
    "recommendedFrequency": "monthly",
    "estimatedGenerationTime": "5-7 minutes"
  },
  "reportMetadata": {
    "defaultTitle": "Funnel Conversion Report",
    "defaultPeriod": "Q4",
    "defaultFormat": "pdf",
    "defaultSegmentation": ["source", "rep"],
    "supportedFormats": ["pdf", "excel", "sheets", "csv"]
  },
  "kpis": [
    {
      "id": "LEAD_TO_OPP_RATE",
      "required": true,
      "displayOrder": 1,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "MQL_TO_SQL_RATE",
      "required": true,
      "displayOrder": 2,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "SQL_TO_OPP_RATE",
      "required": true,
      "displayOrder": 3,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "OPP_TO_CLOSE_RATE",
      "required": true,
      "displayOrder": 4,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "OVERALL_CONVERSION",
      "required": true,
      "displayOrder": 5,
      "chartType": "line",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "MEETING_SHOW_RATE",
      "required": false,
      "displayOrder": 6,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": true
    }
  ],
  "dataSources": {
    "salesforce": {
      "objects": ["Lead", "Contact", "Opportunity", "Event", "Task", "CampaignMember"],
      "requiredFields": {
        "Lead": ["Id", "Status", "ConvertedDate", "ConvertedOpportunityId", "LeadSource", "CreatedDate"],
        "Opportunity": ["Id", "Amount", "StageName", "CloseDate", "IsWon", "IsClosed", "CreatedDate"],
        "Event": ["Id", "Subject", "WhoId", "WhatId", "StartDateTime", "ShowedUp__c"]
      },
      "optionalFields": ["MQL_Date__c", "SQL_Date__c", "Qualified_Date__c"],
      "filters": {
        "convertedLeads": "IsConverted = true",
        "closedWon": "IsWon = true",
        "meetings": "Subject LIKE '%Meeting%' OR Subject LIKE '%Demo%'"
      }
    },
    "hubspot": {
      "objects": ["contacts", "deals", "meetings", "engagements"],
      "requiredProperties": {
        "contacts": ["lifecyclestage", "hs_lead_status", "createdate", "hs_analytics_source"],
        "deals": ["dealstage", "amount", "closedate", "createdate"]
      },
      "optionalProperties": ["hs_lifecyclestage_marketingqualifiedlead_date", "hs_lifecyclestage_salesqualifiedlead_date"],
      "filters": {
        "leads": "lifecyclestage = 'lead'",
        "mqls": "lifecyclestage = 'marketingqualifiedlead'",
        "sqls": "lifecyclestage = 'salesqualifiedlead'"
      }
    }
  },
  "funnelStages": [
    {
      "id": "lead",
      "name": "Lead",
      "order": 1,
      "source": { "salesforce": "Lead", "hubspot": "contacts" },
      "criteria": { "salesforce": "IsConverted = false", "hubspot": "lifecyclestage = 'lead'" }
    },
    {
      "id": "mql",
      "name": "MQL",
      "order": 2,
      "source": { "salesforce": "Lead", "hubspot": "contacts" },
      "criteria": { "salesforce": "Status = 'MQL'", "hubspot": "lifecyclestage = 'marketingqualifiedlead'" }
    },
    {
      "id": "sql",
      "name": "SQL",
      "order": 3,
      "source": { "salesforce": "Lead", "hubspot": "contacts" },
      "criteria": { "salesforce": "Status = 'SQL'", "hubspot": "lifecyclestage = 'salesqualifiedlead'" }
    },
    {
      "id": "opportunity",
      "name": "Opportunity",
      "order": 4,
      "source": { "salesforce": "Opportunity", "hubspot": "deals" },
      "criteria": { "salesforce": "IsClosed = false", "hubspot": "dealstage != 'closedwon' AND dealstage != 'closedlost'" }
    },
    {
      "id": "closed_won",
      "name": "Closed Won",
      "order": 5,
      "source": { "salesforce": "Opportunity", "hubspot": "deals" },
      "criteria": { "salesforce": "IsWon = true", "hubspot": "dealstage = 'closedwon'" }
    }
  ],
  "sections": [
    {
      "id": "executive-summary",
      "title": "Executive Summary",
      "type": "summary",
      "order": 1,
      "content": {
        "blufTemplate": "Overall lead-to-close conversion is ${overall_rate}% (${rate_assessment}). ${bottleneck_stage} is the primary bottleneck at ${bottleneck_rate}%. ${improvement_insight}.",
        "keyMetrics": ["OVERALL_CONVERSION", "LEAD_TO_OPP_RATE", "OPP_TO_CLOSE_RATE"],
        "maxHighlights": 3,
        "maxRecommendations": 3
      }
    },
    {
      "id": "funnel-dashboard",
      "title": "Funnel Overview",
      "type": "dashboard",
      "order": 2,
      "kpis": ["LEAD_TO_OPP_RATE", "MQL_TO_SQL_RATE", "SQL_TO_OPP_RATE", "OPP_TO_CLOSE_RATE"],
      "layout": "2x2",
      "showBenchmarkComparison": true
    },
    {
      "id": "funnel-visualization",
      "title": "Funnel Visualization",
      "type": "chart",
      "order": 3,
      "chartConfig": {
        "type": "funnel",
        "stages": ["Lead", "MQL", "SQL", "Opportunity", "Closed Won"],
        "showVolume": true,
        "showConversionRates": true,
        "showDropoff": true,
        "colorScale": ["#2E5A88", "#5B9BD5", "#70AD47", "#FFC000", "#70AD47"]
      }
    },
    {
      "id": "stage-conversion-detail",
      "title": "Stage-by-Stage Conversion",
      "type": "detail",
      "order": 4,
      "breakdown": {
        "dimension": "stage_transition",
        "metrics": ["from_count", "to_count", "conversion_rate", "avg_time_days", "benchmark_rate"],
        "sortBy": "stage_order",
        "sortOrder": "asc"
      }
    },
    {
      "id": "conversion-trend",
      "title": "Conversion Rate Trends",
      "type": "chart",
      "order": 5,
      "chartConfig": {
        "type": "line",
        "metrics": ["LEAD_TO_OPP_RATE", "MQL_TO_SQL_RATE", "SQL_TO_OPP_RATE", "OPP_TO_CLOSE_RATE"],
        "groupBy": "CALENDAR_MONTH",
        "showMovingAverage": true
      }
    },
    {
      "id": "bottleneck-analysis",
      "title": "Bottleneck Analysis",
      "type": "analysis",
      "order": 6,
      "bottleneckConfig": {
        "identifyBy": "conversion_gap_to_benchmark",
        "metrics": ["stage", "current_rate", "benchmark_rate", "gap_percentage", "volume_impact", "revenue_impact"],
        "prioritizeBy": "revenue_impact"
      }
    },
    {
      "id": "conversion-by-source",
      "title": "Conversion by Lead Source",
      "type": "detail",
      "order": 7,
      "breakdown": {
        "dimension": "lead_source",
        "metrics": ["lead_count", "mql_rate", "sql_rate", "opp_rate", "close_rate", "overall_rate"],
        "sortBy": "overall_rate",
        "sortOrder": "desc"
      }
    },
    {
      "id": "conversion-by-rep",
      "title": "Conversion by Rep",
      "type": "detail",
      "order": 8,
      "breakdown": {
        "dimension": "owner",
        "metrics": ["leads_worked", "mqls_generated", "sqls_created", "opps_created", "deals_closed", "overall_rate"],
        "sortBy": "overall_rate",
        "sortOrder": "desc",
        "showTopN": 10
      }
    },
    {
      "id": "time-to-convert",
      "title": "Time to Convert",
      "type": "chart",
      "order": 9,
      "chartConfig": {
        "type": "horizontal_bar",
        "groupBy": "stage_transition",
        "metric": "avg_days",
        "showMedian": true,
        "showBenchmark": true
      }
    },
    {
      "id": "meeting-analysis",
      "title": "Meeting Conversion Analysis",
      "type": "detail",
      "order": 10,
      "metrics": [
        { "name": "Meetings Scheduled", "id": "meetings_scheduled" },
        { "name": "Meetings Held", "id": "meetings_held" },
        { "name": "Show Rate", "id": "MEETING_SHOW_RATE", "benchmark": 0.80 },
        { "name": "Meeting to Opp Rate", "id": "meeting_to_opp_rate", "benchmark": 0.50 }
      ]
    },
    {
      "id": "drop-off-analysis",
      "title": "Drop-Off Analysis",
      "type": "detail",
      "order": 11,
      "breakdown": {
        "dimension": "drop_off_reason",
        "metrics": ["count", "percentage", "stage", "avg_value_lost"],
        "byStage": true
      }
    },
    {
      "id": "cohort-conversion",
      "title": "Cohort Conversion Analysis",
      "type": "chart",
      "order": 12,
      "chartConfig": {
        "type": "heatmap",
        "cohortBy": "lead_created_month",
        "metric": "cumulative_conversion_rate",
        "periods": 6,
        "periodType": "month"
      }
    },
    {
      "id": "benchmark-comparison",
      "title": "Industry Benchmarks",
      "type": "comparison",
      "order": 13,
      "benchmarks": {
        "metrics": ["LEAD_TO_OPP_RATE", "MQL_TO_SQL_RATE", "SQL_TO_OPP_RATE", "OPP_TO_CLOSE_RATE"],
        "showPercentile": true,
        "showIndustryAvg": true,
        "showTopQuartile": true
      }
    },
    {
      "id": "methodology",
      "title": "Methodology",
      "type": "methodology",
      "order": 99,
      "include": ["dataSources", "formulas", "assumptions", "exclusions", "queries", "stageDefinitions"]
    }
  ],
  "calculations": {
    "lead_to_opp_rate": {
      "formula": "opportunities_created / leads_created * 100",
      "notes": "Percentage of leads that become opportunities"
    },
    "mql_to_sql_rate": {
      "formula": "sqls / mqls * 100",
      "notes": "Percentage of MQLs that qualify as SQLs"
    },
    "sql_to_opp_rate": {
      "formula": "opportunities / sqls * 100",
      "notes": "Percentage of SQLs that become opportunities"
    },
    "opp_to_close_rate": {
      "formula": "closed_won / opportunities * 100",
      "notes": "Percentage of opportunities that close-won (win rate)"
    },
    "overall_conversion": {
      "formula": "closed_won / leads * 100",
      "notes": "End-to-end conversion from lead to closed deal"
    },
    "meeting_show_rate": {
      "formula": "meetings_held / meetings_scheduled * 100",
      "notes": "Percentage of scheduled meetings that occur"
    }
  },
  "benchmarks": {
    "industry": "saas",
    "sources": [
      {
        "name": "HubSpot Sales Benchmark Report",
        "url": "https://www.hubspot.com/sales-benchmark-report",
        "metrics": ["LEAD_TO_OPP_RATE", "MQL_TO_SQL_RATE"]
      },
      {
        "name": "Gartner B2B Conversion Data",
        "url": "https://www.gartner.com",
        "metrics": ["SQL_TO_OPP_RATE", "OPP_TO_CLOSE_RATE"]
      },
      {
        "name": "Forrester Research",
        "url": "https://www.forrester.com",
        "metrics": ["OVERALL_CONVERSION"]
      }
    ],
    "thresholds": {
      "LEAD_TO_OPP_RATE": {
        "excellent": 0.15,
        "good": 0.10,
        "average": 0.05,
        "belowAverage": 0.02
      },
      "MQL_TO_SQL_RATE": {
        "excellent": 0.40,
        "good": 0.30,
        "average": 0.20,
        "belowAverage": 0.10
      },
      "SQL_TO_OPP_RATE": {
        "excellent": 0.60,
        "good": 0.50,
        "average": 0.35,
        "belowAverage": 0.20
      },
      "OPP_TO_CLOSE_RATE": {
        "excellent": 0.30,
        "good": 0.22,
        "average": 0.18,
        "belowAverage": 0.12
      },
      "MEETING_SHOW_RATE": {
        "excellent": 0.90,
        "good": 0.80,
        "average": 0.70,
        "belowAverage": 0.60
      }
    }
  },
  "defaults": {
    "dateRange": {
      "type": "relative",
      "value": "LAST_QUARTER"
    },
    "comparison": {
      "type": "previous_quarter"
    },
    "currency": "USD"
  },
  "exportConfig": {
    "pdf": {
      "orientation": "portrait",
      "includeCharts": true,
      "includeTables": true,
      "pageBreaks": ["conversion-by-source", "meeting-analysis", "methodology"]
    },
    "excel": {
      "sheets": [
        { "name": "Summary", "sections": ["executive-summary", "funnel-dashboard"] },
        { "name": "Funnel", "sections": ["funnel-visualization", "stage-conversion-detail"] },
        { "name": "Trends", "sections": ["conversion-trend"] },
        { "name": "Bottlenecks", "sections": ["bottleneck-analysis", "drop-off-analysis"] },
        { "name": "By Source", "sections": ["conversion-by-source"] },
        { "name": "By Rep", "sections": ["conversion-by-rep"] },
        { "name": "Time Analysis", "sections": ["time-to-convert"] },
        { "name": "Meetings", "sections": ["meeting-analysis"] },
        { "name": "Cohort", "sections": ["cohort-conversion"] },
        { "name": "Benchmarks", "sections": ["benchmark-comparison"] },
        { "name": "Methodology", "sections": ["methodology"] }
      ]
    }
  },
  "stageMapping": {
    "description": "Maps custom stage names to standard funnel stages",
    "customMappings": {
      "instructions": "Add your custom stage mappings here",
      "example": {
        "Prospecting": "lead",
        "Qualified": "mql",
        "Working": "sql",
        "Proposal": "opportunity",
        "Negotiation": "opportunity",
        "Closed Won": "closed_won"
      }
    }
  }
}
