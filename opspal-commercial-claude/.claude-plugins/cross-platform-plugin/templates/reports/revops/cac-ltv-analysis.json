{
  "templateMetadata": {
    "id": "cac-ltv-analysis",
    "name": "Unit Economics Analysis",
    "version": "1.0.0",
    "description": "Deep dive into customer acquisition costs, lifetime value, and unit economics efficiency",
    "category": "acquisition",
    "targetAudience": ["executive", "finance", "marketing", "sales"],
    "recommendedFrequency": "quarterly",
    "estimatedGenerationTime": "5-7 minutes"
  },
  "reportMetadata": {
    "defaultTitle": "Unit Economics Report",
    "defaultPeriod": "Q4",
    "defaultFormat": "pdf",
    "defaultSegmentation": ["segment", "channel"],
    "supportedFormats": ["pdf", "excel", "sheets", "csv"]
  },
  "kpis": [
    {
      "id": "CAC",
      "required": true,
      "displayOrder": 1,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": true,
      "invertColors": true
    },
    {
      "id": "LTV",
      "required": true,
      "displayOrder": 2,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "LTV_CAC_RATIO",
      "required": true,
      "displayOrder": 3,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true,
      "thresholds": {
        "excellent": 5,
        "good": 3,
        "warning": 1
      }
    },
    {
      "id": "CAC_PAYBACK",
      "required": true,
      "displayOrder": 4,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": true,
      "invertColors": true
    },
    {
      "id": "ARPU",
      "required": false,
      "displayOrder": 5,
      "chartType": "line",
      "showTrend": true,
      "showBenchmark": false
    },
    {
      "id": "MAGIC_NUMBER",
      "required": false,
      "displayOrder": 6,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true,
      "thresholds": {
        "excellent": 1.0,
        "good": 0.75,
        "warning": 0.5
      }
    }
  ],
  "dataSources": {
    "salesforce": {
      "objects": ["Opportunity", "Account", "Campaign", "CampaignMember"],
      "requiredFields": ["Amount", "CloseDate", "AccountId", "IsWon", "LeadSource"],
      "optionalFields": ["CampaignId", "Sales_Cost__c", "Marketing_Cost__c"],
      "filters": {
        "newBusiness": "Type = 'New Business' AND IsWon = true",
        "allWon": "IsWon = true"
      }
    },
    "hubspot": {
      "objects": ["deals", "contacts", "companies"],
      "requiredProperties": ["amount", "closedate", "hs_analytics_source", "associatedcompanyid"],
      "optionalProperties": ["campaign_id", "acquisition_cost"],
      "filters": {
        "newBusiness": "dealtype = 'newbusiness' AND dealstage = 'closedwon'"
      }
    },
    "external": {
      "required": ["sales_spend", "marketing_spend"],
      "optional": ["channel_spend_breakdown"],
      "sourceTypes": ["manual_input", "finance_system", "spreadsheet"]
    }
  },
  "sections": [
    {
      "id": "executive-summary",
      "title": "Executive Summary",
      "type": "summary",
      "order": 1,
      "content": {
        "blufTemplate": "LTV:CAC is ${ltv_cac_ratio}:1 (${ratio_assessment}). CAC payback is ${payback_months} months. ${efficiency_insight}.",
        "keyMetrics": ["LTV_CAC_RATIO", "CAC_PAYBACK", "MAGIC_NUMBER"],
        "maxHighlights": 3,
        "maxRecommendations": 3
      }
    },
    {
      "id": "unit-economics-dashboard",
      "title": "Unit Economics Overview",
      "type": "dashboard",
      "order": 2,
      "kpis": ["CAC", "LTV", "LTV_CAC_RATIO", "CAC_PAYBACK"],
      "layout": "2x2",
      "showBenchmarkComparison": true
    },
    {
      "id": "ltv-cac-trend",
      "title": "LTV:CAC Trend",
      "type": "chart",
      "order": 3,
      "chartConfig": {
        "type": "combo",
        "primaryAxis": {
          "metrics": ["LTV", "CAC"],
          "type": "bar"
        },
        "secondaryAxis": {
          "metrics": ["LTV_CAC_RATIO"],
          "type": "line"
        },
        "groupBy": "CALENDAR_QUARTER"
      }
    },
    {
      "id": "cac-breakdown",
      "title": "CAC Component Breakdown",
      "type": "chart",
      "order": 4,
      "chartConfig": {
        "type": "stacked_bar",
        "components": [
          { "name": "Sales Salaries", "color": "#2E5A88" },
          { "name": "Sales Tools", "color": "#5B9BD5" },
          { "name": "Marketing Spend", "color": "#70AD47" },
          { "name": "Marketing Tools", "color": "#FFC000" },
          { "name": "Other", "color": "#9E9E9E" }
        ],
        "groupBy": "CALENDAR_QUARTER"
      }
    },
    {
      "id": "cac-by-channel",
      "title": "CAC by Acquisition Channel",
      "type": "detail",
      "order": 5,
      "breakdown": {
        "dimension": "channel",
        "metrics": ["CAC", "LTV", "LTV_CAC_RATIO", "customers_acquired"],
        "sortBy": "LTV_CAC_RATIO",
        "sortOrder": "desc"
      }
    },
    {
      "id": "cac-by-segment",
      "title": "CAC by Customer Segment",
      "type": "detail",
      "order": 6,
      "breakdown": {
        "dimension": "segment",
        "metrics": ["CAC", "LTV", "LTV_CAC_RATIO", "CAC_PAYBACK"],
        "sortBy": "LTV_CAC_RATIO",
        "sortOrder": "desc"
      }
    },
    {
      "id": "payback-analysis",
      "title": "CAC Payback Analysis",
      "type": "chart",
      "order": 7,
      "chartConfig": {
        "type": "bar",
        "metric": "CAC_PAYBACK",
        "groupBy": "segment",
        "showTarget": true,
        "targetValue": 12,
        "showIndustryBenchmark": true
      }
    },
    {
      "id": "efficiency-metrics",
      "title": "Sales Efficiency Metrics",
      "type": "detail",
      "order": 8,
      "metrics": [
        { "name": "Magic Number", "id": "MAGIC_NUMBER", "benchmark": 0.75 },
        { "name": "Sales Efficiency", "id": "SALES_EFFICIENCY", "benchmark": 1.0 },
        { "name": "Marketing Efficiency", "id": "MARKETING_EFFICIENCY", "benchmark": 5.0 }
      ]
    },
    {
      "id": "benchmark-comparison",
      "title": "Industry Benchmarks",
      "type": "comparison",
      "order": 9,
      "benchmarks": {
        "metrics": ["CAC", "LTV", "LTV_CAC_RATIO", "CAC_PAYBACK"],
        "showPercentile": true,
        "showIndustryAvg": true,
        "showTopQuartile": true
      }
    },
    {
      "id": "methodology",
      "title": "Methodology",
      "type": "methodology",
      "order": 99,
      "include": ["dataSources", "formulas", "assumptions", "exclusions", "queries", "benchmarkSources"]
    }
  ],
  "calculations": {
    "cac": {
      "formula": "(sales_spend + marketing_spend) / new_customers",
      "notes": "Fully loaded customer acquisition cost including all sales and marketing expenses"
    },
    "ltv": {
      "formula": "arpu / monthly_churn_rate",
      "alternativeFormula": "arpu * average_customer_lifetime_months",
      "notes": "Expected lifetime value of a customer"
    },
    "ltv_cac_ratio": {
      "formula": "ltv / cac",
      "notes": "Ratio of lifetime value to acquisition cost; target 3:1+"
    },
    "cac_payback": {
      "formula": "cac / (arpu * gross_margin)",
      "notes": "Months to recover customer acquisition cost"
    },
    "magic_number": {
      "formula": "(current_quarter_arr - previous_quarter_arr) / previous_quarter_sales_marketing_spend",
      "notes": "Sales efficiency metric; >0.75 indicates efficient growth"
    }
  },
  "benchmarks": {
    "industry": "saas",
    "sources": [
      {
        "name": "OpenView SaaS Benchmarks",
        "url": "https://openviewpartners.com/benchmarks",
        "metrics": ["LTV_CAC_RATIO", "CAC_PAYBACK", "MAGIC_NUMBER"]
      },
      {
        "name": "KeyBanc SaaS Survey 2024",
        "url": "https://keybanccm.com/saas-survey",
        "metrics": ["CAC"]
      }
    ],
    "thresholds": {
      "LTV_CAC_RATIO": {
        "excellent": 5.0,
        "good": 3.0,
        "average": 2.0,
        "belowAverage": 1.0
      },
      "CAC_PAYBACK": {
        "excellent": 12,
        "good": 18,
        "average": 24,
        "belowAverage": 36
      },
      "MAGIC_NUMBER": {
        "excellent": 1.0,
        "good": 0.75,
        "average": 0.5,
        "belowAverage": 0.25
      }
    }
  },
  "defaults": {
    "dateRange": {
      "type": "relative",
      "value": "LAST_QUARTER"
    },
    "comparison": {
      "type": "quarter_over_quarter"
    },
    "currency": "USD"
  },
  "exportConfig": {
    "pdf": {
      "orientation": "portrait",
      "includeCharts": true,
      "includeTables": true,
      "pageBreaks": ["cac-by-channel", "efficiency-metrics", "methodology"]
    },
    "excel": {
      "sheets": [
        { "name": "Summary", "sections": ["executive-summary", "unit-economics-dashboard"] },
        { "name": "Trends", "sections": ["ltv-cac-trend", "cac-breakdown"] },
        { "name": "By Channel", "sections": ["cac-by-channel"] },
        { "name": "By Segment", "sections": ["cac-by-segment", "payback-analysis"] },
        { "name": "Efficiency", "sections": ["efficiency-metrics"] },
        { "name": "Benchmarks", "sections": ["benchmark-comparison"] },
        { "name": "Methodology", "sections": ["methodology"] }
      ]
    }
  },
  "inputRequirements": {
    "manualInputs": [
      {
        "id": "sales_spend",
        "label": "Total Sales Spend",
        "type": "currency",
        "required": true,
        "helpText": "Total sales team costs (salaries, tools, travel) for the period"
      },
      {
        "id": "marketing_spend",
        "label": "Total Marketing Spend",
        "type": "currency",
        "required": true,
        "helpText": "Total marketing costs (campaigns, tools, team) for the period"
      }
    ]
  }
}
