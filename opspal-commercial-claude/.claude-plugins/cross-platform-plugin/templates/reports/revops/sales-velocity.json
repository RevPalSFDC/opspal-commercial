{
  "templateMetadata": {
    "id": "sales-velocity",
    "name": "Sales Velocity Analysis",
    "version": "1.0.0",
    "description": "Analyze deal flow, sales cycle length, and velocity optimization opportunities",
    "category": "pipeline",
    "targetAudience": ["sales-leadership", "sales-ops", "executive"],
    "recommendedFrequency": "monthly",
    "estimatedGenerationTime": "4-6 minutes"
  },
  "reportMetadata": {
    "defaultTitle": "Sales Velocity Report",
    "defaultPeriod": "Q4",
    "defaultFormat": "pdf",
    "defaultSegmentation": ["segment", "rep"],
    "supportedFormats": ["pdf", "excel", "sheets", "csv"]
  },
  "kpis": [
    {
      "id": "SALES_VELOCITY",
      "required": true,
      "displayOrder": 1,
      "chartType": "line",
      "showTrend": true,
      "showBenchmark": false,
      "formula": "(opportunities * win_rate * avg_deal_size) / sales_cycle_days"
    },
    {
      "id": "SALES_CYCLE_LENGTH",
      "required": true,
      "displayOrder": 2,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": true,
      "invertColors": true
    },
    {
      "id": "WIN_RATE",
      "required": true,
      "displayOrder": 3,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "AVERAGE_DEAL_SIZE",
      "required": true,
      "displayOrder": 4,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "OPPORTUNITY_COUNT",
      "required": true,
      "displayOrder": 5,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": false
    },
    {
      "id": "TIME_IN_STAGE",
      "required": false,
      "displayOrder": 6,
      "chartType": "stacked_bar",
      "showTrend": true,
      "showBenchmark": false
    }
  ],
  "dataSources": {
    "salesforce": {
      "objects": ["Opportunity", "OpportunityHistory", "OpportunityStage"],
      "requiredFields": ["Amount", "CloseDate", "CreatedDate", "StageName", "IsWon", "IsClosed", "OwnerId"],
      "optionalFields": ["LastStageChangeDate", "DaysInCurrentStage__c", "Product_Line__c"],
      "filters": {
        "closedWon": "IsWon = true",
        "closedLost": "IsClosed = true AND IsWon = false",
        "allClosed": "IsClosed = true"
      }
    },
    "hubspot": {
      "objects": ["deals", "deal_stage_history"],
      "requiredProperties": ["amount", "closedate", "createdate", "dealstage", "hs_is_closed_won", "hubspot_owner_id"],
      "optionalProperties": ["hs_time_in_stage", "product_line"],
      "filters": {
        "closedWon": "hs_is_closed_won = true"
      }
    }
  },
  "sections": [
    {
      "id": "executive-summary",
      "title": "Executive Summary",
      "type": "summary",
      "order": 1,
      "content": {
        "blufTemplate": "Sales velocity is $${velocity}/day (${velocity_change} vs last period). ${cycle_insight}. ${bottleneck_insight}.",
        "keyMetrics": ["SALES_VELOCITY", "SALES_CYCLE_LENGTH", "WIN_RATE"],
        "maxHighlights": 3,
        "maxRecommendations": 3
      }
    },
    {
      "id": "velocity-dashboard",
      "title": "Velocity Overview",
      "type": "dashboard",
      "order": 2,
      "kpis": ["SALES_VELOCITY", "SALES_CYCLE_LENGTH", "WIN_RATE", "AVERAGE_DEAL_SIZE"],
      "layout": "2x2",
      "showVelocityFormula": true
    },
    {
      "id": "velocity-equation",
      "title": "Velocity Equation Breakdown",
      "type": "chart",
      "order": 3,
      "chartConfig": {
        "type": "equation_visual",
        "components": [
          { "name": "Opportunities", "id": "OPPORTUNITY_COUNT", "symbol": "×" },
          { "name": "Win Rate", "id": "WIN_RATE", "symbol": "×" },
          { "name": "Avg Deal Size", "id": "AVERAGE_DEAL_SIZE", "symbol": "÷" },
          { "name": "Sales Cycle", "id": "SALES_CYCLE_LENGTH", "symbol": "=" },
          { "name": "Velocity", "id": "SALES_VELOCITY" }
        ],
        "showImpactAnalysis": true
      }
    },
    {
      "id": "velocity-trend",
      "title": "Velocity Trend",
      "type": "chart",
      "order": 4,
      "chartConfig": {
        "type": "line",
        "metric": "SALES_VELOCITY",
        "groupBy": "CALENDAR_MONTH",
        "showPreviousPeriod": true,
        "showMovingAverage": true,
        "movingAveragePeriods": 3
      }
    },
    {
      "id": "sales-cycle-analysis",
      "title": "Sales Cycle Analysis",
      "type": "detail",
      "order": 5,
      "breakdown": {
        "dimension": "segment",
        "metrics": ["avg_cycle_days", "median_cycle_days", "min_cycle", "max_cycle", "stddev_cycle"],
        "sortBy": "avg_cycle_days",
        "sortOrder": "asc"
      }
    },
    {
      "id": "stage-duration",
      "title": "Time in Each Stage",
      "type": "chart",
      "order": 6,
      "chartConfig": {
        "type": "horizontal_bar",
        "groupBy": "stage",
        "metric": "avg_days_in_stage",
        "showBenchmark": true,
        "colorByPerformance": true
      }
    },
    {
      "id": "stage-bottlenecks",
      "title": "Stage Bottleneck Analysis",
      "type": "detail",
      "order": 7,
      "bottleneckConfig": {
        "identifyBy": "days_above_median",
        "threshold": 1.5,
        "metrics": ["stage_name", "avg_days", "median_days", "deals_stuck", "revenue_at_risk"]
      }
    },
    {
      "id": "velocity-by-segment",
      "title": "Velocity by Segment",
      "type": "detail",
      "order": 8,
      "breakdown": {
        "dimension": "segment",
        "metrics": ["SALES_VELOCITY", "SALES_CYCLE_LENGTH", "WIN_RATE", "AVERAGE_DEAL_SIZE"],
        "sortBy": "SALES_VELOCITY",
        "sortOrder": "desc"
      }
    },
    {
      "id": "velocity-by-rep",
      "title": "Velocity by Rep",
      "type": "detail",
      "order": 9,
      "breakdown": {
        "dimension": "owner",
        "metrics": ["SALES_VELOCITY", "SALES_CYCLE_LENGTH", "WIN_RATE", "deal_count"],
        "sortBy": "SALES_VELOCITY",
        "sortOrder": "desc",
        "showTopN": 10
      }
    },
    {
      "id": "deal-size-analysis",
      "title": "Deal Size Distribution",
      "type": "chart",
      "order": 10,
      "chartConfig": {
        "type": "histogram",
        "metric": "Amount",
        "buckets": 10,
        "showMedian": true,
        "showMean": true,
        "showOutliers": true
      }
    },
    {
      "id": "improvement-opportunities",
      "title": "Velocity Improvement Opportunities",
      "type": "analysis",
      "order": 11,
      "impactAnalysis": {
        "scenarios": [
          {
            "name": "10% cycle reduction",
            "change": { "metric": "SALES_CYCLE_LENGTH", "delta": -0.10 },
            "impact": "Calculate new velocity"
          },
          {
            "name": "5% win rate improvement",
            "change": { "metric": "WIN_RATE", "delta": 0.05 },
            "impact": "Calculate new velocity"
          },
          {
            "name": "10% deal size increase",
            "change": { "metric": "AVERAGE_DEAL_SIZE", "delta": 0.10 },
            "impact": "Calculate new velocity"
          }
        ]
      }
    },
    {
      "id": "methodology",
      "title": "Methodology",
      "type": "methodology",
      "order": 99,
      "include": ["dataSources", "formulas", "assumptions", "exclusions", "queries"]
    }
  ],
  "calculations": {
    "sales_velocity": {
      "formula": "(opportunities * win_rate * avg_deal_size) / sales_cycle_days",
      "notes": "Revenue generated per day based on pipeline flow",
      "unit": "currency_per_day"
    },
    "sales_cycle_length": {
      "formula": "AVG(CloseDate - CreatedDate)",
      "notes": "Average days from opportunity creation to close",
      "unit": "days"
    },
    "win_rate": {
      "formula": "won_count / (won_count + lost_count)",
      "notes": "Percentage of opportunities won",
      "unit": "percentage"
    },
    "time_in_stage": {
      "formula": "AVG(stage_exit_date - stage_enter_date)",
      "notes": "Average days spent in each stage",
      "unit": "days"
    }
  },
  "benchmarks": {
    "industry": "saas",
    "sources": [
      {
        "name": "Gartner Sales Cycle Benchmarks",
        "url": "https://www.gartner.com",
        "metrics": ["SALES_CYCLE_LENGTH"]
      },
      {
        "name": "InsightSquared Win Rate Data",
        "url": "https://www.insightsquared.com",
        "metrics": ["WIN_RATE"]
      }
    ],
    "thresholds": {
      "SALES_CYCLE_LENGTH": {
        "excellent": 45,
        "good": 60,
        "average": 90,
        "belowAverage": 120,
        "segmentAdjustments": {
          "enterprise": 1.5,
          "mid-market": 1.0,
          "smb": 0.5
        }
      },
      "WIN_RATE": {
        "excellent": 0.30,
        "good": 0.22,
        "average": 0.18,
        "belowAverage": 0.15
      }
    }
  },
  "defaults": {
    "dateRange": {
      "type": "relative",
      "value": "LAST_QUARTER"
    },
    "comparison": {
      "type": "previous_quarter"
    },
    "currency": "USD"
  },
  "exportConfig": {
    "pdf": {
      "orientation": "portrait",
      "includeCharts": true,
      "includeTables": true,
      "pageBreaks": ["stage-duration", "velocity-by-rep", "methodology"]
    },
    "excel": {
      "sheets": [
        { "name": "Summary", "sections": ["executive-summary", "velocity-dashboard"] },
        { "name": "Velocity Equation", "sections": ["velocity-equation", "velocity-trend"] },
        { "name": "Cycle Analysis", "sections": ["sales-cycle-analysis", "stage-duration", "stage-bottlenecks"] },
        { "name": "By Segment", "sections": ["velocity-by-segment"] },
        { "name": "By Rep", "sections": ["velocity-by-rep"] },
        { "name": "Deal Size", "sections": ["deal-size-analysis"] },
        { "name": "Improvements", "sections": ["improvement-opportunities"] },
        { "name": "Methodology", "sections": ["methodology"] }
      ]
    }
  }
}
