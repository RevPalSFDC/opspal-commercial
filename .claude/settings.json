{
  "permissions": {
    "allow": [
      "Read", 
      "Write",
      "Edit",
      "MultiEdit",
      "Grep", 
      "Glob",
      "Bash(git:*)",
      "Bash(sf:*)",
      "Bash(sfdx:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(pwd:*)"
    ],
    "ask": [
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm publish:*)",
      "Bash(rm:*)",
      "Bash(mv:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/.ssh/**)",
      "Read(**/node_modules/**)"
    ],
    "additionalDirectories": [
      "./opspal-internal/SFDC",
      "./opspal-internal/HS",
      "./opspal-internal"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/notify_slack.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '{msg:(\"Subagent finished: \" + .tool_name)}' | tee /dev/null"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_PROJECT_DIR": "/home/chris/Desktop/RevPal/Agents",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "model": "opus"
}