{
  "permissions": {
    "allow": [ 
      "Read", 
      "Grep", 
      "Glob" 
    ],
    "ask": [ 
      "Bash(git status:*)", 
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(date:*)"
    ],
    "deny": [ 
      "Write", 
      "Edit", 
      "MultiEdit",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(npm:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { 
        "hooks": [
          { 
            "type": "command", 
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate.sh" 
          }
        ] 
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_PROJECT_DIR": "/home/chris/Desktop/RevPal/Agents/Claude"
  },
  "description": "Parent orchestrator project - read-only by default for safe auditing"
}