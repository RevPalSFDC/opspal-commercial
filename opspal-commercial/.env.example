###############################################################################
# Prevention System Configuration
#
# Copy this file to .env and configure for your environment
# cp .env.example .env
#
# All variables are optional with sensible defaults
###############################################################################

###############################################################################
# MCP Credentials (required for reflection workflows)
###############################################################################

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Asana (optional for task automation)
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_ID=
ASANA_PROJECT_GID=

# Context7 (optional, recommended for higher limits and consistency)
CONTEXT7_API_KEY=

# Slack (optional for notifications)
SLACK_WEBHOOK_URL=
# Set to true to disable local post-push Slack hook when CI workflow notifications are enabled
SKIP_LOCAL_PUSH_SLACK_NOTIFIER=false

###############################################################################
# Platform Credentials
###############################################################################

# Salesforce (required for SF operations)
SF_TARGET_ORG=
# Alternative: SALESFORCE_ORG_ALIAS=production

# HubSpot (required for HS operations)
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_TIER=starter                 # starter | professional | enterprise

###############################################################################
# System Paths (optional overrides for portability)
###############################################################################

# Chrome path for PDF generation (auto-detected if not set)
CHROME_PATH=
# Workspace directory override
WORKSPACE_DIR=
# Output directory for generated files
OUTPUT_DIR=

###############################################################################
# Master Controls
###############################################################################

# Master hook enable/disable
MASTER_HOOK_ENABLED=1                # Enable master prompt handler (default: 1)
PREVENTION_SYSTEM_ENABLED=1          # Enable all prevention hooks (default: 1)
SUBAGENT_BOOST_ENABLED=1             # Enable sub-agent utilization boost (default: 1)
PREVENTION_SYSTEM_VERBOSE=0          # Show detailed prevention hook output (default: 0)

###############################################################################
# Phase 1: Immediate Prevention
###############################################################################

## Phase 1.1: Agent Routing Clarity
ROUTING_CLARITY_ENABLED=1            # Enable routing explanations (default: 1)
ROUTING_CLARITY_VERBOSE=0            # Show detailed routing analysis (default: 0)

## Phase 1.2: Environment Configuration Registry
ENV_VALIDATION_ENABLED=1             # Enable environment validation (default: 1)
ENV_VALIDATION_STRICT=0              # Block operations on validation failure (default: 0)

## Phase 1.3: Post-Operation Verification
EDIT_VERIFICATION_ENABLED=1          # Enable edit verification (default: 1)
EDIT_VERIFICATION_BLOCK_ON_FAIL=1    # Block success claims until verified (default: 1)
EDIT_VERIFICATION_THRESHOLD=0.9      # Completion threshold (default: 0.9 = 90%)

###############################################################################
# Phase 2: Process Prevention
###############################################################################

## Phase 2.1: Idempotent Operation Framework
IDEMPOTENCY_CHECK_ENABLED=1          # Enable duplicate operation detection (default: 1)
IDEMPOTENCY_CHECK_STRICT=0           # Block concurrent operations (default: 0)
IDEMPOTENCY_AUTO_CLEANUP=1           # Auto-cleanup stale operations (default: 1)

## Phase 2.2: Plan Mode Enhancement
PLAN_VALIDATION_ENABLED=1            # Enable scope validation (default: 1)
PLAN_VALIDATION_STRICT=0             # Block on any scope risk (default: 0)
PLAN_AUTO_ANALYZE=1                  # Auto-analyze on plan mode entry (default: 1)

## Phase 2.3: Agent Decision Matrix
AGENT_RECOMMENDATION_ENABLED=1       # Enable agent recommendations (default: 1)
AGENT_RECOMMENDATION_VERBOSE=0       # Show full agent analysis (default: 0)

###############################################################################
# Phase 3: Strategic Improvements
###############################################################################

## Phase 3.2: Defensive Error Recovery
ERROR_RECOVERY_ENABLED=1             # Enable state snapshots (default: 1)
ERROR_RECOVERY_AUTO_ROLLBACK=1       # Auto-rollback on failure (default: 1)
ERROR_RECOVERY_VERBOSE=0             # Show snapshot details (default: 0)

## Phase 3.3: Cross-Session Context Sharing
SESSION_CONTEXT_ENABLED=1            # Enable context loading (default: 1)
SESSION_CONTEXT_AUTO_DISPLAY=1       # Auto-display contexts at session start (default: 1)
SESSION_CONTEXT_TTL_DAYS=7           # Context time-to-live in days (default: 7)

###############################################################################
# Quick Profiles
###############################################################################

# Development Profile (verbose, permissive)
# Uncomment to enable:
# PREVENTION_SYSTEM_VERBOSE=1
# ROUTING_CLARITY_VERBOSE=1
# ENV_VALIDATION_STRICT=0

# Production Profile (strict, minimal output)
# Uncomment to enable:
# ENV_VALIDATION_STRICT=1
# PLAN_VALIDATION_STRICT=1
# IDEMPOTENCY_CHECK_STRICT=1
