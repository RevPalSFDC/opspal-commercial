{
  "version": "1.0.0",
  "canonical_layout": "packages",
  "core": {
    "name": "opspal-core",
    "path": ".claude-plugins/opspal-core-plugin/packages/opspal-core",
    "description": "Authoritative shared core for orchestration, governance, routing, lifecycle, and intelligence.",
    "asset_roots": [
      "agents",
      "scripts",
      "commands",
      "hooks",
      "runbooks",
      "docs",
      "templates"
    ],
    "compat_roots": [
      "cross-platform-plugin",
      "developer-tools-plugin",
      "shared-docs"
    ],
    "dependency_rules": [
      "core must not depend on domains"
    ]
  },
  "domains": [
    {
      "name": "salesforce",
      "path": ".claude-plugins/opspal-core-plugin/packages/domains/salesforce",
      "source_plugin": "salesforce-plugin",
