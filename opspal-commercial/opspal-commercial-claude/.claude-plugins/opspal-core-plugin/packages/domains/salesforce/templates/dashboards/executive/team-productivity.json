{
  "templateMetadata": {
    "templateName": "Executive Team Productivity Dashboard",
    "templateVersion": "1.0",
    "description": "High-level team activity metrics: rep performance, activity volume, engagement rates",
    "audience": "CRO, VP Sales, Sales Operations",
    "useCase": "Monitor sales team efficiency, identify coaching needs, optimize headcount allocation",
    "refreshFrequency": "Daily",
    "componentCount": 6
  },
  "dashboardLayout": {
    "components": [
      {
        "position": 1,
        "size": "third-width",
        "type": "Metric",
        "title": "Quota Attainment (Team Avg)",
        "sourceReport": "team-quota-attainment",
        "metric": "AVG(Quota_Attainment__c)",
        "target": "100%",
        "greenZone": ">=100%",
        "yellowZone": "85-100%",
        "redZone": "<85%",
        "showComparison": "vs Last Quarter"
      },
      {
        "position": 2,
        "size": "third-width",
        "type": "Metric",
        "title": "Reps at Risk (<70% Attainment)",
        "sourceReport": "reps-at-risk",
        "metric": "COUNT(User WHERE Quota_Attainment__c < 0.7)",
        "colorCode": {"0": "green", "1-2": "yellow", ">=3": "red"}
      },
      {
        "position": 3,
        "size": "third-width",
        "type": "Metric",
        "title": "Avg Activities per Rep per Day",
        "sourceReport": "daily-activity-average",
        "metric": "AVG(Daily_Activities__c)",
        "target": "20",
        "greenZone": ">=20",
        "yellowZone": "10-20",
        "redZone": "<10"
      },
      {
        "position": 4,
        "size": "half-width",
        "type": "Bar Chart",
        "title": "Quota Attainment by Rep (This Quarter)",
        "sourceReport": "quota-attainment-by-rep",
        "groupBy": "Owner",
        "metric": "Quota_Attainment__c",
        "sortBy": "Quota_Attainment__c DESC",
        "showTarget": "100%",
        "colorCode": {">=100%": "green", "85-100%": "yellow", "<85%": "red"}
      },
      {
        "position": 5,
        "size": "half-width",
        "type": "Line Chart",
        "title": "Team Activity Trend (Last 90 Days)",
        "sourceReport": "team-activity-trend",
        "xAxis": "Week",
        "yAxis": "Total Activities (Calls + Emails + Meetings)",
        "showMovingAverage": true,
        "trendline": true
      },
      {
        "position": 6,
        "size": "full-width",
        "type": "Table",
        "title": "Rep Performance Scorecard",
        "sourceReport": "rep-performance-scorecard",
        "columns": [
          "Rep Name",
          "Quota",
          "Closed Won",
          "Attainment %",
          "Open Pipeline",
          "Coverage Ratio",
          "Win Rate",
          "Avg Deal Size",
          "Activities/Day"
        ],
        "sortBy": "Attainment % DESC",
        "conditionalFormatting": {
          "Attainment__c": {">=1.0": "green", ">=0.85": "yellow", "<0.85": "red"},
          "Pipeline_Coverage__c": {">=3": "green", ">=2": "yellow", "<2": "red"},
          "Win_Rate__c": {">=0.25": "green", ">=0.15": "yellow", "<0.15": "red"}
        }
      }
    ]
  },
  "dashboardFilters": [
    {"field": "Time Period", "type": "Date Range", "default": "THIS_FISCAL_QUARTER"},
    {"field": "Team", "type": "Picklist", "default": "All", "values": ["Enterprise", "Mid-Market", "SMB"]},
    {"field": "Region", "type": "Picklist", "default": "All", "values": ["North America", "EMEA", "APAC"]}
  ],
  "sourceReportTemplates": [
    "team-quota-attainment.json",
    "reps-at-risk.json",
    "daily-activity-average.json",
    "quota-attainment-by-rep.json",
    "team-activity-trend.json",
    "rep-performance-scorecard.json"
  ],
  "calculatedFieldsRequired": [
    {
      "fieldName": "Quota_Attainment__c",
      "fieldType": "Formula (Percent)",
      "formula": "Closed_Won_This_Quarter__c / Quarterly_Quota__c",
      "object": "User",
      "description": "Rep's quota attainment percentage"
    },
    {
      "fieldName": "Pipeline_Coverage__c",
      "fieldType": "Formula (Number)",
      "formula": "Open_Pipeline__c / Quarterly_Quota__c",
      "object": "User",
      "description": "Rep's pipeline coverage ratio"
    },
    {
      "fieldName": "Win_Rate__c",
      "fieldType": "Formula (Percent)",
      "formula": "Closed_Won_Count__c / (Closed_Won_Count__c + Closed_Lost_Count__c)",
      "object": "User",
      "description": "Rep's win rate"
    },
    {
      "fieldName": "Daily_Activities__c",
      "fieldType": "Rollup Summary or Formula",
      "formula": "Total_Activities_This_Quarter__c / Days_Elapsed_This_Quarter__c",
      "object": "User",
      "description": "Average daily activity count"
    }
  ],
  "deploymentInstructions": {
    "steps": [
      "1. Create calculated fields on User object (Quota_Attainment__c, Pipeline_Coverage__c, Win_Rate__c, Daily_Activities__c)",
      "2. Set up rollup summaries or scheduled batch jobs to calculate metrics",
      "3. Create all 6 source reports using templates",
      "4. Create dashboard in Dashboards folder (Executive)",
      "5. Add components in order specified",
      "6. Configure filters (Time Period, Team, Region)",
      "7. Set refresh schedule to daily at 6 AM",
      "8. Share with sales leadership (view-only)",
      "9. Create alerts: Avg attainment <85%, Reps at risk >3"
    ],
    "rollupSummaryAlternatives": {
      "ifRollupsNotPossible": [
        "Option 1: Scheduled Apex batch job to calculate User-level metrics daily",
        "Option 2: Flow scheduled to run daily and update User fields",
        "Option 3: External ETL tool (e.g., Workato, Zapier) to calculate and update"
      ]
    }
  },
  "kpiDefinitions": {
    "quotaAttainment": {
      "formula": "Closed Won Revenue / Quota",
      "benchmark": "100% = on target, 80-90% = needs attention, <70% = at risk",
      "whyItMatters": "Primary measure of sales team performance and forecast accuracy"
    },
    "pipelineCoverageRatio": {
      "formula": "Open Pipeline / Quota",
      "benchmark": "3-4x for healthy pipeline",
      "whyItMatters": "Leading indicator of future quota attainment"
    },
    "activitiesPerDay": {
      "formula": "Total Activities / Working Days",
      "benchmark": "20-30 activities/day for outbound sales",
      "whyItMatters": "Measures rep effort and engagement levels"
    },
    "winRate": {
      "formula": "Closed Won / (Closed Won + Closed Lost)",
      "benchmark": "20-30% typical for B2B SaaS",
      "whyItMatters": "Indicates deal qualification quality and sales effectiveness"
    }
  },
  "dashboardUsageNotes": {
    "weeklyReview": "Check reps at risk and activity trends",
    "monthlyReview": "Analyze quota attainment by rep, identify coaching needs",
    "quarterlyReview": "Assess team productivity trends, plan headcount and training",
    "coachingTriggers": [
      "Quota attainment <70% mid-quarter",
      "Pipeline coverage <2x",
      "Win rate <15%",
      "Activities <10/day",
      "No new opportunities created in 2+ weeks"
    ],
    "performanceSegmentation": {
      "topPerformers": ">=120% attainment (study and replicate)",
      "corePerformers": "85-120% attainment (maintain momentum)",
      "developmentNeeded": "70-85% attainment (coaching focus)",
      "performanceImprovement": "<70% attainment (PIP or role change)"
    }
  },
  "relatedTemplates": [
    "revenue-performance.json",
    "pipeline-health.json"
  ]
}
