{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flow Diagnostic Report Schema",
  "description": "Schema for Flow diagnostic reports generated by FlowDiagnosticOrchestrator",
  "type": "object",
  "required": [
    "metadata",
    "overallSummary",
    "preflightResults",
    "executionResults",
    "coverageResults",
    "issues",
    "governorLimits"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Report metadata and generation information",
      "required": ["flowName", "orgAlias", "timestamp", "diagnosticType", "version"],
      "properties": {
        "flowName": {
          "type": "string",
          "description": "API name of the Flow being diagnosed"
        },
        "orgAlias": {
          "type": "string",
          "description": "Salesforce org alias where diagnostic was run"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the diagnostic was generated (ISO 8601)"
        },
        "diagnosticType": {
          "type": "string",
          "enum": ["preflight", "execution", "coverage", "full"],
          "description": "Type of diagnostic workflow run"
        },
        "version": {
          "type": "string",
          "description": "Diagnostic orchestrator version (e.g., 3.43.0)"
        },
        "apiVersion": {
          "type": "string",
          "description": "Salesforce API version used (e.g., 62.0)"
        },
        "totalDuration": {
          "type": "number",
          "description": "Total diagnostic duration in milliseconds"
        }
      }
    },
    "overallSummary": {
      "type": "object",
      "description": "High-level summary of diagnostic results",
      "required": ["readyForProduction", "canDeploy", "coveragePercentage", "criticalIssues", "warnings"],
      "properties": {
        "readyForProduction": {
          "type": "boolean",
          "description": "True if Flow meets production readiness criteria (can deploy + no warnings + coverage ≥ 80%)"
        },
        "canDeploy": {
          "type": "boolean",
          "description": "True if Flow can be deployed (pre-flight passed + no fatal errors)"
        },
        "coveragePercentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall branch coverage percentage"
        },
        "criticalIssues": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of critical issues that block deployment"
        },
        "warnings": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of warnings that should be addressed"
        },
        "infoCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of informational messages"
        },
        "readinessStatus": {
          "type": "string",
          "enum": ["PRODUCTION_READY", "CAN_DEPLOY", "NOT_READY"],
          "description": "Overall readiness status"
        },
        "readinessExplanation": {
          "type": "string",
          "description": "Human-readable explanation of readiness decision"
        }
      }
    },
    "preflightResults": {
      "type": "object",
      "description": "Results from pre-flight validation checks",
      "required": ["passed", "checks"],
      "properties": {
        "passed": {
          "type": "boolean",
          "description": "True if all pre-flight checks passed"
        },
        "checks": {
          "type": "array",
          "description": "Individual pre-flight check results",
          "items": {
            "type": "object",
            "required": ["checkName", "status", "passed"],
            "properties": {
              "checkName": {
                "type": "string",
                "description": "Name of the check (e.g., 'Org Connectivity')"
              },
              "status": {
                "type": "string",
                "enum": ["PASSED", "FAILED", "WARNING", "SKIPPED"],
                "description": "Check result status"
              },
              "passed": {
                "type": "boolean",
                "description": "True if check passed"
              },
              "details": {
                "type": "string",
                "description": "Additional details about check result"
              },
              "recommendation": {
                "type": "string",
                "description": "Recommendation if check failed"
              }
            }
          }
        },
        "duration": {
          "type": "number",
          "description": "Pre-flight validation duration in milliseconds"
        }
      }
    },
    "executionResults": {
      "type": "object",
      "description": "Results from Flow execution testing",
      "required": ["testCases", "statistics"],
      "properties": {
        "testCases": {
          "type": "array",
          "description": "Individual test case results",
          "items": {
            "type": "object",
            "required": ["testCaseId", "testCaseName", "success", "duration"],
            "properties": {
              "testCaseId": {
                "type": "string",
                "description": "Unique test case identifier (e.g., RT-001)"
              },
              "testCaseName": {
                "type": "string",
                "description": "Human-readable test case name"
              },
              "success": {
                "type": "boolean",
                "description": "True if test case passed"
              },
              "duration": {
                "type": "number",
                "description": "Execution duration in milliseconds"
              },
              "executionId": {
                "type": "string",
                "description": "Salesforce Flow execution ID"
              },
              "recordId": {
                "type": "string",
                "description": "Salesforce record ID created/modified during test"
              },
              "object": {
                "type": "string",
                "description": "Salesforce object tested (e.g., Account)"
              },
              "operation": {
                "type": "string",
                "enum": ["insert", "update", "delete"],
                "description": "DML operation performed"
              },
              "error": {
                "type": "object",
                "description": "Error details if test failed",
                "properties": {
                  "errorType": {
                    "type": "string",
                    "description": "Error type (e.g., FIELD_CUSTOM_VALIDATION_EXCEPTION)"
                  },
                  "errorMessage": {
                    "type": "string",
                    "description": "Error message"
                  },
                  "stackTrace": {
                    "type": "string",
                    "description": "Full stack trace"
                  },
                  "recommendation": {
                    "type": "string",
                    "description": "Recommended fix"
                  }
                }
              }
            }
          }
        },
        "statistics": {
          "type": "object",
          "description": "Aggregate execution statistics",
          "required": ["totalExecutions", "successfulExecutions", "failedExecutions"],
          "properties": {
            "totalExecutions": {
              "type": "integer",
              "minimum": 0,
              "description": "Total number of executions"
            },
            "successfulExecutions": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of successful executions"
            },
            "failedExecutions": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of failed executions"
            },
            "successRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Success rate percentage"
            },
            "avgDuration": {
              "type": "number",
              "description": "Average execution duration in milliseconds"
            },
            "minDuration": {
              "type": "number",
              "description": "Minimum execution duration in milliseconds"
            },
            "maxDuration": {
              "type": "number",
              "description": "Maximum execution duration in milliseconds"
            }
          }
        }
      }
    },
    "coverageResults": {
      "type": "object",
      "description": "Branch coverage analysis results",
      "required": ["coveragePercentage", "totalBranches", "coveredBranches", "uncoveredBranches"],
      "properties": {
        "coveragePercentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall branch coverage percentage"
        },
        "totalBranches": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of decision branches"
        },
        "coveredBranches": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of branches executed during testing"
        },
        "uncoveredBranches": {
          "type": "array",
          "description": "List of branches not covered by tests",
          "items": {
            "type": "object",
            "required": ["elementName", "decisionLabel", "branchLabel"],
            "properties": {
              "elementName": {
                "type": "string",
                "description": "Flow element API name"
              },
              "decisionLabel": {
                "type": "string",
                "description": "Decision element label"
              },
              "branchLabel": {
                "type": "string",
                "description": "Branch label (e.g., 'When Status = Active')"
              },
              "condition": {
                "type": "string",
                "description": "Branch condition expression"
              },
              "suggestedTestCase": {
                "type": "string",
                "description": "Suggested test case to cover this branch"
              }
            }
          }
        },
        "coverageByType": {
          "type": "array",
          "description": "Coverage breakdown by element type",
          "items": {
            "type": "object",
            "required": ["elementType", "total", "covered", "uncovered", "percentage"],
            "properties": {
              "elementType": {
                "type": "string",
                "description": "Flow element type (e.g., Decision, Assignment, Record Update)"
              },
              "total": {
                "type": "integer",
                "minimum": 0,
                "description": "Total elements of this type"
              },
              "covered": {
                "type": "integer",
                "minimum": 0,
                "description": "Elements covered by tests"
              },
              "uncovered": {
                "type": "integer",
                "minimum": 0,
                "description": "Elements not covered by tests"
              },
              "percentage": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Coverage percentage for this element type"
              }
            }
          }
        }
      }
    },
    "issues": {
      "type": "object",
      "description": "Categorized issues and recommendations",
      "required": ["critical", "warnings", "info"],
      "properties": {
        "critical": {
          "type": "array",
          "description": "Critical issues that block production deployment",
          "items": {
            "type": "object",
            "required": ["issue", "description", "recommendation"],
            "properties": {
              "issue": {
                "type": "string",
                "description": "Short issue summary"
              },
              "description": {
                "type": "string",
                "description": "Detailed issue description"
              },
              "impact": {
                "type": "string",
                "description": "Impact of the issue"
              },
              "recommendation": {
                "type": "string",
                "description": "Recommended fix"
              },
              "elementName": {
                "type": "string",
                "description": "Flow element where issue was found"
              }
            }
          }
        },
        "warnings": {
          "type": "array",
          "description": "Warnings that should be addressed",
          "items": {
            "type": "object",
            "required": ["issue", "description", "recommendation"],
            "properties": {
              "issue": {
                "type": "string",
                "description": "Short warning summary"
              },
              "description": {
                "type": "string",
                "description": "Detailed warning description"
              },
              "impact": {
                "type": "string",
                "description": "Impact of the warning"
              },
              "recommendation": {
                "type": "string",
                "description": "Recommended action"
              },
              "priority": {
                "type": "string",
                "enum": ["HIGH", "MEDIUM", "LOW"],
                "description": "Warning priority"
              }
            }
          }
        },
        "info": {
          "type": "array",
          "description": "Informational messages",
          "items": {
            "type": "object",
            "required": ["issue", "description"],
            "properties": {
              "issue": {
                "type": "string",
                "description": "Short info summary"
              },
              "description": {
                "type": "string",
                "description": "Detailed information"
              }
            }
          }
        }
      }
    },
    "governorLimits": {
      "type": "array",
      "description": "Salesforce governor limit usage during testing",
      "items": {
        "type": "object",
        "required": ["limitType", "used", "available", "percentage", "status"],
        "properties": {
          "limitType": {
            "type": "string",
            "enum": ["CPU_TIME", "HEAP_SIZE", "SOQL_QUERIES", "DML_STATEMENTS", "DML_ROWS"],
            "description": "Governor limit type"
          },
          "used": {
            "type": "number",
            "description": "Amount used"
          },
          "available": {
            "type": "number",
            "description": "Total available"
          },
          "percentage": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Percentage used"
          },
          "status": {
            "type": "string",
            "enum": ["SAFE", "WARNING", "CRITICAL"],
            "description": "Status based on thresholds (< 80% = SAFE, 80-89% = WARNING, ≥ 90% = CRITICAL)"
          },
          "recommendation": {
            "type": "string",
            "description": "Recommendation if usage is high"
          }
        }
      }
    },
    "executionLogs": {
      "type": "array",
      "description": "Detailed execution sequence logs (optional)",
      "items": {
        "type": "object",
        "required": ["sequenceNumber", "elementType", "elementName", "status"],
        "properties": {
          "sequenceNumber": {
            "type": "integer",
            "description": "Execution order"
          },
          "elementType": {
            "type": "string",
            "description": "Flow element type (e.g., Decision, Assignment)"
          },
          "elementName": {
            "type": "string",
            "description": "Flow element API name"
          },
          "status": {
            "type": "string",
            "enum": ["SUCCESS", "FAILED", "SKIPPED"],
            "description": "Execution status"
          },
          "duration": {
            "type": "number",
            "description": "Element execution duration in milliseconds"
          },
          "decisionResult": {
            "type": "string",
            "description": "Result if element is a decision"
          },
          "assignment": {
            "type": "string",
            "description": "Assignment details if element is an assignment"
          },
          "error": {
            "type": "string",
            "description": "Error message if element failed"
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Next steps and recommendations",
      "items": {
        "type": "object",
        "required": ["recommendation", "priority"],
        "properties": {
          "recommendation": {
            "type": "string",
            "description": "Recommended action"
          },
          "priority": {
            "type": "string",
            "enum": ["IMMEDIATE", "HIGH", "MEDIUM", "LOW"],
            "description": "Recommendation priority"
          },
          "category": {
            "type": "string",
            "enum": ["COVERAGE", "PERFORMANCE", "QUALITY", "DEPLOYMENT"],
            "description": "Recommendation category"
          },
          "effort": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH"],
            "description": "Estimated effort to implement"
          },
          "impact": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH"],
            "description": "Expected impact if implemented"
          }
        }
      }
    }
  }
}
