{
  "persona": "sales-manager",
  "label": "Sales Manager",
  "description": "Team manager focused on coaching reps, monitoring team performance, and ensuring quota attainment",
  "role": "Manager / Team Lead",
  "decisionScope": "Team performance, resource allocation, deal strategy, coaching",
  "keyQuestions": [
    "Which reps need coaching this week?",
    "Are we on pace to hit team quota?",
    "Which deals are at risk?",
    "Where should I focus my time?"
  ],
  "layoutCharacteristics": {
    "fieldCount": {
      "optimal": 75,
      "max": 125,
      "priority": "Team context and aggregate metrics"
    },
    "sectionCount": {
      "optimal": 5,
      "max": 7,
      "recommended": ["Deal Overview", "Team Context", "Forecasting", "Risk Factors", "Historical Performance"]
    },
    "components": {
      "required": ["Highlights Panel", "Path"],
      "recommended": ["Related List - Team Members", "Related List - Opportunities by Rep", "Report Chart - Pipeline", "Activities"],
      "conditional": ["Dashboard Component - Team Performance"]
    },
    "relatedLists": {
      "max": 8,
      "priority": ["Opportunities", "Contacts", "Team", "Activities", "Notes", "Tasks", "Quotes"]
    }
  },
  "fieldPriorities": {
    "opportunity": {
      "criticalFields": [
        "Name",
        "Amount",
        "CloseDate",
        "StageName",
        "Probability",
        "AccountId",
        "OwnerId",
        "ForecastCategory"
      ],
      "importantFields": [
        "Type",
        "LeadSource",
        "NextStep",
        "ExpectedRevenue",
        "Age",
        "LastActivityDate",
        "LastStageChangeDate"
      ],
      "contextualFields": [
        "Description",
        "CompetitorName",
        "Budget",
        "Authority",
        "Need",
        "Timeline"
      ],
      "managerSpecificFields": [
        "ForecastCategory",
        "IsSplit",
        "HasOpportunityLineItem",
        "CreatedById",
        "LastModifiedById"
      ]
    },
    "account": {
      "criticalFields": [
        "Name",
        "Type",
        "Industry",
        "OwnerId",
        "NumberOfEmployees",
        "AnnualRevenue"
      ],
      "importantFields": [
        "Phone",
        "Website",
        "BillingAddress",
        "ParentId",
        "Description"
      ],
      "managerSpecificFields": [
        "AccountNumber",
        "AccountSource",
        "Ownership",
        "Rating",
        "SLA__c"
      ]
    }
  },
  "compactLayoutFields": {
    "opportunity": ["Amount", "CloseDate", "StageName", "Owner.Name", "ForecastCategory"],
    "account": ["Phone", "Type", "Owner.Name", "AnnualRevenue"],
    "contact": ["AccountId", "Email", "Title", "Owner.Name"]
  },
  "conditionalVisibility": {
    "rules": [
      {
        "name": "High-Value Deal Insights",
        "condition": "Amount > 100000",
        "action": "Show section 'Executive Summary' with approval history"
      },
      {
        "name": "At-Risk Deal Warning",
        "condition": "Probability < 50 AND StageName NOT IN ('Closed Won', 'Closed Lost')",
        "action": "Show section 'Risk Mitigation' with coaching notes"
      },
      {
        "name": "Deal Age Alert",
        "condition": "Age > 180",
        "action": "Show section 'Deal Health' with time in stage breakdown"
      },
      {
        "name": "Split Opportunity",
        "condition": "IsSplit = true",
        "action": "Show section 'Split Details' with team member breakdown"
      }
    ]
  },
  "mobile": {
    "optimized": true,
    "maxFieldsFirstScreen": 20,
    "priority": "Deal summary, owner, forecast category, risk indicators"
  },
  "bestPractices": {
    "useDynamicForms": true,
    "useHighlightsPanel": true,
    "usePathComponent": true,
    "maxComponentsPerPage": 18,
    "includeReportCharts": true,
    "showTeamContext": true
  },
  "objectGuidance": {
    "Account": {
      "sections": [
        {"name": "Account Overview", "fields": ["Name", "OwnerId", "Type", "Industry", "Rating"]},
        {"name": "Business Metrics", "fields": ["AnnualRevenue", "NumberOfEmployees", "AccountSource"]},
        {"name": "Team Context", "fields": ["Owner.Name", "ParentId"]},
        {"name": "Contact Information", "fields": ["Phone", "Website"]}
      ],
      "compactFields": ["Type", "OwnerId", "AnnualRevenue", "Industry"],
      "relatedLists": ["Opportunities", "Contacts", "OpenActivities", "Cases", "Team"],
      "defaultTab": "Related",
      "rationale": "Sales managers review accounts to see team pipeline - Related tab shows Opportunities by rep and team activities"
    },
    "Contact": {
      "sections": [
        {"name": "Contact Details", "fields": ["Name", "AccountId", "Title", "OwnerId"]},
        {"name": "Contact Methods", "fields": ["Email", "Phone", "MobilePhone"]},
        {"name": "Team Assignments", "fields": ["OwnerId", "ReportsToId"]},
        {"name": "Preferences", "fields": ["DoNotCall", "HasOptedOutOfEmail"]}
      ],
      "compactFields": ["AccountId", "Email", "Title", "OwnerId"],
      "relatedLists": ["Opportunities", "Cases", "Activities"],
      "defaultTab": "Details",
      "rationale": "Managers view contacts to understand stakeholder relationships - Details for context, Related for deal involvement"
    },
    "Opportunity": {
      "sections": [
        {"name": "Deal Overview", "fields": ["Name", "AccountId", "Amount", "CloseDate", "StageName", "OwnerId"]},
        {"name": "Forecasting", "fields": ["ForecastCategory", "Probability", "ExpectedRevenue"]},
        {"name": "Deal Context", "fields": ["Type", "LeadSource", "Age", "LastActivityDate", "LastStageChangeDate"]},
        {"name": "Coaching Notes", "fields": ["NextStep", "Description", "CompetitorName"]}
      ],
      "compactFields": ["Amount", "CloseDate", "StageName", "OwnerId", "ForecastCategory"],
      "relatedLists": ["OpportunityLineItems", "Contacts", "Activities", "Quotes", "Team"],
      "defaultTab": "Details",
      "rationale": "Managers review Opportunities for forecasting and coaching - Details tab shows deal health and owner for quick assessment"
    },
    "Quote": {
      "sections": [
        {"name": "Quote Overview", "fields": ["Name", "OpportunityId", "Status", "OwnerId"]},
        {"name": "Pricing & Approval", "fields": ["GrandTotal", "Discount", "TotalPrice"]},
        {"name": "Timeline", "fields": ["ExpirationDate", "CreatedDate"]},
        {"name": "Customer", "fields": ["AccountId", "ContactId"]}
      ],
      "compactFields": ["Status", "GrandTotal", "ExpirationDate", "OwnerId"],
      "relatedLists": ["QuoteLineItems", "ApprovalHistory", "Documents"],
      "defaultTab": "Details",
      "rationale": "Managers review Quotes for approval decisions - Details shows pricing and status for quick approval/reject"
    },
    "QuoteLineItem": {
      "sections": [
        {"name": "Product Details", "fields": ["Product2Id", "Description"]},
        {"name": "Pricing Review", "fields": ["Quantity", "UnitPrice", "Discount", "TotalPrice"]}
      ],
      "compactFields": ["Product2Id", "Quantity", "Discount", "TotalPrice"],
      "relatedLists": [],
      "defaultTab": "Details",
      "rationale": "Managers review line items for discount approval - Details shows pricing breakdown"
    }
  }
}
