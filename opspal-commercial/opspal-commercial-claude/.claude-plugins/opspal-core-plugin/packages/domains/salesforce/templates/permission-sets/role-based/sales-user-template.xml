<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <!--
    TEMPLATE: Sales User Permission Set
    CATEGORY: Role-Based
    DESCRIPTION: Comprehensive permissions for sales representatives in Sales Cloud
    TIER: 2 (Composed/Role-Based)

    USE CASES:
    - Sales Representatives managing leads, opportunities, accounts
    - Inside Sales team members
    - Business Development Representatives (BDRs)
    - Account Executives managing customer relationships

    OBJECTS INCLUDED:
    - Account (CRED)
    - Contact (CRED)
    - Opportunity (CRED)
    - Lead (CRED)
    - Quote (CRE)
    - OpportunityLineItem (CRED)
    - Task (CRED)
    - Event (CRED)
    - Campaign (Read)
    - CampaignMember (CR)

    FIELD ACCESS:
    - Standard sales fields: Read and Edit
    - Revenue/amount fields: Read and Edit
    - Forecast fields: Read and Edit
    - Custom sales fields: Add as needed

    SYSTEM PERMISSIONS:
    - API Enabled: true
    - View All Data: false (respects territory/sharing)
    - Edit Forecasts: false (use for managers only)

    CUSTOMIZATION CHECKLIST:
    □ 1. Replace {{PERMISSION_SET_NAME}} with your naming
    □ 2. Update {{LABEL}} and {{DESCRIPTION}}
    □ 3. Review object permissions for your sales process
    □ 4. Add custom objects (Product configurations, etc.)
    □ 5. Add field permissions for custom fields
    □ 6. Configure forecast permissions (if using Collaborative Forecasts)
    □ 7. Set territory access (if using Territory Management)
    □ 8. Configure quote permissions (if using Salesforce CPQ)
    □ 9. Test with real sales user

    NAMING CONVENTION:
    Sales_<Role> (e.g., Sales_Representative, Sales_Manager)

    TWO-TIER ARCHITECTURE:
    This is a Tier 2 role-based set. Can compose Tier 1 foundational sets:
    - Standard_Account_Edit (Tier 1)
    - Standard_Opportunity_Edit (Tier 1)
    - Standard_Lead_Edit (Tier 1)
    Or use this template as standalone permission set.
    -->

    <description>{{DESCRIPTION}}</description>
    <label>{{LABEL}}</label>

    <!-- OBJECT PERMISSIONS -->
    <!-- Sales Cloud standard objects -->

    <!-- Account: Full CRUD for customer management -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Contact: Full CRUD for contact management -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Opportunity: Full CRUD for deal management -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Opportunity</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Lead: Full CRUD for lead management -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Lead</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Quote: Create/Read/Edit for quotation management -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Quote</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- OpportunityLineItem: Full CRUD for product/pricing -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>OpportunityLineItem</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Task: Full CRUD for activity management -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Task</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Event: Full CRUD for calendar management -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Event</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Campaign: Read-only for marketing campaign visibility -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Campaign</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- CampaignMember: Create/Read for adding leads/contacts to campaigns -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>CampaignMember</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

