    <!-- SYSTEM PERMISSIONS -->
    <!-- Sales Cloud system permissions -->

    <!-- API Enabled: Allow API access -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>

    <!-- Convert Leads: Allow lead conversion -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ConvertLeads</name>
    </userPermissions>

    <!-- Create and Customize Reports -->
    <userPermissions>
        <enabled>true</enabled>
        <name>CreateCustomizeReports</name>
    </userPermissions>

    <!-- Run Reports -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunReports</name>
    </userPermissions>

    <!-- View All Forecasts: View team forecasts (for managers) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewAllForecasts</name>
    </userPermissions>

    <!-- Edit Forecasts: Edit forecast data (for managers) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>EditMyForecasts</name>
    </userPermissions>

    <!-- View All Data: Bypass sharing (typically false for reps) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewAllData</name>
    </userPermissions>

    <!-- APPLICATION VISIBILITY -->
    <!-- Sales Cloud app -->
    <applicationVisibilities>
        <application>standard__Sales</application>
        <default>true</default>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- TAB SETTINGS -->
    <!-- Standard Sales tabs -->
    <tabSettings>
        <tab>standard-Account</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>standard-Contact</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>standard-Opportunity</tab>
