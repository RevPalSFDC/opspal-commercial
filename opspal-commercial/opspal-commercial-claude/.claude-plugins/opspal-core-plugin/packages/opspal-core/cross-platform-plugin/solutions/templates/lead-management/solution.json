{
  "name": "lead-management",
  "version": "1.0.0",
  "description": "Complete lead management solution with scoring, routing, and automated assignment based on configurable criteria",

  "metadata": {
    "author": "RevPal Engineering",
    "created": "2025-12-04",
    "updated": "2025-12-04",
    "tags": ["lead", "routing", "scoring", "automation"],
    "complexity": "moderate",
    "estimatedDeployTime": "15 min"
  },

  "platforms": {
    "salesforce": {
      "minApiVersion": "62.0",
      "requiredFeatures": ["Flow", "CustomField", "PermissionSet"]
    }
  },

  "parameters": {
    "scoringThreshold": {
      "type": "number",
      "description": "Minimum lead score to qualify for routing (0-100)",
      "required": false,
      "default": 50,
      "validation": {
        "min": 0,
        "max": 100
      }
    },
    "defaultOwnerId": {
      "type": "userId",
      "description": "Default owner for leads that don't match routing criteria",
      "required": true
    },
    "routingQueueId": {
      "type": "queueId",
      "description": "Queue ID for round-robin lead assignment",
      "required": true
    },
    "enableScoring": {
      "type": "boolean",
      "description": "Enable automatic lead scoring based on engagement",
      "required": false,
      "default": true
    },
    "highPriorityThreshold": {
      "type": "number",
      "description": "Score threshold for high-priority leads",
      "required": false,
      "default": 80
    },
    "enableNotifications": {
      "type": "boolean",
      "description": "Send email notifications for high-priority leads",
      "required": false,
      "default": false
    },
    "notificationRecipient": {
      "type": "userId",
      "description": "User to receive high-priority lead notifications",
      "required": false,
      "dependsOn": {
        "parameter": "enableNotifications",
        "value": true
      }
    }
  },

  "components": [
    {
      "id": "lead-score-field",
      "type": "salesforce:customField",
      "template": "components/fields/Lead.Score__c.field-meta.xml",
      "description": "Custom field to store calculated lead score",
      "order": 1,
      "dependsOn": []
    },
    {
      "id": "lead-priority-field",
      "type": "salesforce:customField",
      "template": "components/fields/Lead.Priority__c.field-meta.xml",
      "description": "Custom picklist field for lead priority classification",
      "order": 2,
      "dependsOn": []
    },
    {
      "id": "lead-routing-flow",
      "type": "salesforce:flow",
      "template": "components/flows/Lead_Routing.flow-meta.xml",
      "description": "Record-triggered flow for lead assignment and routing",
      "order": 3,
      "dependsOn": ["lead-score-field", "lead-priority-field"]
    },
    {
      "id": "lead-manager-permission-set",
      "type": "salesforce:permissionSet",
      "template": "components/permissions/Lead_Manager.permissionset-meta.xml",
      "description": "Permission set for lead management access",
      "order": 4,
      "dependsOn": ["lead-score-field", "lead-priority-field"]
    }
  ],

  "preDeployChecks": [
    {
      "name": "verify-lead-object",
      "type": "objectExists",
      "objectName": "Lead",
      "severity": "error",
      "message": "Lead object must exist"
    },
    {
      "name": "verify-default-owner",
      "type": "userAccessible",
      "parameter": "defaultOwnerId",
      "severity": "error",
      "message": "Default owner user must exist and be active"
    },
    {
      "name": "verify-routing-queue",
      "type": "fieldExists",
      "objectName": "Group",
      "fieldName": "Id",
      "severity": "warning",
      "message": "Routing queue should be configured"
    }
  ],

  "postDeployActions": [
    {
      "name": "activate-flow",
      "type": "activateFlow",
      "flowName": "Lead_Routing",
      "failOnError": false
    },
    {
      "name": "verify-deployment",
      "type": "validateRecords",
      "query": "SELECT Id FROM FlowDefinition WHERE DeveloperName = 'Lead_Routing'",
      "expectedCount": 1,
      "failOnError": true
    }
  ],

  "rollbackStrategy": {
    "type": "checkpoint",
    "maxCheckpoints": 5
  }
}
