    <!-- SYSTEM PERMISSIONS -->
    <!-- Service Cloud system permissions -->

    <!-- API Enabled: Allow API access -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>

    <!-- Manage Cases: Case management capabilities -->
    <userPermissions>
        <enabled>true</enabled>
        <name>EditCaseComments</name>
    </userPermissions>

    <!-- Send Email: Allow email from Salesforce -->
    <userPermissions>
        <enabled>true</enabled>
        <name>SendSitRequests</name>
    </userPermissions>

    <!-- Create and Customize Reports -->
    <userPermissions>
        <enabled>false</enabled>
        <name>CreateCustomizeReports</name>
    </userPermissions>

    <!-- Run Reports -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunReports</name>
    </userPermissions>

    <!-- View Knowledge: Access knowledge base -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewDataLeakageEvents</name>
    </userPermissions>

    <!-- Manage Knowledge: Publish articles (for authors only) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ManageKnowledge</name>
    </userPermissions>

    <!-- View All Data: Bypass sharing (typically false for agents) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewAllData</name>
    </userPermissions>

    <!-- APPLICATION VISIBILITY -->
    <!-- Service Cloud app -->
    <applicationVisibilities>
        <application>standard__Service</application>
        <default>true</default>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- TAB SETTINGS -->
    <!-- Standard Service tabs -->
    <tabSettings>
        <tab>standard-Case</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>standard-Account</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>standard-Contact</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!--
    TESTING CHECKLIST:
    □ 1. Create test service agent user
    □ 2. Assign this permission set
    □ 3. Test case creation
    □ 4. Test case editing (status, priority)
    □ 5. Test email sending from case
    □ 6. Test knowledge article search
    □ 7. Test solution linking to cases
    □ 8. Test task/event logging
    □ 9. Test account/contact viewing (read-only)
    □ 10. Test Omni-Channel (if configured)
    □ 11. Test Live Chat (if configured)
    □ 12. Test Macros (if configured)

    OMNI-CHANNEL ROUTING:
    If using Omni-Channel for case routing:
    - Add presence status permissions
    - Configure service channel permissions
    - Set up capacity models
    - Test routing assignment

    KNOWLEDGE:
    If using Salesforce Knowledge:
    - Add Knowledge__kav object permissions
    - Configure article types
    - Set up data category groups
    - Enable ViewDataCategories permission

    LIVE CHAT:
    If using Live Agent/Chat:
    - Add LiveChatTranscript permissions
    - Configure chat button deployments
    - Set up chat visitor object permissions
    - Test chat accept/transfer/escalate

    MACROS:
    If using Macros for automation:
    - Enable Use Macros permission
    - Test macro execution
    - Verify field updates work correctly

    BEST PRACTICES:
    - Use case queues for team-based routing
    - Enable case feed for collaboration
    - Configure auto-response rules
    - Set up escalation rules
    - Use case assignment rules
    - Enable email-to-case
    - Configure SLA tracking (if using entitlements)

    MAINTENANCE:
    - Review quarterly for new case fields
    - Audit permission usage
    - Update as Service Cloud features evolve
    - Track case metrics (first response time, resolution time)
    - Review knowledge article usage
    -->
</PermissionSet>
