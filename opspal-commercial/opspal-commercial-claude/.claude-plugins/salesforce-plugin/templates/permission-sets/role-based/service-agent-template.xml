<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <!--
    TEMPLATE: Service Agent Permission Set
    CATEGORY: Role-Based
    DESCRIPTION: Comprehensive permissions for customer service agents in Service Cloud
    TIER: 2 (Composed/Role-Based)

    USE CASES:
    - Customer Service Representatives handling cases
    - Support Agents managing customer inquiries
    - Help Desk Technicians
    - Technical Support Specialists
    - Customer Success Representatives

    OBJECTS INCLUDED:
    - Case (CRED)
    - Account (RE - for context)
    - Contact (RE - for context)
    - Solution (Read)
    - Knowledge Articles (Read/Create)
    - Task (CRED)
    - Event (CRED)
    - EmailMessage (Read)

    FIELD ACCESS:
    - Case fields: Full access
    - Knowledge fields: Read access
    - Account/Contact: Read-only for context

    SYSTEM PERMISSIONS:
    - API Enabled: true
    - Manage Knowledge: false (for authors only)
    - View All Data: false

    CUSTOMIZATION CHECKLIST:
    □ 1. Replace {{PERMISSION_SET_NAME}} with your naming
    □ 2. Update {{LABEL}} and {{DESCRIPTION}}
    □ 3. Review object permissions for your support process
    □ 4. Configure Knowledge permissions (if using Knowledge)
    □ 5. Add Omni-Channel permissions (if using Omni-Channel routing)
    □ 6. Configure Live Agent/Chat permissions (if using)
    □ 7. Set up Macros permissions (if using)
    □ 8. Add field permissions for custom case fields
    □ 9. Test with real support agent

    NAMING CONVENTION:
    Service_<Role> (e.g., Service_Agent, Service_Manager)

    TWO-TIER ARCHITECTURE:
    This is a Tier 2 role-based set. Can compose Tier 1 foundational sets:
    - Standard_Case_Edit (Tier 1)
    - Standard_Account_Read (Tier 1)
    - Standard_Contact_Read (Tier 1)
    Or use this template as standalone permission set.
    -->

    <description>{{DESCRIPTION}}</description>
    <label>{{LABEL}}</label>

    <!-- OBJECT PERMISSIONS -->
    <!-- Service Cloud standard objects -->

    <!-- Case: Full CRUD for case management -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Case</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Account: Read-only for customer context -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Contact: Read-only for customer context -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Solution: Read access for troubleshooting -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Solution</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Task: Full CRUD for follow-up activities -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Task</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Event: Full CRUD for scheduling -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Event</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- EmailMessage: Read access for case email threads -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>EmailMessage</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- ADD CUSTOM OBJECTS AS NEEDED -->
    <!-- Example: Service Contract, Asset, Product, etc. -->

