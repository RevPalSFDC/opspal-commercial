{
  "persona": "customer-success",
  "label": "Customer Success Manager",
  "description": "Customer Success Manager focused on onboarding, adoption, retention, and expansion",
  "role": "Individual Contributor",
  "decisionScope": "Customer health, adoption metrics, renewal risk, expansion opportunities",
  "keyQuestions": [
    "Is this customer at risk for churn?",
    "How is product adoption trending?",
    "What expansion opportunities exist?",
    "When is the next renewal or review?"
  ],
  "layoutCharacteristics": {
    "fieldCount": {
      "optimal": 55,
      "max": 90,
      "priority": "Customer health and engagement over administrative details"
    },
    "sectionCount": {
      "optimal": 5,
      "max": 7,
      "recommended": ["Account Information", "Health & Risk", "Adoption & Usage", "Renewals & Contracts", "Engagement History"]
    },
    "components": {
      "required": ["Highlights Panel", "Activities"],
      "recommended": ["Related List - Cases", "Related List - Opportunities", "Related List - Contracts", "Einstein Activity Capture"],
      "avoid": ["Lead Conversion", "Campaign Members"]
    },
    "relatedLists": {
      "max": 6,
      "priority": ["Cases", "Opportunities", "Contracts", "Activities", "Contacts", "Notes & Attachments"]
    }
  },
  "fieldPriorities": {
    "account": {
      "criticalFields": [
        "Name",
        "Health_Score__c",
        "Renewal_Date__c",
        "ARR__c",
        "CSM_Owner__c",
        "Customer_Stage__c",
        "Risk_Level__c"
      ],
      "importantFields": [
        "Last_Touchpoint_Date__c",
        "Product_Adoption_Score__c",
        "NPS_Score__c",
        "Onboarding_Status__c",
        "Contract_End_Date__c",
        "Expansion_Potential__c",
        "Type",
        "Industry"
      ],
      "contextualFields": [
        "Implementation_Date__c",
        "Last_QBR_Date__c",
        "Next_QBR_Date__c",
        "Support_Tier__c",
        "Primary_Use_Case__c",
        "Executive_Sponsor__c",
        "Champion_Contact__c"
      ],
      "lowPriorityFields": [
        "BillingAddress",
        "ShippingAddress",
        "Website",
        "Fax",
        "AccountSource"
      ]
    },
    "contact": {
      "criticalFields": [
        "Name",
        "AccountId",
        "Title",
        "Email",
        "Phone",
        "Is_Champion__c",
        "Influence_Level__c"
      ],
      "importantFields": [
        "Department",
        "Role__c",
        "Product_User__c",
        "Last_Login_Date__c",
        "Engagement_Score__c",
        "Decision_Maker__c"
      ],
      "contextualFields": [
        "ReportsToId",
        "LinkedIn__c",
        "Preferred_Contact_Method__c",
        "Timezone__c"
      ]
    },
    "opportunity": {
      "criticalFields": [
        "Name",
        "AccountId",
        "Type",
        "Amount",
        "CloseDate",
        "StageName",
        "Expansion_Type__c"
      ],
      "importantFields": [
        "Products__c",
        "Renewal_Probability__c",
        "Upsell_Reason__c",
        "Cross_Sell_Product__c",
        "NextStep"
      ]
    },
    "case": {
      "criticalFields": [
        "CaseNumber",
        "Subject",
        "Status",
        "Priority",
        "AccountId",
        "ContactId",
        "OwnerId"
      ],
      "importantFields": [
        "Type",
        "Reason",
        "Origin",
        "Created_Date",
        "Escalated__c"
      ]
    }
  },
  "sections": {
    "account": [
      {
        "label": "Account Information",
        "order": 1,
        "fields": ["Name", "Type", "Industry", "ARR__c", "Customer_Stage__c", "CSM_Owner__c", "Executive_Sponsor__c"]
      },
      {
        "label": "Health & Risk",
        "order": 2,
        "fields": ["Health_Score__c", "Risk_Level__c", "NPS_Score__c", "Churn_Reason__c", "Risk_Notes__c", "Last_Touchpoint_Date__c"]
      },
      {
        "label": "Adoption & Usage",
        "order": 3,
        "fields": ["Product_Adoption_Score__c", "Primary_Use_Case__c", "Active_Users__c", "Feature_Adoption__c", "Onboarding_Status__c", "Implementation_Date__c"]
      },
      {
        "label": "Renewals & Contracts",
        "order": 4,
        "fields": ["Renewal_Date__c", "Contract_End_Date__c", "Contract_Value__c", "Renewal_Probability__c", "Expansion_Potential__c", "Support_Tier__c"]
      },
      {
        "label": "Engagement History",
        "order": 5,
        "fields": ["Last_QBR_Date__c", "Next_QBR_Date__c", "Success_Plan_Status__c", "EBR_Date__c", "Training_Completed__c"]
      }
    ],
    "contact": [
      {
        "label": "Contact Information",
        "order": 1,
        "fields": ["Name", "AccountId", "Title", "Email", "Phone", "Department", "Role__c"]
      },
      {
        "label": "Stakeholder Details",
        "order": 2,
        "fields": ["Is_Champion__c", "Decision_Maker__c", "Influence_Level__c", "ReportsToId", "Engagement_Score__c"]
      },
      {
        "label": "Product Engagement",
        "order": 3,
        "fields": ["Product_User__c", "Last_Login_Date__c", "Feature_Usage__c", "Training_Completed__c", "Certification_Status__c"]
      }
    ],
    "opportunity": [
      {
        "label": "Opportunity Information",
        "order": 1,
        "fields": ["Name", "AccountId", "Type", "Expansion_Type__c", "Amount", "CloseDate", "StageName"]
      },
      {
        "label": "Expansion Details",
        "order": 2,
        "fields": ["Products__c", "Upsell_Reason__c", "Cross_Sell_Product__c", "Renewal_Probability__c", "NextStep", "Description"]
      }
    ],
    "case": [
      {
        "label": "Case Information",
        "order": 1,
        "fields": ["CaseNumber", "Subject", "Status", "Priority", "Type", "Reason", "Origin"]
      },
      {
        "label": "Case Details",
        "order": 2,
        "fields": ["AccountId", "ContactId", "OwnerId", "Escalated__c", "Resolution_Notes__c", "Root_Cause__c"]
      }
    ]
  },
  "compactLayoutFields": {
    "account": ["Health_Score__c", "ARR__c", "Renewal_Date__c", "CSM_Owner__c"],
    "contact": ["AccountId", "Title", "Is_Champion__c", "Engagement_Score__c"],
    "opportunity": ["Type", "Amount", "CloseDate", "Expansion_Type__c"],
    "case": ["Status", "Priority", "AccountId", "Created_Date"]
  },
  "conditionalVisibility": {
    "rules": [
      {
        "name": "At Risk Fields",
        "condition": "Health_Score__c = 'Red' OR Risk_Level__c = 'High'",
        "action": "Show section 'Mitigation Plan'"
      },
      {
        "name": "Renewal Approaching",
        "condition": "DAYS(Renewal_Date__c, TODAY()) < 90",
        "action": "Highlight 'Renewal Section'"
      },
      {
        "name": "Expansion Opportunity",
        "condition": "Expansion_Potential__c = 'High'",
        "action": "Show section 'Expansion Strategy'"
      },
      {
        "name": "Onboarding Active",
        "condition": "Onboarding_Status__c = 'In Progress'",
        "action": "Show section 'Onboarding Milestones'"
      }
    ]
  },
  "mobile": {
    "optimized": true,
    "maxFieldsFirstScreen": 15,
    "priority": "Health score, renewal date, ARR, last touchpoint, open cases"
  },
  "bestPractices": {
    "useDynamicForms": true,
    "useHighlightsPanel": true,
    "usePathComponent": false,
    "maxComponentsPerPage": 15,
    "filterRelatedListsToRelevant": true
  },
  "objectGuidance": {
    "Account": {
      "sections": [
        {"name": "Account Overview", "fields": ["Name", "Type", "Industry", "CSM_Owner__c", "Customer_Stage__c"]},
        {"name": "Health & Risk", "fields": ["Health_Score__c", "Risk_Level__c", "NPS_Score__c", "Churn_Reason__c"]},
        {"name": "Adoption & Usage", "fields": ["Product_Adoption_Score__c", "Active_Users__c", "Onboarding_Status__c"]},
        {"name": "Renewals & Revenue", "fields": ["ARR__c", "Renewal_Date__c", "Contract_End_Date__c", "Expansion_Potential__c"]},
        {"name": "Engagement", "fields": ["Last_Touchpoint_Date__c", "Last_QBR_Date__c", "Next_QBR_Date__c"]}
      ],
      "compactFields": ["Health_Score__c", "ARR__c", "Renewal_Date__c", "CSM_Owner__c"],
      "relatedLists": ["Cases", "Opportunities", "Contracts", "Contacts", "Activities"],
      "defaultTab": "Details",
      "rationale": "CSMs need health and renewal data immediately - Details tab shows customer health for proactive management"
    },
    "Contact": {
      "sections": [
        {"name": "Contact Details", "fields": ["Name", "AccountId", "Title", "Email", "Phone", "Department"]},
        {"name": "Stakeholder Role", "fields": ["Is_Champion__c", "Decision_Maker__c", "Influence_Level__c"]},
        {"name": "Product Engagement", "fields": ["Product_User__c", "Last_Login_Date__c", "Engagement_Score__c"]}
      ],
      "compactFields": ["AccountId", "Title", "Is_Champion__c", "Engagement_Score__c"],
      "relatedLists": ["Cases", "Activities"],
      "defaultTab": "Details",
      "rationale": "CSMs need to understand stakeholder relationships - Details shows champion status and engagement"
    },
    "Opportunity": {
      "sections": [
        {"name": "Opportunity Details", "fields": ["Name", "AccountId", "Type", "Amount", "CloseDate", "StageName"]},
        {"name": "Expansion Context", "fields": ["Expansion_Type__c", "Products__c", "Upsell_Reason__c"]},
        {"name": "Renewal Info", "fields": ["Renewal_Probability__c", "Cross_Sell_Product__c", "NextStep"]}
      ],
      "compactFields": ["Type", "Amount", "CloseDate", "Expansion_Type__c"],
      "relatedLists": ["Contacts", "Activities", "Quotes"],
      "defaultTab": "Details",
      "rationale": "CSMs work expansion/renewal opportunities - Details shows renewal probability and expansion type"
    },
    "Quote": {
      "sections": [
        {"name": "Quote Information", "fields": ["Name", "Status", "OpportunityId", "AccountId"]},
        {"name": "Pricing", "fields": ["GrandTotal", "Discount", "TotalPrice"]},
        {"name": "Timeline", "fields": ["ExpirationDate"]}
      ],
      "compactFields": ["Status", "GrandTotal", "ExpirationDate", "OpportunityId"],
      "relatedLists": ["QuoteLineItems", "Documents"],
      "defaultTab": "Details",
      "rationale": "CSMs reference quotes for renewal discussions - Details shows pricing summary"
    },
    "QuoteLineItem": {
      "sections": [
        {"name": "Product Details", "fields": ["Product2Id", "Description"]},
        {"name": "Pricing", "fields": ["Quantity", "UnitPrice", "TotalPrice"]}
      ],
      "compactFields": ["Product2Id", "Quantity", "TotalPrice"],
      "relatedLists": [],
      "defaultTab": "Details",
      "rationale": "CSMs may review line items for renewal/expansion conversations"
    }
  }
}
