{
  "templateMetadata": {
    "templateName": "Team Performance - Quota Attainment by Rep",
    "templateVersion": "1.0",
    "description": "Compare sales team members' performance with quota attainment, win rates, and activity metrics",
    "audience": "Sales Managers, Sales Directors, VPs of Sales",
    "useCase": "Weekly team reviews, identify coaching opportunities, recognize top performers, allocate resources",
    "customizationPoints": [
      "Owner filter (My Team's Opportunities vs specific team/region)",
      "Date range for performance period",
      "Quota data source (external vs Salesforce field)",
      "Additional metrics (activities, pipeline coverage, etc.)"
    ],
    "prerequisites": [
      "Opportunities with standard fields",
      "Quota data (via Forecasting, custom fields, or external integration)",
      "Sales team hierarchy configured (for 'My Team' filters)"
    ]
  },
  "fieldHints": {
    "OPPORTUNITY_OWNER": {
      "patterns": ["OWNER_NAME", "OWNER.FULL_NAME", "FULL_NAME", "OWNER", "OPP_OWNER"],
      "fallback": "CREATED_BY",
      "required": true,
      "description": "Opportunity owner for grouping by sales rep"
    },
    "OPPORTUNITY_NAME": {
      "patterns": ["OPPORTUNITY_NAME", "OPP_NAME", "NAME", "TITLE"],
      "required": true,
      "description": "Name of the opportunity"
    },
    "ACCOUNT_NAME": {
      "patterns": ["ACCOUNT_NAME", "ACCOUNT.NAME", "ACC_NAME", "COMPANY"],
      "required": true,
      "description": "Associated account name"
    },
    "AMOUNT": {
      "patterns": ["AMOUNT", "OPP_AMOUNT", "TOTAL_AMOUNT", "VALUE"],
      "required": true,
      "description": "Opportunity amount/value"
    },
    "STAGE_NAME": {
      "patterns": ["STAGE_NAME", "OPP_STAGE_NAME", "STAGE", "STATUS"],
      "fallback": "STATUS",
      "required": true,
      "description": "Current opportunity stage"
    },
    "CLOSE_DATE": {
      "patterns": ["CLOSE_DATE", "CLOSEDATE", "CLOSED_DATE", "TARGET_CLOSE_DATE"],
      "required": true,
      "description": "Expected or actual close date"
    },
    "IS_WON": {
      "patterns": ["IS_WON", "ISWON", "WON", "IS_CLOSED_WON"],
      "fallback": "STAGE_NAME",
      "required": false,
      "description": "Whether opportunity was won (boolean)"
    },
    "PROBABILITY": {
      "patterns": ["PROBABILITY", "OPP_PROBABILITY", "WIN_PROBABILITY"],
      "required": false,
      "description": "Win probability percentage"
    }
  },
  "orgAdaptation": {
    "requiredObjects": ["Opportunity"],
    "requiredFields": ["OPPORTUNITY_OWNER", "AMOUNT", "CLOSE_DATE"],
    "optionalFields": ["IS_WON", "PROBABILITY", "STAGE_NAME"],
    "customFieldAdaptation": {
      "quotaFields": {
        "patterns": ["Quota__c", "User.Quota__c", "Territory_Quota__c"],
        "fallback": null,
        "note": "If no quota field, report shows revenue only without attainment %"
      }
    },
    "minimumFidelity": 0.7,
    "adaptationStrategy": "graceful-degradation",
    "fallbackBehavior": {
      "missingOwner": "Group by CREATED_BY instead",
      "missingIsWon": "Filter STAGE_NAME = 'Closed Won' instead",
      "missingQuota": "Show revenue totals without quota comparison"
    }
  },
  "reportMetadata": {
    "name": "Team Performance - {Period}",
    "description": "Sales team quota attainment and performance metrics by rep",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "team",
    "showDetails": true,
    "reportBooleanFilter": null,
    "reportFilters": [
      {
        "column": "OPPORTUNITY_OWNER",
        "operator": "equals",
        "value": "$User.ManagerId.Team",
        "customizable": true,
        "customizationNote": "Use 'My Team's Opportunities' or filter to specific role/region"
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_QUARTER",
        "customizable": true,
        "customizationNote": "Adjust to THIS_MONTH, THIS_YEAR, or custom date range"
      }
    ],
    "groupingsDown": [
      {
        "field": "OPPORTUNITY_OWNER",
        "sortOrder": "Asc",
        "dateGranularity": null,
        "customizable": false,
        "customizationNote": "Group by owner to compare individual reps"
      }
    ],
    "groupingsAcross": [],
    "detailColumns": [
      "OPPORTUNITY_NAME",
      "ACCOUNT_NAME",
      "AMOUNT",
      "STAGE_NAME",
      "CLOSE_DATE",
      "IS_WON",
      "PROBABILITY"
    ],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "filterCriteria": "IS_WON = TRUE",
        "description": "Total closed won revenue per rep"
      },
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "filterCriteria": "IS_WON = TRUE",
        "description": "Count of won opportunities"
      },
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "description": "Total opportunities (won + lost + open)"
      },
      {
        "name": "AMOUNT",
        "aggregateType": "Average",
        "filterCriteria": "IS_WON = TRUE",
        "description": "Average deal size"
      }
    ],
    "customSummaryFormulas": [
      {
        "name": "Quota_Attainment_Percent",
        "description": "% of quota achieved (requires external quota data)",
        "formula": "(SUM_AMOUNT_WON / Quota) * 100",
        "dataType": "percent",
        "decimalPlaces": 1,
        "note": "Quota must come from Forecasting, custom field, or be manually added"
      },
      {
        "name": "Win_Rate_Percent",
        "description": "% of closed opportunities that were won",
        "formula": "(COUNT_WON / (COUNT_WON + COUNT_LOST)) * 100",
        "dataType": "percent",
        "decimalPlaces": 1
      },
      {
        "name": "Pipeline_to_Quota_Ratio",
        "description": "Current pipeline coverage relative to remaining quota",
        "formula": "SUM_OPEN_PIPELINE / (Quota - SUM_AMOUNT_WON)",
        "dataType": "number",
        "decimalPlaces": 1,
        "note": "Healthy ratio is 3-5x"
      }
    ],
    "chart": {
      "chartType": "HorizontalBarGrouped",
      "groupingColumn": "OPPORTUNITY_OWNER",
      "aggregateColumns": ["Quota", "ClosedWon"],
      "legendPosition": "Bottom",
      "showChartValues": true,
      "sortBy": "QuotaAttainment",
      "sortOrder": "Descending",
      "chartColorPalette": "custom",
      "chartColors": {
        "Quota": "#95a5a6",
        "ClosedWon": "#27ae60"
      },
      "note": "Grouped bar chart: Quota (gray) vs Actual (green) per rep"
    }
  },
  "quotaDataOptions": [
    {
      "method": "Salesforce Forecasting",
      "setup": "Enable Collaborative Forecasts, assign quotas to users",
      "pros": "Native Salesforce, quota history tracked",
      "cons": "Requires Enterprise or Unlimited edition"
    },
    {
      "method": "Custom Field on User",
      "setup": "Create Quota__c field on User object, populate manually or via import",
      "pros": "Simple, works on any edition",
      "cons": "Manual maintenance, no history tracking"
    },
    {
      "method": "External Integration",
      "setup": "Sync quota data from Anaplan, Salesforce CPQ, or BI tool",
      "pros": "Centralized quota management",
      "cons": "Requires integration setup"
    }
  ],
  "deploymentInstructions": {
    "steps": [
      "1. Determine quota data source (Forecasting, custom field, or external)",
      "2. If using custom field, create User.Quota__c and populate values",
      "3. Update CLOSE_DATE filter to match performance period",
      "4. Update owner filter to 'My Team' or specific role/region",
      "5. Deploy report to Sales Reports folder",
      "6. Create custom summary formulas for Quota Attainment, Win Rate",
      "7. Add chart comparing quota vs actual per rep"
    ],
    "expectedResults": {
      "quotaBenchmarks": {
        "Excellent": ">100% quota attainment",
        "OnTrack": "80-100%",
        "NeedsAttention": "50-80%",
        "Critical": "<50%"
      },
      "winRateBenchmarks": {
        "Excellent": ">30%",
        "Good": "20-30%",
        "Fair": "10-20%",
        "Poor": "<10%"
      },
      "actionItems": [
        "Reps below 50% need immediate coaching",
        "Celebrate reps exceeding quota",
        "Analyze top performers' tactics for team training",
        "Check if low performers have sufficient pipeline"
      ]
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "Sales Manager - Team Performance Dashboard",
      "Executive - Sales Summary Dashboard"
    ],
    "dashboardComponents": [
      {
        "componentType": "Horizontal Bar Chart",
        "title": "Quota Attainment by Rep",
        "size": "half-width",
        "refreshFrequency": "Daily"
      },
      {
        "componentType": "Table",
        "title": "Top Performers This Month",
        "filter": "Sort by ClosedWon DESC, Limit 5",
        "size": "third-width"
      },
      {
        "componentType": "Metric",
        "title": "Team Win Rate",
        "aggregation": "Average across all reps",
        "size": "third-width"
      }
    ]
  },
  "relatedTemplates": [
    "win-loss-analysis.json",
    "forecast-accuracy.json",
    "../sales-reps/my-pipeline-by-stage.json"
  ]
}
