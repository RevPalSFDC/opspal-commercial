{
  "templateMetadata": {
    "templateName": "Renewal Pipeline by Quarter",
    "templateVersion": "1.0",
    "description": "Track upcoming contract renewals with risk assessment and value projection",
    "audience": "Customer Success, Sales Leadership, Finance",
    "useCase": "Forecast renewal revenue, identify at-risk renewals, plan CS team capacity",
    "prerequisites": ["Renewal opportunities OR Account.Contract_End_Date__c", "ARR/MRR fields"]
  },
  "reportMetadata": {
    "name": "Renewal Pipeline - {Period}",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "reportFilters": [
      {"column": "TYPE", "operator": "equals", "value": "Renewal"},
      {"column": "CLOSE_DATE", "operator": "equals", "value": "NEXT_2_QUARTERS"}
    ],
    "groupingsDown": [
      {"field": "CLOSE_DATE", "dateGranularity": "QUARTER"},
      {"field": "Opportunity.Renewal_Risk__c"}
    ],
    "detailColumns": ["ACCOUNT_NAME", "AMOUNT", "STAGE_NAME", "Opportunity.Contract_Value__c", "Account.Health_Score__c"],
    "aggregates": [{"name": "AMOUNT", "aggregateType": "Sum"}, {"name": "RowCount", "aggregateType": "Sum"}],
    "chart": {"chartType": "StackedBar", "groupingColumn": "CLOSE_DATE", "aggregateColumn": "AMOUNT"}
  }
}
