# Salesforce Plugin Environment Variables
#
# Copy this file to the project root as .env and fill in your values
# Location: /path/to/your/project/.env (NOT in the plugin directory)
#
# Usage: source .claude-plugins/developer-tools-plugin/scripts/lib/load-env.sh

# ============================================================================
# SALESFORCE CONFIGURATION
# ============================================================================

# Salesforce Environment Type
# Options: sandbox | production
SALESFORCE_ENVIRONMENT=sandbox

# Salesforce Org Instance Name
# Example: your-company-sandbox, your-company-prod
SALESFORCE_INSTANCE=your-org-instance

# SFDX CLI Alias for the org
# This should match an authenticated org in: sf org list
SFDX_ALIAS=your-org-alias

# Default SFDX Username
# The username you use to authenticate with this org
SFDX_DEFAULT_USERNAME=your.email@company.com.sandbox

# ============================================================================
# REFLECTION SYSTEM (Optional - for /reflect command)
# ============================================================================

# Supabase Configuration (for storing session reflections)
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# User Email (for attribution in reflections)
USER_EMAIL=your.email@company.com

# ============================================================================
# NOTIFICATIONS (Optional)
# ============================================================================

# Slack Webhook URL (for deployment notifications)
# Create webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# NOTES
# ============================================================================
#
# Required Variables:
#   - SALESFORCE_ENVIRONMENT (for org-specific operations)
#   - SFDX_ALIAS (for CLI commands)
#
# Optional Variables:
#   - SUPABASE_* (only if using /reflect command)
#   - SLACK_WEBHOOK_URL (only if you want Slack notifications)
#
# Security:
#   - NEVER commit .env file to git
#   - Add .env to your .gitignore
#   - Use different credentials for sandbox vs production
#
