{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-utilization-booster.sh",
            "timeout": 10000,
            "description": "Route tasks to agents with complexity analysis"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-task-graph-trigger.sh",
            "timeout": 5000,
            "description": "Detect when Task Graph orchestration is needed based on complexity"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-contract-validation.sh",
            "timeout": 5000,
            "description": "Validate tool inputs against contracts before execution"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/task-graph-policy-enforcer.sh",
            "timeout": 3000,
            "description": "Enforce risk-based tool policies for Task Graph tasks"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.sh",
            "timeout": 10000,
            "description": "Backup conversation transcript before compaction to prevent data loss"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh",
            "timeout": 5000,
            "description": "Validate tool execution results to catch errors before propagation"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-contract-validation.sh",
            "timeout": 5000,
            "description": "Validate tool outputs against contracts and data quality gates"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-audit-bluf-generator.sh",
            "timeout": 10000,
            "description": "Auto-generate BLUF+4 executive summary after audit/assessment completion"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-todowrite-scratchpad.sh",
            "timeout": 5000,
            "description": "Persist TodoWrite state for session continuity"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-task-stall-check.sh",
            "timeout": 5000,
            "description": "Check for stalls during multi-agent operations"
          }
        ]
      },
      {
        "matcher": "Write(*SESSION_REFLECTION*)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-reflect-strategy-update.sh",
            "timeout": 15000,
            "description": "Extract skills from reflections and update routing confidence"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-scratchpad.sh",
            "timeout": 10000,
            "description": "Load previous session context for continuity"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-env-config.sh",
            "timeout": 10000,
            "description": "Detect missing ENV_CONFIG.json"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end-scratchpad.sh",
            "timeout": 10000,
            "description": "Save session state for continuity"
          }
        ]
      }
    ]
  }
}
