{
  "templateId": "1VUGRtUbqwz-UIc9J2pDXp3PQllFdv9K27cHPrM-urhc",
  "name": "RevPal Master Template",
  "version": "1.0.0",
  "description": "RevPal master presentation template with standard branding and layouts",
  "deckType": "general",
  "targetAudience": ["executive", "technical", "sales", "customer"],
  "branding": {
    "primaryFont": "Montserrat",
    "bodyFont": "Figtree",
    "colors": {
      "primary": "#5F3B8C",
      "primaryName": "Deep Grape",
      "secondary": "#3E4A61",
      "secondaryName": "Slate Indigo",
      "accent": "#E99560",
      "accentName": "Muted Apricot",
      "success": "#6FBF73",
      "successName": "Success Green",
      "warning": "#E99560",
      "error": "#E94B3C"
    },
    "typography": {
      "h1": { "font": "Montserrat", "weight": "Bold", "size": 48 },
      "h2": { "font": "Montserrat", "weight": "SemiBold", "size": 32 },
      "h3": { "font": "Montserrat", "weight": "Medium", "size": 28 },
      "body": { "font": "Figtree", "weight": "Regular", "size": 16 },
      "caption": { "font": "Figtree", "weight": "Regular", "size": 12 }
    },
    "companyName": "RevPal",
    "tagline": "OpsPal by RevPal",
    "logo": "{{revpal_logo}}"
  },
  "layouts": [
    {
      "id": "TITLE",
      "name": "Title Slide",
      "description": "Opening slide with title, subtitle, and branding",
      "placeholders": [
        "{{title}}",
        "{{subtitle}}",
        "{{date}}",
        "{{presenter}}"
      ],
      "recommendedFor": ["opening", "cover"]
    },
    {
      "id": "SECTION_HEADER",
      "name": "Section Header",
      "description": "Divider slide for major sections",
      "placeholders": [
        "{{section_title}}",
        "{{section_number}}"
      ],
      "recommendedFor": ["transitions", "chapters"]
    },
    {
      "id": "CONTENT",
      "name": "Content Slide",
      "description": "Standard content slide with title and bullet points",
      "placeholders": [
        "{{slide_title}}",
        "{{bullet_1}}",
        "{{bullet_2}}",
        "{{bullet_3}}",
        "{{bullet_4}}",
        "{{bullet_5}}"
      ],
      "recommendedFor": ["main_content", "lists", "key_points"]
    },
    {
      "id": "TWO_COLUMN",
      "name": "Two Column",
      "description": "Side-by-side content comparison",
      "placeholders": [
        "{{slide_title}}",
        "{{left_header}}",
        "{{left_content}}",
        "{{right_header}}",
        "{{right_content}}"
      ],
      "recommendedFor": ["comparisons", "before_after", "pros_cons"]
    },
    {
      "id": "QUOTE",
      "name": "Quote Slide",
      "description": "Customer testimonial or quote emphasis",
      "placeholders": [
        "{{quote_text}}",
        "{{author}}",
        "{{author_title}}",
        "{{company}}"
      ],
      "recommendedFor": ["testimonials", "social_proof", "emphasis"]
    },
    {
      "id": "KPI",
      "name": "KPI Dashboard",
      "description": "Key metrics and performance indicators",
      "placeholders": [
        "{{slide_title}}",
        "{{metric_1_label}}",
        "{{metric_1_value}}",
        "{{metric_2_label}}",
        "{{metric_2_value}}",
        "{{metric_3_label}}",
        "{{metric_3_value}}",
        "{{metric_4_label}}",
        "{{metric_4_value}}"
      ],
      "recommendedFor": ["metrics", "results", "performance"]
    },
    {
      "id": "IMAGE_TITLE",
      "name": "Image with Title",
      "description": "Large image with caption",
      "placeholders": [
        "{{slide_title}}",
        "{{image_url}}",
        "{{caption}}"
      ],
      "recommendedFor": ["visuals", "screenshots", "diagrams"]
    },
    {
      "id": "CLOSING",
      "name": "Closing Slide",
      "description": "Thank you and next steps",
      "placeholders": [
        "{{closing_message}}",
        "{{contact_name}}",
        "{{contact_email}}",
        "{{contact_phone}}",
        "{{website}}"
      ],
      "recommendedFor": ["conclusion", "cta", "contact"]
    }
  ],
  "contentGuidelines": {
    "maxBulletsPerSlide": 5,
    "maxWordsPerBullet": 15,
    "maxSlidesPerDeck": 50,
    "minFontSize": 12,
    "recommendedPacing": "1-2 minutes per slide"
  },
  "disclaimer": "This presentation includes analysis and insights generated with the assistance of OpsPal, by RevPal. While every effort has been made to ensure accuracy, results may include inaccuracies or omissions. Please validate findings before relying on them for business decisions.",
  "createdBy": "OpsPal by RevPal",
  "lastUpdated": "2025-12-08"
}
