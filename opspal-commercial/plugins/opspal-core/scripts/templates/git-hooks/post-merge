#!/usr/bin/env bash
#
# post-merge hook - Installed by project-connect schema migration
#
# Runs after every git pull/merge in the .repo/ directory.
# Logs the merge event for observability.
#

LOG_DIR="$HOME/.claude/logs"
LOG_FILE="$LOG_DIR/git-hooks.jsonl"

# Ensure log directory exists
mkdir -p "$LOG_DIR"

# Detect org slug from repo path
# Expected path: .../orgs/{slug}/.repo/.git/hooks/post-merge
REPO_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
ORG_DIR="$(dirname "$REPO_DIR")"
ORG_SLUG="$(basename "$ORG_DIR")"

# Get current branch and latest commit
BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')"
COMMIT="$(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
COMMIT_MSG="$(git log -1 --pretty=%s 2>/dev/null || echo '')"
TIMESTAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# Was this a squash merge? ($1 is 1 for squash, 0 for normal)
SQUASH="${1:-0}"

# Log the event
echo "{\"event\":\"post-merge\",\"org\":\"${ORG_SLUG}\",\"branch\":\"${BRANCH}\",\"commit\":\"${COMMIT}\",\"message\":\"${COMMIT_MSG}\",\"squash\":${SQUASH},\"timestamp\":\"${TIMESTAMP}\"}" >> "$LOG_FILE"

exit 0
