{
  "templateMetadata": {
    "templateName": "My Quota Attainment",
    "templateVersion": "1.1",
    "description": "Your current quota attainment percentage",
    "audience": "Sales Reps, Account Executives",
    "useCase": "Progress tracking, self-assessment, motivation",
    "customizationPoints": [
      "Time period",
      "Quota source",
      "Include pipeline"
    ],
    "prerequisites": [
      "Opportunity object",
      "Quota data available"
    ]
  },
  "metricDefinitionId": "quota_attainment",
  "reportMetadata": {
    "name": "My Quota Attainment",
    "description": "Closed won vs quota",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "user",
    "showDetails": false,
    "reportFilters": [
      {
        "column": "IS_WON",
        "operator": "equals",
        "value": "true",
        "customizable": false
      },
      {
        "column": "OPPORTUNITY_OWNER",
        "operator": "equals",
        "value": "$User.Id",
        "customizable": false
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_QUARTER",
        "customizable": true
      }
    ],
    "groupingsDown": [],
    "groupingsAcross": [],
    "detailColumns": [],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Closed won"
      }
    ],
    "customSummaryFormulas": [
      {
        "name": "Attainment",
        "description": "Closed Won / Quota",
        "formula": "(SUM(AMOUNT) / Quota) * 100",
        "dataType": "percent",
        "decimalPlaces": 1
      }
    ],
    "chart": {
      "chartType": "Gauge",
      "aggregateColumn": "Attainment",
      "thresholds": {
        "green": {
          "min": 100,
          "max": 200
        },
        "yellow": {
          "min": 70,
          "max": 100
        },
        "red": {
          "min": 0,
          "max": 70
        }
      }
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "my-quota"
    ],
    "componentType": "Gauge",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified individual rep report",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full individual rep report"
      },
      "cpq": {
        "description": "CPQ-enabled with quote metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise deal focus",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "50000"
          }
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Amount": {
        "patterns": [
          "Amount",
          "Total_Amount__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "Quota": {
        "patterns": [
          "Quota__c",
          "Quarterly_Quota__c",
          "Target__c"
        ],
        "dataType": "currency"
      }
    }
  }
}
