{
  "templateMetadata": {
    "templateName": "My Open Pipeline",
    "templateVersion": "1.1",
    "description": "Total value of your open opportunities",
    "audience": "Sales Reps, BDRs, Account Executives",
    "useCase": "Daily pipeline monitoring, self-management, forecast preparation",
    "customizationPoints": [
      "Date range",
      "Stage filter",
      "Minimum deal size"
    ],
    "prerequisites": [
      "Opportunity object with Amount",
      "Opportunities assigned to user"
    ]
  },
  "metricDefinitionId": "pipeline.arr",
  "reportMetadata": {
    "name": "My Open Pipeline",
    "description": "Total open pipeline value for current user",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "user",
    "showDetails": false,
    "reportFilters": [
      {
        "column": "IS_CLOSED",
        "operator": "equals",
        "value": "false",
        "customizable": false
      },
      {
        "column": "OPPORTUNITY_OWNER",
        "operator": "equals",
        "value": "$User.Id",
        "customizable": false
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_QUARTER",
        "customizable": true
      }
    ],
    "groupingsDown": [],
    "groupingsAcross": [],
    "detailColumns": [],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Total pipeline value"
      },
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "description": "Deal count"
      }
    ],
    "chart": {
      "chartType": "Metric",
      "aggregateColumn": "AMOUNT:SUM",
      "format": "currency"
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "my-pipeline"
    ],
    "componentType": "Metric",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified individual rep report",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full individual rep report"
      },
      "cpq": {
        "description": "CPQ-enabled with quote metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise deal focus",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "50000"
          }
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Amount": {
        "patterns": [
          "Amount",
          "Total_Amount__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "Quota": {
        "patterns": [
          "Quota__c",
          "Quarterly_Quota__c",
          "Target__c"
        ],
        "dataType": "currency"
      }
    }
  }
}
