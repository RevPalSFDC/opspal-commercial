{
  "templateMetadata": {
    "templateName": "At-Risk Accounts - Health Score Monitoring",
    "templateVersion": "1.1",
    "description": "Identify at-risk customer accounts based on health score, activity, and engagement metrics",
    "audience": "Customer Success Managers, Customer Success Directors",
    "useCase": "Proactive churn prevention, prioritize outreach, track customer health trends",
    "customizationPoints": [
      "Health_Score__c field name",
      "Risk threshold values",
      "Date range filters"
    ],
    "prerequisites": [
      "Account.Health_Score__c field",
      "Account.Type = Customer filter",
      "Last activity tracking"
    ]
  },
  "reportMetadata": {
    "name": "At-Risk Accounts - {Period}",
    "reportType": "AccountList",
    "reportFormat": "SUMMARY",
    "reportFilters": [
      {
        "column": "TYPE",
        "operator": "equals",
        "value": "Customer"
      },
      {
        "column": "Account.Health_Score__c",
        "operator": "equals",
        "value": "Red,Yellow"
      }
    ],
    "groupingsDown": [
      {
        "field": "Account.Health_Score__c",
        "sortOrder": "Desc"
      }
    ],
    "detailColumns": [
      "ACCOUNT_NAME",
      "Account.CSM_Owner__c",
      "LAST_ACTIVITY",
      "Account.Next_Renewal_Date__c",
      "Account.Open_Cases__c"
    ],
    "aggregates": [
      {
        "name": "RowCount",
        "aggregateType": "Sum"
      }
    ],
    "chart": {
      "chartType": "Donut",
      "groupingColumn": "Health_Score__c"
    }
  },
  "calculatedFieldsRequired": [
    {
      "fieldName": "Health_Score__c",
      "fieldType": "Formula (Text)",
      "formula": "IF(Days_Since_Last_Touch__c > 90, 'Red', IF(Open_Critical_Cases__c > 0, 'Red', IF(NPS_Score__c < 6, 'Yellow', 'Green')))"
    }
  ],
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "enterprise",
      "high-touch"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified report with essential columns only",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full report with all standard columns"
      },
      "enterprise": {
        "description": "Enterprise focus with ARR-weighted metrics",
        "filterOverrides": [
          {
            "column": "Account.ARR__c",
            "operator": "greaterOrEqual",
            "value": "100000"
          }
        ]
      },
      "high-touch": {
        "description": "High-touch CS model with engagement metrics",
        "additionalColumns": [
          "Last_Touch_Date__c",
          "Engagement_Score__c"
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "HealthScore": {
        "patterns": [
          "Health_Score__c",
          "Customer_Health__c",
          "Account_Health__c",
          "Risk_Level__c"
        ],
        "dataType": "picklist"
      },
      "ARR": {
        "patterns": [
          "ARR__c",
          "Annual_Recurring_Revenue__c",
          "MRR__c"
        ],
        "cpqPatterns": [
          "SBQQ__RenewedAmount__c"
        ],
        "dataType": "currency"
      },
      "NPS": {
        "patterns": [
          "NPS_Score__c",
          "NPS__c",
          "Net_Promoter_Score__c"
        ],
        "dataType": "number"
      }
    }
  }
}
