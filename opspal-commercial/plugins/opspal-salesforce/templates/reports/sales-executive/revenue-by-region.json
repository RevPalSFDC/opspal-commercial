{
  "templateMetadata": {
    "templateName": "Revenue by Region",
    "templateVersion": "1.1",
    "description": "Closed won revenue broken down by geographic region for territory analysis",
    "audience": "CRO, VP Sales, Regional Directors",
    "useCase": "Regional performance comparison, territory planning, resource allocation",
    "customizationPoints": [
      "Date range",
      "Region field (Billing State, Territory, custom)",
      "Include pipeline for comparison"
    ],
    "prerequisites": [
      "Opportunity object with Amount",
      "Region/Territory field on Account or Opportunity"
    ]
  },
  "metricDefinitionId": "bookings.tcv",
  "reportMetadata": {
    "name": "Revenue by Region",
    "description": "Closed won revenue grouped by region",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "organization",
    "showDetails": false,
    "reportFilters": [
      {
        "column": "IS_WON",
        "operator": "equals",
        "value": "true",
        "customizable": false
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_QUARTER",
        "customizable": true
      }
    ],
    "groupingsDown": [
      {
        "field": "Account.Region__c",
        "sortOrder": "Asc",
        "dateGranularity": null,
        "customizable": true,
        "customizationNote": "Use Territory, BillingState, or custom region field"
      }
    ],
    "groupingsAcross": [],
    "detailColumns": [],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Total revenue per region"
      },
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "description": "Deal count per region"
      }
    ],
    "chart": {
      "chartType": "Pie",
      "groupingColumn": "Region__c",
      "aggregateColumn": "AMOUNT:SUM",
      "showChartValues": true,
      "showPercentages": true
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "revenue-performance"
    ],
    "componentType": "Pie Chart",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Executive summary report",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full executive report"
      },
      "cpq": {
        "description": "CPQ-enabled executive metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c",
          "Quote.TotalPrice": "SBQQ__Quote__c.SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise executive focus with higher thresholds",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "250000"
          }
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Revenue": {
        "patterns": [
          "Amount",
          "Revenue__c",
          "Total_Revenue__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "WinRate": {
        "patterns": [
          "Win_Rate__c",
          "Conversion_Rate__c"
        ],
        "dataType": "percent"
      }
    }
  }
}
