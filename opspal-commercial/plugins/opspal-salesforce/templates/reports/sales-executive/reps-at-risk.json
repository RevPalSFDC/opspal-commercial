{
  "templateMetadata": {
    "templateName": "Reps at Risk (<70% Attainment)",
    "templateVersion": "1.1",
    "description": "Identifies sales reps below 70% quota attainment requiring intervention",
    "audience": "CRO, VP Sales, Sales Directors",
    "useCase": "Performance management, coaching prioritization, resource allocation",
    "customizationPoints": [
      "Threshold percentage (default 70%)",
      "Date range",
      "Include pipeline coverage"
    ],
    "prerequisites": [
      "Opportunity object with Amount and Owner",
      "Quota data available per rep"
    ]
  },
  "metricDefinitionId": "quota_attainment",
  "reportMetadata": {
    "name": "Reps at Risk (<70% Attainment)",
    "description": "Sales reps below quota threshold",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "organization",
    "showDetails": false,
    "reportFilters": [
      {
        "column": "IS_WON",
        "operator": "equals",
        "value": "true",
        "customizable": false
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_QUARTER",
        "customizable": true
      }
    ],
    "groupingsDown": [
      {
        "field": "OPPORTUNITY_OWNER",
        "sortOrder": "Asc",
        "dateGranularity": null
      }
    ],
    "groupingsAcross": [],
    "detailColumns": [],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Closed won per rep"
      }
    ],
    "customSummaryFormulas": [
      {
        "name": "Attainment_Percent",
        "description": "Revenue / Quota * 100",
        "formula": "(SUM(AMOUNT) / Owner.Quota__c) * 100",
        "dataType": "percent",
        "decimalPlaces": 1
      }
    ],
    "postFilter": {
      "field": "Attainment_Percent",
      "operator": "lessThan",
      "value": 70
    },
    "chart": {
      "chartType": "HorizontalBar",
      "groupingColumn": "OPPORTUNITY_OWNER",
      "aggregateColumn": "Attainment_Percent",
      "chartColors": {
        "default": "#e74c3c"
      }
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "team-productivity"
    ],
    "componentType": "Metric",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Executive summary report",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full executive report"
      },
      "cpq": {
        "description": "CPQ-enabled executive metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c",
          "Quote.TotalPrice": "SBQQ__Quote__c.SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise executive focus with higher thresholds",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "250000"
          }
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Revenue": {
        "patterns": [
          "Amount",
          "Revenue__c",
          "Total_Revenue__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "WinRate": {
        "patterns": [
          "Win_Rate__c",
          "Conversion_Rate__c"
        ],
        "dataType": "percent"
      }
    }
  }
}
