  "deploymentGuide": {
    "prerequisites": [
      "Salesforce org with Reports & Dashboards enabled",
      "Appropriate report types (Opportunities, Leads, Cases, Accounts)",
      "Custom fields as specified in template prerequisites"
    ],
    "steps": [
      "1. Select template from registry based on persona/function",
      "2. Review template prerequisites and verify org compatibility",
      "3. Deploy source report templates first",
      "4. Deploy dashboard using sfdc-reports-dashboards agent",
      "5. Configure filters and set refresh schedule",
      "6. Assign to appropriate folder and share with users"
    ],
    "agentCommand": "Task(subagent_type='opspal-salesforce:sfdc-reports-dashboards', prompt='Deploy {templateId} dashboard from registry')"
