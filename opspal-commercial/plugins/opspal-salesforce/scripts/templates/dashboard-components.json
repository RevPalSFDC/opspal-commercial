{
  "componentTemplates": {
    "metric": {
      "description": "Standard metric component with indicator colors",
      "template": {
        "componentType": "Metric",
        "autoselectColumnsFromReport": true,
        "displayUnits": "Auto",
        "indicatorHighColor": "#00716B",
        "indicatorLowColor": "#C23934",
        "indicatorMiddleColor": "#FFB75D",
        "indicatorBreakpoint1": 33,
        "indicatorBreakpoint2": 67,
        "showRange": false,
        "showTotal": true
      },
      "requiredFields": ["report", "header"],
      "optionalFields": ["metricLabel", "footer"]
    },
    
    "chart": {
      "description": "Standard chart component",
      "template": {
        "componentType": "Chart",
        "autoselectColumnsFromReport": true,
        "chartType": "VerticalColumn",
        "displayUnits": "Auto",
        "enableHover": true,
        "expandOthers": true,
        "legendPosition": "Bottom",
        "showChartValues": false,
        "showPercentage": false,
        "showTotal": false,
        "showValues": false,
        "sortBy": "Default",
        "useReportChart": false
      },
      "requiredFields": ["report", "header"],
      "chartTypeOptions": [
        "VerticalColumn", "VerticalColumnGrouped", "VerticalColumnStacked",
        "HorizontalBar", "HorizontalBarGrouped", "HorizontalBarStacked",
        "Line", "LineGrouped", "Pie", "Donut", "Funnel"
      ]
    },
    
    "table": {
      "description": "Standard table component",
      "template": {
        "componentType": "Table",
        "autoselectColumnsFromReport": true,
        "drillEnabled": true,
        "drillToDetailEnabled": false,
        "indicatorHighColor": "#00716B",
        "indicatorLowColor": "#C23934",
        "indicatorMiddleColor": "#FFB75D",
        "maxValuesDisplayed": 200,
        "showPicturesOnTables": true,
        "showRowNumbers": false,
        "showTotal": true
      },
      "requiredFields": ["report", "header"],
      "optionalFields": ["footer", "title"]
    },
    
    "flexTable": {
      "description": "Flexible table component for advanced layouts",
      "template": {
        "componentType": "FlexTable",
        "autoselectColumnsFromReport": false,
        "flexComponentProperties": {
          "decimalPrecision": 0,
          "hideChatterPhotos": false,
          "hideZeroColumns": false,
          "showChartValues": false,
          "showTotal": true
        }
      },
      "requiredFields": ["report", "header", "flexComponentProperties"],
      "warnings": ["Do not use displayUnits with FlexTable"]
    },
    
    "gauge": {
      "description": "Gauge component for KPI visualization",
      "template": {
        "componentType": "Gauge",
        "autoselectColumnsFromReport": true,
        "displayUnits": "Auto",
        "gaugeMax": 100,
        "gaugeMin": 0,
        "indicatorBreakpoint1": 33,
        "indicatorBreakpoint2": 67,
        "indicatorHighColor": "#00716B",
        "indicatorLowColor": "#C23934",
        "indicatorMiddleColor": "#FFB75D",
        "showPercentage": true,
        "showRange": true,
        "showTotal": true
      },
      "requiredFields": ["report", "header"],
      "optionalFields": ["gaugeMin", "gaugeMax"]
    }
  },
  
  "layoutTemplates": {
    "standardGrid": {
      "description": "Standard 12-column grid layout",
      "numberOfColumns": 12,
      "rowHeight": "Medium"
    },
    
    "compactGrid": {
      "description": "Compact grid for mobile-friendly dashboards",
      "numberOfColumns": 9,
      "rowHeight": "Small"
    },
    
    "wideGrid": {
      "description": "Wide grid for large displays",
      "numberOfColumns": 15,
      "rowHeight": "Large"
    }
  },
  
  "colorPalettes": {
    "standard": ["unity", "light", "accessible"],
    "seasonal": ["spring", "summer", "fall", "winter"],
    "thematic": ["ocean", "fire", "earth", "water", "mineral"],
    "modern": ["skyline", "sunset", "tropic", "dusk"],
    "deprecated": ["wildflowers"],
    "default": "unity"
  },
  
  "dashboardSettings": {
    "standard": {
      "backgroundEndColor": "#FFFFFF",
      "backgroundFadeDirection": "Diagonal",
      "backgroundStartColor": "#FFFFFF",
      "chartTheme": "light",
      "colorPalette": "unity",
      "dashboardChartTheme": "light",
      "dashboardColorPalette": "unity",
      "dashboardType": "SpecifiedUser",
      "isGridLayout": true,
      "runningUser": "viewer@salesforce.com",
      "textColor": "#000000",
      "title": "Dashboard Title",
      "titleColor": "#000000",
      "titleSize": 12
    }
  },
  
  "gridPositioning": {
    "headerRow": {
      "description": "KPI metrics in header row",
      "positions": [
        {"colSpan": 3, "columnIndex": 0, "rowIndex": 0, "rowSpan": 4},
        {"colSpan": 3, "columnIndex": 3, "rowIndex": 0, "rowSpan": 4},
        {"colSpan": 3, "columnIndex": 6, "rowIndex": 0, "rowSpan": 4},
        {"colSpan": 3, "columnIndex": 9, "rowIndex": 0, "rowSpan": 4}
      ]
    },
    
    "mainContent": {
      "description": "Main content area below header",
      "positions": [
        {"colSpan": 6, "columnIndex": 0, "rowIndex": 4, "rowSpan": 8},
        {"colSpan": 6, "columnIndex": 6, "rowIndex": 4, "rowSpan": 8}
      ]
    },
    
    "fullWidth": {
      "description": "Full width component",
      "positions": [
        {"colSpan": 12, "columnIndex": 0, "rowIndex": 0, "rowSpan": 8}
      ]
    }
  },
  
  "reportRequirements": {
    "dashboardCompatible": {
      "formats": ["Summary", "Matrix"],
      "requirements": [
        "Must have at least one grouping for charts",
        "Cannot use tabular format for most components",
        "Should have aggregated metrics for gauge/metric components"
      ]
    },
    
    "componentMapping": {
      "Metric": ["Summary", "Matrix"],
      "Chart": ["Summary", "Matrix"],
      "Table": ["Tabular", "Summary", "Matrix"],
      "FlexTable": ["Summary", "Matrix"],
      "Gauge": ["Summary", "Matrix"]
    }
  },
  
  "apiVersionCompatibility": {
    "60.0": {
      "supportedComponents": ["Bar", "Column", "Line", "Pie", "Table", "Metric"],
      "unsupportedFeatures": ["FlexTable.displayUnits"]
    },
    "64.0": {
      "supportedComponents": ["all"],
      "newFeatures": ["FlexTable", "enhanced color palettes"]
    }
  },
  
  "validationRules": {
    "metric": {
      "required": ["indicatorHighColor", "indicatorLowColor", "indicatorMiddleColor"],
      "forbidden": []
    },
    "flexTable": {
      "required": ["flexComponentProperties"],
      "forbidden": ["displayUnits"]
    },
    "chart": {
      "required": ["chartType"],
      "validChartTypes": ["VerticalColumn", "HorizontalBar", "Line", "Pie", "Donut", "Funnel"]
    }
  },
  
  "commonErrors": {
    "colorPalette": {
      "error": "Invalid color palette",
      "fix": "Use 'unity' or another valid palette from colorPalettes.standard"
    },
    "chartType": {
      "error": "'Column' is not valid",
      "fix": "Use 'VerticalColumn' instead"
    },
    "reportFormat": {
      "error": "Tabular report cannot be used",
      "fix": "Convert report to Summary or Matrix format with groupings"
    },
    "flexTableDisplayUnits": {
      "error": "FlexTable cannot use displayUnits",
      "fix": "Remove displayUnits from FlexTable components"
    },
    "missingIndicatorColors": {
      "error": "Metric missing indicator colors",
      "fix": "Add indicatorHighColor, indicatorLowColor, and indicatorMiddleColor"
    }
  }
}