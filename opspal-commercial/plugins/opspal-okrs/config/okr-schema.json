{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OKR Cycle Schema",
  "description": "Data model for a complete OKR cycle including objectives, key results, and initiatives",
  "type": "object",
  "required": ["id", "period", "stance", "status", "company_context", "objectives"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^OKR-\\d{4}-Q[1-4](-H[12])?$",
      "description": "Cycle identifier, e.g. OKR-2026-Q3 or OKR-2026-H2"
    },
    "period": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" },
        "cadence": {
          "type": "string",
          "enum": ["quarterly", "half-yearly", "annual"]
        }
      }
    },
    "stance": {
      "type": "string",
      "enum": ["aggressive", "base", "conservative"],
      "description": "Target-setting posture for this OKR set"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "scoring", "approved", "active", "closed"],
      "description": "Lifecycle state of the OKR cycle"
    },
    "company_context": {
      "type": "object",
      "required": ["arr_at_start", "stage", "gtm_model"],
      "properties": {
        "arr_at_start": {
          "type": "number",
          "description": "Annual recurring revenue at cycle start"
        },
        "nrr_at_start": {
          "type": ["number", "null"],
          "description": "Net revenue retention rate at cycle start (decimal, e.g. 1.15)"
        },
        "grr_at_start": {
          "type": ["number", "null"],
          "description": "Gross revenue retention rate at cycle start (decimal, e.g. 0.92)"
        },
        "pipeline_health_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100,
          "description": "Pipeline health score (0-100) from pipeline-intelligence-agent"
        },
        "pipeline_coverage_ratio": {
          "type": ["number", "null"],
          "description": "Pipeline / quota ratio"
        },
        "plg_pql_count": {
          "type": ["integer", "null"],
          "description": "Current PQL count from product analytics"
        },
        "stage": {
          "type": "string",
          "enum": ["seed", "series-a", "series-b", "series-c", "growth", "scale"],
          "description": "Company funding stage"
        },
        "gtm_model": {
          "type": "string",
          "enum": ["plg", "slg", "hybrid", "channel"],
          "description": "Primary go-to-market motion"
        },
        "headcount": {
          "type": ["integer", "null"],
          "description": "Total company headcount"
        },
        "acv_tier": {
          "type": ["string", "null"],
          "enum": ["sub-10k", "10k-50k", "50k-100k", "100k-250k", "250k-plus", null],
          "description": "Average contract value tier"
        }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "$ref": "#/definitions/Objective"
      }
    },
    "snapshot_id": {
      "type": ["string", "null"],
      "description": "Reference to the revenue snapshot used to generate these OKRs"
    },
    "board_summary": {
      "type": ["string", "null"],
      "description": "BLUF-ready board summary for the current OKR cycle"
    },
    "asana_project_gid": {
      "type": ["string", "null"],
      "description": "Asana project identifier used for OKR tracking sync"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "approved_by": { "type": ["string", "null"] },
    "approved_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "definitions": {
    "Objective": {
      "type": "object",
      "required": ["id", "title", "owner", "strategic_theme", "key_results"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^OBJ-\\d{3}$",
          "description": "Objective identifier, e.g. OBJ-001"
        },
        "title": {
          "type": "string",
          "minLength": 10,
          "maxLength": 200,
          "description": "Outcome-oriented objective statement"
        },
        "owner": {
          "type": "string",
          "enum": ["sales", "marketing", "cs", "product", "revops", "executive"],
          "description": "Functional owner of this objective"
        },
        "rationale": {
          "type": "string",
          "description": "Data-driven rationale for why this objective matters now"
        },
        "strategic_theme": {
          "type": "string",
          "enum": ["growth", "retention", "efficiency", "expansion", "plg", "enablement"],
          "description": "Strategic pillar this objective supports"
        },
        "key_results": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": {
            "$ref": "#/definitions/KeyResult"
          }
        },
        "initiatives": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Initiative"
          }
        }
      }
    },
    "KeyResult": {
      "type": "object",
      "required": ["id", "description", "metric_id", "baseline", "target"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^KR-\\d{3}-\\d{2}$",
          "description": "Key result identifier, e.g. KR-001-01"
        },
        "description": {
          "type": "string",
          "description": "Measurable outcome statement"
        },
        "metric_id": {
          "type": "string",
          "description": "Reference to canonical metric in revops-kpi-definitions.json"
        },
        "baseline": {
          "type": "object",
          "required": ["value", "measured_at", "source"],
          "properties": {
            "value": {
              "type": "number",
              "description": "Current/starting metric value"
            },
            "measured_at": {
              "type": "string",
              "format": "date-time",
              "description": "When the baseline was measured"
            },
            "source": {
              "type": "string",
              "enum": ["salesforce", "hubspot", "gong", "product_analytics", "manual", "derived"],
              "description": "Where the baseline data came from"
            },
            "query_evidence": {
              "type": ["string", "null"],
              "description": "SOQL/API query used to derive baseline value"
            }
          }
        },
        "target": {
          "type": "number",
          "description": "Target value for base stance"
        },
        "target_aggressive": {
          "type": ["number", "null"],
          "description": "Target for aggressive stance"
        },
        "target_conservative": {
          "type": ["number", "null"],
          "description": "Target for conservative stance"
        },
        "confidence_band": {
          "$ref": "#/definitions/ConfidenceBand"
        },
        "current": {
          "type": ["number", "null"],
          "description": "Current value (updated during tracking)"
        },
        "health": {
          "type": ["string", "null"],
          "enum": ["on_track", "at_risk", "off_track", null],
          "description": "KR health status based on progress vs expected trajectory"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Relative weight within the objective (all KR weights in an objective sum to 1)"
        },
        "unit": {
          "type": ["string", "null"],
          "description": "Unit of measurement (%, $, count, ratio, days)"
        }
      }
    },
    "Initiative": {
      "type": "object",
      "required": ["id", "title", "owner"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^INIT-\\d{3}$",
          "description": "Initiative identifier, e.g. INIT-001"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "estimated_effort": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "estimated_impact": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "priority_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100,
          "description": "Composite score from 5-dimension scoring (0-100)"
        },
        "funnel_leverage_estimate": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Normalized 0-5 leverage score from funnel analysis showing how strongly the initiative compounds downstream revenue impact"
        },
        "scoring_breakdown": {
          "$ref": "#/definitions/InitiativeScore"
        },
        "asana_task_id": {
          "type": ["string", "null"]
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "approved", "in_progress", "completed", "abandoned"]
        },
        "outcome": {
          "type": ["string", "null"],
          "enum": ["hit", "miss", "partial", null]
        }
      }
    },
    "InitiativeScore": {
      "type": "object",
      "properties": {
        "revenue_impact": {
          "type": "number", "minimum": 0, "maximum": 20,
          "description": "Estimated ARR contribution, weighted by time-to-impact"
        },
        "effort_cost": {
          "type": "number", "minimum": 0, "maximum": 20,
          "description": "Inverted: lower effort = higher score"
        },
        "strategic_alignment": {
          "type": "number", "minimum": 0, "maximum": 20,
          "description": "Match to active objectives, board priorities, PLG/SLG fit"
        },
        "timing_sensitivity": {
          "type": "number", "minimum": 0, "maximum": 20,
          "description": "Market window, competitive signals, seasonality"
        },
        "confidence_data_quality": {
          "type": "number", "minimum": 0, "maximum": 20,
          "description": "Live baseline evidence, historical analog, benchmark coverage"
        },
        "total": {
          "type": "number", "minimum": 0, "maximum": 100
        }
      }
    },
    "ConfidenceBand": {
      "type": "object",
      "required": ["p10", "p50", "p90"],
      "properties": {
        "p10": {
          "type": "number",
          "description": "10th percentile outcome"
        },
        "p50": {
          "type": "number",
          "description": "Median expected outcome"
        },
        "p90": {
          "type": "number",
          "description": "90th percentile outcome"
        }
      }
    }
  }
}
