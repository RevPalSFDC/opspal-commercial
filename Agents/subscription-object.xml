        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Contract__c</fullName>
        <label>Contract</label>
        <referenceTo>Contract</referenceTo>
        <relationshipName>Subscriptions</relationshipName>
        <relationshipType>Lookup</relationshipType>
        <required>true</required>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Product__c</fullName>
        <label>Product</label>
        <referenceTo>Product2</referenceTo>
        <relationshipName>Subscriptions</relationshipName>
        <relationshipType>Lookup</relationshipType>
        <required>true</required>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Opportunity__c</fullName>
        <label>Opportunity</label>
        <referenceTo>Opportunity</referenceTo>
        <relationshipName>Subscriptions</relationshipName>
        <relationshipType>Lookup</relationshipType>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Quote__c</fullName>
        <label>Quote</label>
        <referenceTo>Quote</referenceTo>
        <relationshipName>Subscriptions</relationshipName>
        <relationshipType>Lookup</relationshipType>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>AmendedFromSubscription__c</fullName>
        <label>Amended From Subscription</label>
        <referenceTo>Subscription__c</referenceTo>
        <relationshipName>AmendedSubscriptions</relationshipName>
        <relationshipType>Lookup</relationshipType>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>StartDate__c</fullName>
        <label>Start Date</label>
        <type>Date</type>
        <required>true</required>
    </fields>
    <fields>
        <fullName>EndDate__c</fullName>
        <label>End Date</label>
        <type>Date</type>
        <required>true</required>
    </fields>
    <fields>
        <fullName>TermMonths__c</fullName>
        <label>Term (Months)</label>
        <precision>3</precision>
        <scale>0</scale>
        <type>Number</type>
    </fields>
    <fields>
        <fullName>CotermEndDate__c</fullName>
        <label>Co-term End Date</label>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Quantity__c</fullName>
        <label>Quantity</label>
        <precision>10</precision>
        <scale>2</scale>
        <type>Number</type>
        <required>true</required>
        <defaultValue>1</defaultValue>
    </fields>
    <fields>
        <fullName>UnitPrice__c</fullName>
        <label>Unit Price</label>
        <precision>16</precision>
        <scale>2</scale>
        <type>Currency</type>
        <required>true</required>
    </fields>
    <fields>
        <fullName>ProrateMultiplier__c</fullName>
        <label>Prorate Multiplier</label>
        <precision>5</precision>
        <scale>3</scale>
        <type>Number</type>
        <defaultValue>1.000</defaultValue>
    </fields>
    <fields>
        <fullName>NetPrice__c</fullName>
        <label>Net Price</label>
        <formula>UnitPrice__c * Quantity__c * ProrateMultiplier__c</formula>
        <precision>18</precision>
        <scale>2</scale>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>ARR__c</fullName>
        <label>Annual Recurring Revenue</label>
        <formula>IF(TermMonths__c > 0, UnitPrice__c * Quantity__c * (12 / TermMonths__c), 0)</formula>
        <precision>18</precision>
        <scale>2</scale>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>MRR__c</fullName>
        <label>Monthly Recurring Revenue</label>
        <formula>ARR__c / 12</formula>
        <precision>18</precision>
        <scale>2</scale>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>SubscriptionType__c</fullName>
        <label>Subscription Type</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <value>
                    <fullName>Renewable</fullName>
                    <default>true</default>
                </value>
                <value>
                    <fullName>Evergreen</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>One-Time</fullName>
                    <default>false</default>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PricingModel__c</fullName>
        <label>Pricing Model</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <value>
                    <fullName>Fixed Price</fullName>
                    <default>true</default>
                </value>
                <value>
                    <fullName>Percent of Total</fullName>
                    <default>false</default>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Status__c</fullName>
        <label>Status</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <value>
                    <fullName>Active</fullName>
                    <default>true</default>
                </value>
                <value>
                    <fullName>Pending Activation</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Canceled</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Expired</fullName>
                    <default>false</default>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>BillingFrequency__c</fullName>
        <label>Billing Frequency</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <value>
                    <fullName>Monthly</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Quarterly</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Annually</fullName>
                    <default>true</default>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>RenewalUpliftPct__c</fullName>
        <label>Renewal Uplift %</label>
        <precision>5</precision>
        <scale>2</scale>
        <type>Percent</type>
        <defaultValue>0</defaultValue>
    </fields>
    <fields>
        <fullName>RenewalTerm__c</fullName>
        <label>Renewal Term (Months)</label>
        <precision>3</precision>
        <scale>0</scale>
        <type>Number</type>
        <defaultValue>12</defaultValue>
    </fields>
    <fields>
        <fullName>OriginalQuoteLineId__c</fullName>
        <label>Original Quote Line ID</label>
        <length>18</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>IsNetNew__c</fullName>
        <label>Is Net New</label>
        <defaultValue>false</defaultValue>
        <type>Checkbox</type>
    </fields>
</CustomObject>