{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://revpal.dev/schemas/opspal-next-best-action.schema.json",
  "title": "OpsPal Next-Best Action Report",
  "type": "object",
  "required": [
    "generated_at",
    "source_fingerprint",
    "source_file",
    "actions"
  ],
  "properties": {
    "generated_at": {
      "type": "string"
    },
    "source_fingerprint": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "source_opportunity_id",
          "title",
          "category",
          "source_plugin",
          "target_object",
          "owner_team",
          "risk_class",
          "confidence",
          "rank_score",
          "impact_score",
          "risk_reduction_score",
          "time_to_value_score",
          "effort_score",
          "approval_required",
          "action_summary",
          "expected_impact",
          "rollback_plan",
          "artifacts",
          "submission_status"
        ],
        "properties": {
          "action_id": {
            "type": "string"
          },
          "source_opportunity_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "enum": [
              "ai_leverage",
              "feature_gap"
            ]
          },
          "source_plugin": {
            "type": "string"
          },
          "source_agent": {
            "type": [
              "string",
              "null"
            ]
          },
          "target_object": {
            "type": "string"
          },
          "owner_team": {
            "type": "string"
          },
          "risk_class": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rank_score": {
            "type": "number"
          },
          "impact_score": {
            "type": "number"
          },
          "risk_reduction_score": {
            "type": "number"
          },
          "time_to_value_score": {
            "type": "number"
          },
          "effort_score": {
            "type": "number"
          },
          "approval_required": {
            "type": "boolean"
          },
          "action_summary": {
            "type": "string"
          },
          "expected_impact": {
            "type": "object",
            "required": [
              "impact_index",
              "narrative",
              "evidence"
            ],
            "properties": {
              "impact_index": {
                "type": "number"
              },
              "narrative": {
                "type": "string"
              },
              "evidence": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "rollback_plan": {
            "type": "string"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "approval_payload_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "submission_status": {
            "enum": [
              "not_submitted",
              "submitted",
              "submit_failed"
            ]
          },
          "submission_error": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
