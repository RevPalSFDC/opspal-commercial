# Slack Integration Configuration
# ================================

# Slack Webhook URL for sending release notifications
# To get this: 
# 1. Run ./scripts/setup-slack-webhook.sh
# 2. Follow the prompts to create an incoming webhook
# 3. Copy the webhook URL and add it as a GitHub secret
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Override default channel (defaults to webhook's configured channel)
# SLACK_CHANNEL=#releases

# Slack App Information (for reference)
# These are specific to your Slack workspace
SLACK_APP_ID=A08FC8K02AJ
SLACK_CLIENT_ID=4172559150165.8522291002358
SLACK_CHANNEL_ID=C09D86TQVU5

# GitHub Configuration (auto-populated in Actions)
# GITHUB_TOKEN is automatically available in GitHub Actions
# GITHUB_ACTOR is automatically available in GitHub Actions

# Project Configuration (optional overrides)
# PROJECT_NAME=RevPal Agents
# REPO_URL=https://github.com/RevPal/Agents