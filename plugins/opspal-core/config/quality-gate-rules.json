{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Quality Gate Rules",
  "description": "Validation rules for task deliverables to ensure completeness and quality",
  "version": "1.0.0",
  "created": "2025-10-24",

  "report_generation": {
    "description": "Validate report completeness and quality",
    "checks": [
      {
        "name": "file_exists",
        "description": "Report file must exist",
        "severity": "CRITICAL",
        "validator": "fileExists"
      },
      {
        "name": "minimum_sections",
        "description": "Report must have required sections",
        "severity": "HIGH",
        "validator": "hasRequiredSections",
        "params": {
          "requiredSections": ["Summary", "Findings", "Recommendations"]
        }
      },
      {
        "name": "data_completeness",
        "description": "Report must contain actual data, not placeholders",
        "severity": "HIGH",
        "validator": "noPlaceholders"
      },
      {
        "name": "minimum_content_length",
        "description": "Report must have substantial content",
        "severity": "MEDIUM",
        "validator": "minimumLength",
        "params": {
          "minimumWords": 100
        }
      }
    ]
  },

  "deployment": {
    "description": "Validate deployment success and verification",
    "checks": [
      {
        "name": "deployment_status",
        "description": "Deployment must have succeeded",
        "severity": "CRITICAL",
        "validator": "deploymentSucceeded"
      },
      {
        "name": "post_deployment_verification",
        "description": "Changes must be verified in target environment",
        "severity": "HIGH",
        "validator": "changesVerified"
      },
      {
        "name": "test_execution",
        "description": "Tests must have run and passed (production only)",
        "severity": "HIGH",
        "validator": "testsExecuted"
      },
      {
        "name": "rollback_plan_documented",
        "description": "Rollback plan must be documented for production",
        "severity": "MEDIUM",
        "validator": "rollbackPlanExists"
      }
    ]
  },

  "data_operation": {
    "description": "Validate data operations completed successfully",
    "checks": [
      {
        "name": "operation_completion",
        "description": "Data operation must have completed",
        "severity": "CRITICAL",
        "validator": "operationCompleted"
      },
      {
        "name": "record_count_verification",
        "description": "Actual record count matches expected",
        "severity": "HIGH",
        "validator": "recordCountMatches"
      },
      {
        "name": "error_handling",
        "description": "Errors must be documented and handled",
        "severity": "MEDIUM",
        "validator": "errorsHandled"
      },
      {
        "name": "data_verification_sample",
        "description": "Sample records verified in system",
        "severity": "HIGH",
        "validator": "sampleRecordsVerified"
      }
    ]
  },

  "configuration": {
    "description": "Validate configuration changes",
    "checks": [
      {
        "name": "config_applied",
        "description": "Configuration changes must be applied",
        "severity": "CRITICAL",
        "validator": "configurationApplied"
      },
      {
        "name": "config_verification",
        "description": "Configuration must be verified in system",
        "severity": "HIGH",
        "validator": "configurationVerified"
      },
      {
        "name": "backup_created",
        "description": "Configuration backup created before changes",
        "severity": "MEDIUM",
        "validator": "backupExists"
      }
    ]
  },

  "flow_development": {
    "description": "Validate Flow development and deployment",
    "checks": [
      {
        "name": "flow_deployed",
        "description": "Flow must be deployed successfully",
        "severity": "CRITICAL",
        "validator": "deploymentSucceeded"
      },
      {
        "name": "flow_activated",
        "description": "Flow must be activated (if applicable)",
        "severity": "HIGH",
        "validator": "flowActivated"
      },
      {
        "name": "field_references_verified",
        "description": "All field references must exist in org",
        "severity": "CRITICAL",
        "validator": "fieldReferencesValid"
      },
      {
        "name": "smoke_test_passed",
        "description": "Flow smoke test must pass",
        "severity": "HIGH",
        "validator": "smokeTestPassed"
      }
    ]
  },

  "metadata_change": {
    "description": "Validate metadata changes",
    "checks": [
      {
        "name": "metadata_deployed",
        "description": "Metadata must be deployed successfully",
        "severity": "CRITICAL",
        "validator": "deploymentSucceeded"
      },
      {
        "name": "metadata_verified",
        "description": "Metadata changes verified in org",
        "severity": "HIGH",
        "validator": "changesVerified"
      },
      {
        "name": "dependencies_resolved",
        "description": "All metadata dependencies satisfied",
        "severity": "HIGH",
        "validator": "dependenciesResolved"
      }
    ]
  },

  "api_integration": {
    "description": "Validate API integration tasks",
    "checks": [
      {
        "name": "api_connection_tested",
        "description": "API connection must be tested",
        "severity": "CRITICAL",
        "validator": "apiConnectionVerified"
      },
      {
        "name": "authentication_validated",
        "description": "API authentication must be validated",
        "severity": "CRITICAL",
        "validator": "authenticationVerified"
      },
      {
        "name": "sample_request_successful",
        "description": "Sample API request must succeed",
        "severity": "HIGH",
        "validator": "sampleRequestSucceeded"
      },
      {
        "name": "error_handling_tested",
        "description": "Error handling must be tested",
        "severity": "MEDIUM",
        "validator": "errorHandlingTested"
      }
    ]
  },

  "analysis_task": {
    "description": "Validate analysis and assessment tasks",
    "checks": [
      {
        "name": "data_collected",
        "description": "Required data must be collected",
        "severity": "CRITICAL",
        "validator": "dataCollected"
      },
      {
        "name": "analysis_documented",
        "description": "Analysis findings must be documented",
        "severity": "HIGH",
        "validator": "analysisDocumented"
      },
      {
        "name": "recommendations_provided",
        "description": "Actionable recommendations must be provided",
        "severity": "HIGH",
        "validator": "recommendationsProvided"
      }
    ]
  },

  "bulk_operation": {
    "description": "Validate bulk data operations",
    "checks": [
      {
        "name": "operation_completed",
        "description": "Bulk operation must complete",
        "severity": "CRITICAL",
        "validator": "operationCompleted"
      },
      {
        "name": "success_rate_acceptable",
        "description": "Success rate must be above threshold",
        "severity": "CRITICAL",
        "validator": "successRateAcceptable",
        "params": {
          "minimumSuccessRate": 0.95
        }
      },
      {
        "name": "errors_analyzed",
        "description": "All errors must be analyzed and documented",
        "severity": "HIGH",
        "validator": "errorsAnalyzed"
      },
      {
        "name": "rollback_available",
        "description": "Rollback mechanism must be available",
        "severity": "HIGH",
        "validator": "rollbackAvailable"
      }
    ]
  },

  "security_change": {
    "description": "Validate security-related changes",
    "checks": [
      {
        "name": "change_applied",
        "description": "Security change must be applied",
        "severity": "CRITICAL",
        "validator": "configurationApplied"
      },
      {
        "name": "access_verified",
        "description": "Access levels must be verified",
        "severity": "CRITICAL",
        "validator": "accessLevelsVerified"
      },
      {
        "name": "no_unintended_access",
        "description": "No unintended access granted",
        "severity": "CRITICAL",
        "validator": "noUnintendedAccess"
      },
      {
        "name": "audit_trail_present",
        "description": "Change must be logged in audit trail",
        "severity": "HIGH",
        "validator": "auditTrailPresent"
      }
    ]
  }
}
