{
  "description": "Address format configurations for UK and Ireland",
  "version": "1.0.0",
  "GB": {
    "name": "United Kingdom",
    "format": {
      "order": ["street", "street2", "city", "county", "postalCode"],
      "template": "{number} {street}\n{street2}\n{city}\n{county}\n{postalCode}",
      "uppercase": true
    },
    "postalCode": {
      "name": "Postcode",
      "format": "AA## #AA / A## #AA / A# #AA / AA# #AA / AA#A #AA",
      "regex": "^[A-Z]{1,2}\\d[A-Z\\d]?\\s?\\d[A-Z]{2}$",
      "examples": ["SW1A 2AA", "M1 1AE", "B33 8TH", "CR2 6XH", "W1A 0AX"],
      "outwardCode": "First part (area + district)",
      "inwardCode": "Second part (sector + unit)"
    },
    "streetTypes": {
      "Street": "St",
      "Road": "Rd",
      "Avenue": "Ave",
      "Lane": "Ln",
      "Drive": "Dr",
      "Close": "Cl",
      "Court": "Ct",
      "Place": "Pl",
      "Way": "Way",
      "Gardens": "Gdns",
      "Terrace": "Terr",
      "Grove": "Gr",
      "Crescent": "Cres",
      "Hill": "Hill",
      "Rise": "Rise",
      "Walk": "Walk",
      "Mews": "Mews",
      "Square": "Sq",
      "Park": "Pk",
      "Row": "Row",
      "Passage": "Pass",
      "Yard": "Yd",
      "Gate": "Gate",
      "Green": "Grn"
    },
    "directions": {
      "North": "N",
      "South": "S",
      "East": "E",
      "West": "W"
    },
    "units": {
      "Flat": "Flat",
      "Floor": "Fl",
      "Suite": "Suite",
      "Unit": "Unit",
      "Office": "Office",
      "Building": "Bldg",
      "House": "House",
      "Block": "Block"
    },
    "postcodeAreas": {
      "London": ["E", "EC", "N", "NW", "SE", "SW", "W", "WC"],
      "Birmingham": ["B"],
      "Manchester": ["M"],
      "Leeds": ["LS"],
      "Glasgow": ["G"],
      "Edinburgh": ["EH"],
      "Cardiff": ["CF"],
      "Belfast": ["BT"]
    }
  },
  "IE": {
    "name": "Ireland",
    "format": {
      "order": ["street", "street2", "city", "county", "postalCode"],
      "template": "{number} {street}\n{street2}\n{city}\n{county}\n{postalCode}",
      "uppercase": false
    },
    "postalCode": {
      "name": "Eircode",
      "format": "A## A#A#",
      "regex": "^[A-Z]\\d{2}\\s?[A-Z\\d]{4}$",
      "examples": ["D02 AF30", "A65 F4E2"],
      "routingKey": "First 3 characters (area)",
      "uniqueIdentifier": "Last 4 characters"
    },
    "streetTypes": {
      "Street": "St",
      "Road": "Rd",
      "Avenue": "Ave",
      "Lane": "Ln",
      "Drive": "Dr",
      "Close": "Cl",
      "Court": "Ct",
      "Place": "Pl",
      "Way": "Way",
      "Gardens": "Gdns",
      "Terrace": "Terr",
      "Grove": "Gr",
      "Crescent": "Cres",
      "Park": "Pk",
      "Square": "Sq",
      "Green": "Grn",
      "View": "View",
      "Heights": "Hts"
    },
    "units": {
      "Apartment": "Apt",
      "Flat": "Flat",
      "Floor": "Fl",
      "Suite": "Suite",
      "Unit": "Unit",
      "Office": "Office"
    },
    "countyPrefixes": {
      "standard": "Co.",
      "dublin": "Dublin"
    }
  }
}
