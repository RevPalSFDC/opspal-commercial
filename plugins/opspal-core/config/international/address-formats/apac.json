  "JP": {
    "name": "Japan",
    "format": {
      "order": ["postalCode", "prefecture", "city", "ward", "block", "building"],
      "template": "〒{postalCode}\n{prefecture}{city}{ward}\n{block}\n{building}",
      "templateLatin": "{postalCode}\n{building}\n{block}\n{ward}, {city}\n{prefecture}",
      "uppercase": false,
      "addressOrder": "large-to-small"
    },
    "postalCode": {
      "name": "郵便番号",
      "format": "###-####",
      "regex": "^\\d{3}-?\\d{4}$",
      "examples": ["100-0001", "150-0041"]
    },
    "addressComponents": {
      "prefecture": "都道府県",
      "city": "市区町村",
      "ward": "区",
      "block": "丁目・番地",
      "building": "建物名・部屋番号"
    },
    "units": {
      "号室": "Room",
      "階": "Floor",
      "棟": "Building"
    }
  },
  "KR": {
    "name": "South Korea",
    "format": {
      "order": ["postalCode", "province", "city", "district", "street", "building"],
      "template": "({postalCode})\n{province} {city} {district}\n{street} {number}\n{building}",
      "templateLatin": "{building}\n{number} {street}\n{district}, {city}\n{province} {postalCode}",
      "uppercase": false,
      "addressOrder": "large-to-small"
    },
    "postalCode": {
