  "AU": {
    "name": "Australia",
    "format": {
      "order": ["street", "street2", "city", "state", "postalCode"],
      "template": "{number} {street}\n{street2}\n{city} {state} {postalCode}",
      "uppercase": true
    },
    "postalCode": {
      "name": "Postcode",
      "format": "####",
      "regex": "^\\d{4}$",
      "examples": ["2000", "3000", "4000"]
    },
