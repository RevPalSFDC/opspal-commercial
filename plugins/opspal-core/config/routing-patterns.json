  "deploymentHierarchy": {
    "rules": [
      "1. 'deploy to production' / 'production deploy' -> release-coordinator (mandatoryPatterns)",
      "2. 'sf project deploy' / 'deploy metadata' -> sfdc-deployment-manager (platform-level)",
      "3. release-coordinator delegates to sfdc-deployment-manager for actual SF deploys",
      "4. sfdc-deployment-manager NEVER calls release-coordinator (prevents circular)"
    ]
  },
  "complexityRules": {
    "description": "Rules for calculating complexity scores",
    "highComplexityKeywords": {
      "score": 0.3,
      "keywords": [
        "production",
        "prod deploy",
        "merge.*main",
        "release",
        "audit",
        "assessment",
        "comprehensive",
        "migrate",
        "bulk",
        "mass",
        "delete all"
      ]
    },
    "mediumComplexityKeywords": {
      "score": 0.2,
      "keywords": [
        "create",
        "build",
        "new",
        "implement",
        "workflow",
        "flow",
        "automation",
        "trigger",
        "permission",
        "security",
        "profile"
      ]
    },
    "lowComplexityKeywords": {
      "score": 0.1,
      "keywords": [
        "query",
        "search",
        "find",
        "list",
        "show",
        "check",
        "validate",
        "verify",
        "test"
      ]
    }
  },
  "blockingThresholds": {
    "mandatory": 1.0,
    "high": 0.7,
    "recommended": 0.5,
    "available": 0.0
  },
  "settings": {
    "enableMandatoryBlocking": true,
    "enableComplexityBlocking": true,
    "defaultTimeout": 10000,
    "verboseLogging": false
  },
  "exclusiveKeywords": {
    "description": "Keywords that must route to exactly ONE agent. Any overlap triggers validation error.",
    "mappings": {
      "cpq": "opspal-salesforce:sfdc-cpq-assessor",
      "q2c": "opspal-salesforce:sfdc-cpq-assessor",
      "revops": "opspal-salesforce:sfdc-revops-auditor",
