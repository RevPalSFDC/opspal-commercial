{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "3.6.0",
  "description": "CANONICAL ROUTING REGISTRY - Single source of truth for all agent routing rules. Used by unified-router.sh, pre-task-agent-validator.sh, and auto-generates CLAUDE.md routing tables and docs/routing-help.md.",
  "lastUpdated": "2026-04-10",
  "canonicalSource": true,
  "generatesDocumentation": [
    "docs/routing-help.md (routing table)",
    "CLAUDE.md (routing table)",
    "plugins/*/CLAUDE.md (plugin-specific routing)"
  ],
  "mandatoryPatterns": {
    "description": "Patterns that trigger hard blocking (exit code 1) - destructive operations",
    "patterns": [
      {
        "id": "prod-deploy",
        "keywords": [
          "deploy.*prod",
          "production.*deploy",
          "push.*production"
        ],
        "agent": "opspal-core:release-coordinator",
        "clearanceAgents": [
          "opspal-core:release-coordinator",
          "opspal-salesforce:sfdc-deployment-manager"
        ],
        "reason": "Production deployments require orchestration"
      },
      {
        "id": "bulk-delete",
        "keywords": [
          "delete.*bulk",
          "bulk.*delete",
          "mass.*delete",
          "delete.*all"
        ],
        "agent": "opspal-salesforce:sfdc-data-operations",
        "clearanceAgents": [
          "opspal-salesforce:sfdc-data-operations",
          "opspal-salesforce:sfdc-query-specialist",
          "opspal-salesforce:sfdc-bulkops-orchestrator",
          "opspal-salesforce:sfdc-upsert-orchestrator",
          "opspal-salesforce:sfdc-data-export-manager"
        ],
        "reason": "Bulk deletions require safety checks"
      },
      {
        "id": "compound-salesforce-cleanup-indicators",
        "keywords": [
          "fix.*account.*naming.*contact",
          "account.*naming.*reparent",
          "naming.*issue.*duplicate.*account",
          "resume.*reparent.*contact.*duplicate",
          "continue.*contact.*cleanup.*account",
          "fix.*duplicate.*account.*contact",
          "account.*contact.*reparent.*delete"
        ],
        "agent": "opspal-salesforce:sfdc-orchestrator",
        "clearanceAgents": [
          "opspal-salesforce:sfdc-orchestrator",
          "opspal-salesforce:sfdc-query-specialist",
          "opspal-salesforce:sfdc-data-export-manager",
          "opspal-salesforce:sfdc-csv-enrichment",
          "opspal-salesforce:sfdc-bulkops-orchestrator",
          "opspal-salesforce:sfdc-merge-orchestrator",
          "opspal-salesforce:sfdc-dedup-safety-copilot"
        ],
        "reason": "Compound account/contact cleanup workflows require orchestrated multi-step execution."
      },
      {
        "id": "mixed-salesforce-data-cleanup",
        "keywords": [
          "reparent.*contacts?.*duplicate.*account",
          "duplicate.*account.*reparent.*contacts?",
          "reparent.*contacts?.*delete.*duplicate.*account",
          "delete.*duplicate.*account.*reparent.*contacts?",
          "count.*contacts?.*csv.*reparent.*duplicate.*account",
          "cleanup.*duplicate.*account.*contacts?"
        ],
        "agent": "opspal-salesforce:sfdc-orchestrator",
        "clearanceAgents": [
          "opspal-salesforce:sfdc-orchestrator",
          "opspal-salesforce:sfdc-query-specialist",
          "opspal-salesforce:sfdc-data-export-manager",
          "opspal-salesforce:sfdc-csv-enrichment",
          "opspal-salesforce:sfdc-bulkops-orchestrator",
          "opspal-salesforce:sfdc-merge-orchestrator",
          "opspal-salesforce:sfdc-dedup-safety-copilot"
        ],
        "reason": "Mixed Salesforce cleanup workflows require orchestrated verification, CSV generation, bulk reparenting, and duplicate cleanup."
      },
      {
        "id": "salesforce-duplicate-discovery-cleanup",
        "keywords": [
          "find.*duplicate.*account.*query",
          "find.*duplicate.*account.*validate",
          "find.*duplicate.*account.*clean",
          "find.*duplicate.*account.*merge",
          "find.*duplicate.*account.*created",
          "identify.*duplicate.*account.*cleanup",
          "detect.*duplicate.*account.*merge",
          "duplicate.*account.*finder",
          "duplicate.*account.*discovery"
        ],
        "agent": "opspal-salesforce:sfdc-orchestrator",
        "clearanceAgents": [
          "opspal-salesforce:sfdc-orchestrator",
          "opspal-salesforce:sfdc-query-specialist",
          "opspal-salesforce:sfdc-data-export-manager",
          "opspal-salesforce:sfdc-csv-enrichment",
          "opspal-salesforce:sfdc-bulkops-orchestrator",
          "opspal-salesforce:sfdc-merge-orchestrator",
          "opspal-salesforce:sfdc-dedup-safety-copilot"
        ],
        "reason": "Duplicate account discovery workflows with embedded cleanup/validation steps require orchestrated multi-step execution."
      },
      {
        "id": "automation-destructive",
        "keywords": [
          "delete.*flow",
          "remove.*flow",
          "deactivate.*flow",
          "disable.*flow",
          "delete.*automation",
          "remove.*automation",
          "deactivate.*trigger",
          "delete.*validation.*rule"
        ],
        "agent": "opspal-salesforce:sfdc-automation-builder",
        "clearanceAgents": [
          "opspal-salesforce:sfdc-automation-builder",
          "opspal-salesforce:sfdc-deployment-manager",
          "opspal-salesforce:sfdc-metadata-manager"
        ],
        "reason": "Destructive automation changes require a write-capable automation specialist with deployment clearance."
      },
      {
        "id": "permission-security-write",
        "keywords": [
          "create.*permission set",
          "update.*permission set",
          "modify.*permission set",
          "assign.*permission set",
          "permission set.*assignment",
          "grant.*field.*access",
          "grant.*object.*access",
          "field level security",
          "profile.*permission",
          "sharing rule",
          "role hierarchy"
        ],
        "agent": "opspal-salesforce:sfdc-permission-orchestrator",
        "clearanceAgents": [
          "opspal-salesforce:sfdc-permission-orchestrator",
          "opspal-salesforce:sfdc-deployment-manager",
          "opspal-salesforce:sfdc-metadata-manager",
          "opspal-salesforce:sfdc-security-admin"
        ],
        "reason": "Permission/security writes must start with the canonical permission orchestrator"
      },
      {
        "id": "prod-permissions",
        "keywords": [
          "permission.*prod",
          "profile.*change.*prod",
          "update.*permission.*prod"
        ],
        "agent": "opspal-salesforce:sfdc-permission-orchestrator",
        "clearanceAgents": [
          "opspal-salesforce:sfdc-permission-orchestrator",
          "opspal-salesforce:sfdc-deployment-manager",
          "opspal-salesforce:sfdc-metadata-manager",
          "opspal-salesforce:sfdc-security-admin"
        ],
        "reason": "Production permission/security changes require canonical orchestration and audit"
      },
      {
        "id": "destructive-metadata",
        "keywords": [
          "drop.*field",
          "remove.*object",
          "delete.*object",
          "truncate"
        ],
        "agent": "opspal-salesforce:sfdc-metadata-manager",
        "reason": "Destructive metadata operations require rollback plan"
      },
      {
        "id": "prod-merge",
        "keywords": [
          "merge.*prod",
          "merge.*main",
          "merge.*master"
        ],
        "agent": "opspal-core:release-coordinator",
        "reason": "Production merges require release coordination"
      },
      {
        "id": "record-dedup-merge",
        "keywords": [
          "merge.*duplicate.*(account|contact|lead)",
          "dedup(e|lication)?.*(account|contact|lead)",
          "consolidate.*(account|contact|lead)"
        ],
        "agent": "opspal-salesforce:sfdc-merge-orchestrator",
        "clearanceAgents": [
          "opspal-salesforce:sfdc-merge-orchestrator",
          "opspal-salesforce:sfdc-dedup-safety-copilot"
        ],
        "reason": "Record merge/dedup operations require controlled orchestration"
      }
    ]
  },
