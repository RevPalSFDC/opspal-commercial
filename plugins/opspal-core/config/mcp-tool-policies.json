      "namespace": "monday",
      "mutability": "read_only",
      "pendingRouteAction": "allow",
      "notes": "Monday read and search operations."
    },
    {
      "id": "monday-mutating",
      "patterns": ["^mcp__monday__(create_|change_|move_|archive_|delete_|add_).*"],
      "namespace": "monday",
      "mutability": "mutating",
