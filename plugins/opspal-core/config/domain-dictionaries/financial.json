      "ISIN": "International Securities Identification Number",
      "SEDOL": "Stock Exchange Daily Official List",
      "LEI": "Legal Entity Identifier",
      "GIIN": "Global Intermediary Identification Number",
      "EIN": "Employer Identification Number",
