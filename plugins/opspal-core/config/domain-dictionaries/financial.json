{
  "$schema": "../../schemas/domain-dictionary.schema.json",
  "domain": "financial",
  "version": "1.0.0",
  "description": "Financial services, banking, credit unions, investment firms, and regulatory compliance",

  "detectionPatterns": {
    "keywords": [
      "bank", "credit", "loan", "investment", "financial", "finance",
      "wealth", "asset", "fund", "capital", "mortgage", "insurance",
      "broker", "advisor", "portfolio", "securities", "trading"
    ],
    "entityTypes": ["Bank", "CreditUnion", "Investment", "InsuranceCompany", "Broker"],
    "fieldPatterns": [
      "AccountNumber", "RoutingNumber", "CUSIP", "ISIN", "AUM",
      "NAV", "InterestRate", "APY", "APR", "CreditScore"
    ]
  },

