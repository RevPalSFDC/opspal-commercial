  "suffixes": {
    "strip": ["Inc", "Inc.", "LLC", "Corp", "Corporation", "Ltd", "Co"],
    "preserve": [
      "Bank", "Credit Union", "Federal Credit Union", "Savings Bank",
      "Trust", "Trust Company", "Financial", "Capital", "Investments",
      "Asset Management", "Wealth Management", "Securities", "Insurance",
      "NA", "N.A.", "FSB", "F.S.B."
    ]
  },

  "synonyms": {
    "Federal Credit Union": ["FCU", "Fed Credit Union"],
    "Credit Union": ["CU"],
    "Bank": ["Banking", "Bancorp", "Banc"],
    "National Association": ["NA", "N.A."],
    "Federal Savings Bank": ["FSB", "F.S.B."],
    "Trust Company": ["Trust Co", "Trust"],
    "Insurance Company": ["Insurance Co", "Ins Co", "Ins"],
    "Financial Services": ["Financial Svcs", "Fin Svcs"],
    "Asset Management": ["Asset Mgmt", "AM"],
    "Wealth Management": ["Wealth Mgmt", "WM"],
    "Investment": ["Investments", "Inv"]
  },

  "matchingRules": {
    "ignoreCase": true,
    "expandBeforeMatch": true,
    "synonymWeight": 0.85,
    "minimumConfidence": 75
  },

  "matchingPolicy": {
    "sameNameDifferentStatePolicy": "REVIEW",
    "uniquenessLevel": "MEDIUM",
    "confidenceThresholds": {
      "autoMerge": 90,
      "review": 80,
      "tag": 65
    },
    "stateMismatchPenalty": -30
  },

  "genericEntityPatterns": [
    "* Federal Credit Union",
    "* Credit Union",
    "* Employees Credit Union",
    "* Teachers Credit Union",
    "* Community Credit Union",
    "* Community Bank",
    "* Savings Bank",
    "First * Bank",
    "Community Bank of *",
    "* Insurance Agency",
    "* Insurance Group",
    "* Mutual Insurance Company",
    "Farm Bureau of *"
  ],

  "sameEntitySignals": {
    "required": [],
    "boosts": ["routing_number_match", "domain_match", "charter_number_match"],
    "blockers": ["different_charter"]
  },

