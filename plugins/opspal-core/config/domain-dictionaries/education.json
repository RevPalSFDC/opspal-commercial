{
  "$schema": "../../schemas/domain-dictionary.schema.json",
  "domain": "education",
  "version": "1.0.0",
  "description": "Higher education institutions, university systems, colleges, and educational organizations",

  "detectionPatterns": {
    "keywords": [
      "university", "college", "campus", "academic", "education",
      "school", "institute", "faculty", "student", "alumni",
      "undergraduate", "graduate", "doctoral", "research", "provost"
    ],
    "entityTypes": ["University", "College", "Institute", "Campus", "System"],
    "fieldPatterns": [
      "IPEDS", "FICE", "OPE", "AccreditationId", "CampusCode"
    ]
  },

  "abbreviations": {
    "degrees": {
      "BA": "Bachelor of Arts",
      "BS": "Bachelor of Science",
      "MA": "Master of Arts",
      "MS": "Master of Science",
      "MBA": "Master of Business Administration",
      "PhD": "Doctor of Philosophy",
      "EdD": "Doctor of Education",
      "JD": "Juris Doctor",
      "MD": "Doctor of Medicine",
      "DO": "Doctor of Osteopathic Medicine"
    },
    "systems": {
      "UC": "University of California",
      "CSU": "California State University",
      "SUNY": "State University of New York",
      "CUNY": "City University of New York",
      "UT": "University of Texas"
    },
    "organizations": {
      "NCAA": "National Collegiate Athletic Association",
      "AAUP": "American Association of University Professors",
      "ACE": "American Council on Education"
    }
  },

  "suffixes": {
    "strip": ["Inc", "LLC"],
    "preserve": [
      "University", "College", "Institute", "School",
      "Academy", "Center", "Campus"
    ]
  },

  "synonyms": {
    "University": ["Univ", "Univ."],
    "College": ["Coll", "Coll."],
    "Institute": ["Inst", "Inst."],
    "Community College": ["CC", "Junior College", "JC"]
  },

  "matchingRules": {
    "ignoreCase": true,
    "expandBeforeMatch": true,
    "synonymWeight": 0.90,
    "minimumConfidence": 80
  },

  "matchingPolicy": {
    "sameNameDifferentStatePolicy": "BLOCK",
    "uniquenessLevel": "HIGH",
    "confidenceThresholds": {
      "autoMerge": 95,
      "review": 85,
      "tag": 70
    },
    "stateMismatchPenalty": -40
  },

  "genericEntityPatterns": [
    "University of *",
    "* State University",
    "* University",
    "* College",
    "* Community College",
    "* Technical College",
    "* Institute of Technology",
    "* School of *"
  ],

  "sameEntitySignals": {
    "required": ["state_match OR system_match"],
    "boosts": ["domain_match", "ipeds_match", "system_match"],
    "blockers": ["different_state_generic_name"]
  },

  "knownEntities": [
    "Harvard University",
