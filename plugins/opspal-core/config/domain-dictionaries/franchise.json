  "locationPatterns": [
    {
      "pattern": "^(.+?)\\s*[-–—]\\s*([A-Za-z][A-Za-z\\s]+)$",
      "description": "Dash separator: 'Marriott - Dallas'",
      "baseGroup": 1,
      "locationGroup": 2
    },
    {
      "pattern": "^(.+?)\\s*#(\\d+)$",
      "description": "Store number with hash: 'McDonald's #1234'",
      "baseGroup": 1,
      "storeNumberGroup": 2
    },
    {
      "pattern": "^(.+?)\\s*\\(([A-Z]{2})\\)$",
      "description": "State code in parentheses: 'Hilton (TX)'",
      "baseGroup": 1,
      "locationGroup": 2
    },
    {
      "pattern": "^(.+?)\\s+(?:Store|Location|Branch|Unit)\\s*#?(\\d+)$",
      "description": "Store keyword: 'Target Store 1234'",
      "baseGroup": 1,
      "storeNumberGroup": 2
    },
    {
      "pattern": "^(.+?)\\s+(North|South|East|West|Central|Downtown|Uptown|Midtown|Northwest|Northeast|Southwest|Southeast)$",
      "description": "Regional suffix: 'Starbucks Downtown'",
      "baseGroup": 1,
      "locationGroup": 2
    },
    {
      "pattern": "^(.+?)\\s+at\\s+(.+)$",
      "description": "At location: 'Starbucks at Main Street'",
      "baseGroup": 1,
      "locationGroup": 2
    }
  ]
