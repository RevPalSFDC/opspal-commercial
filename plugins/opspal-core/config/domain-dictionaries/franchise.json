{
  "$schema": "../../schemas/domain-dictionary.schema.json",
  "domain": "franchise",
  "version": "1.0.0",
  "description": "Franchises, hotels, restaurants, and multi-location branded businesses where same name in different states typically represents the same corporate entity",

  "detectionPatterns": {
    "keywords": [
      "franchise", "franchisee", "store", "location", "branch", "outlet",
      "restaurant", "hotel", "motel", "inn", "lodge", "resort",
      "fast food", "quick service", "drive-thru", "chain"
    ],
    "entityTypes": ["Franchise", "Store", "Branch", "Location", "Outlet", "Hotel", "Restaurant"],
    "fieldPatterns": [
      "StoreNumber", "FranchiseId", "LocationCode", "UnitNumber",
      "BrandId", "ChainCode", "PropertyCode"
    ]
  },

  "abbreviations": {
    "operations": {
      "HQ": "Headquarters",
      "DC": "Distribution Center",
      "RO": "Regional Office",
      "CO": "Corporate Office",
      "FC": "Franchise Center"
    },
    "hospitality": {
      "H&S": "Hotel and Suites",
      "B&B": "Bed and Breakfast",
      "EI": "Extended Stay",
      "ES": "Executive Suites"
    },
    "foodService": {
      "QSR": "Quick Service Restaurant",
      "FSR": "Full Service Restaurant",
      "FC": "Food Court",
      "DT": "Drive-Thru"
    }
  },

  "suffixes": {
    "strip": ["Inc", "LLC", "Corp", "Franchising"],
    "preserve": [
      "Hotel", "Inn", "Suites", "Resort", "Lodge",
      "Restaurant", "Cafe", "Grill", "Kitchen",
      "Express", "Plus", "Select"
    ]
  },

  "synonyms": {
    "Hotel": ["Hotels"],
    "Inn": ["Inns"],
    "Restaurant": ["Restaurants", "Grill"],
    "Store": ["Stores", "Shop", "Outlet"],
    "Domino's": ["Domino's Pizza", "Dominos", "Dominos Pizza"],
    "Chipotle": ["Chipotle Mexican Grill"],
    "Dunkin'": ["Dunkin Donuts", "Dunkin' Donuts"],
    "KFC": ["Kentucky Fried Chicken"]
  },

  "matchingRules": {
    "ignoreCase": true,
    "expandBeforeMatch": true,
    "synonymWeight": 0.90,
    "minimumConfidence": 60
  },

  "matchingPolicy": {
    "sameNameDifferentStatePolicy": "ALLOW_WITH_PATTERN",
    "uniquenessLevel": "LOW",
    "confidenceThresholds": {
      "autoMerge": 85,
      "review": 75,
      "tag": 50
    },
    "stateMismatchPenalty": -10
  },

  "genericEntityPatterns": [],

  "sameEntitySignals": {
    "required": [],
    "boosts": ["known_franchise", "parent_pattern", "store_number_pattern", "domain_match"],
    "blockers": []
  },

