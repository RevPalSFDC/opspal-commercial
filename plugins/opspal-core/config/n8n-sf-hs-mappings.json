  "dataTransformations": {
    "timestamp": {
      "description": "Convert date to Unix timestamp for HubSpot",
      "code": "new Date(value).getTime()"
    },
    "sfDate": {
      "description": "Convert timestamp to Salesforce date format",
      "code": "new Date(value).toISOString().split('T')[0]"
    },
    "booleanToString": {
      "description": "Convert boolean to Yes/No string",
      "code": "value ? 'Yes' : 'No'"
    },
    "stringToBoolean": {
      "description": "Convert Yes/No to boolean",
      "code": "value.toLowerCase() === 'yes' || value.toLowerCase() === 'true'"
    },
    "currencyToNumber": {
      "description": "Strip currency formatting",
      "code": "parseFloat(value.replace(/[^0-9.-]/g, ''))"
    }
  },

  "customPropertySuggestions": {
    "salesforce": {
      "note": "Custom fields use __c suffix in API name",
      "example": {
        "fieldName": "Custom_Field__c",
        "expression": "={{ $json.Custom_Field__c }}"
      }
    },
    "hubspot": {
      "note": "Custom properties use snake_case naming",
      "example": {
        "propertyName": "custom_property_name",
        "expression": "={{ $json.properties.custom_property_name }}"
      }
    }
  },

  "idFields": {
    "salesforce": {
      "recordId": "Id",
      "externalIds": ["External_ID__c"],
      "note": "Use external IDs for upsert operations"
    },
    "hubspot": {
      "recordId": "hs_object_id",
      "alternativeIds": ["email", "domain"],
      "note": "Contacts can be identified by email, Companies by domain"
    }
  },

  "associationMappings": {
    "contactToAccount": {
      "salesforce": "AccountId",
      "hubspot": "associatedcompanyid",
      "note": "Lookup company association"
    },
    "opportunityToAccount": {
      "salesforce": "AccountId",
      "hubspot": "associatedcompanyid",
      "note": "Deal to Company association"
    },
    "contactToOpportunity": {
      "salesforce": "via OpportunityContactRole",
      "hubspot": "via associations API",
      "note": "Many-to-many relationship"
    }
  }
