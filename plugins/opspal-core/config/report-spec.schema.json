{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReportSpec",
  "description": "JSON Schema for RevOps report specifications. Defines the complete structure for deterministic report generation.",
  "type": "object",
  "required": [
    "id",
    "title",
    "grain",
    "sections",
    "sources",
    "output",
    "appendix"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the report specification",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable report title"
    },
    "owner": {
      "type": "string",
      "description": "Report owner/creator email or name"
    },
    "question": {
      "type": "string",
      "description": "Business question the report answers"
    },
    "audience": {
      "type": "string",
      "description": "Target audience for the report",
      "enum": ["exec", "manager", "ic", "analyst", "all"]
    },
    "cadence": {
      "type": "string",
      "description": "How often this report is generated",
      "enum": ["daily", "weekly", "monthly", "quarterly", "adhoc"]
    },
    "grain": {
      "type": "string",
      "description": "Primary grain for the report, e.g. opportunity, deal, account-month"
    },
    "time": {
      "type": "object",
      "description": "Time range configuration",
      "properties": {
        "range": {
          "type": "string",
          "description": "Named time range",
          "enum": [
            "this_quarter",
            "last_quarter",
            "next_quarter",
            "this_fiscal_quarter",
            "last_fiscal_quarter",
            "next_fiscal_quarter",
            "this_fiscal_year",
            "last_fiscal_year",
            "next_fiscal_year",
            "this_year",
            "last_year",
            "next_year",
            "last_90_days",
            "last_30_days",
            "last_n_days",
            "next_n_days",
            "ytd",
            "fiscal_ytd",
            "custom"
          ]
        },
        "filterFamily": {
          "type": "string",
          "description": "Filter family for consistency validation. Reports on the same dashboard should use the same filter family.",
          "enum": ["calendar", "fiscal", "relative", "custom"]
        },
        "start": {
          "type": "string",
          "format": "date",
          "description": "Start date (ISO 8601)"
        },
        "end": {
          "type": "string",
          "format": "date",
          "description": "End date (ISO 8601)"
        },
        "timezone": {
          "type": "string",
          "description": "Timezone for date calculations",
          "default": "UTC"
        }
      }
    },
    "sources": {
      "type": "array",
      "description": "Data sources for the report",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Source identifier for referencing in datasets"
          },
          "type": {
            "type": "string",
            "enum": [
              "salesforce",
              "hubspot",
              "marketo",
              "csv",
              "excel",
              "google_sheets",
              "warehouse",
              "api"
            ]
          },
          "config": {
            "type": "object",
            "description": "Source-specific configuration",
            "properties": {
              "org": {
                "type": "string",
                "description": "Salesforce org alias"
              },
              "portalId": {
                "type": "string",
                "description": "HubSpot portal ID"
              },
              "filePath": {
                "type": "string",
                "description": "Path for file-based sources"
              },
              "spreadsheetId": {
                "type": "string",
                "description": "Google Sheets spreadsheet ID"
              },
              "connectionString": {
                "type": "string",
                "description": "Warehouse connection string"
              }
            }
          }
        }
      }
    },
    "datasets": {
      "type": "array",
      "description": "Dataset definitions for data retrieval",
      "items": {
        "type": "object",
        "required": ["id", "source", "entity", "fields"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Dataset identifier for referencing in sections"
          },
          "source": {
            "type": "string",
            "description": "Reference to source.id"
          },
          "entity": {
            "type": "string",
            "description": "Entity/object name, e.g. Opportunity, Deal, Contact"
          },
          "fields": {
            "type": "array",
            "description": "Fields to retrieve",
            "items": {
              "type": "string"
            }
          },
          "where": {
            "type": "array",
            "description": "Filter conditions",
            "items": {
              "type": "object",
              "properties": {
                "field": {"type": "string"},
                "op": {
                  "type": "string",
                  "enum": ["=", "!=", ">", "<", ">=", "<=", "in", "not_in", "like", "contains"]
                },
                "value": {}
              }
            }
          },
          "joins": {
            "type": "array",
            "description": "Join definitions for related entities",
            "items": {
              "type": "object",
              "properties": {
                "entity": {"type": "string"},
                "on": {"type": "string"},
                "fields": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              }
            }
          },
          "limit": {
            "type": "integer",
            "description": "Maximum records to retrieve"
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "description": "Report sections/pages",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "dataset"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Section identifier"
          },
          "type": {
            "type": "string",
            "enum": [
              "table",
              "pivot",
              "chart",
              "text",
              "kpi_grid",
              "summary",
              "executive_summary"
            ]
          },
          "dataset": {
            "type": "string",
            "description": "Reference to dataset.id"
          },
          "title": {
            "type": "string",
            "description": "Section title"
          },
          "description": {
            "type": "string",
            "description": "Section description/context"
          },
          "layout": {
            "type": "object",
            "description": "Layout configuration",
            "properties": {
              "position": {"type": "string"},
              "width": {"type": "string"},
              "height": {"type": "string"}
            }
          },
          "columns": {
            "type": "array",
            "description": "Column definitions for tables",
            "items": {
              "type": "object",
              "properties": {
                "field": {"type": "string"},
                "label": {"type": "string"},
                "format": {"type": "string"},
                "width": {"type": "integer"}
              }
            }
          },
          "filters": {
            "type": "array",
            "description": "Section-level filters",
            "items": {
              "type": "object",
              "properties": {
                "field": {"type": "string"},
                "op": {"type": "string"},
                "value": {}
              }
            }
          },
          "group_by": {
            "type": "array",
            "description": "Grouping fields for aggregation",
            "items": {
              "type": "string"
            }
          },
          "metrics": {
            "type": "array",
            "description": "Metric calculations",
            "items": {
              "type": "object",
              "properties": {
                "field": {"type": "string"},
                "op": {
                  "type": "string",
                  "enum": ["sum", "count", "avg", "min", "max", "distinct_count", "median"]
                },
                "label": {"type": "string"},
                "format": {"type": "string"}
              }
            }
          },
          "sort": {
            "type": "array",
            "description": "Sort configuration",
            "items": {
              "type": "object",
              "properties": {
                "field": {"type": "string"},
                "direction": {
                  "type": "string",
                  "enum": ["asc", "desc"]
                }
              }
            }
          },
          "chart": {
            "type": "object",
            "description": "Chart configuration (for chart type)",
            "properties": {
              "chartType": {
                "type": "string",
                "enum": ["bar", "line", "pie", "donut", "area", "scatter", "funnel", "gauge"]
              },
              "xAxis": {"type": "string"},
              "yAxis": {"type": "string"},
              "series": {
                "type": "array",
                "items": {"type": "string"}
              },
              "colors": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          },
          "kpis": {
            "type": "array",
            "description": "KPI definitions (for kpi_grid type)",
            "items": {
              "type": "object",
              "properties": {
                "id": {"type": "string"},
                "label": {"type": "string"},
                "value": {"type": "string"},
                "benchmark": {"type": "string"},
                "format": {"type": "string"},
                "trend": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "description": "Output configuration",
      "required": ["format"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["xlsx", "csv", "pdf", "google_sheets", "json"]
        },
        "path": {
          "type": "string",
          "description": "Output file path"
        },
        "template": {
          "type": "object",
          "description": "Template configuration",
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["none", "xlsx_file", "google_sheet_template", "pdf_template"]
            },
            "path": {
              "type": "string",
              "description": "Template file path"
            },
            "spreadsheetId": {
              "type": "string",
              "description": "Google Sheets template ID"
            },
            "mapping": {
              "type": "object",
              "description": "Field-to-cell mapping for templates"
            }
          }
        },
        "tabs": {
          "type": "array",
          "description": "Tab/sheet configuration for Excel/Sheets",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "sectionId": {"type": "string"}
            }
          }
        },
        "pdf": {
          "type": "object",
          "description": "PDF-specific options",
          "properties": {
            "coverTemplate": {"type": "string"},
            "includeCharts": {"type": "boolean"},
            "pageSize": {"type": "string", "enum": ["letter", "a4"]},
            "orientation": {"type": "string", "enum": ["portrait", "landscape"]}
          }
        }
      }
    },
    "appendix": {
      "type": "object",
      "description": "Methodology appendix configuration",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to include appendix"
        },
        "include": {
          "type": "array",
          "description": "Appendix sections to include",
          "items": {
            "type": "string",
            "enum": [
              "data_dictionary",
              "query_log",
              "metric_formulas",
              "assumptions",
              "qa_results",
              "run_metadata",
              "benchmark_sources",
              "exclusions"
            ]
          }
        }
      }
    },
    "qa": {
      "type": "object",
      "description": "QA checks configuration",
      "properties": {
        "checks": {
          "type": "array",
          "description": "QA checks to run",
          "items": {
            "type": "string",
            "enum": [
              "row_count",
              "null_rate",
              "duplicates",
              "amount_negative",
              "amount_zero",
              "percentage_bounds",
              "date_validity",
              "drift_vs_previous",
              "row_count_drift",
              "win_rate_sanity",
              "pipeline_coverage_sanity",
              "sales_cycle_sanity",
              "nrr_sanity"
            ]
          }
        },
        "config": {
          "type": "object",
          "description": "Check-specific configuration",
          "properties": {
            "minRows": {"type": "integer"},
            "maxNullRate": {"type": "number"},
            "driftThreshold": {"type": "number"},
            "criticalFields": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "previousSnapshot": {
          "type": "string",
          "description": "Path to previous run data for drift comparison"
        }
      }
    },
    "benchmarks": {
      "type": "object",
      "description": "Benchmark configuration",
      "properties": {
        "enabled": {"type": "boolean"},
        "industry": {
          "type": "string",
          "enum": ["saas", "enterprise", "smb", "marketplace", "fintech"]
        },
        "source": {"type": "string"}
      }
    },
    "metadata": {
      "type": "object",
      "description": "Report metadata",
      "properties": {
        "version": {"type": "string"},
        "createdAt": {"type": "string", "format": "date-time"},
        "updatedAt": {"type": "string", "format": "date-time"},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
