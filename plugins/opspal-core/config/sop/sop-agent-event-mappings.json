{
  "$schema": "https://revpal.io/schemas/sop-agent-event-mappings.json",
  "version": "1.0.0",
  "description": "Maps agent names to SOP event types and confidence levels for hook-based event emission",
  "mappings": {
    "intelligent-intake-orchestrator": {
      "event": "intake.created",
      "confidence": "inferred_high"
    },
    "task-graph-orchestrator": {
      "event": "task_graph.created",
      "confidence": "inferred_high"
    },
    "sfdc-cpq-assessor": {
      "event": "work.started",
      "confidence": "inferred_high",
      "classification": "audit",
      "sub_type": "cpq-assessment"
    },
    "sfdc-revops-auditor": {
      "event": "work.started",
      "confidence": "inferred_high",
      "classification": "audit",
      "sub_type": "revops-audit"
    },
    "sfdc-automation-auditor": {
      "event": "work.started",
      "confidence": "inferred_high",
      "classification": "audit",
      "sub_type": "automation-audit"
    },
    "sfdc-architecture-auditor": {
      "event": "work.started",
      "confidence": "inferred_high",
      "classification": "audit",
      "sub_type": "architecture-audit"
    },
    "hubspot-assessment-analyzer": {
      "event": "work.started",
      "confidence": "inferred_high",
      "classification": "audit",
      "sub_type": "hubspot-assessment"
    },
    "sfdc-automation-builder": {
      "event": "work.started",
      "confidence": "inferred_high",
