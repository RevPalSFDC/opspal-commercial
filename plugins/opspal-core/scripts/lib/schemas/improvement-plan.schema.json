{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://revpal.dev/schemas/process-reflections/improvement-plan.schema.json",
  "title": "Process Reflections Improvement Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "title",
    "summary",
    "plan_items",
    "triage_items",
    "execution_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_reflections_analyzed",
        "implementation_ready_items",
        "triage_items",
        "aggregate_roi_annual",
        "estimated_effort_hours"
      ],
      "properties": {
        "total_reflections_analyzed": {
          "type": "integer",
          "minimum": 0
        },
        "implementation_ready_items": {
          "type": "integer",
          "minimum": 0
        },
        "triage_items": {
          "type": "integer",
          "minimum": 0
        },
        "aggregate_roi_annual": {
          "type": "number",
          "minimum": 0
        },
        "estimated_effort_hours": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "plan_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source_cohort_ids",
          "taxonomy",
          "issue_summary",
          "evidence",
          "likely_root_cause",
          "recommended_fix",
          "prevention_safeguard",
          "implementation_steps",
          "owner_suggestion",
          "priority",
          "success_criteria",
          "estimated_effort_hours",
          "expected_roi_annual",
          "affected_components"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source_cohort_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "taxonomy": {
            "type": "string",
            "minLength": 1
          },
          "issue_summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "pattern",
              "reflection_count",
              "reflection_ids",
              "affected_orgs",
              "recurrence_count"
            ],
            "properties": {
              "pattern": {
                "type": "string",
                "minLength": 1
              },
              "reflection_count": {
                "type": "integer",
                "minimum": 1
              },
              "reflection_ids": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "affected_orgs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "recurrence_count": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "likely_root_cause": {
            "type": "string",
            "minLength": 1
          },
          "recommended_fix": {
            "type": "string",
            "minLength": 1
          },
          "prevention_safeguard": {
            "type": "string",
            "minLength": 1
          },
          "implementation_steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "owner_suggestion": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "success_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "estimated_effort_hours": {
            "type": "number",
            "minimum": 0
          },
          "expected_roi_annual": {
            "type": "number",
            "minimum": 0
          },
          "affected_components": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "triage_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cohort_id",
          "taxonomy",
          "status",
          "issue_summary",
          "reason",
          "required_dependency",
          "recommended_next_step",
          "reflection_ids"
        ],
        "properties": {
          "cohort_id": {
            "type": "string",
            "minLength": 1
          },
          "taxonomy": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["needs_triage", "blocked_external_dependency"]
          },
          "issue_summary": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "required_dependency": {
            "type": "string",
            "minLength": 1
          },
          "recommended_next_step": {
            "type": "string",
            "minLength": 1
          },
          "reflection_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "execution_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planning_complete",
        "task_creation_is_downstream",
        "downstream_task_system"
      ],
      "properties": {
        "planning_complete": {
          "type": "boolean",
          "const": true
        },
        "task_creation_is_downstream": {
          "type": "boolean",
          "const": true
        },
        "downstream_task_system": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
