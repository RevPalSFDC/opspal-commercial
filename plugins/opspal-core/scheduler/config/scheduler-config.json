      "schedule": "30 8 * * 1",
      "command": "node ${PLUGIN_ROOT}/scripts/lib/roi-tracker.js pending",
      "workingDir": "${PLUGIN_ROOT}",
      "timeout": 300,
      "enabled": true,
      "notifications": {
        "slack": {
          "notifyOn": [
            "failure"
          ]
        }
      },
      "metadata": {
