<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Lead Manager</label>
    <description>Permission set for lead management with access to scoring and routing fields. Part of lead-management solution v{{solution.version}}.</description>
    <license>Salesforce</license>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Lead Object Permissions -->
    <objectPermissions>
        <object>Lead</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- Custom Field Permissions -->
    <fieldPermissions>
        <field>Lead.Score__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <fieldPermissions>
        <field>Lead.Priority__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <!-- Standard Field Permissions -->
    <fieldPermissions>
        <field>Lead.OwnerId</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <fieldPermissions>
        <field>Lead.Status</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <fieldPermissions>
        <field>Lead.Rating</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <!-- Tab Settings -->
    <tabSettings>
        <tab>standard-Lead</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Record Type Permissions (if applicable) -->
    {{#if leadRecordTypes}}
    {{#each leadRecordTypes}}
    <recordTypeVisibilities>
        <recordType>Lead.{{this}}</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    {{/each}}
    {{/if}}

    <!-- Application Visibility -->
    <applicationVisibilities>
        <application>standard__Sales</application>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- User Permissions -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewSetup</name>
    </userPermissions>
</PermissionSet>
