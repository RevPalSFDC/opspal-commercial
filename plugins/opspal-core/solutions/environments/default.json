{
  "name": "default",
  "description": "Base environment configuration - inherit from this for all other environments",
  "type": "development",

  "credentials": {
    "salesforce": {
      "orgAlias": "{{env.SF_ORG_ALIAS}}",
      "apiVersion": "62.0",
      "loginUrl": "https://login.salesforce.com"
    },
    "hubspot": {
      "portalId": "{{env.HUBSPOT_PORTAL_ID}}",
      "accessToken": "{{env.HUBSPOT_ACCESS_TOKEN}}",
      "environment": "production"
    },
    "n8n": {
      "baseUrl": "{{env.N8N_BASE_URL}}",
      "apiKey": "{{env.N8N_API_KEY}}"
    }
  },

  "fieldMappings": {},

  "objectMappings": {},

  "labelCustomizations": {},

  "defaults": {
    "salesforce": {
      "testLevel": "NoTestRun",
      "checkOnly": false,
      "waitTime": 30,
      "ignoreWarnings": false
    },
    "hubspot": {
      "validateBeforeActivate": true
    },
    "n8n": {
      "activateOnDeploy": false
    },
    "deployment": {
      "dryRun": false,
      "validateOnly": false,
      "activateFlows": true,
      "runPostDeployTests": false,
      "createCheckpoint": true,
      "notifyOnComplete": false
    }
  },

  "featureFlags": {
    "enableCPQ": false,
    "enableServiceCloud": false,
    "enableNurturing": true,
    "enableAdvancedApprovals": false
  },

  "parameters": {},

  "restrictions": {
    "requireApproval": false,
    "blockedComponents": []
  }
}
