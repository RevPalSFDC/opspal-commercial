{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-dispatcher.sh",
            "timeout": 30,
            "description": "Sequential UPS dispatcher: first-run → task-graph → routing-refresher → unified-router → task-scope (ambient extractor runs async)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-task-agent-validator.sh",
            "timeout": 5,
            "description": "Validate and resolve agent names - detects commands mistakenly invoked as agents, auto-resolves short names to fully-qualified"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-task-runbook-policy-enforcer.sh",
            "timeout": 10,
            "description": "Enforce runbook policy retrieval for operational agents before field selection (Runbook Policy Infrastructure)"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-task-work-context.sh",
            "timeout": 5,
            "description": "Load client work history and inject project memory context before agent execution"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-operation-data-validator.sh",
            "timeout": 8,
            "description": "Validate data inputs using enhanced data-quality-monitor.js (cross-field, freshness, semantic)"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/task-graph-policy-enforcer.sh",
            "timeout": 5,
            "description": "Enforce risk-based tool policies for Task Graph tasks"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-operation-data-validator.sh",
            "timeout": 8,
            "description": "Validate data inputs using enhanced data-quality-monitor.js (cross-field, freshness, semantic)"
          }
        ]
      },
      {
        "matcher": "^mcp__salesforce.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-operation-data-validator.sh",
            "timeout": 8,
            "description": "Validate data inputs using enhanced data-quality-monitor.js (cross-field, freshness, semantic)"
          }
        ]
      },
      {
        "matcher": "^mcp__hubspot.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-operation-data-validator.sh",
            "timeout": 8,
            "description": "Validate data inputs using enhanced data-quality-monitor.js (cross-field, freshness, semantic)"
          }
        ]
      },
      {
        "matcher": "^mcp__marketo.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-operation-data-validator.sh",
            "timeout": 8,
            "description": "Validate data inputs using enhanced data-quality-monitor.js (cross-field, freshness, semantic)"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-contract-validation.sh",
            "timeout": 5,
            "description": "Validate tool inputs against contracts before execution"
          }
        ]
      },
      {
        "matcher": "^mcp__gong.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-gong-api-call.sh",
            "timeout": 5,
            "description": "Validate Gong credentials and check daily API budget before Gong API calls"
          }
        ]
      },
      {
        "matcher": "^mcp__fireflies.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-fireflies-api-call.sh",
            "timeout": 5,
            "description": "Validate Fireflies credentials and check daily API budget before Fireflies API calls"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/permission-request-handler.sh",
            "timeout": 2,
            "description": "Auto-approve safe read/query permission requests and log an audit trail"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.sh",
            "timeout": 10,
            "description": "Backup conversation transcript before compaction to prevent data loss"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ambient-flush-trigger.sh",
            "timeout": 10,
            "description": "Flush ambient reflections before context compaction"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-agent-dispatcher.sh",
            "timeout": 30,
            "description": "Sequential PostToolUse/Agent dispatcher: work-index → runbook-compliance → tool-use → contract → bluf → win-loss → stall-check"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh",
            "timeout": 5,
            "description": "Validate tool execution results to catch errors before propagation"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-contract-validation.sh",
            "timeout": 5,
            "description": "Validate tool outputs against contracts and data quality gates"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh",
            "timeout": 5,
            "description": "Validate tool execution results to catch errors before propagation"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-contract-validation.sh",
            "timeout": 5,
            "description": "Validate tool outputs against contracts and data quality gates"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh",
            "timeout": 5,
            "description": "Validate tool execution results to catch errors before propagation"
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-todowrite-scratchpad.sh",
            "timeout": 5,
            "description": "Persist TodoWrite state for session continuity"
          }
        ]
      },
      {
        "matcher": "^mcp__salesforce.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh",
            "timeout": 5,
            "description": "Validate tool execution results to catch errors before propagation"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-contract-validation.sh",
            "timeout": 5,
            "description": "Validate tool outputs against contracts and data quality gates"
          }
        ]
      },
      {
        "matcher": "^mcp__hubspot.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh",
            "timeout": 5,
            "description": "Validate tool execution results to catch errors before propagation"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-contract-validation.sh",
            "timeout": 5,
            "description": "Validate tool outputs against contracts and data quality gates"
          }
        ]
      },
      {
        "matcher": "^mcp__marketo.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh",
            "timeout": 5,
            "description": "Validate tool execution results to catch errors before propagation"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-contract-validation.sh",
            "timeout": 5,
            "description": "Validate tool outputs against contracts and data quality gates"
          }
        ]
      },
      {
        "matcher": "^mcp__gong.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-gong-sync.sh",
            "timeout": 5,
            "description": "Log Gong sync events and trigger work-index auto-capture"
          }
        ]
      },
      {
        "matcher": "^mcp__fireflies.*$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-fireflies-sync.sh",
            "timeout": 5,
            "description": "Log Fireflies sync events and trigger work-index auto-capture"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-reflect-strategy-update.sh",
            "timeout": 15,
            "description": "Extract skills from reflections and update routing confidence"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ambient-candidate-extractor.sh",
            "timeout": 5,
            "description": "Extract ambient reflection candidates from tool results"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ambient-hook-error-observer.sh",
            "timeout": 5,
            "description": "Observe hook errors and create reflection candidates with immediate flush"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ambient-flush-trigger.sh",
            "timeout": 5,
            "description": "Evaluate ambient reflection flush conditions"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-dispatcher.sh",
            "timeout": 30,
            "description": "Sequential SessionStart dispatcher: first-run → init → silent-failure-check → envcheck → repo-sync → capture-init"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-start-context.sh",
            "timeout": 10,
            "description": "Inject runbook/template/field/work context into spawned subagents"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop-dispatcher.sh",
            "timeout": 20,
            "description": "Sequential SubagentStop dispatcher: capture → verification → execution-proof → ambient-extraction"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/task-completed-metrics.sh",
            "timeout": 5,
            "description": "Record subagent completion metrics for routing feedback loops"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ambient-candidate-extractor.sh",
            "timeout": 5,
            "description": "Extract ambient reflection candidates from task completion"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ambient-flush-trigger.sh",
            "timeout": 5,
            "description": "Evaluate flush on task completion"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-dispatcher.sh",
            "timeout": 90,
            "description": "Sequential Stop dispatcher: org-verification → session-end → reliability → silent-failure-summary → error-observer → ambient-flush"
          }
        ]
      }
    ]
  }
}
