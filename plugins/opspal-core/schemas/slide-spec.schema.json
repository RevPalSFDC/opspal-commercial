{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SlideSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "slides"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "org": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "version": { "type": "string" },
        "deckPurpose": { "type": "string" },
        "persona": { "type": "string" }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/slide" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout"],
      "properties": {
        "layout": {
          "type": "string",
          "enum": [
            "TITLE",
            "SECTION",
            "CONTENT",
            "KPI",
            "TWO_COLUMN",
            "TABLE",
            "IMAGE",
            "PROCESS",
            "TIMELINE",
            "QUOTE",
            "CHART",
            "CHART_TEXT",
            "CODE",
            "CLOSING",
            "APPENDIX"
          ]
        },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "punchline": { "type": "string" },
        "slideKind": { "type": "string", "enum": ["editable", "static"] },
        "quote": { "type": "string" },
        "author": { "type": "string" },
        "bullets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "chart": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string" },
            "style": { "type": "string" },
            "series": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "label": { "type": "string" },
                  "value": { "type": "number" },
                  "display": { "type": "string" }
                }
              }
            }
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        },
        "columns": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "heading": { "type": "string" },
              "bullets": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "table": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "headers": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rows": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "alt": { "type": "string" }
          }
        },
        "code": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "language": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
