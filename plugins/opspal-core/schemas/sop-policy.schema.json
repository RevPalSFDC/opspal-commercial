{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://revpal.io/schemas/sop-policy.schema.json",
  "title": "SopPolicy",
  "description": "Schema for SOP policy definition files",
  "type": "object",
  "required": ["id", "schema_version", "enabled", "scope", "event", "mode", "actions"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^sop-[a-z0-9][a-z0-9-]*$",
      "description": "Unique policy identifier (kebab-case, sop- prefix)"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version for forward compatibility"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Policy content version"
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether this policy is active"
    },
    "scope": {
      "type": "string",
      "enum": ["global", "revpal-internal", "client-delivery"],
      "description": "Policy scope layer"
    },
    "event": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$",
      "description": "Canonical event type (dot-namespaced)"
    },
    "mode": {
      "type": "string",
      "enum": ["off", "recommend", "enforce", "dry_run"],
      "description": "Execution mode"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000,
      "default": 50,
      "description": "Higher priority wins on conflict (default 50)"
    },
    "when": {
      "type": "array",
      "items": { "$ref": "#/definitions/Condition" },
      "description": "All conditions must be true (AND logic)"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Action" },
      "description": "Actions to execute when policy matches"
    },
    "mapping_ref": {
      "type": "string",
      "description": "Reference to a target mapping definition by id"
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ref": { "type": "string" }
        },
        "required": ["ref"]
      },
      "description": "References to reusable action template fragments"
    },
    "idempotency": {
      "$ref": "#/definitions/IdempotencyConfig"
    },
    "allow_backward_transition": {
      "type": "boolean",
      "default": false,
      "description": "Allow work-index backward state transitions (e.g., completed -> in_progress)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable policy description"
    },
    "created_at": {
      "type": "string",
      "description": "ISO-8601 creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO-8601 last updated timestamp"
    }
  },
  "definitions": {
    "Condition": {
      "type": "object",
      "required": ["field", "op"],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string",
          "description": "Dot-path field reference (e.g., context.work_item.classification, event.confidence)"
        },
        "op": {
          "type": "string",
          "enum": ["eq", "neq", "in", "nin", "exists", "regex"],
          "description": "Comparison operator"
        },
        "value": {
          "description": "Single comparison value (for eq, neq, regex)"
        },
        "values": {
          "type": "array",
          "description": "Array of values (for in, nin)"
        },
        "allow_inferred_low": {
          "type": "boolean",
          "default": false,
          "description": "Allow enforce mode on inferred_low confidence events"
        }
      }
    },
    "Action": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["asana", "work-index", "log"],
          "description": "Executor type"
        },
        "params": {
          "type": "object",
          "description": "Executor-specific parameters"
        },
        "template": {
          "type": "string",
          "description": "Template reference for this action"
        }
      }
    },
    "IdempotencyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["event+policy", "event+policy+target"],
          "default": "event+policy",
          "description": "Granularity of idempotency key derivation"
        },
        "ttl_hours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 168,
          "default": 24,
          "description": "TTL for idempotency records in hours"
        }
      }
    }
  }
}
