{
  "templateMetadata": {
    "id": "plg-funnel",
    "name": "Product-Led Growth Funnel",
    "version": "2.0.0",
    "description": "Track PLG funnel metrics including trial conversion, PQLs, activation rates, and product-qualified pipeline",
    "category": "acquisition",
    "targetAudience": ["growth", "product", "marketing"],
    "recommendedFrequency": "weekly",
    "estimatedGenerationTime": "4-6 minutes"
  },
  "reportMetadata": {
    "defaultTitle": "PLG Funnel Report",
    "defaultPeriod": "Last 30 Days",
    "defaultFormat": "pdf",
    "defaultSegmentation": ["plan_type", "signup_source"],
    "supportedFormats": ["pdf", "excel", "sheets", "csv"]
  },
  "kpis": [
    {
      "id": "pqls",
      "required": true,
      "displayOrder": 1,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "trial_conversion",
      "required": true,
      "displayOrder": 2,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "activation_rate",
      "required": true,
      "displayOrder": 3,
      "chartType": "gauge",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "lead_velocity_rate",
      "required": true,
      "displayOrder": 4,
      "chartType": "line",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "time_to_value",
      "required": false,
      "displayOrder": 5,
      "chartType": "histogram",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "expansion_revenue_rate",
      "required": false,
      "displayOrder": 6,
      "chartType": "line",
      "showTrend": true,
      "showBenchmark": true
    },
    {
      "id": "product_qualified_pipeline",
      "required": false,
      "displayOrder": 7,
      "chartType": "bar",
      "showTrend": true,
      "showBenchmark": false
    }
  ],
  "dataSources": {
    "salesforce": {
      "objects": ["Lead", "Opportunity", "Account", "Contact"],
      "requiredFields": ["Id", "Status", "LeadSource", "CreatedDate", "ConvertedDate"],
      "optionalFields": ["Trial_Start_Date__c", "Product_Qualified__c", "Activation_Date__c"],
      "filters": {
        "standard": "LeadSource IN ('Trial', 'Freemium', 'Product')"
      }
    },
    "hubspot": {
      "objects": ["contacts", "deals"],
      "requiredProperties": ["lifecyclestage", "createdate", "hs_lead_status"],
      "optionalProperties": ["trial_start_date", "product_qualified_lead", "activation_date"],
      "filters": {
        "standard": "lifecyclestage IN ('subscriber', 'lead', 'marketingqualifiedlead')"
      }
    },
    "product_analytics": {
      "recommended": true,
      "description": "For accurate activation and usage metrics",
      "supportedPlatforms": ["Amplitude", "Mixpanel", "Heap", "Pendo", "Segment"],
      "metrics": ["active_users", "feature_adoption", "session_duration", "key_actions"]
    },
    "manual": {
      "required": [
        {
          "field": "total_signups",
          "description": "Total new signups/trials started in period",
          "type": "number"
        },
        {
          "field": "activated_users",
          "description": "Users who completed activation milestone",
          "type": "number"
        },
        {
          "field": "converted_users",
          "description": "Users who converted to paid",
          "type": "number"
        }
      ],
      "optional": [
        {
          "field": "avg_time_to_activation",
          "description": "Average days from signup to activation",
          "type": "number"
        },
        {
          "field": "feature_adoption_rate",
          "description": "Percentage using key features",
          "type": "percentage"
        },
        {
          "field": "sales_assisted_conversions",
          "description": "Conversions with sales involvement",
          "type": "number"
        }
      ]
    }
  },
  "sections": [
    {
      "id": "executive-summary",
      "title": "Executive Summary",
      "type": "summary",
      "order": 1,
      "content": {
        "blufTemplate": "PLG funnel health: Trial conversion at ${trial_conversion}%, activation at ${activation_rate}%. Lead velocity ${lvr_status} at ${lead_velocity_rate}% MoM. ${key_insight}.",
        "keyMetrics": ["trial_conversion", "activation_rate", "pqls"],
        "maxHighlights": 3,
        "maxRecommendations": 2
      }
    },
    {
      "id": "funnel-overview",
      "title": "PLG Funnel Overview",
      "type": "funnel",
      "order": 2,
      "funnelConfig": {
        "stages": [
          { "id": "visitors", "label": "Visitors", "color": "#e0e0e0" },
          { "id": "signups", "label": "Signups", "color": "#90caf9" },
          { "id": "activated", "label": "Activated", "color": "#4caf50" },
          { "id": "pql", "label": "PQL", "color": "#ff9800" },
          { "id": "converted", "label": "Converted", "color": "#2196f3" }
        ],
        "showConversionRates": true,
        "showDropoffAnalysis": true
      }
    },
    {
      "id": "pql-scorecard",
      "title": "Product Qualified Leads",
      "type": "dashboard",
      "order": 3,
      "kpis": ["pqls", "trial_conversion", "activation_rate"],
      "layout": "1x3",
      "showBenchmarkComparison": true,
      "showInterpretation": true
    },
    {
      "id": "velocity-trend",
      "title": "Lead Velocity & Growth Trend",
      "type": "chart",
      "order": 4,
      "chartConfig": {
        "type": "line",
        "kpis": ["lead_velocity_rate", "pqls"],
        "groupBy": "CALENDAR_WEEK",
        "showTarget": true,
        "showPreviousPeriod": true
      }
    },
    {
      "id": "conversion-funnel",
      "title": "Conversion Rates by Stage",
      "type": "chart",
      "order": 5,
      "chartConfig": {
        "type": "waterfall",
        "stages": ["signup_to_activated", "activated_to_pql", "pql_to_converted"],
        "showBenchmark": true,
        "showDropoff": true
      }
    },
    {
      "id": "activation-analysis",
      "title": "Activation Analysis",
      "type": "detail",
      "order": 6,
      "breakdown": {
        "metrics": ["activation_rate", "time_to_value"],
        "segmentation": ["plan_type", "signup_source", "company_size"],
        "showCohortComparison": true
      }
    },
    {
      "id": "source-performance",
      "title": "Performance by Signup Source",
      "type": "comparison",
      "order": 7,
      "comparisonConfig": {
        "dimension": "signup_source",
        "metrics": ["trial_conversion", "activation_rate", "time_to_value"],
        "sortBy": "trial_conversion",
        "sortOrder": "desc"
      }
    },
    {
      "id": "expansion-opportunity",
      "title": "Expansion Opportunity",
      "type": "detail",
      "order": 8,
      "breakdown": {
        "metrics": ["expansion_revenue_rate", "product_qualified_pipeline"],
        "showUpsellIndicators": true,
        "showProductUsageTriggers": true
      }
    },
    {
      "id": "methodology",
      "title": "Methodology",
      "type": "methodology",
      "order": 99,
      "include": ["dataSources", "formulas", "assumptions", "pqlCriteria", "activationDefinition"]
    }
  ],
  "calculations": {
    "pqls": {
      "formula": "COUNT(Users) WHERE meets_pql_criteria = true",
      "notes": "Users demonstrating product value through usage behaviors",
      "pqlCriteria": {
        "examples": [
          "Completed 3+ key actions",
          "Invited team members",
          "Used premium features in trial",
          "Active 7+ days in first 14 days"
        ]
      }
    },
    "trial_conversion": {
      "formula": "(Converted Users / Total Trial Signups) × 100",
      "notes": "Percentage of trial users who convert to paid",
      "interpretation": {
        "lessThan5": "Below average - review activation experience",
        "5to10": "Average PLG conversion",
        "10to15": "Good - healthy product-market fit",
        "greaterThan15": "Excellent - strong self-serve motion"
      }
    },
    "activation_rate": {
      "formula": "(Activated Users / Total Signups) × 100",
      "notes": "Users completing key activation milestone",
      "interpretation": {
        "lessThan20": "Activation friction - simplify onboarding",
        "20to40": "Average - room for improvement",
        "40to60": "Good - clear time-to-value",
        "greaterThan60": "Excellent - smooth onboarding"
      }
    },
    "lead_velocity_rate": {
      "formula": "((MQLs_current - MQLs_previous) / MQLs_previous) × 100",
      "notes": "Month-over-month growth in qualified leads",
      "interpretation": {
        "lessThan5": "Stagnant - growth initiatives needed",
        "5to10": "Healthy growth",
        "10to20": "Strong momentum",
        "greaterThan20": "Exceptional - scale operations"
      }
    },
    "time_to_value": {
      "formula": "AVG(Activation_Date - Signup_Date) in days",
      "notes": "Average time for users to reach activation milestone"
    },
    "product_qualified_pipeline": {
      "formula": "SUM(Opportunity.Amount) WHERE Source = 'Product Qualified'",
      "notes": "Pipeline value from product-qualified leads"
    }
  },
  "benchmarks": {
    "industry": "saas_plg",
    "sources": [
      {
        "name": "OpenView PLG Benchmarks 2024",
        "url": "https://openviewpartners.com",
        "metrics": ["trial_conversion", "activation_rate", "pqls"]
      },
      {
        "name": "ProductLed Benchmark Report 2024",
        "url": "https://productled.com",
        "metrics": ["time_to_value", "lead_velocity_rate"]
      },
      {
        "name": "Pendo State of Product-Led 2024",
        "url": "https://pendo.io",
        "metrics": ["activation_rate", "expansion_revenue_rate"]
      }
    ],
    "thresholds": {
      "trial_conversion": {
        "excellent": 15,
        "good": 10,
        "average": 5,
        "belowAverage": 2
      },
      "activation_rate": {
        "excellent": 60,
        "good": 40,
        "average": 25,
        "belowAverage": 15
      },
      "lead_velocity_rate": {
        "excellent": 20,
        "good": 10,
        "average": 5,
        "belowAverage": 0
      },
      "time_to_value": {
        "excellent": 1,
        "good": 3,
        "average": 7,
        "belowAverage": 14
      }
    }
  },
  "defaults": {
    "dateRange": {
      "type": "relative",
      "value": "LAST_30_DAYS"
    },
    "comparison": {
      "type": "week_over_week"
    },
    "cohortAnalysis": {
      "enabled": true,
      "period": "weekly"
    }
  },
  "exportConfig": {
    "pdf": {
      "orientation": "portrait",
      "includeCharts": true,
      "includeTables": true,
      "pageBreaks": ["activation-analysis", "methodology"]
    },
    "excel": {
      "sheets": [
        { "name": "Summary", "sections": ["executive-summary", "pql-scorecard"] },
        { "name": "Funnel Analysis", "sections": ["funnel-overview", "conversion-funnel"] },
        { "name": "Trends", "sections": ["velocity-trend", "source-performance"] },
        { "name": "Activation", "sections": ["activation-analysis"] },
        { "name": "Expansion", "sections": ["expansion-opportunity"] },
        { "name": "Methodology", "sections": ["methodology"] }
      ]
    }
  }
}
