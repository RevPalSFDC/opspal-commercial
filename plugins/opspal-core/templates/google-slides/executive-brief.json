{
  "templateId": "1iFug0S1BfOx9uW__McTPNFXOidg47wqgavhIWQltcNU",
  "name": "Executive Brief Template",
  "version": "1.0.0",
  "description": "Concise presentation for executive audiences focusing on high-level insights and recommendations",
  "deckType": "executive_brief",
  "targetAudience": ["executive", "board", "c-suite"],
  "inheritsFrom": "revpal-master",
  "recommendedStructure": [
    {
      "section": "Opening",
      "slides": [
        {
          "layout": "TITLE",
          "title": "{{topic}} - Executive Brief",
          "required": true
        }
      ]
    },
    {
      "section": "Summary",
      "slides": [
        {
          "layout": "CONTENT",
          "title": "Executive Summary",
          "description": "3-5 key takeaways, BLUF format",
          "required": true
        }
      ]
    },
    {
      "section": "Situation",
      "slides": [
        {
          "layout": "CONTENT",
          "title": "Current State",
          "description": "Where we are today, context"
        },
        {
          "layout": "KPI",
          "title": "Key Metrics",
          "description": "Performance indicators"
        }
      ]
    },
    {
      "section": "Analysis",
      "slides": [
        {
          "layout": "TWO_COLUMN",
          "title": "Strengths & Opportunities",
          "description": "What's working, what's possible"
        },
        {
          "layout": "CONTENT",
          "title": "Risks & Challenges",
          "description": "What needs attention"
        }
      ]
    },
    {
      "section": "Recommendations",
      "slides": [
        {
          "layout": "CONTENT",
          "title": "Recommended Actions",
          "description": "Prioritized next steps",
          "required": true
        },
        {
          "layout": "CONTENT",
          "title": "Resource Requirements",
          "description": "What's needed (people, budget, time)"
        }
      ]
    },
    {
      "section": "Closing",
      "slides": [
        {
          "layout": "CLOSING",
          "title": "Next Steps & Contact",
          "required": true
        }
      ]
    }
  ],
  "contentGuidelines": {
    "maxSlides": 15,
    "maxBulletsPerSlide": 5,
    "maxWordsPerBullet": 12,
    "tone": "concise, data-driven, action-oriented",
    "avoidJargon": true,
    "focusOnOutcomes": true,
    "recommendedDuration": "15-20 minutes"
  },
  "styleOverrides": {
    "emphasisOnData": true,
    "minimalistDesign": true,
    "highContrastVisuals": true
  }
}
