{
  "templateId": "1iFug0S1BfOx9uW__McTPNFXOidg47wqgavhIWQltcNU",
  "name": "Deep Dive Template",
  "version": "1.0.0",
  "description": "Comprehensive technical or analytical presentation with detailed supporting data",
  "deckType": "deep_dive",
  "targetAudience": ["technical", "analyst", "implementer"],
  "inheritsFrom": "revpal-master",
  "recommendedStructure": [
    {
      "section": "Opening",
      "slides": [
        {
          "layout": "TITLE",
          "title": "{{topic}} - Technical Deep Dive",
          "required": true
        },
        {
          "layout": "CONTENT",
          "title": "Agenda & Scope",
          "description": "What we'll cover"
        }
      ]
    },
    {
      "section": "Context",
      "slides": [
        {
          "layout": "SECTION_HEADER",
          "title": "Background & Context"
        },
        {
          "layout": "CONTENT",
          "title": "Problem Statement",
          "description": "What we're solving"
        },
        {
          "layout": "CONTENT",
          "title": "Success Criteria",
          "description": "How we'll measure success"
        }
      ]
    },
    {
      "section": "Analysis",
      "slides": [
        {
          "layout": "SECTION_HEADER",
          "title": "Detailed Analysis"
        },
        {
          "layout": "CONTENT",
          "title": "Current State Architecture",
          "description": "How it works today"
        },
        {
          "layout": "IMAGE_TITLE",
          "title": "System Diagram",
          "description": "Visual architecture"
        },
        {
          "layout": "KPI",
          "title": "Performance Metrics",
          "description": "Baseline measurements"
        },
        {
          "layout": "TWO_COLUMN",
          "title": "Strengths & Weaknesses",
          "description": "Gap analysis"
        }
      ]
    },
    {
      "section": "Findings",
      "slides": [
        {
          "layout": "SECTION_HEADER",
          "title": "Key Findings"
        },
        {
          "layout": "CONTENT",
          "title": "Discovery #1",
          "description": "Detailed finding"
        },
        {
          "layout": "CONTENT",
          "title": "Discovery #2",
          "description": "Detailed finding"
        },
        {
          "layout": "CONTENT",
          "title": "Discovery #3",
          "description": "Detailed finding"
        }
      ]
    },
    {
      "section": "Recommendations",
      "slides": [
        {
          "layout": "SECTION_HEADER",
          "title": "Proposed Solution"
        },
        {
          "layout": "CONTENT",
          "title": "Approach Overview",
          "description": "High-level solution"
        },
        {
          "layout": "IMAGE_TITLE",
          "title": "Proposed Architecture",
          "description": "Visual of new design"
        },
        {
          "layout": "CONTENT",
          "title": "Implementation Phases",
          "description": "Step-by-step plan"
        },
        {
          "layout": "TWO_COLUMN",
          "title": "Trade-offs & Alternatives",
          "description": "Why this approach"
        }
      ]
    },
    {
      "section": "Implementation",
      "slides": [
        {
          "layout": "SECTION_HEADER",
          "title": "Implementation Details"
        },
        {
          "layout": "CONTENT",
          "title": "Technical Requirements",
          "description": "Dependencies and prerequisites"
        },
        {
          "layout": "CONTENT",
          "title": "Timeline & Milestones",
          "description": "Project plan"
        },
        {
          "layout": "CONTENT",
          "title": "Resource Allocation",
          "description": "Team and budget"
        },
        {
          "layout": "CONTENT",
          "title": "Risk Mitigation",
          "description": "Potential blockers and contingencies"
        }
      ]
    },
    {
      "section": "Appendix",
      "slides": [
        {
          "layout": "SECTION_HEADER",
          "title": "Appendix & Supporting Data"
        },
        {
          "layout": "CONTENT",
          "title": "Detailed Metrics",
          "description": "Raw data and calculations"
        },
        {
          "layout": "CONTENT",
          "title": "Alternative Approaches Considered",
          "description": "Other options evaluated"
        },
        {
          "layout": "CONTENT",
          "title": "References & Citations",
          "description": "Sources and documentation"
        }
      ]
    },
    {
      "section": "Closing",
      "slides": [
        {
          "layout": "CONTENT",
          "title": "Summary & Next Steps",
          "required": true
        },
        {
          "layout": "CLOSING",
          "title": "Questions & Discussion",
          "required": true
        }
      ]
    }
  ],
  "contentGuidelines": {
    "maxSlides": 50,
    "maxBulletsPerSlide": 7,
    "maxWordsPerBullet": 20,
    "tone": "analytical, thorough, evidence-based",
    "includeDataSources": true,
    "technicality": "high",
    "detailLevel": "comprehensive",
    "recommendedDuration": "45-60 minutes"
  },
  "styleOverrides": {
    "emphasizeVisuals": true,
    "includeDiagrams": true,
    "detailedCaptions": true,
    "appendixEncouraged": true
  }
}
