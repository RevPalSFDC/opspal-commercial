erDiagram
  %% Salesforce Standard Objects ERD Template
  %% Core CRM objects and relationships

  Account {
    string Id PK
    string Name
    string Industry
    string Type
    number AnnualRevenue
    string Phone
    string Website
    string BillingAddress
    string ShippingAddress
  }

  Contact {
    string Id PK
    string AccountId FK
    string FirstName
    string LastName
    string Email
    string Phone
    string Title
    string Department
  }

  Opportunity {
    string Id PK
    string AccountId FK
    string Name
    string StageName
    date CloseDate
    number Amount
    string Type
    string LeadSource
    number Probability
  }

  OpportunityContactRole {
    string Id PK
    string OpportunityId FK
    string ContactId FK
    string Role
    boolean IsPrimary
  }

  Lead {
    string Id PK
    string FirstName
    string LastName
    string Company
    string Email
    string Phone
    string Status
    string LeadSource
  }

  Case {
    string Id PK
    string AccountId FK
    string ContactId FK
    string Subject
    string Status
    string Priority
    string Origin
    string Type
  }

  Task {
    string Id PK
    string WhoId FK
    string WhatId FK
    string Subject
    string Status
    string Priority
    date ActivityDate
  }

  Event {
    string Id PK
    string WhoId FK
    string WhatId FK
    string Subject
    datetime StartDateTime
    datetime EndDateTime
    string Location
  }

  %% Relationships
  Account ||--o{ Contact : "has contacts"
  Account ||--o{ Opportunity : "has opportunities"
  Account ||--o{ Case : "has cases"
  Contact ||--o{ Opportunity : "influenced by"
  Opportunity ||--o{ OpportunityContactRole : "has contact roles"
  Contact ||--o{ OpportunityContactRole : "plays roles in"
  Contact ||--o{ Case : "has cases"
  Contact ||--o{ Task : "assigned tasks"
  Contact ||--o{ Event : "has events"
  Account ||--o{ Task : "related tasks"
  Account ||--o{ Event : "related events"
  Opportunity ||--o{ Task : "has tasks"
  Opportunity ||--o{ Event : "has events"
