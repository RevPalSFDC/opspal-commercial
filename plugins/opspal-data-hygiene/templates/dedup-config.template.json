{
  "hubspot": {
    "portalId": "REPLACE_WITH_PORTAL_ID",
    "accessToken": "${HUBSPOT_PRIVATE_APP_TOKEN}",
    "note": "Get private app token from HubSpot Settings > Integrations > Private Apps"
  },
  "salesforce": {
    "instanceUrl": "${SALESFORCE_INSTANCE_URL}",
    "accessToken": "${SALESFORCE_ACCESS_TOKEN}",
    "orgAlias": "production",
    "note": "Run 'sf org display --target-org <alias>' to get these values"
  },
  "execution": {
    "dryRun": true,
    "note_dryRun": "Set to false to execute. Always test in sandbox first!",
    "autoAssociateOffDuringCleanup": true,
    "note_autoAssociate": "CRITICAL: Must be OFF in HubSpot during cleanup",
    "batchSize": 100,
    "maxWritePerMin": 60,
    "idempotencyPrefix": "dedupe-{{TIMESTAMP}}",
    "note_idempotency": "Automatically replaced with timestamp on execution"
  },
  "canonicalWeights": {
    "hasSalesforceAccountId": 100,
    "syncHealth": 50,
    "note_syncHealth": "Sync recency + object source validation (production-validated)",
    "customFieldCompleteness": 50,
    "note_customFieldCompleteness": "NEW: Score based on criticalCustomFields completeness",
    "numContacts": 40,
    "numDeals": 25,
    "ownerPresent": 10,
    "createdateOldest": 5,
    "note": "Higher weight = higher priority. Total possible: 280 points (enhanced from 230)"
  },
  "criticalCustomFields": {
    "FY26_SGA__c": {
      "weight": 15,
      "conflictStrategy": "highest-value",
      "note": "Revenue field - prefer higher values"
    },
    "AnnualRevenue": {
      "weight": 12,
      "conflictStrategy": "highest-value"
    },
    "ARR__c": {
      "weight": 12,
      "conflictStrategy": "highest-value"
    },
    "ACV__c": {
      "weight": 10,
      "conflictStrategy": "highest-value"
    },
    "Segment__c": {
      "weight": 10,
      "conflictStrategy": "most-recent",
      "note": "Classification field - prefer most recently updated"
    },
    "Industry": {
      "weight": 8,
      "conflictStrategy": "most-recent"
    },
    "Type": {
      "weight": 6,
      "conflictStrategy": "favor-master"
    },
    "OwnerId": {
      "weight": 12,
      "conflictStrategy": "from-decision",
      "note": "Owner conflicts require manual decision"
    },
    "note_strategies": "Valid strategies: highest-value, most-recent, from-decision, favor-master, favor-duplicate, longest-string, non-null"
  },
  "output": {
    "outputDir": "./dedup-reports",
    "alertSlackWebhook": "${SLACK_WEBHOOK_URL}",
    "generateCSV": true,
    "generateJSON": true,
    "generateMarkdown": true
  },
  "guardrails": {
    "createExternalSFDCAccountIdProperty": true,
    "enforceUniqueConstraint": true,
    "keepAutoAssociateOff": true,
    "note": "Prevents duplicate recurrence after cleanup"
  },
  "validation": {
    "spotCheckPercentage": 5,
    "requireZeroDuplicatesAfter7Days": true,
    "validateAssociationPreservation": true,
    "failOnDataLoss": true
  }
}
