{
  "name": "salesforce-flow-authoring",
  "version": "4.0.3",
  "description": "Complete Salesforce Flow authoring system with CLI, templates, and batch operations",
  "main": "scripts/lib/flow-author.js",
  "bin": {
    "flow": "./cli/flow-cli.js"
  },
  "scripts": {
    "test": "bash test/run-tests.sh",
    "test:phase1.1": "node test/flow-nlp-modifier.test.js",
    "test:phase1.2": "node test/flow-permission-escalator.test.js",
    "test:phase2.1": "node test/flow-xml-parser.test.js && node test/flow-diff-checker.test.js",
    "test:phase2.2": "node test/flow-nlp-modifier-phase2.2.test.js",
    "test:phase2.3": "node test/flow-condition-parser.test.js && node test/flow-nlp-modifier-phase2.3.test.js",
    "test:phase3.0": "node test/flow-author.test.js",
    "cli": "node cli/flow-cli.js"
  },
  "keywords": [
    "salesforce",
    "flow",
    "automation",
    "cli",
    "deployment",
    "testing"
  ],
  "author": "RevPal Engineering",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "glob": "^10.3.10",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1",
    "p-limit": "^5.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@xmldom/xmldom": "^0.8.11",
    "jest": "^30.2.0",
    "mocha": "^11.7.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RevPalSFDC/opspal-plugin-internal-marketplace"
  }
}
