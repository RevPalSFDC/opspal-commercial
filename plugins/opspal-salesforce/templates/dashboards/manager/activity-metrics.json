{
  "templateMetadata": {
    "templateId": "activity-metrics",
    "templateName": "Sales Manager Activity Metrics Dashboard",
    "templateVersion": "1.1",
    "description": "Team activity tracking: calls, emails, meetings, engagement rates, and productivity trends",
    "audience": "Sales Managers, Team Leads, Sales Operations",
    "function": "sales",
    "level": "manager",
    "useCase": "Monitor team effort levels, identify coaching needs, correlate activity to pipeline",
    "refreshFrequency": "Daily",
    "componentCount": 7,
    "tags": ["activity", "calls", "emails", "meetings", "productivity", "sales"]
  },
  "variations": {
    "schemaVersion": "1.0",
    "baseTemplate": true,
    "availableVariations": ["simple", "standard", "outbound", "inbound"],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified view with 5 key activity components",
        "componentOverrides": {
          "maxComponents": 5,
          "exclude": ["Inactive Reps (No Activity 48h)", "Team Activity Trend (Last 30 Days)"]
        },
        "orgAdaptationOverrides": {
          "minimumFidelity": 0.5
        }
      },
      "standard": {
        "description": "Full activity metrics dashboard with all 7 components"
      },
      "outbound": {
        "description": "Outbound sales team focus with higher activity targets",
        "metricAdjustments": {
          "activitiesPerRep": {
            "target": "50",
            "thresholds": { "green": ">=50", "yellow": "30-50", "red": "<30" }
          }
        }
      },
      "inbound": {
        "description": "Inbound/inside sales with response-focused metrics",
        "metricAdjustments": {
          "activitiesPerRep": {
            "target": "25",
            "thresholds": { "green": ">=25", "yellow": "15-25", "red": "<15" }
          }
        }
      }
    }
  },
  "orgAdaptation": {
    "requiredFields": ["Task.ActivityDate", "Task.OwnerId", "Task.Type"],
    "optionalFields": ["Task.Subject", "Event.StartDateTime", "Last_Activity_Date__c"],
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "ActivityType": {
        "patterns": ["Type", "Activity_Type__c", "TaskSubtype"],
        "labelHints": ["Activity Type", "Task Type", "Type"],
        "dataType": "picklist"
      },
      "ActivityDate": {
        "patterns": ["ActivityDate", "Activity_Date__c", "CompletedDateTime"],
        "labelHints": ["Activity Date", "Due Date", "Completed"],
        "dataType": "date"
      }
    },
    "dataAvailabilityTiers": {
      "complete": {
        "minimumFidelity": 0.9,
        "components": "all"
      },
      "partial": {
        "minimumFidelity": 0.7,
        "components": "essential + fallbacks",
        "enabledComponents": ["Team Activities Today", "Avg Activities per Rep", "Activities by Rep (This Week)", "Rep Activity Scorecard"]
      },
      "minimal": {
        "minimumFidelity": 0.5,
        "components": "essential only",
        "enabledComponents": ["Team Activities Today", "Avg Activities per Rep"]
      }
    }
  },
  "dashboardLayout": {
    "components": [
      {
        "position": 1,
        "size": "quarter-width",
        "type": "Metric",
        "title": "Team Activities Today",
        "sourceReport": "team-activities-today",
        "metric": "COUNT(Task WHERE ActivityDate = TODAY)",
        "showComparison": "vs Yesterday",
        "trendIndicator": true
      },
      {
        "position": 2,
        "size": "quarter-width",
        "type": "Metric",
        "title": "Avg Activities per Rep",
        "sourceReport": "avg-activities-per-rep",
        "metric": "Total_Activities__c / Active_Rep_Count__c",
        "target": "20",
        "greenZone": ">=20",
        "yellowZone": "10-20",
        "redZone": "<10"
      },
      {
        "position": 3,
        "size": "quarter-width",
        "type": "Metric",
        "title": "New Opportunities Created",
        "sourceReport": "new-opps-this-week",
        "metric": "COUNT(Opportunity WHERE CreatedDate = THIS_WEEK)",
        "showComparison": "vs Last Week"
      },
      {
        "position": 4,
        "size": "quarter-width",
        "type": "Metric",
        "title": "Inactive Reps (No Activity 48h)",
        "sourceReport": "inactive-reps",
        "metric": "COUNT(User WHERE Last_Activity_Date__c < TODAY - 2)",
        "colorCode": {"0": "green", "1-2": "yellow", ">=3": "red"}
      },
      {
        "position": 5,
        "size": "half-width",
        "type": "Stacked Bar Chart",
        "title": "Activities by Rep (This Week)",
        "sourceReport": "activities-by-rep-this-week",
        "groupBy": "Owner",
        "stackBy": "Activity Type (Call, Email, Meeting)",
        "metric": "COUNT(Task)",
        "sortBy": "Total Activities DESC",
        "showDataLabels": true
      },
      {
        "position": 6,
        "size": "half-width",
        "type": "Line Chart",
        "title": "Team Activity Trend (Last 30 Days)",
        "sourceReport": "team-activity-trend-30d",
        "xAxis": "Date",
        "yAxis": "Total Activities",
        "showMovingAverage": "7-day",
        "trendline": true
      },
      {
        "position": 7,
        "size": "full-width",
        "type": "Table",
        "title": "Rep Activity Scorecard (This Week)",
        "sourceReport": "rep-activity-scorecard",
        "columns": [
          "Rep Name",
          "Total Activities",
          "Calls",
          "Emails",
          "Meetings",
          "New Opps Created",
          "Pipeline Added ($)",
          "Activities per Opp",
          "Last Activity Date"
        ],
        "sortBy": "Total Activities DESC",
        "conditionalFormatting": {
          "Total_Activities__c": {">=100": "green", ">=50": "yellow", "<50": "red"},
          "Last_Activity_Date__c": {"<TODAY-2": "red", "<TODAY-1": "yellow"}
        }
      }
    ]
  },
  "dashboardFilters": [
    {"field": "Activity Date", "type": "Date Range", "default": "THIS_WEEK"},
    {"field": "Activity Type", "type": "Picklist", "default": "All", "values": ["All", "Call", "Email", "Meeting"]},
    {"field": "Rep", "type": "Picklist", "default": "All", "source": "User.Manager = $User.Id"}
  ],
  "sourceReportTemplates": [
    "sales-managers/team-activities-today",
    "sales-managers/avg-activities-per-rep",
    "sales-managers/new-opps-this-week",
    "sales-managers/inactive-reps",
    "sales-managers/activities-by-rep-this-week",
    "sales-managers/team-activity-trend-30d",
    "sales-managers/rep-activity-scorecard"
  ],
  "dataRequirements": {
    "objects": ["Task", "Event", "Opportunity"],
    "fields": [
      "Task.Subject",
      "Task.ActivityDate",
      "Task.Type (Call, Email, Other)",
      "Task.OwnerId",
      "Event.StartDateTime",
      "Event.Subject"
    ],
    "prerequisites": [
      "Activity logging enabled",
      "Tasks associated with Opportunities/Leads/Contacts",
      "Activity Types standardized (Call, Email, Meeting)"
    ]
  },
  "calculatedFieldsRequired": [
    {
      "fieldName": "Last_Activity_Date__c",
      "fieldType": "Formula (Date)",
      "formula": "MAX(Task.ActivityDate, Event.StartDateTime)",
      "object": "User",
      "description": "Most recent activity date for rep"
    },
    {
      "fieldName": "Activities_Per_Opp__c",
      "fieldType": "Formula (Number)",
      "formula": "Total_Activities__c / New_Opps_This_Period__c",
      "object": "User",
      "description": "Activity efficiency metric"
    }
  ],
  "deploymentInstructions": {
    "steps": [
      "1. Verify Task and Event objects are properly configured",
      "2. Standardize Activity Types (Call, Email, Meeting) via picklist values",
      "3. Create calculated fields (Last_Activity_Date__c, Activities_Per_Opp__c)",
      "4. Create all 7 source reports using templates",
      "5. Add report filter: Owner.Manager = $User.Id (dynamic filtering)",
      "6. Create dashboard in Dashboards folder (Manager)",
      "7. Add components in order specified",
      "8. Configure filters (Activity Date, Activity Type, Rep)",
      "9. Set refresh schedule to daily at 6 AM",
      "10. Share with managers (view-only or editor)",
      "11. Create alerts: Team activities <target, Inactive reps >=3"
    ],
    "activityTrackingSetup": {
      "salesforceMobileApp": "Enable mobile app for reps to log calls/emails on-the-go",
      "emailIntegration": "Connect Gmail/Outlook to auto-log emails to Salesforce",
      "calendarSync": "Sync calendar to auto-create Events for meetings",
      "callLogging": "Use CTI integration (Aircall, RingCentral) to auto-log calls"
    }
  },
  "kpiDefinitions": {
    "activitiesPerRep": {
      "formula": "Total Activities / Number of Reps",
      "benchmark": "20-30 activities/day for outbound sales, 10-15 for inbound",
      "whyItMatters": "Measures rep effort and engagement levels"
    },
    "activitiesPerOpp": {
      "formula": "Total Activities / New Opportunities Created",
      "benchmark": "10-20 activities per opportunity (varies by sales cycle)",
      "whyItMatters": "Efficiency metric - are reps creating pipeline with reasonable effort?"
    },
    "newOppsCreated": {
      "formula": "COUNT(Opportunity WHERE CreatedDate = Period)",
      "benchmark": "Varies by role (BDR: 5-10/week, AE: 2-5/week)",
      "whyItMatters": "Leading indicator of future pipeline health"
    }
  },
  "usageScenarios": {
    "dailyCheckIn": {
      "focus": "Team activities today, inactive reps",
      "questions": [
        "Is the team on pace for weekly activity goals?",
        "Are any reps inactive and need a check-in?"
      ]
    },
    "weeklyReview": {
      "focus": "Activities by rep, new opps created, scorecard",
      "questions": [
        "Who's the most active? Who needs coaching?",
        "Are we creating enough new pipeline?",
        "Is activity correlated with pipeline creation?"
      ]
    },
    "monthlyPerformance": {
      "focus": "Activity trend, activities per opp",
      "questions": [
        "Are activity levels increasing or decreasing?",
        "Is the team becoming more or less efficient?"
      ]
    }
  },
  "coachingInsights": {
    "activityBenchmarks": {
      "outboundSDR": "50-80 activities/day (mostly calls/emails)",
      "inboundSDR": "20-30 activities/day (responding to inbound)",
      "AE": "10-20 activities/day (meetings + follow-ups)",
      "manager": "5-10 activities/day (coaching + escalations)"
    },
    "redFlags": [
      "Rep with <10 activities/day",
      "No activity for 48+ hours",
      "High activity but no new opportunities (inefficient prospecting)",
      "Low activities per opp (<5) - may indicate poor qualification"
    ],
    "actionItems": [
      "Low activity → 1-on-1 to identify blockers or motivation issues",
      "Inactive rep → Immediate check-in (sick? PTO? quit?)",
      "High activity, no opps → Review prospecting quality and targeting",
      "Low activities per opp → Review data entry compliance"
    ]
  },
  "relatedTemplates": [
    "team-pipeline.json",
    "quota-attainment.json"
  ]
}
