{
  "templateMetadata": {
    "templateId": "team-pipeline",
    "templateName": "Sales Manager Team Pipeline Dashboard",
    "templateVersion": "1.1",
    "description": "Detailed team pipeline view with rep-level breakdown, stage distribution, and deal inspection",
    "audience": "Sales Managers, Team Leads",
    "function": "sales",
    "level": "manager",
    "useCase": "Daily pipeline reviews, 1-on-1 coaching, deal prioritization, forecast accuracy",
    "refreshFrequency": "Hourly or Real-time",
    "componentCount": 7,
    "tags": ["pipeline", "team", "manager", "forecast", "sales"]
  },
  "variations": {
    "schemaVersion": "1.0",
    "baseTemplate": true,
    "availableVariations": ["simple", "standard", "cpq", "enterprise", "smb"],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified view with 5 key components for smaller teams",
        "componentOverrides": {
          "maxComponents": 5,
          "exclude": ["Pipeline by Close Date", "Top 15 Deals by Value"]
        },
        "orgAdaptationOverrides": {
          "minimumFidelity": 0.5
        }
      },
      "standard": {
        "description": "Full team pipeline dashboard with all 7 components"
      },
      "cpq": {
        "description": "CPQ-optimized with SBQQ quote-linked pipeline values",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c",
          "Team_Pipeline__c": "SUM(SBQQ__NetAmount__c WHERE IsClosed=FALSE)"
        },
        "metricAdjustments": {
          "teamCoverageRatio": {
            "formula": "SUM(SBQQ__NetAmount__c WHERE IsClosed=FALSE) / Team_Quota__c"
          }
        }
      },
      "enterprise": {
        "description": "Enterprise thresholds with higher coverage targets",
        "metricAdjustments": {
          "teamCoverageRatio": {
            "target": "4x",
            "thresholds": { "green": ">=4x", "yellow": "3-4x", "red": "<3x" }
          }
        }
      },
      "smb": {
        "description": "SMB focus with faster deal cycles and lower thresholds",
        "metricAdjustments": {
          "teamCoverageRatio": {
            "target": "2.5x",
            "thresholds": { "green": ">=2.5x", "yellow": "2-2.5x", "red": "<2x" }
          }
        }
      }
    }
  },
  "orgAdaptation": {
    "requiredFields": ["Amount", "StageName", "CloseDate", "OwnerId", "IsClosed"],
    "optionalFields": ["Close_Date_Bucket__c", "Age__c", "Probability"],
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Amount": {
        "patterns": ["Amount", "Deal_Value__c", "Pipeline_Value__c"],
        "cpqPatterns": ["SBQQ__NetAmount__c", "SBQQ__CustomerAmount__c"],
        "namespaceAware": true,
        "fallbackChain": [
          { "namespace": "SBQQ", "field": "SBQQ__NetAmount__c" },
          { "namespace": null, "field": "Amount" }
        ],
        "dataType": "currency"
      },
      "Quota": {
        "patterns": ["Team_Quota__c", "Quota__c", "Target_Quota__c"],
        "labelHints": ["Quota", "Target", "Goal"],
        "dataType": "currency"
      }
    },
    "dataAvailabilityTiers": {
      "complete": {
        "minimumFidelity": 0.9,
        "components": "all"
      },
      "partial": {
        "minimumFidelity": 0.7,
        "components": "essential + fallbacks",
        "enabledComponents": ["Team Pipeline Value", "Team Coverage Ratio", "Pipeline by Rep", "Team Pipeline by Stage"]
      },
      "minimal": {
        "minimumFidelity": 0.5,
        "components": "essential only",
        "enabledComponents": ["Team Pipeline Value", "Pipeline by Rep"]
      }
    }
  },
  "dashboardLayout": {
    "components": [
      {
        "position": 1,
        "size": "third-width",
        "type": "Metric",
        "title": "Team Pipeline Value",
        "sourceReport": "team-pipeline-total",
        "metric": "SUM(Amount WHERE IsClosed=FALSE AND Owner.Manager = $User.Id)",
        "showComparison": "vs Last Week",
        "trendIndicator": true
      },
      {
        "position": 2,
        "size": "third-width",
        "type": "Metric",
        "title": "Team Coverage Ratio",
        "sourceReport": "team-coverage-ratio",
        "metric": "Team_Pipeline__c / Team_Quota__c",
        "target": "3x",
        "greenZone": ">=3x",
        "yellowZone": "2-3x",
        "redZone": "<2x"
      },
      {
        "position": 3,
        "size": "third-width",
        "type": "Metric",
        "title": "Deals Closing This Month",
        "sourceReport": "deals-closing-this-month",
        "metric": "COUNT(Opportunity WHERE CloseDate = THIS_MONTH)",
        "showValue": "Count and Total Amount"
      },
      {
        "position": 4,
        "size": "half-width",
        "type": "Horizontal Bar Chart",
        "title": "Pipeline by Rep",
        "sourceReport": "pipeline-by-rep",
        "groupBy": "Owner",
        "metric": "SUM(Amount)",
        "sortBy": "Amount DESC",
        "showDataLabels": true,
        "colorCode": "by coverage ratio"
      },
      {
        "position": 5,
        "size": "half-width",
        "type": "Funnel Chart",
        "title": "Team Pipeline by Stage",
        "sourceReport": "team-pipeline-by-stage",
        "groupBy": "Stage",
        "metric": "SUM(Amount)",
        "showConversionRates": true,
        "showCounts": true
      },
      {
        "position": 6,
        "size": "half-width",
        "type": "Donut Chart",
        "title": "Pipeline by Close Date",
        "sourceReport": "pipeline-by-close-date",
        "groupBy": "Close_Date_Bucket__c",
        "metric": "SUM(Amount)",
        "segments": ["This Month", "Next Month", "This Quarter", "Later"],
        "colorCode": {"This Month": "green", "Next Month": "blue", "This Quarter": "orange", "Later": "gray"}
      },
      {
        "position": 7,
        "size": "half-width",
        "type": "Table",
        "title": "Top 15 Deals by Value",
        "sourceReport": "top-deals-by-value",
        "columns": ["Opportunity Name", "Account", "Owner", "Amount", "Stage", "Probability %", "Close Date", "Age (Days)"],
        "sortBy": "Amount DESC",
        "rowLimit": 15,
        "conditionalFormatting": {
          "Age__c": {">=60": "red", ">=30": "yellow"},
          "Probability": {">=70": "green", ">=50": "yellow", "<50": "gray"}
        },
        "clickthrough": "Open Opportunity Record"
      }
    ]
  },
  "dashboardFilters": [
    {"field": "Close Date", "type": "Date Range", "default": "THIS_FISCAL_QUARTER"},
    {"field": "Stage", "type": "Picklist", "default": "All Open", "values": ["All Open", "Qualification", "Discovery", "Proposal", "Negotiation"]},
    {"field": "Rep", "type": "Picklist", "default": "All", "source": "User.Manager = $User.Id"}
  ],
  "sourceReportTemplates": [
    "sales-managers/team-pipeline-total",
    "sales-managers/team-coverage-ratio",
    "sales-managers/deals-closing-this-month",
    "sales-managers/pipeline-by-rep",
    "sales-managers/team-pipeline-by-stage",
    "sales-managers/pipeline-by-close-date",
    "sales-managers/top-deals-by-value"
  ],
  "calculatedFieldsRequired": [
    {
      "fieldName": "Close_Date_Bucket__c",
      "fieldType": "Formula (Text)",
      "formula": "IF(CloseDate <= TODAY() + 30, 'This Month', IF(CloseDate <= TODAY() + 60, 'Next Month', IF(CloseDate <= End_of_Quarter__c, 'This Quarter', 'Later')))",
      "description": "Group opportunities by close date proximity"
    },
    {
      "fieldName": "Age__c",
      "fieldType": "Formula (Number)",
      "formula": "TODAY() - CreatedDate",
      "description": "Days since opportunity was created"
    }
  ],
  "deploymentInstructions": {
    "steps": [
      "1. Create calculated fields (Close_Date_Bucket__c, Age__c)",
      "2. Create all 7 source reports using templates",
      "3. Add report filter: Owner.Manager = $User.Id (dynamic filtering)",
      "4. Create dashboard in Dashboards folder (Manager)",
      "5. Add components in order specified",
      "6. Configure filters (Close Date, Stage, Rep)",
      "7. Set refresh schedule to hourly (or real-time if available)",
      "8. Share with managers (view-only or editor based on role)",
      "9. Subscribe managers to daily morning email snapshot"
    ],
    "managerAccessNote": "Dashboard dynamically filters to show only opportunities owned by reps reporting to the logged-in manager"
  },
  "usageScenarios": {
    "dailyStandup": {
      "focus": "Top deals by value table, deals closing this month",
      "questions": [
        "Which deals are closing this month?",
        "Are any large deals at risk?",
        "Where do we need to focus team attention?"
      ]
    },
    "ogamma-corp": {
      "focus": "Pipeline by rep, top deals by value",
      "questions": [
        "Does this rep have enough pipeline?",
        "What deals should we prioritize?",
        "Are there any stalled deals?"
      ]
    },
    "weeklyReview": {
      "focus": "Team coverage ratio, pipeline by stage",
      "questions": [
        "Is our team coverage healthy?",
        "Where are deals getting stuck?",
        "Do we need more top-of-funnel activity?"
      ]
    }
  },
  "kpiDefinitions": {
    "teamCoverageRatio": {
      "formula": "Team Pipeline / Team Quota",
      "benchmark": "3-4x for healthy coverage",
      "whyItMatters": "Ensures team has enough pipeline to hit collective quota"
    },
    "pipelineDistribution": {
      "formula": "Pipeline amount by rep",
      "benchmark": "Relatively even distribution (within 2x range)",
      "whyItMatters": "Identifies reps with insufficient pipeline who need coaching or lead redistribution"
    }
  },
  "coachingInsights": {
    "redFlags": [
      "Rep with <2x coverage ratio",
      "Deals >60 days old with no recent activity",
      "Heavy concentration in early stages (Qualification/Discovery)",
      "Large deals with <50% probability and close date this month"
    ],
    "actionItems": [
      "Coverage <2x → Increase prospecting activity or lead redistribution",
      "Stalled deals → Manager to join customer calls and unblock",
      "Early-stage concentration → Review qualification criteria",
      "Large at-risk deals → Escalate to leadership for support"
    ]
  },
  "relatedTemplates": [
    "activity-metrics.json",
    "quota-attainment.json"
  ]
}
