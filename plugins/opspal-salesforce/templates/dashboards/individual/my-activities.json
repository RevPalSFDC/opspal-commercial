{
  "templateMetadata": {
    "templateId": "my-activities",
    "templateName": "My Activities Dashboard (Individual Rep)",
    "templateVersion": "1.1",
    "description": "Personal activity tracking: calls, emails, meetings, daily goals, productivity trends",
    "audience": "Sales Reps, BDRs, AEs",
    "function": "sales",
    "level": "individual",
    "useCase": "Track personal productivity, hit daily activity goals, monitor effort levels",
    "refreshFrequency": "Real-time or Hourly",
    "componentCount": 7,
    "tags": ["activity", "personal", "tasks", "productivity", "sales"]
  },
  "variations": {
    "schemaVersion": "1.0",
    "baseTemplate": true,
    "availableVariations": ["simple", "standard", "bdr", "ae"],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified view with 5 key activity components",
        "componentOverrides": {
          "maxComponents": 5,
          "exclude": ["My Daily Activity Trend (Last 30 Days)", "My Activity Mix (This Week)"]
        },
        "orgAdaptationOverrides": {
          "minimumFidelity": 0.5
        }
      },
      "standard": {
        "description": "Full personal activity dashboard with all 7 components"
      },
      "bdr": {
        "description": "BDR/SDR focus with higher outbound activity targets",
        "metricAdjustments": {
          "activitiesPerDay": {
            "target": "50",
            "thresholds": { "green": ">=50", "yellow": "30-50", "red": "<30" }
          }
        }
      },
      "ae": {
        "description": "Account Executive focus with meeting-centric metrics",
        "metricAdjustments": {
          "activitiesPerDay": {
            "target": "15",
            "thresholds": { "green": ">=15", "yellow": "10-15", "red": "<10" }
          }
        }
      }
    }
  },
  "orgAdaptation": {
    "requiredFields": ["Task.ActivityDate", "Task.OwnerId"],
    "optionalFields": ["Task.Type", "Task.Subject", "Event.StartDateTime"],
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "ActivityType": {
        "patterns": ["Type", "Activity_Type__c", "TaskSubtype"],
        "labelHints": ["Activity Type", "Task Type", "Type"],
        "dataType": "picklist"
      },
      "ActivityDate": {
        "patterns": ["ActivityDate", "Activity_Date__c", "CompletedDateTime"],
        "labelHints": ["Activity Date", "Due Date"],
        "dataType": "date"
      }
    },
    "dataAvailabilityTiers": {
      "complete": {
        "minimumFidelity": 0.9,
        "components": "all"
      },
      "partial": {
        "minimumFidelity": 0.7,
        "components": "essential + fallbacks",
        "enabledComponents": ["My Activities Today", "Calls Today", "Emails Today", "My Upcoming Tasks"]
      },
      "minimal": {
        "minimumFidelity": 0.5,
        "components": "essential only",
        "enabledComponents": ["My Activities Today", "My Upcoming Tasks"]
      }
    }
  },
  "dashboardLayout": {
    "components": [
      {
        "position": 1,
        "size": "quarter-width",
        "type": "Metric",
        "title": "My Activities Today",
        "sourceReport": "my-activities-today",
        "metric": "COUNT(Task WHERE ActivityDate=TODAY() AND OwnerId=$User.Id)",
        "target": "20",
        "showProgress": "towards daily goal",
        "greenZone": ">=20",
        "yellowZone": "10-20",
        "redZone": "<10"
      },
      {
        "position": 2,
        "size": "quarter-width",
        "type": "Metric",
        "title": "Calls Today",
        "sourceReport": "my-calls-today",
        "metric": "COUNT(Task WHERE Type='Call' AND ActivityDate=TODAY())",
        "showComparison": "vs Yesterday"
      },
      {
        "position": 3,
        "size": "quarter-width",
        "type": "Metric",
        "title": "Emails Today",
        "sourceReport": "my-emails-today",
        "metric": "COUNT(Task WHERE Type='Email' AND ActivityDate=TODAY())",
        "showComparison": "vs Yesterday"
      },
      {
        "position": 4,
        "size": "quarter-width",
        "type": "Metric",
        "title": "Meetings This Week",
        "sourceReport": "my-meetings-this-week",
        "metric": "COUNT(Event WHERE StartDateTime>=THIS_WEEK)",
        "target": "5"
      },
      {
        "position": 5,
        "size": "half-width",
        "type": "Line Chart",
        "title": "My Daily Activity Trend (Last 30 Days)",
        "sourceReport": "my-activity-trend-30d",
        "xAxis": "Date",
        "yAxis": "Total Activities",
        "showMovingAverage": "7-day",
        "showTarget": "20 activities/day",
        "trendline": true
      },
      {
        "position": 6,
        "size": "half-width",
        "type": "Donut Chart",
        "title": "My Activity Mix (This Week)",
        "sourceReport": "my-activity-mix-this-week",
        "groupBy": "Activity Type",
        "metric": "COUNT(Task)",
        "segments": ["Call", "Email", "Meeting", "Other"],
        "colorCode": {"Call": "blue", "Email": "green", "Meeting": "orange", "Other": "gray"}
      },
      {
        "position": 7,
        "size": "full-width",
        "type": "Table",
        "title": "My Upcoming Tasks (Next 7 Days)",
        "sourceReport": "my-upcoming-tasks",
        "columns": [
          "Subject",
          "Related To (Opp/Lead/Contact)",
          "Type",
          "Due Date",
          "Priority",
          "Status"
        ],
        "sortBy": "Due Date ASC",
        "rowLimit": 20,
        "conditionalFormatting": {
          "DueDate": {"<TODAY()": "red", "=TODAY()": "orange", "<=TODAY()+3": "yellow"},
          "Priority": {"High": "red", "Normal": "blue"}
        },
        "clickthrough": "Open Task Record"
      }
    ]
  },
  "dashboardFilters": [
    {"field": "Activity Date", "type": "Date Range", "default": "THIS_WEEK"},
    {"field": "Activity Type", "type": "Picklist", "default": "All", "values": ["All", "Call", "Email", "Meeting", "Other"]}
  ],
  "sourceReportTemplates": [
    "sales-reps/my-activities-today",
    "sales-reps/my-calls-today",
    "sales-reps/my-emails-today",
    "sales-reps/my-meetings-this-week",
    "sales-reps/my-activity-trend-30d",
    "sales-reps/my-activity-mix-this-week",
    "sales-reps/my-upcoming-tasks"
  ],
  "dataRequirements": {
    "objects": ["Task", "Event"],
    "fields": [
      "Task.Subject",
      "Task.Type (Call, Email, Other)",
      "Task.ActivityDate",
      "Task.Status (Not Started, In Progress, Completed)",
      "Task.Priority (High, Normal, Low)",
      "Task.WhoId (Lead/Contact)",
      "Task.WhatId (Opportunity/Account)",
      "Event.Subject",
      "Event.StartDateTime"
    ],
    "prerequisites": [
      "Reps must log activities in Salesforce",
      "Activity Types standardized (Call, Email, Meeting)",
      "Tasks linked to Opportunities/Leads/Contacts"
    ]
  },
  "deploymentInstructions": {
    "steps": [
      "1. Verify Task and Event objects have required fields",
      "2. Standardize Activity Types via picklist values",
      "3. Create all 7 source reports using templates",
      "4. Add report filter: OwnerId = $User.Id (shows only logged-in user's records)",
      "5. Create dashboard in Dashboards folder (My Dashboards)",
      "6. Add components in order specified",
      "7. Configure filters (Activity Date, Activity Type)",
      "8. Set refresh to real-time (if available) or hourly",
      "9. Make dashboard personal (not shared) or share with all reps",
      "10. Pin dashboard to Home Page for easy access"
    ],
    "activityGoalSetting": {
      "BDR": "50-80 activities/day (mostly outbound calls/emails)",
      "InboundSDR": "20-30 activities/day (responding to inbound leads)",
      "AE": "10-20 activities/day (meetings, follow-ups, proposals)",
      "customizableTargets": "Adjust metric targets based on your role"
    }
  },
  "usageScenarios": {
    "morningSetup": {
      "time": "8:00 AM - Start of day",
      "focus": "Upcoming tasks table",
      "questions": [
        "What tasks are due today?",
        "What calls do I need to make?",
        "What meetings do I have?"
      ],
      "actions": [
        "Review and prioritize task list",
        "Block time for high-priority calls",
        "Prepare for scheduled meetings"
      ]
    },
    "midDayTracking": {
      "time": "12:00 PM - Mid-day",
      "focus": "Activities today metric, activity mix",
      "questions": [
        "Am I on track for my daily goal?",
        "Am I balanced between calls/emails/meetings?",
        "Do I need to increase activity this afternoon?"
      ],
      "actions": [
        "If <50% of goal, increase activity pace",
        "Ensure balanced mix (not just emails)",
        "Log all morning activities if not done yet"
      ]
    },
    "endOfDayReview": {
      "time": "5:00 PM - End of day",
      "focus": "Activities today, activity trend",
      "questions": [
        "Did I hit my daily activity goal?",
        "How does today compare to my 7-day average?",
        "What tasks carry over to tomorrow?"
      ],
      "actions": [
        "Log any missed activities",
        "Create tasks for tomorrow's follow-ups",
        "Celebrate if goal achieved!"
      ]
    }
  },
  "kpiDefinitions": {
    "activitiesPerDay": {
      "formula": "COUNT(Task WHERE ActivityDate = Period)",
      "benchmark": "20-30 for outbound, 10-15 for inbound, 5-10 for AE",
      "whyItMatters": "Measures daily effort and engagement"
    },
    "activityMix": {
      "formula": "% of activities by type (Call, Email, Meeting)",
      "benchmark": "Balanced mix: 40% calls, 40% emails, 20% meetings (varies by role)",
      "whyItMatters": "Ensures reps aren't relying too heavily on one activity type"
    }
  },
  "bestPractices": {
    "activityLogging": [
      "Log activities in real-time (don't wait until end of day)",
      "Link every activity to a Lead/Contact/Opportunity",
      "Use standardized Activity Types (don't use 'Other')",
      "Add meaningful notes in Task description"
    ],
    "dailyGoals": [
      "Set realistic daily activity goals based on role",
      "Track progress throughout the day (not just at end)",
      "Celebrate hitting goals (gamification)",
      "Review weekly trends to identify patterns"
    ],
    "commonMistakes": [
      "❌ Not logging activities (makes you look inactive)",
      "❌ Logging activities at end of week (lack of detail)",
      "❌ Using 'Other' activity type (not useful for reporting)",
      "❌ Not linking activities to records (can't correlate to results)"
    ]
  },
  "gamificationIdeas": {
    "dailyStreaks": "Track consecutive days hitting activity goal",
    "weeklyLeaderboard": "Compare activity levels with peers (friendly competition)",
    "badges": "Earn badges for milestones (100 calls, 50 meetings, etc.)",
    "activityBingo": "Complete activity mix goals (e.g., 10 calls + 10 emails + 2 meetings)"
  },
  "relatedTemplates": [
    "my-pipeline.json",
    "my-quota.json"
  ]
}
