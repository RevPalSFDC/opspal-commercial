<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <!--
    TEMPLATE: Read-Only Base Permission Set
    CATEGORY: Basic
    DESCRIPTION: Provides read-only access to standard objects for reporting and analysis
    TIER: 1 (Foundational)

    USE CASES:
    - Reporting analysts who need to view data
    - External consultants requiring read-only access
    - Audit users who need to review data
    - Dashboard viewers without edit rights

    OBJECTS INCLUDED:
    - Account (Read)
    - Contact (Read)
    - Opportunity (Read)
    - Lead (Read)
    - Case (Read)

    FIELD ACCESS:
    - Standard fields: Read-only
    - Custom fields: Add as needed (read-only)

    SYSTEM PERMISSIONS:
    - API Enabled: true (for data extraction)
    - View All Data: false (respects sharing rules)

    CUSTOMIZATION CHECKLIST:
    □ 1. Replace {{PERMISSION_SET_NAME}} with your naming convention
    □ 2. Update {{LABEL}} with human-readable name
    □ 3. Update {{DESCRIPTION}} with specific use case
    □ 4. Add/remove objects as needed
    □ 5. Add field permissions for custom fields
    □ 6. Review and adjust system permissions
    □ 7. Set app visibility (add applicationVisibilities section)
    □ 8. Test with real user before production

    NAMING CONVENTION:
    Standard_<Object>_Read (e.g., Standard_Account_Read)

    TWO-TIER ARCHITECTURE:
    This is a Tier 1 foundational set. Can be composed into Tier 2 role-based sets:
    - Reporting_Analyst (composes multiple *_Read sets)
    - External_Consultant (read-only across modules)
    - Audit_User (read-only with enhanced security)
    -->

    <description>{{DESCRIPTION}}</description>
    <label>{{LABEL}}</label>

    <!-- OBJECT PERMISSIONS -->
    <!-- Pattern: Read-only access (allowRead=true, all others=false) -->

    <!-- Account: Read-only access -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Contact: Read-only access -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Opportunity: Read-only access -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Opportunity</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Lead: Read-only access -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Lead</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Case: Read-only access -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Case</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- ADD MORE OBJECTS AS NEEDED -->
    <!-- Copy pattern above, set allowRead=true, all others=false -->

    <!-- FIELD PERMISSIONS -->
    <!-- Pattern: Read-only access (readable=true, editable=false) -->
    <!-- Add field permissions as needed for custom fields -->

    <!-- Example: Account custom fields -->
    <!--
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.CustomField__c</field>
        <readable>true</readable>
    </fieldPermissions>
    -->

    <!-- SYSTEM PERMISSIONS -->
    <!-- Minimal system permissions for read-only users -->

    <!-- API Enabled: Allow API access for reporting/integration tools -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>

    <!-- Run Reports: Allow running existing reports -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunReports</name>
    </userPermissions>

    <!-- View Setup: Allow viewing setup (but not modifying) -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewSetup</name>
    </userPermissions>

    <!-- View All Data: Set to true only if needed to bypass sharing rules -->
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewAllData</name>
    </userPermissions>

    <!-- APPLICATION VISIBILITY -->
    <!-- Add applicationVisibilities section to grant app access -->
    <!--
    <applicationVisibilities>
        <application>standard__Sales</application>
        <default>false</default>
        <visible>true</visible>
    </applicationVisibilities>
    -->

    <!-- TAB SETTINGS -->
    <!-- Add tabSettings section to control tab visibility -->
    <!--
    <tabSettings>
        <tab>standard-Account</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>standard-Opportunity</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    -->

    <!--
    TESTING CHECKLIST:
    □ 1. Deploy to sandbox
    □ 2. Create test user
    □ 3. Assign permission set to test user
    □ 4. Verify read access to all objects
    □ 5. Verify cannot create/edit/delete records
    □ 6. Verify respects sharing rules (if ViewAllData=false)
    □ 7. Verify can run reports
    □ 8. Verify can access API (if ApiEnabled=true)
    □ 9. Document any issues
    □ 10. Get approval before production deployment

    SECURITY CONSIDERATIONS:
    - ViewAllData=false ensures sharing rules are respected
    - No modify permissions prevents data changes
    - API access should only be granted when needed
    - Review field permissions to ensure no sensitive data exposure

    MAINTENANCE:
    - Review quarterly for new custom fields
    - Audit actual usage vs granted permissions
    - Remove unused objects to reduce complexity
    - Document any exceptions or special cases
    -->
</PermissionSet>
