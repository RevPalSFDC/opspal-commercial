{
  "persona": "support-manager",
  "label": "Support Manager",
  "description": "Support team manager focused on team performance, SLA compliance, customer satisfaction, and escalation management",
  "role": "Manager / Team Lead",
  "decisionScope": "Team performance, resource allocation, escalation handling, process improvement",
  "keyQuestions": [
    "Which agents need coaching?",
    "Are we meeting our SLA targets?",
    "Which customers are at risk?",
    "What are our trending issues?",
    "How is team productivity?"
  ],
  "layoutCharacteristics": {
    "fieldCount": {
      "optimal": 80,
      "max": 130,
      "priority": "Team metrics, SLA compliance, escalation details, customer satisfaction"
    },
    "sectionCount": {
      "optimal": 6,
      "max": 8,
      "recommended": ["Case Overview", "Team Context", "SLA & Performance", "Customer Satisfaction", "Escalation Details", "Historical Analysis"]
    },
    "components": {
      "required": ["Highlights Panel"],
      "recommended": ["Report Chart - Team SLA Compliance", "Report Chart - Case Aging", "Related List - Team Members", "Related List - Escalations", "Dashboard Component - Support Metrics"],
      "conditional": ["Knowledge Component", "Macros"]
    },
    "relatedLists": {
      "max": 9,
      "priority": ["Cases by Agent", "Escalated Cases", "Related Cases", "Assets", "Contacts", "Entitlements", "Survey Responses", "Emails", "Knowledge Articles"]
    }
  },
  "fieldPriorities": {
    "case": {
      "criticalFields": [
        "CaseNumber",
        "Subject",
        "Status",
        "Priority",
        "AccountId",
        "ContactId",
        "OwnerId",
        "CreatedDate",
        "ClosedDate"
      ],
      "importantFields": [
        "Origin",
        "Type",
        "Reason",
        "Description",
        "AssetId",
        "EntitlementId",
        "ParentId"
      ],
      "managerSpecificFields": [
        "SlaStartDate",
        "SlaExitDate",
        "IsStopped",
        "StopStartDate",
        "IsEscalated",
        "EscalationDate",
        "BusinessHoursId",
        "MilestoneStatus"
      ],
      "performanceFields": [
        "FirstResponseTime__c",
        "TimeToResolution__c",
        "ReopenCount__c",
        "CustomerSatisfactionScore__c",
        "AgentUtilization__c"
      ]
    },
    "account": {
      "criticalFields": [
        "Name",
        "Type",
        "OwnerId",
        "AccountNumber",
        "NumberOfEmployees",
        "AnnualRevenue"
      ],
      "managerSpecificFields": [
        "CustomerPriority__c",
        "SLA__c",
        "SupportTier__c",
        "ContractStatus__c",
        "TotalCasesOpen__c",
        "AverageCaseResolutionTime__c",
        "CustomerHealthScore__c"
      ]
    }
  },
  "compactLayoutFields": {
    "case": ["CaseNumber", "Status", "Priority", "Owner.Name", "SlaStartDate", "IsEscalated"],
    "account": ["Type", "SLA__c", "CustomerHealthScore__c", "Owner.Name"],
    "contact": ["Email", "AccountId", "Phone", "Title"]
  },
  "conditionalVisibility": {
    "rules": [
      {
        "name": "Escalated to Manager",
        "condition": "IsEscalated = true AND Owner.ManagerId = $User.Id",
        "action": "Show section 'Manager Escalation' with resolution notes and coaching opportunities"
      },
      {
        "name": "SLA Breach",
        "condition": "SlaStartDate != null AND SlaExitDate != null AND ClosedDate > SlaExitDate",
        "action": "Show section 'SLA Breach Analysis' with root cause and corrective actions"
      },
      {
        "name": "SLA At Risk",
        "condition": "SlaStartDate != null AND Status NOT IN ('Closed', 'Resolved') AND TimeToSlaExpiration < 4 hours",
        "action": "Show section 'SLA Risk Alert' with resource allocation options"
      },
      {
        "name": "High-Priority Account",
        "condition": "Account.CustomerPriority__c = 'High' OR Account.AnnualRevenue > 1000000",
        "action": "Show section 'Strategic Account' with executive briefing"
      },
      {
        "name": "Recurring Issue",
        "condition": "ParentId != null OR RecurrenceCount__c > 2",
        "action": "Show section 'Pattern Analysis' with root cause investigation"
      },
      {
        "name": "Low Customer Satisfaction",
        "condition": "CustomerSatisfactionScore__c < 3",
        "action": "Show section 'Customer Experience' with recovery plan"
      }
    ]
  },
  "mobile": {
    "optimized": true,
    "maxFieldsFirstScreen": 22,
    "priority": "Case overview, owner, SLA status, escalation flag, customer priority"
  },
  "bestPractices": {
    "useDynamicForms": true,
    "useHighlightsPanel": true,
    "usePathComponent": false,
    "maxComponentsPerPage": 18,
    "includeReportCharts": true,
    "includeDashboardComponents": true,
    "showTeamMetrics": true,
    "prioritizeSLACompliance": true
  },
  "notes": [
    "Managers need visibility into team performance and SLA compliance",
    "Escalations and at-risk cases require immediate attention",
    "Customer satisfaction metrics drive process improvements",
    "Pattern analysis helps identify systemic issues",
    "Resource allocation based on case priority and SLA risk",
    "Coaching opportunities identified through case handling analysis"
  ],
  "objectGuidance": {
    "Account": {
      "sections": [
        {"name": "Account Overview", "fields": ["Name", "Type", "OwnerId", "AccountNumber"]},
        {"name": "Support Metrics", "fields": ["TotalCasesOpen__c", "AverageCaseResolutionTime__c", "CustomerHealthScore__c"]},
        {"name": "Service Level", "fields": ["SLA__c", "SupportTier__c", "CustomerPriority__c"]},
        {"name": "Financial Context", "fields": ["AnnualRevenue", "NumberOfEmployees"]}
      ],
      "compactFields": ["Type", "SLA__c", "CustomerHealthScore__c", "OwnerId"],
      "relatedLists": ["Cases", "Contacts", "Entitlements", "Surveys"],
      "defaultTab": "Related",
      "rationale": "Support managers review accounts for case patterns and SLA compliance - Related tab shows case distribution"
    },
    "Contact": {
      "sections": [
        {"name": "Contact Information", "fields": ["Name", "AccountId", "Title", "Email", "Phone"]},
        {"name": "Support History", "fields": ["TotalCases__c", "LastCaseDate__c"]},
        {"name": "Preferences", "fields": ["PreferredContactMethod__c", "DoNotCall", "HasOptedOutOfEmail"]}
      ],
      "compactFields": ["Email", "AccountId", "Phone", "Title"],
      "relatedLists": ["Cases", "Activities"],
      "defaultTab": "Details",
      "rationale": "Managers view contacts for escalation context - Details shows communication history"
    },
    "Opportunity": {
      "sections": [
        {"name": "Opportunity Overview", "fields": ["Name", "AccountId", "Amount", "StageName", "OwnerId"]},
        {"name": "Timeline", "fields": ["CloseDate", "Type"]}
      ],
      "compactFields": ["Amount", "StageName", "AccountId", "OwnerId"],
      "relatedLists": ["Activities"],
      "defaultTab": "Details",
      "rationale": "Support managers rarely access Opportunities - basic context layout"
    },
    "Quote": {
      "sections": [
        {"name": "Quote Details", "fields": ["Name", "Status", "GrandTotal", "OpportunityId"]},
        {"name": "Timeline", "fields": ["ExpirationDate", "CreatedDate"]}
      ],
      "compactFields": ["Status", "GrandTotal", "ExpirationDate", "OpportunityId"],
      "relatedLists": ["QuoteLineItems"],
      "defaultTab": "Details",
      "rationale": "Support managers may review quotes for billing escalations"
    },
    "QuoteLineItem": {
      "sections": [
        {"name": "Line Item", "fields": ["Product2Id", "Quantity", "TotalPrice"]}
      ],
      "compactFields": ["Product2Id", "Quantity", "TotalPrice"],
      "relatedLists": [],
      "defaultTab": "Details",
      "rationale": "Minimal layout - rarely accessed by support managers"
    }
  }
}
