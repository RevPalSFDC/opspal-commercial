{
  "persona": "sales-rep",
  "label": "Sales Representative",
  "description": "Individual contributor focused on managing deals, following up on leads, and hitting personal quota",
  "role": "Individual Contributor",
  "decisionScope": "Personal performance, daily priorities, deal management",
  "keyQuestions": [
    "What do I need to do today?",
    "Am I on track to hit quota?",
    "Which deals should I prioritize?",
    "Who do I need to follow up with?"
  ],
  "layoutCharacteristics": {
    "fieldCount": {
      "optimal": 50,
      "max": 100,
      "priority": "Deal-specific details over aggregate metrics"
    },
    "sectionCount": {
      "optimal": 4,
      "max": 6,
      "recommended": ["Primary Details", "Customer Info", "Deal Status", "Next Steps"]
    },
    "components": {
      "required": ["Path", "Activities", "Highlights Panel"],
      "recommended": ["Related List - Contacts", "Related List - Tasks", "Chatter"],
      "avoid": ["Dashboard Components", "Report Charts"]
    },
    "relatedLists": {
      "max": 5,
      "priority": ["Open Tasks", "Contacts", "Activities", "Notes", "Files"]
    }
  },
  "fieldPriorities": {
    "opportunity": {
      "criticalFields": [
        "Name",
        "Amount",
        "CloseDate",
        "StageName",
        "Probability",
        "AccountId",
        "OwnerId"
      ],
      "importantFields": [
        "Type",
        "LeadSource",
        "NextStep",
        "Description",
        "ContactId"
      ],
      "contextualFields": [
        "ExpectedRevenue",
        "ForecastCategory",
        "TotalOpportunityQuantity",
        "LastModifiedDate",
        "CreatedDate"
      ],
      "lowPriorityFields": [
        "FiscalYear",
        "FiscalQuarter",
        "CampaignId"
      ]
    },
    "account": {
      "criticalFields": [
        "Name",
        "Type",
        "Industry",
        "Phone",
        "Website",
        "OwnerId"
      ],
      "importantFields": [
        "BillingAddress",
        "NumberOfEmployees",
        "AnnualRevenue",
        "Description"
      ],
      "contextualFields": [
        "ShippingAddress",
        "ParentId",
        "AccountSource"
      ]
    },
    "lead": {
      "criticalFields": [
        "Name",
        "Company",
        "Status",
        "Email",
        "Phone",
        "LeadSource",
        "OwnerId"
      ],
      "importantFields": [
        "Title",
        "Industry",
        "Rating",
        "Description"
      ]
    },
    "contact": {
      "criticalFields": [
        "Name",
        "AccountId",
        "Email",
        "Phone",
        "Title",
        "OwnerId"
      ],
      "importantFields": [
        "Department",
        "ReportsToId",
        "MailingAddress",
        "Description"
      ]
    }
  },
  "sections": {
    "contact": [
      {
        "label": "Contact Information",
        "order": 1,
        "fields": ["Name", "AccountId", "Title", "Email", "Phone", "MobilePhone", "Department", "ReportsToId", "OwnerId"]
      },
      {
        "label": "Address Information",
        "order": 2,
        "fields": ["MailingAddress", "OtherAddress"]
      },
      {
        "label": "Additional Information",
        "order": 3,
        "fields": ["LeadSource", "Description", "Birthdate"]
      }
    ],
    "opportunity": [
      {
        "label": "Opportunity Information",
        "order": 1,
        "fields": ["Name", "AccountId", "Amount", "CloseDate", "StageName", "Probability", "Type", "LeadSource", "OwnerId"]
      },
      {
        "label": "Deal Details",
        "order": 2,
        "fields": ["NextStep", "Description", "ContactId", "ExpectedRevenue", "ForecastCategory"]
      }
    ],
    "account": [
      {
        "label": "Account Information",
        "order": 1,
        "fields": ["Name", "Type", "Industry", "Phone", "Website", "NumberOfEmployees", "AnnualRevenue", "OwnerId"]
      },
      {
        "label": "Address Information",
        "order": 2,
        "fields": ["BillingAddress", "ShippingAddress"]
      },
      {
        "label": "Additional Information",
        "order": 3,
        "fields": ["ParentId", "AccountSource", "Description"]
      }
    ],
    "lead": [
      {
        "label": "Lead Information",
        "order": 1,
        "fields": ["Name", "Company", "Status", "Email", "Phone", "Title", "LeadSource", "OwnerId"]
      },
      {
        "label": "Qualification Details",
        "order": 2,
        "fields": ["Industry", "Rating", "NumberOfEmployees", "AnnualRevenue", "Description"]
      }
    ]
  },
  "compactLayoutFields": {
    "opportunity": ["Amount", "CloseDate", "StageName", "AccountId"],
    "account": ["Phone", "Type", "Industry", "Owner.Name"],
    "lead": ["Company", "Email", "Status", "Rating"],
    "contact": ["AccountId", "Email", "Phone", "Title"]
  },
  "conditionalVisibility": {
    "rules": [
      {
        "name": "Closed Won Reason",
        "condition": "StageName = 'Closed Won'",
        "action": "Show section 'Win Analysis'"
      },
      {
        "name": "Closed Lost Reason",
        "condition": "StageName = 'Closed Lost'",
        "action": "Show section 'Loss Analysis'"
      },
      {
        "name": "Renewal Details",
        "condition": "Type = 'Renewal'",
        "action": "Show section 'Renewal Information'"
      }
    ]
  },
  "mobile": {
    "optimized": true,
    "maxFieldsFirstScreen": 15,
    "priority": "Contact info, amount, close date, next steps"
  },
  "bestPractices": {
    "useDynamicForms": true,
    "useHighlightsPanel": true,
    "usePathComponent": true,
    "maxComponentsPerPage": 15,
    "filterRelatedListsToRelevant": true
  },
  "objectGuidance": {
    "Account": {
      "sections": [
        {"name": "Account Details", "fields": ["Name", "OwnerId", "Type", "Industry", "Phone", "Website"]},
        {"name": "Company Information", "fields": ["NumberOfEmployees", "AnnualRevenue", "Description"]},
        {"name": "Address Information", "fields": ["BillingAddress", "ShippingAddress"]}
      ],
      "compactFields": ["Phone", "Industry", "OwnerId", "Type"],
      "relatedLists": ["Contacts", "Opportunities", "Activities", "Notes"],
      "defaultTab": "Related",
      "rationale": "Sales reps navigate to Account to access Contacts and Opportunities - Related tab saves clicks for this hub object"
    },
    "Contact": {
      "sections": [
        {"name": "Contact Details", "fields": ["Name", "AccountId", "Title", "Department", "OwnerId"]},
        {"name": "Contact Information", "fields": ["Email", "Phone", "MobilePhone"]},
        {"name": "Address", "fields": ["MailingAddress"]},
        {"name": "Communication Preferences", "fields": ["DoNotCall", "HasOptedOutOfEmail"]}
      ],
      "compactFields": ["Phone", "Email", "AccountId", "Title"],
      "relatedLists": ["Opportunities", "Activities", "Cases"],
      "defaultTab": "Details",
      "rationale": "Sales reps need quick access to contact info (phone, email) for immediate outreach - Details tab with opt-out indicators"
    },
    "Opportunity": {
      "sections": [
        {"name": "Opportunity Details", "fields": ["Name", "AccountId", "Amount", "CloseDate", "StageName", "Probability", "OwnerId"]},
        {"name": "Deal Information", "fields": ["Type", "LeadSource", "CampaignId", "ContactId"]},
        {"name": "Next Steps", "fields": ["NextStep", "Description"]},
        {"name": "Forecasting", "fields": ["ForecastCategory", "ExpectedRevenue"]}
      ],
      "compactFields": ["Amount", "CloseDate", "StageName", "AccountId"],
      "relatedLists": ["OpportunityLineItems", "Contacts", "Activities", "Quotes"],
      "defaultTab": "Details",
      "rationale": "Sales reps work with Opportunities by updating Stage, Amount, and Close Date - Details tab for daily deal management"
    },
    "Quote": {
      "sections": [
        {"name": "Quote Details", "fields": ["Name", "OpportunityId", "Status", "ExpirationDate"]},
        {"name": "Pricing Summary", "fields": ["Subtotal", "Discount", "TotalPrice", "GrandTotal"]},
        {"name": "Customer Information", "fields": ["AccountId", "ContactId"]},
        {"name": "Addresses", "fields": ["BillingAddress", "ShippingAddress"]}
      ],
      "compactFields": ["Status", "GrandTotal", "ExpirationDate", "OpportunityId"],
      "relatedLists": ["QuoteLineItems", "Documents", "EmailMessages"],
      "defaultTab": "Related",
      "rationale": "Sales reps primarily add/edit Quote Line Items - Related tab provides quick access to line items"
    },
    "QuoteLineItem": {
      "sections": [
        {"name": "Product Information", "fields": ["Product2Id", "Description", "PricebookEntryId"]},
        {"name": "Quantity and Price", "fields": ["Quantity", "UnitPrice", "Discount", "TotalPrice"]}
      ],
      "compactFields": ["Product2Id", "Quantity", "TotalPrice"],
      "relatedLists": [],
      "defaultTab": "Details",
      "rationale": "Quote Line Items are detail records - sales reps edit quantity and pricing on Details tab"
    }
  }
}
