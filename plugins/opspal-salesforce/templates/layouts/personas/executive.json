{
  "persona": "executive",
  "label": "Executive Leadership",
  "description": "C-level and VP executives focused on strategic decisions, quarterly targets, and company-wide performance",
  "role": "Executive / VP",
  "decisionScope": "Company strategy, resource allocation, quarterly targets, board reporting",
  "keyQuestions": [
    "Are we on track to hit quarterly revenue targets?",
    "Where are our pipeline gaps?",
    "How is team productivity trending?",
    "What's our forecast accuracy?",
    "Which accounts need executive engagement?"
  ],
  "layoutCharacteristics": {
    "fieldCount": {
      "optimal": 40,
      "max": 75,
      "priority": "High-level summary and strategic metrics"
    },
    "sectionCount": {
      "optimal": 3,
      "max": 5,
      "recommended": ["Executive Summary", "Strategic Metrics", "Key Stakeholders"]
    },
    "components": {
      "required": ["Highlights Panel"],
      "recommended": ["Report Chart - Pipeline Trend", "Report Chart - Win Rate", "Dashboard Component - Executive Overview"],
      "avoid": ["Detailed Field Sections", "Granular Activity Timeline"]
    },
    "relatedLists": {
      "max": 4,
      "priority": ["Key Contacts", "Major Opportunities", "Strategic Initiatives"]
    }
  },
  "fieldPriorities": {
    "opportunity": {
      "criticalFields": [
        "Name",
        "Amount",
        "CloseDate",
        "StageName",
        "AccountId",
        "ForecastCategory",
        "Type"
      ],
      "importantFields": [
        "ExpectedRevenue",
        "Probability",
        "OwnerId",
        "LeadSource",
        "Age"
      ],
      "executiveSpecificFields": [
        "IsStrategic__c",
        "ExecutiveSponsor__c",
        "CompetitivePosition__c",
        "BoardVisibility__c"
      ],
      "lowPriorityFields": [
        "NextStep",
        "Description",
        "Individual task details",
        "Detailed contact roles"
      ]
    },
    "account": {
      "criticalFields": [
        "Name",
        "Type",
        "Industry",
        "AnnualRevenue",
        "NumberOfEmployees",
        "Owner.Name"
      ],
      "executiveSpecificFields": [
        "AccountTier__c",
        "StrategicValue__c",
        "LifetimeValue__c",
        "ExecutiveRelationship__c",
        "ChurnRisk__c"
      ],
      "lowPriorityFields": [
        "Detailed address",
        "Fax",
        "Shipping preferences"
      ]
    },
    "contact": {
      "criticalFields": [
        "Name",
        "Title",
        "AccountId",
        "Email",
        "Phone"
      ],
      "executiveSpecificFields": [
        "Level",
        "DecisionMakingAuthority__c",
        "ExecutiveSponsor__c"
      ]
    }
  },
  "compactLayoutFields": {
    "opportunity": ["Amount", "CloseDate", "ForecastCategory", "AccountId"],
    "account": ["Type", "AnnualRevenue", "Industry", "Owner.Name"],
    "contact": ["Title", "AccountId", "Email", "Level"]
  },
  "conditionalVisibility": {
    "rules": [
      {
        "name": "Strategic Deal",
        "condition": "Amount > 500000 OR IsStrategic__c = true",
        "action": "Show section 'Executive Briefing' with board notes"
      },
      {
        "name": "At-Risk High-Value",
        "condition": "Amount > 250000 AND Probability < 50",
        "action": "Show section 'Risk & Mitigation' with executive sponsor"
      },
      {
        "name": "Churn Risk",
        "condition": "Type = 'Renewal' AND ChurnRisk__c = 'High'",
        "action": "Show section 'Retention Strategy' with executive action items"
      }
    ]
  },
  "mobile": {
    "optimized": true,
    "maxFieldsFirstScreen": 10,
    "priority": "Deal size, close date, forecast category, executive sponsor"
  },
  "bestPractices": {
    "useDynamicForms": true,
    "useHighlightsPanel": true,
    "usePathComponent": false,
    "maxComponentsPerPage": 10,
    "includeDashboardCharts": true,
    "showAggregateMetrics": true,
    "minimizeDetailFields": true
  },
  "notes": [
    "Executives need high-level summary, not operational detail",
    "Focus on metrics that drive strategic decisions",
    "Prioritize visualization (charts/dashboards) over raw data",
    "Show only exceptions and high-value items",
    "Enable quick drill-down when needed, but don't show by default"
  ],
  "objectGuidance": {
    "Account": {
      "sections": [
        {"name": "Executive Summary", "fields": ["Name", "Type", "Industry", "AnnualRevenue", "OwnerId"]},
        {"name": "Strategic Value", "fields": ["NumberOfEmployees", "Rating", "AccountTier__c"]},
        {"name": "Key Contacts", "fields": ["Executive_Sponsor__c", "Primary_Contact__c"]}
      ],
      "compactFields": ["Type", "AnnualRevenue", "Industry", "OwnerId"],
      "relatedLists": ["Opportunities", "Contacts"],
      "defaultTab": "Related",
      "rationale": "Executives access accounts for strategic deals - Related tab shows high-value opportunities requiring attention"
    },
    "Contact": {
      "sections": [
        {"name": "Executive Contact", "fields": ["Name", "Title", "AccountId", "Email", "Phone"]},
        {"name": "Decision Authority", "fields": ["Level", "DecisionMakingAuthority__c"]}
      ],
      "compactFields": ["Title", "AccountId", "Email", "Level"],
      "relatedLists": ["Opportunities"],
      "defaultTab": "Details",
      "rationale": "Executives view contacts for stakeholder understanding - Details shows title and authority level"
    },
    "Opportunity": {
      "sections": [
        {"name": "Deal Summary", "fields": ["Name", "AccountId", "Amount", "CloseDate", "StageName"]},
        {"name": "Strategic Context", "fields": ["Type", "ForecastCategory", "IsStrategic__c"]},
        {"name": "Executive Engagement", "fields": ["ExecutiveSponsor__c", "BoardVisibility__c"]}
      ],
      "compactFields": ["Amount", "CloseDate", "ForecastCategory", "AccountId"],
      "relatedLists": ["Contacts", "Quotes"],
      "defaultTab": "Details",
      "rationale": "Executives focus on deal value and forecast - Details tab shows strategic metrics without operational clutter"
    },
    "Quote": {
      "sections": [
        {"name": "Quote Summary", "fields": ["Name", "Status", "GrandTotal", "OpportunityId"]},
        {"name": "Approval Status", "fields": ["ExpirationDate", "ApprovalStatus__c"]}
      ],
      "compactFields": ["Status", "GrandTotal", "ExpirationDate", "OpportunityId"],
      "relatedLists": ["ApprovalHistory"],
      "defaultTab": "Details",
      "rationale": "Executives review quotes for executive approval - Details shows pricing summary and approval status"
    },
    "QuoteLineItem": {
      "sections": [
        {"name": "Line Summary", "fields": ["Product2Id", "Quantity", "TotalPrice"]}
      ],
      "compactFields": ["Product2Id", "Quantity", "TotalPrice"],
      "relatedLists": [],
      "defaultTab": "Details",
      "rationale": "Executives rarely access line items directly - minimal layout sufficient"
    }
  }
}
