{
  "name": "lead-assignment",
  "description": "Automatically assign leads to users based on criteria",
  "category": "core",
  "type": "Record-Triggered Flow",
  "parameters": {
    "assignmentField": {
      "type": "string",
      "description": "Field to use for assignment criteria (e.g., State, Industry)",
      "required": true,
      "example": "State"
    },
    "assignmentValue": {
      "type": "string",
      "description": "Value to match for assignment",
      "required": true,
      "example": "California"
    },
    "ownerUserId": {
      "type": "string",
      "description": "Salesforce User ID to assign matching leads",
      "required": true,
      "example": "005xx000000XXXX"
    },
    "notificationEmail": {
      "type": "string",
      "description": "Email to notify on assignment",
      "required": false,
      "default": ""
    }
  },
  "structure": {
    "metadata": {
      "apiVersion": "62.0",
      "processType": "AutoLaunchedFlow",
      "status": "Draft",
      "triggerType": "RecordAfterSave"
    },
    "elements": [
      {
        "instruction": "Add a decision called Check_Assignment_Criteria with rule Matches_Criteria if {{assignmentField}} equals {{assignmentValue}} then Assign_Lead, otherwise End"
      },
      {
        "instruction": "Add a record update called Assign_Lead to update the triggering record, setting OwnerId to {{ownerUserId}}"
      }
    ]
  },
  "examples": [
    {
      "name": "California Lead Assignment",
      "params": {
        "assignmentField": "State",
        "assignmentValue": "California",
        "ownerUserId": "005xx000000XXXX"
      }
    },
    {
      "name": "Enterprise Lead Assignment",
      "params": {
        "assignmentField": "Industry",
        "assignmentValue": "Technology",
        "ownerUserId": "005xx000000YYYY"
      }
    }
  ]
}
