{
  "templateMetadata": {
    "templateName": "My Pacing",
    "templateVersion": "1.1",
    "description": "Your progress vs where you should be to hit quota",
    "audience": "Sales Reps, Account Executives",
    "useCase": "Pace tracking, early warning, urgency assessment",
    "customizationPoints": [
      "Time period",
      "Quota source",
      "Pace calculation"
    ],
    "prerequisites": [
      "Opportunity object",
      "Quota data available"
    ]
  },
  "metricDefinitionId": "quota_attainment",
  "reportMetadata": {
    "name": "My Pacing",
    "description": "Current pace vs target pace",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "user",
    "showDetails": false,
    "reportFilters": [
      {
        "column": "IS_WON",
        "operator": "equals",
        "value": "true",
        "customizable": false
      },
      {
        "column": "OPPORTUNITY_OWNER",
        "operator": "equals",
        "value": "$User.Id",
        "customizable": false
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_QUARTER",
        "customizable": true
      }
    ],
    "groupingsDown": [],
    "groupingsAcross": [],
    "detailColumns": [],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Closed won to date"
      }
    ],
    "customSummaryFormulas": [
      {
        "name": "Expected_Pace",
        "description": "Quota * (Days Elapsed / Total Days)",
        "formula": "Quota * (DaysElapsed / TotalQuarterDays)",
        "dataType": "currency",
        "decimalPlaces": 0
      },
      {
        "name": "Pace_Variance",
        "description": "Actual - Expected",
        "formula": "SUM(AMOUNT) - Expected_Pace",
        "dataType": "currency",
        "decimalPlaces": 0
      }
    ],
    "chart": {
      "chartType": "Metric",
      "aggregateColumn": "Pace_Variance",
      "conditionalFormatting": {
        "positive": "#27ae60",
        "negative": "#e74c3c"
      }
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "my-quota"
    ],
    "componentType": "Metric",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified individual rep report",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full individual rep report"
      },
      "cpq": {
        "description": "CPQ-enabled with quote metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise deal focus",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "50000"
          }
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Amount": {
        "patterns": [
          "Amount",
          "Total_Amount__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "Quota": {
        "patterns": [
          "Quota__c",
          "Quarterly_Quota__c",
          "Target__c"
        ],
        "dataType": "currency"
      }
    }
  }
}
