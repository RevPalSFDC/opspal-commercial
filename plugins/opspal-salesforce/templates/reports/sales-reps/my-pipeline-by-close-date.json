{
  "templateMetadata": {
    "templateName": "My Pipeline by Close Date",
    "templateVersion": "1.1",
    "description": "Your pipeline distribution by expected close date",
    "audience": "Sales Reps, Account Executives",
    "useCase": "Planning, time allocation, deal pacing",
    "customizationPoints": [
      "Date grouping (week/month)",
      "Time horizon",
      "Show details"
    ],
    "prerequisites": [
      "Opportunity object with CloseDate"
    ]
  },
  "metricDefinitionId": "pipeline.arr",
  "reportMetadata": {
    "name": "My Pipeline by Close Date",
    "description": "My open pipeline grouped by close date",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "user",
    "showDetails": true,
    "reportFilters": [
      {
        "column": "IS_CLOSED",
        "operator": "equals",
        "value": "false",
        "customizable": false
      },
      {
        "column": "OPPORTUNITY_OWNER",
        "operator": "equals",
        "value": "$User.Id",
        "customizable": false
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "NEXT_N_MONTHS:6",
        "customizable": true
      }
    ],
    "groupingsDown": [
      {
        "field": "CLOSE_DATE",
        "sortOrder": "Asc",
        "dateGranularity": "Month"
      }
    ],
    "groupingsAcross": [],
    "detailColumns": [
      "OPPORTUNITY_NAME",
      "ACCOUNT_NAME",
      "STAGE_NAME",
      "AMOUNT"
    ],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Pipeline per period"
      },
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "description": "Deals per period"
      }
    ],
    "chart": {
      "chartType": "VerticalBar",
      "groupingColumn": "CLOSE_DATE",
      "aggregateColumn": "AMOUNT:SUM"
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "my-pipeline"
    ],
    "componentType": "Bar Chart",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified individual rep report",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full individual rep report"
      },
      "cpq": {
        "description": "CPQ-enabled with quote metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise deal focus",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "50000"
          }
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Amount": {
        "patterns": [
          "Amount",
          "Total_Amount__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "Quota": {
        "patterns": [
          "Quota__c",
          "Quarterly_Quota__c",
          "Target__c"
        ],
        "dataType": "currency"
      }
    }
  }
}
