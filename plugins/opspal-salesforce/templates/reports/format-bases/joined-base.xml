<?xml version="1.0" encoding="UTF-8"?>
<!--
    JOINED (MultiBlock) Report Base Template

    Template: joined-base
    Version: 1.0.0
    Documentation: ../../docs/runbooks/report-api-development/05-joined-reports-basics.md
                   ../../docs/runbooks/report-api-development/06-joined-reports-advanced.md

    IMPORTANT: REST API CANNOT create joined reports!
    Use Metadata API (sf project deploy) to deploy this template.

    Variables:
    - {{REPORT_NAME}}
    - {{DESCRIPTION}}
    - {{FOLDER}}
    - {{COMMON_GROUPING_FIELD}}
    - {{BLOCK_1_REPORT_TYPE}}
    - {{BLOCK_2_REPORT_TYPE}}

    Row Limit: 2,000 rows per block (max 5 blocks)
    Max Blocks: 5
    Requires: Common grouping field across all blocks
-->
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <!-- Report Identity -->
    <name>{{REPORT_NAME}}</name>
    <description>{{DESCRIPTION}}</description>

    <!-- Joined (MultiBlock) Format -->
    <format>MultiBlock</format>

    <!-- Report Folder (API name) -->
    <reportFolder>{{FOLDER}}</reportFolder>

    <!-- ========================================
         BLOCK 1: Primary Data Source
         ======================================== -->
    <block>
        <blockInfo>
            <blockId>B1</blockId>
            <joinTable>{{BLOCK_1_REPORT_TYPE}}</joinTable>
        </blockInfo>

        <!-- Report Type for this block -->
        <reportType>{{BLOCK_1_REPORT_TYPE}}</reportType>

        <!-- Columns for Block 1 -->
        <!-- Use Object$FieldName format for joined reports -->
        <columns>
            <field>{{BLOCK_1_OBJECT}}$Name</field>
        </columns>
        <columns>
            <field>{{BLOCK_1_OBJECT}}$Amount</field>
        </columns>
        <columns>
            <field>{{BLOCK_1_OBJECT}}$CreatedDate</field>
        </columns>

        <!-- Block 1 Filters -->
        <filter>
            <criteriaItems>
                <column>{{BLOCK_1_OBJECT}}$IsClosed</column>
                <operator>equals</operator>
                <value>true</value>
            </criteriaItems>
        </filter>

        <!-- Block 1 Aggregates -->
        <aggregates>
            <acrossGroupingContext>B1</acrossGroupingContext>
            <calculatedFormula>{{BLOCK_1_OBJECT}}$Amount:SUM</calculatedFormula>
            <datatype>currency</datatype>
            <developerName>B1_Total_Amount</developerName>
            <downGroupingContext>GRAND_SUMMARY</downGroupingContext>
            <isActive>true</isActive>
            <masterLabel>Block 1 Total</masterLabel>
            <scale>2</scale>
        </aggregates>
    </block>

    <!-- ========================================
         BLOCK 2: Comparison Data Source
         ======================================== -->
    <block>
        <blockInfo>
            <blockId>B2</blockId>
            <joinTable>{{BLOCK_2_REPORT_TYPE}}</joinTable>
        </blockInfo>

        <!-- Report Type for this block -->
        <reportType>{{BLOCK_2_REPORT_TYPE}}</reportType>

        <!-- Columns for Block 2 -->
        <columns>
            <field>{{BLOCK_2_OBJECT}}$Name</field>
        </columns>
        <columns>
            <field>{{BLOCK_2_OBJECT}}$Amount</field>
        </columns>
        <columns>
            <field>{{BLOCK_2_OBJECT}}$CreatedDate</field>
        </columns>

        <!-- Block 2 Filters -->
        <filter>
            <criteriaItems>
                <column>{{BLOCK_2_OBJECT}}$IsClosed</column>
                <operator>equals</operator>
                <value>true</value>
            </criteriaItems>
        </filter>

        <!-- Block 2 Aggregates -->
        <aggregates>
            <acrossGroupingContext>B2</acrossGroupingContext>
            <calculatedFormula>{{BLOCK_2_OBJECT}}$Amount:SUM</calculatedFormula>
            <datatype>currency</datatype>
            <developerName>B2_Total_Amount</developerName>
            <downGroupingContext>GRAND_SUMMARY</downGroupingContext>
            <isActive>true</isActive>
            <masterLabel>Block 2 Total</masterLabel>
            <scale>2</scale>
        </aggregates>
    </block>

    <!-- ========================================
         COMMON GROUPING (Required)
         Links blocks together for alignment
         ======================================== -->
    <groupingsDown>
        <dateGranularity>None</dateGranularity>
        <field>{{COMMON_GROUPING_FIELD}}</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>

    <!-- ========================================
         CROSS-BLOCK FORMULAS (Optional)
         Reference aggregates from multiple blocks
         Syntax: B{blockId}#{aggregateName}
         ======================================== -->
    <customSummaryFormulas>
        <aggregate>Sum</aggregate>
        <calculatedFormula>BB1#B1_Total_Amount - BB2#B2_Total_Amount</calculatedFormula>
        <datatype>currency</datatype>
        <developerName>Difference</developerName>
        <downGroupingContext>GRAND_SUMMARY</downGroupingContext>
        <isActive>true</isActive>
        <masterLabel>Block 1 - Block 2 Difference</masterLabel>
        <scale>2</scale>
    </customSummaryFormulas>

    <customSummaryFormulas>
        <aggregate>Sum</aggregate>
        <calculatedFormula>IF(BB2#B2_Total_Amount != 0, (BB1#B1_Total_Amount - BB2#B2_Total_Amount) / BB2#B2_Total_Amount * 100, 0)</calculatedFormula>
        <datatype>percent</datatype>
        <developerName>Growth_Rate</developerName>
        <downGroupingContext>GRAND_SUMMARY</downGroupingContext>
        <isActive>true</isActive>
        <masterLabel>Growth Rate %</masterLabel>
        <scale>2</scale>
    </customSummaryFormulas>

    <!-- ========================================
         REPORT SETTINGS
         ======================================== -->
    <currency>USD</currency>
    <scope>organization</scope>
    <showDetails>true</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
    <timeFrameFilter>
        <dateColumn>CREATED_DATE</dateColumn>
        <interval>INTERVAL_CURFY</interval>
    </timeFrameFilter>
</Report>

<!--
================================================================================
JOINED REPORT REFERENCE GUIDE
================================================================================

FIELD NAMING CONVENTION:
- Use: Object$FieldName (e.g., Opportunity$Amount)
- NOT: OPPORTUNITY_AMOUNT (standard report field naming)

CROSS-BLOCK FORMULA SYNTAX:
- Reference: B{blockId}#{aggregateName}
- Example: BB1#B1_Revenue - BB2#B2_Revenue
- Division: IF(BB2#B2_Revenue != 0, BB1#B1_Revenue / BB2#B2_Revenue, 0)

COMMON GROUPING REQUIREMENTS:
- Field must exist in ALL block report types
- Common choices: AccountName, OwnerId, CreatedDate (with granularity)

BLOCK LIMITATIONS:
- Minimum: 2 blocks
- Maximum: 5 blocks
- Each block: 2,000 row limit

DEPLOYMENT:
sf project deploy start \
    --source-dir force-app/main/default/reports \
    --target-org your-org-alias

COMMON USE CASES:
1. Year-over-Year Comparison
   - Block 1: Current Year Opportunities
   - Block 2: Previous Year Opportunities
   - Formula: Growth % = (B1-B2)/B2 * 100

2. Forecast vs Actual
   - Block 1: Closed Won Opportunities
   - Block 2: Forecast Records
   - Formula: Variance = B1-B2

3. Customer 360
   - Block 1: Account Opportunities
   - Block 2: Account Cases
   - Block 3: Account Activities
   - Common Grouping: ACCOUNT_NAME

4. Pipeline vs Closed
   - Block 1: Open Pipeline
   - Block 2: Closed Won
   - Formula: Conversion % = B2/(B1+B2) * 100

================================================================================
-->
