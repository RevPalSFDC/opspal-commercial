{
  "templateMetadata": {
    "templateName": "Expansion Revenue Report",
    "templateVersion": "1.1",
    "description": "Track revenue from upsells and cross-sells to existing customers",
    "audience": "CS Directors, CCO, CFO, Revenue Operations",
    "useCase": "Measure expansion revenue, track upsell performance, calculate NRR components",
    "customizationPoints": [
      "Opportunity.Type values for expansion (Upsell, Cross-sell, Expansion)",
      "Date range filter",
      "Revenue field (Amount, ARR__c, ACV__c)",
      "Segment grouping"
    ],
    "prerequisites": [
      "Opportunity.Type with expansion values",
      "Existing customer identification (Account.Type or Opportunity linkage)",
      "Closed Won opportunities for expansion"
    ]
  },
  "reportMetadata": {
    "name": "Expansion Revenue - {Period}",
    "description": "Closed Won expansion revenue from existing customers",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "organization",
    "showDetails": true,
    "reportBooleanFilter": null,
    "reportFilters": [
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_YEAR",
        "customizable": true,
        "customizationNote": "Adjust to match reporting period"
      },
      {
        "column": "WON",
        "operator": "equals",
        "value": "true",
        "customizable": false,
        "customizationNote": "Only closed won expansion"
      },
      {
        "column": "TYPE",
        "operator": "equals",
        "value": "Upsell,Cross-sell,Expansion,Add-on",
        "customizable": true,
        "customizationNote": "Update to match your expansion type values"
      }
    ],
    "groupingsDown": [
      {
        "field": "TYPE",
        "sortOrder": "Desc",
        "dateGranularity": null,
        "customizable": false
      },
      {
        "field": "Account.Segment__c",
        "sortOrder": "Asc",
        "dateGranularity": null,
        "customizable": true,
        "customizationNote": "Can group by segment, region, or CSM"
      }
    ],
    "groupingsAcross": [
      {
        "field": "CLOSE_DATE",
        "sortOrder": "Asc",
        "dateGranularity": "Month",
        "customizable": true
      }
    ],
    "detailColumns": [
      "OPPORTUNITY_NAME",
      "ACCOUNT_NAME",
      "TYPE",
      "AMOUNT",
      "CLOSE_DATE",
      "OWNER_NAME"
    ],
    "aggregates": [
      {
        "name": "Total_Expansion",
        "field": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Total expansion revenue"
      },
      {
        "name": "Deal_Count",
        "aggregateType": "RowCount",
        "description": "Number of expansion deals"
      },
      {
        "name": "Avg_Deal_Size",
        "field": "AMOUNT",
        "aggregateType": "Average",
        "description": "Average expansion deal size"
      }
    ],
    "customSummaryFormulas": [
      {
        "name": "Expansion_Rate",
        "description": "Expansion as percentage of beginning ARR (requires custom calculation)",
        "formula": "Total_Expansion / Beginning_ARR * 100",
        "dataType": "percent",
        "decimalPlaces": 1,
        "note": "Beginning_ARR requires separate calculation or custom field"
      }
    ],
    "chart": {
      "chartType": "StackedBar",
      "groupingColumn": "CLOSE_DATE",
      "aggregateColumn": "Total_Expansion",
      "stackBy": "TYPE",
      "legendPosition": "Bottom",
      "showChartValues": true
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "HealthScore": {
        "patterns": [
          "Health_Score__c",
          "Customer_Health__c",
          "Account_Health__c",
          "Risk_Level__c"
        ],
        "dataType": "picklist"
      },
      "ARR": {
        "patterns": [
          "ARR__c",
          "Annual_Recurring_Revenue__c",
          "MRR__c"
        ],
        "cpqPatterns": [
          "SBQQ__RenewedAmount__c"
        ],
        "dataType": "currency"
      },
      "NPS": {
        "patterns": [
          "NPS_Score__c",
          "NPS__c",
          "Net_Promoter_Score__c"
        ],
        "dataType": "number"
      }
    }
  },
  "kpiDefinitions": {
    "expansion_revenue": {
      "formula": "SUM(Amount) WHERE Type IN (Expansion Types) AND IsWon = TRUE",
      "note": "Component of NRR calculation"
    },
    "expansion_rate": {
      "formula": "Expansion Revenue / Beginning ARR * 100",
      "benchmark": {
        "excellent": ">30%",
        "good": ">20%",
        "warning": "<10%"
      }
    }
  },
  "deploymentInstructions": {
    "steps": [
      "1. Query existing Type values: SELECT Type, COUNT(Id) FROM Opportunity GROUP BY Type",
      "2. Update TYPE filter with your expansion values",
      "3. Verify existing customer identification method",
      "4. Replace {Period} with actual period",
      "5. Deploy to Customer Success Reports folder"
    ],
    "expectedResults": {
      "healthyExpansion": {
        "annualRate": ">20% of beginning ARR",
        "dealCount": "Growing quarter over quarter"
      }
    }
  },
  "relatedTemplates": [
    "nrr-calculation.json",
    "cs-overview.json"
  ],
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "enterprise",
      "high-touch"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified report with essential columns only",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full report with all standard columns"
      },
      "enterprise": {
        "description": "Enterprise focus with ARR-weighted metrics",
        "filterOverrides": [
          {
            "column": "Account.ARR__c",
            "operator": "greaterOrEqual",
            "value": "100000"
          }
        ]
      },
      "high-touch": {
        "description": "High-touch CS model with engagement metrics",
        "additionalColumns": [
          "Last_Touch_Date__c",
          "Engagement_Score__c"
        ]
      }
    }
  }
}
