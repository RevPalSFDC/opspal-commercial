{
  "templateMetadata": {
    "templateName": "Rep Activity Scorecard",
    "templateVersion": "1.1",
    "description": "Comprehensive activity metrics by rep for performance analysis",
    "audience": "Sales Managers",
    "useCase": "Activity reviews, productivity coaching, benchmarking",
    "customizationPoints": [
      "Activity types",
      "Time period",
      "Team scope"
    ],
    "prerequisites": [
      "Activity tracking enabled",
      "Multiple activity types logged"
    ]
  },
  "metricDefinitionId": "activity_volume",
  "reportMetadata": {
    "name": "Rep Activity Scorecard",
    "description": "Activity breakdown by rep and type",
    "reportType": "Activity",
    "reportFormat": "MATRIX",
    "scope": "team",
    "showDetails": false,
    "reportFilters": [
      {
        "column": "ACTIVITY_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_QUARTER",
        "customizable": true
      },
      {
        "column": "OWNER_MANAGER_ID",
        "operator": "equals",
        "value": "$User.Id",
        "customizable": true
      }
    ],
    "groupingsDown": [
      {
        "field": "OWNER_NAME",
        "sortOrder": "Asc",
        "dateGranularity": null
      }
    ],
    "groupingsAcross": [
      {
        "field": "ACTIVITY_TYPE",
        "sortOrder": "Asc"
      }
    ],
    "detailColumns": [],
    "aggregates": [
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "description": "Activity count by rep and type"
      }
    ],
    "chart": null
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "activity-metrics"
    ],
    "componentType": "Table",
    "refreshFrequency": "Weekly"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise",
      "smb"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified team report",
        "reportOverrides": {
          "maxColumns": 6
        }
      },
      "standard": {
        "description": "Full team management report"
      },
      "cpq": {
        "description": "CPQ-enabled team metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise team focus",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "100000"
          }
        ]
      },
      "smb": {
        "description": "SMB team with higher volume targets",
        "metricAdjustments": {
          "activityTarget": {
            "target": 30
          }
        }
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "TeamPipeline": {
        "patterns": [
          "Team_Pipeline__c",
          "Pipeline__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "QuotaAttainment": {
        "patterns": [
          "Quota_Attainment__c",
          "Attainment__c",
          "Quota_Pct__c"
        ],
        "dataType": "percent"
      }
    }
  }
}
