{
  "templateMetadata": {
    "templateName": "New Opps This Week",
    "templateVersion": "1.1",
    "description": "New opportunities created by the team this week",
    "audience": "Sales Managers",
    "useCase": "Pipeline generation tracking, activity correlation, coaching",
    "customizationPoints": [
      "Team scope",
      "Time period",
      "Minimum deal size"
    ],
    "prerequisites": [
      "Opportunity object with CreatedDate"
    ]
  },
  "metricDefinitionId": "pipeline.arr",
  "reportMetadata": {
    "name": "New Opportunities - This Week",
    "description": "Opportunities created this week",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "team",
    "showDetails": true,
    "reportFilters": [
      {
        "column": "CREATED_DATE",
        "operator": "equals",
        "value": "THIS_WEEK",
        "customizable": true
      },
      {
        "column": "OPPORTUNITY_OWNER",
        "operator": "equals",
        "value": "$User.ManagerId.Team",
        "customizable": true
      }
    ],
    "groupingsDown": [
      {
        "field": "OPPORTUNITY_OWNER",
        "sortOrder": "Desc",
        "sortColumn": "RowCount",
        "dateGranularity": null
      }
    ],
    "groupingsAcross": [],
    "detailColumns": [
      "OPPORTUNITY_NAME",
      "ACCOUNT_NAME",
      "AMOUNT",
      "STAGE_NAME",
      "CLOSE_DATE"
    ],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "New pipeline created"
      },
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "description": "New opp count"
      }
    ],
    "chart": {
      "chartType": "HorizontalBar",
      "groupingColumn": "OPPORTUNITY_OWNER",
      "aggregateColumn": "RowCount"
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "activity-metrics"
    ],
    "componentType": "Metric",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise",
      "smb"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Simplified team report",
        "reportOverrides": {
          "maxColumns": 6
        }
      },
      "standard": {
        "description": "Full team management report"
      },
      "cpq": {
        "description": "CPQ-enabled team metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise team focus",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "100000"
          }
        ]
      },
      "smb": {
        "description": "SMB team with higher volume targets",
        "metricAdjustments": {
          "activityTarget": {
            "target": 30
          }
        }
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "TeamPipeline": {
        "patterns": [
          "Team_Pipeline__c",
          "Pipeline__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "QuotaAttainment": {
        "patterns": [
          "Quota_Attainment__c",
          "Attainment__c",
          "Quota_Pct__c"
        ],
        "dataType": "percent"
      }
    }
  }
}
