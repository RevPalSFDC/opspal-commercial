{
  "templateMetadata": {
    "templateName": "Board Report",
    "templateVersion": "1.0",
    "description": "Board-level revenue and pipeline rollup for quarterly reporting.",
    "audience": "Board of Directors, Executives",
    "useCase": "Board decks, quarterly revenue updates, strategic KPIs.",
    "customizationPoints": [
      "Fiscal year/quarter filters",
      "Stage definitions and close status",
      "Aggregation fields"
    ],
    "prerequisites": [
      "Opportunity report type access",
      "Fiscal calendar configured",
      "Consistent stage definitions"
    ]
  },
  "reportMetadata": {
    "reportName": "Board Report",
    "reportDescription": "Board-level revenue snapshot: quarterly performance, pipeline health, and key growth metrics",
    "reportFormat": "SUMMARY",
    "scope": "organization",
    "showDetails": false,
    "groupings": [
      {
        "field": "FISCAL_QUARTER",
        "sortOrder": "Asc",
        "dateGranularity": "Quarter"
      }
    ],
    "columns": [
      {
        "field": "OPPORTUNITY_NAME",
        "label": "Opportunity Name"
      },
      {
        "field": "AMOUNT",
        "label": "Amount"
      },
      {
        "field": "STAGE_NAME",
        "label": "Stage"
      },
      {
        "field": "CLOSE_DATE",
        "label": "Close Date"
      }
    ],
    "filters": [
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_YEAR"
      }
    ],
    "aggregates": [
      {
        "field": "AMOUNT",
        "aggregateType": "Sum",
        "label": "Quarterly Revenue"
      },
      {
        "field": "OPPORTUNITY_NAME",
        "aggregateType": "RowCount",
        "label": "Deal Count"
      }
    ],
    "chart": {
      "chartType": "Line",
      "groupingColumn": "FISCAL_QUARTER",
      "aggregateColumn": "s!AMOUNT",
      "title": "Revenue Trend by Quarter",
      "showPercentages": false,
      "showValues": true
    },
    "reportType": "Opportunity"
  },
  "dashboardUsage": {
    "createDashboard": true,
    "dashboardName": "Board Report Dashboard",
    "description": "Board-level metrics: revenue performance, growth trajectory, and strategic health indicators",
    "components": [
      {
        "title": "YTD Revenue",
        "componentType": "Metric",
        "section": "left",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "Year to Date"
      },
      {
        "title": "Quarterly Growth",
        "componentType": "Metric",
        "section": "left",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "QoQ Growth %"
      },
      {
        "title": "Revenue Trend",
        "componentType": "Line",
        "section": "middle",
        "sortBy": "RowLabelAscending",
        "legendPosition": "Bottom",
        "chartAxisRange": "Auto",
        "showValues": true
      },
      {
        "title": "Total Deals Closed",
        "componentType": "Metric",
        "section": "right",
        "indicatorHighColor": "#00C853",
        "indicatorLowColor": "#D50000",
        "indicatorMiddleColor": "#FFD600",
        "footer": "This Fiscal Year"
      }
    ]
  }
}
