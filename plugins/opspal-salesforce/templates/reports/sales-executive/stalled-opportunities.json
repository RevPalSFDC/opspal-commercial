{
  "templateMetadata": {
    "templateName": "Stalled Opportunities",
    "templateVersion": "1.1",
    "description": "Identifies opportunities with no recent activity that may need intervention",
    "audience": "CRO, VP Sales, Sales Directors, Sales Managers",
    "useCase": "Deal rescue, coaching opportunities, pipeline cleanup",
    "customizationPoints": [
      "Days since last activity threshold (default 14)",
      "Minimum deal size to include",
      "Exclude specific stages"
    ],
    "prerequisites": [
      "Opportunity object with LastActivityDate",
      "Activity tracking enabled"
    ]
  },
  "metricDefinitionId": "pipeline.arr",
  "reportMetadata": {
    "name": "Stalled Opportunities (No Activity >14 Days)",
    "description": "Open opportunities with no activity in the past 14 days",
    "reportType": "Opportunity",
    "reportFormat": "TABULAR",
    "scope": "organization",
    "showDetails": true,
    "reportFilters": [
      {
        "column": "IS_CLOSED",
        "operator": "equals",
        "value": "false",
        "customizable": false
      },
      {
        "column": "LAST_ACTIVITY",
        "operator": "lessThan",
        "value": "LAST_N_DAYS:14",
        "customizable": true,
        "customizationNote": "Adjust threshold based on your sales cycle"
      }
    ],
    "groupingsDown": [],
    "groupingsAcross": [],
    "detailColumns": [
      "OPPORTUNITY_NAME",
      "ACCOUNT_NAME",
      "OPPORTUNITY_OWNER",
      "STAGE_NAME",
      "AMOUNT",
      "CLOSE_DATE",
      "LAST_ACTIVITY",
      "AGE"
    ],
    "sortBy": [
      {
        "column": "AMOUNT",
        "order": "Descending"
      }
    ],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Total at-risk pipeline"
      },
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "description": "Number of stalled deals"
      }
    ],
    "chart": null
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "pipeline-health"
    ],
    "componentType": "Table",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Executive summary report",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full executive report"
      },
      "cpq": {
        "description": "CPQ-enabled executive metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c",
          "Quote.TotalPrice": "SBQQ__Quote__c.SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise executive focus with higher thresholds",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "250000"
          }
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Revenue": {
        "patterns": [
          "Amount",
          "Revenue__c",
          "Total_Revenue__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "WinRate": {
        "patterns": [
          "Win_Rate__c",
          "Conversion_Rate__c"
        ],
        "dataType": "percent"
      }
    }
  }
}
