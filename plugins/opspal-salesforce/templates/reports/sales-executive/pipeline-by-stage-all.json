{
  "templateMetadata": {
    "templateName": "Pipeline Health by Stage",
    "templateVersion": "1.1",
    "description": "Complete view of open pipeline grouped by stage for health monitoring",
    "audience": "CRO, VP Sales, Sales Directors",
    "useCase": "Pipeline reviews, stage progression analysis, funnel health",
    "customizationPoints": [
      "Date range (close date filter)",
      "Team/territory scope",
      "Show/hide stage details"
    ],
    "prerequisites": [
      "Opportunity object with Stage and Amount",
      "Sales process stages configured"
    ]
  },
  "metricDefinitionId": "pipeline.arr",
  "reportMetadata": {
    "name": "Pipeline Health by Stage",
    "description": "All open opportunities grouped by sales stage",
    "reportType": "Opportunity",
    "reportFormat": "SUMMARY",
    "scope": "organization",
    "showDetails": true,
    "reportFilters": [
      {
        "column": "IS_CLOSED",
        "operator": "equals",
        "value": "false",
        "customizable": false
      },
      {
        "column": "CLOSE_DATE",
        "operator": "equals",
        "value": "THIS_FISCAL_QUARTER",
        "customizable": true
      }
    ],
    "groupingsDown": [
      {
        "field": "STAGE_NAME",
        "sortOrder": "Asc",
        "dateGranularity": null
      }
    ],
    "groupingsAcross": [],
    "detailColumns": [
      "OPPORTUNITY_NAME",
      "ACCOUNT_NAME",
      "OPPORTUNITY_OWNER",
      "AMOUNT",
      "CLOSE_DATE",
      "PROBABILITY"
    ],
    "aggregates": [
      {
        "name": "AMOUNT",
        "aggregateType": "Sum",
        "description": "Total pipeline per stage"
      },
      {
        "name": "RowCount",
        "aggregateType": "Sum",
        "description": "Deal count per stage"
      },
      {
        "name": "AMOUNT",
        "aggregateType": "Average",
        "description": "Average deal size per stage"
      }
    ],
    "chart": {
      "chartType": "Funnel",
      "groupingColumn": "STAGE_NAME",
      "aggregateColumn": "AMOUNT:SUM",
      "showChartValues": true
    }
  },
  "dashboardUsage": {
    "recommendedDashboards": [
      "revenue-performance",
      "pipeline-health"
    ],
    "componentType": "Funnel",
    "refreshFrequency": "Daily"
  },
  "variations": {
    "schemaVersion": "1.0",
    "availableVariations": [
      "simple",
      "standard",
      "cpq",
      "enterprise"
    ],
    "defaultVariation": "standard",
    "variationOverrides": {
      "simple": {
        "description": "Executive summary report",
        "reportOverrides": {
          "maxColumns": 5
        }
      },
      "standard": {
        "description": "Full executive report"
      },
      "cpq": {
        "description": "CPQ-enabled executive metrics",
        "fieldSubstitutions": {
          "Amount": "SBQQ__NetAmount__c",
          "Quote.TotalPrice": "SBQQ__Quote__c.SBQQ__NetAmount__c"
        }
      },
      "enterprise": {
        "description": "Enterprise executive focus with higher thresholds",
        "filterOverrides": [
          {
            "column": "Amount",
            "operator": "greaterOrEqual",
            "value": "250000"
          }
        ]
      }
    }
  },
  "orgAdaptation": {
    "adaptationStrategy": "graceful-degradation",
    "minimumFidelity": 0.7,
    "fieldFallbacks": {
      "Revenue": {
        "patterns": [
          "Amount",
          "Revenue__c",
          "Total_Revenue__c"
        ],
        "cpqPatterns": [
          "SBQQ__NetAmount__c"
        ],
        "dataType": "currency"
      },
      "WinRate": {
        "patterns": [
          "Win_Rate__c",
          "Conversion_Rate__c"
        ],
        "dataType": "percent"
      }
    }
  }
}
