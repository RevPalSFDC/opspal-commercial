  "environmentRestrictions": {
    "production": {
      "allowedTiers": [1, 2, 3, 4],
      "requiresApprovalForTiers": [2, 3, 4, 5],
      "maxRecordsPerOperation": 10000,
      "deploymentWindow": {
        "enabled": true,
        "days": ["Tuesday", "Thursday"],
        "hours": "22:00-02:00 UTC",
        "exceptions": ["emergency-override"]
      },
      "additionalControls": {
        "requiresChangeTicket": true,
        "requiresBackupBeforeDestructive": true,
        "requiresPostDeploymentVerification": true
      }
    },
    "fullSandbox": {
      "allowedTiers": [1, 2, 3, 4],
      "requiresApprovalForTiers": [4, 5],
      "maxRecordsPerOperation": 50000,
      "additionalControls": {
        "requiresChangeTicket": false,
        "requiresBackupBeforeDestructive": true
      }
    },
    "sandbox": {
      "allowedTiers": [1, 2, 3, 4, 5],
      "requiresApprovalForTiers": [5],
      "maxRecordsPerOperation": 50000,
      "additionalControls": {
        "requiresChangeTicket": false,
        "requiresBackupBeforeDestructive": false
      }
    },
    "dev": {
      "allowedTiers": [1, 2, 3, 4, 5],
      "requiresApprovalForTiers": [],
      "maxRecordsPerOperation": 100000,
      "additionalControls": {
        "requiresChangeTicket": false,
        "requiresBackupBeforeDestructive": false
      }
    }
  },
  "approvalRouting": {
    "LOW": {
      "riskRange": [0, 30],
      "requiresApproval": false,
      "action": "PROCEED",
      "logging": "standard"
    },
    "MEDIUM": {
      "riskRange": [31, 50],
      "requiresApproval": false,
      "action": "PROCEED",
      "logging": "enhanced",
      "notification": ["team-lead"]
    },
    "HIGH": {
      "riskRange": [51, 70],
      "requiresApproval": true,
      "action": "REQUIRE_APPROVAL",
      "approvers": {
        "dataOperations": ["team-lead"],
        "metadataDeployment": ["architect"],
        "securityChanges": ["security-lead"]
      },
      "responseTime": {
        "dataOperations": "1 hour",
        "metadataDeployment": "4 hours",
        "securityChanges": "2 hours"
      }
    },
    "CRITICAL": {
      "riskRange": [71, 100],
      "requiresApproval": true,
      "action": "BLOCK",
      "approvers": {
        "dataOperations": ["team-lead", "manager"],
        "metadataDeployment": ["architect", "director"],
        "securityChanges": ["security-lead", "ciso"],
        "destructiveOperations": ["director", "vp"]
      },
      "responseTime": {
        "dataOperations": "4 hours",
        "metadataDeployment": "1 business day",
        "securityChanges": "1 business day",
        "destructiveOperations": "2 business days"
      },
      "requiresManualReview": true,
      "requiresDetailedJustification": true
    }
  },
  "emergencyOverride": {
    "enabled": true,
    "requiresCode": true,
    "codeValidityMinutes": 60,
    "allowedPersonnel": [
      "cto",
      "vp-engineering",
      "director-engineering",
      "security-lead"
    ],
    "triggers": [
      "Immediate notification to security team",
      "Audit log entry with full context",
      "Follow-up review required within 24 hours",
      "Override code expires after single use"
    ]
  },
  "auditTrail": {
    "storage": {
      "local": ".claude/logs/agent-governance/",
