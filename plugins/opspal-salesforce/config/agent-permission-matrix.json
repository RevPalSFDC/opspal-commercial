        "enabled": true,
        "table": "agent_actions"
      },
      "salesforce": {
        "enabled": true,
        "eventMonitoring": true
      }
    },
    "retention": {
      "production": "7 years",
      "sandbox": "2 years",
      "dev": "6 months"
    },
    "requiredFields": [
      "logId",
      "timestamp",
      "agent",
      "operation",
      "riskScore",
      "riskLevel",
      "approvalRequired",
      "approvalStatus",
      "environment",
