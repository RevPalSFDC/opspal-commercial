{
  "version": "1.0.0",
  "lastUpdated": "2025-10-25",
  "description": "Agent Permission Matrix - Defines what each agent tier can do and approval requirements",
  "permissionTiers": {
    "tier1": {
      "name": "Read-Only Agents",
      "description": "Agents that only query data and read metadata",
      "permissions": {
        "read": ["*"],
        "write": [],
        "deploy": [],
        "delete": []
      },
      "limits": {
        "maxRecordsPerQuery": 50000,
        "maxConcurrentQueries": 10
      },
      "requiresApproval": false,
      "requiresDocumentation": false,
      "requiresRollbackPlan": false
    },
    "tier2": {
      "name": "Standard Operations",
      "description": "CRUD on records, non-destructive metadata",
      "permissions": {
        "read": ["*"],
        "write": ["records"],
        "deploy": ["reports", "dashboards", "layouts"],
        "delete": []
      },
      "limits": {
        "maxRecordsPerOperation": 10000,
        "maxComponentsPerDeployment": 25
      },
      "requiresApproval": {
        "production": true,
        "recordCountThreshold": 1000,
        "bulkOperations": true
      },
      "requiresDocumentation": false,
      "requiresRollbackPlan": "recommended"
    },
    "tier3": {
      "name": "Metadata Management",
      "description": "Deploy fields, flows, validation rules, permission sets",
      "permissions": {
        "read": ["*"],
        "write": ["records", "metadata"],
        "deploy": [
          "customFields",
          "customObjects",
          "flows",
          "validationRules",
          "workflowRules",
          "permissionSets",
          "customTabs",
          "lightningPages"
        ],
        "delete": []
      },
      "limits": {
        "maxComponentsPerDeployment": 50,
        "maxFieldsPerObject": 20
      },
      "requiresApproval": {
        "production": true,
        "sandbox": {
          "componentCountThreshold": 5
        },
        "fields": true,
        "flows": true
      },
      "requiresDocumentation": true,
      "requiresRollbackPlan": true
    },
    "tier4": {
      "name": "Security & Permissions",
      "description": "Modify profiles, permission sets, roles, sharing rules",
      "permissions": {
        "read": ["*"],
        "write": ["records", "metadata", "security"],
        "deploy": [
          "profiles",
          "permissionSets",
          "permissionSetGroups",
          "roles",
          "sharingRules",
          "groups",
          "queues"
        ],
        "delete": []
      },
      "limits": {
        "maxPermissionSetsPerOperation": 10,
        "maxUsersAffected": 500
      },
      "requiresApproval": {
        "all": true,
        "multipleApprovers": true
      },
      "requiresDocumentation": true,
      "requiresRollbackPlan": true,
      "requiresSecurityReview": true
    },
    "tier5": {
      "name": "Destructive Operations",
      "description": "Delete records, destructive metadata changes",
      "permissions": {
        "read": ["*"],
        "write": ["records", "metadata"],
        "deploy": ["*"],
        "delete": ["records", "metadata"]
      },
      "limits": {
        "maxRecordsPerDelete": 100,
        "maxComponentsPerDestructive": 5
      },
      "requiresApproval": {
        "all": true,
        "executiveApproval": true,
        "multipleApprovers": true,
        "minimumApprovers": 2
      },
      "requiresDocumentation": true,
      "requiresRollbackPlan": true,
      "requiresBackup": true,
      "requiresSecurityReview": true
    }
  },
