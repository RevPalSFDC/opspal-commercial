{
  "schemaVersion": "1.1",
  "description": "Canonical metric semantics for Salesforce reporting. Used for field resolution and semantic validation. Includes sales, marketing, and customer success metrics. Business term aliases link to business-term-mappings.json for disambiguation.",
  "businessTermAliases": {
    "churn": ["gross_churn", "logo_churn"],
    "nrr": ["net_retention"],
    "grr": ["gross_churn"],
    "pipeline": ["pipeline.arr"],
    "win_rate": ["win_rate.count"],
    "bookings": ["bookings.tcv"],
    "arr": ["arr.subscription"],
    "expansion": ["expansion_revenue"],
    "renewal": ["renewal_rate"],
    "conversion_rate": ["stage_conversion", "mql_to_sql_conversion"],
    "sales_cycle": ["sales_cycle_length"],
    "velocity": ["pipeline.arr"],
    "aso": ["bookings.tcv"],
    "coverage_ratio": ["pipeline.arr"],
    "quota_attainment": ["quota_attainment"],
    "forecast_accuracy": ["forecast_accuracy"]
  },
  "_note_business_terms": "See config/business-term-mappings.json for full disambiguation mappings used by report-semantic-disambiguator.js",
  "defaultVariants": {
    "pipeline": "pipeline.arr",
    "bookings": "bookings.tcv",
    "revenue": "revenue.recognized",
    "acv": "acv.contract",
    "arr": "arr.subscription",
    "tcv": "tcv.contract",
    "win_rate": "win_rate.count",
    "sales_cycle_length": "sales_cycle_length.won",
    "quota_attainment": "quota_attainment",
    "forecast_accuracy": "forecast_accuracy",
    "stage_conversion": "stage_conversion_rate",
    "renewal_rate": "renewal_rate",
    "gross_churn": "gross_churn",
    "net_retention": "net_revenue_retention",
    "logo_churn": "logo_churn",
    "health_score": "health_score",
    "nps": "nps",
    "csat": "csat",
    "expansion_revenue": "expansion_revenue",
    "time_to_value": "time_to_value",
    "support_cases": "support_cases",
    "mql_volume": "mql_volume",
    "pipeline_sourced": "pipeline_sourced",
    "cost_per_lead": "cost_per_lead",
    "campaign_roi": "campaign_roi",
