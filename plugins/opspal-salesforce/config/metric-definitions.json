      "category": "pipeline",
      "baseObject": "Opportunity",
      "timeFieldRole": "closeDate",
      "description": "Open opportunities expected to close in a period, measured as total contract value.",
      "fieldRoles": {
        "amount": {
          "required": true,
          "description": "Total contract value for the deal.",
