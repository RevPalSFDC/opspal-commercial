  "metrics": {
    "pipeline.arr": {
      "metricName": "Pipeline (ARR)",
      "category": "pipeline",
      "baseObject": "Opportunity",
      "timeFieldRole": "closeDate",
      "description": "Open opportunities expected to close in a period, annualized to recurring revenue.",
      "fieldRoles": {
        "amount": {
          "required": true,
          "description": "Annualized recurring value for the deal.",
          "preferredFields": ["ARR__c", "Annual_Recurring_Revenue__c", "ACV__c", "Amount"],
          "labelHints": ["ARR", "Annual Recurring", "ACV", "Annual Contract", "Amount"],
          "cpqPatterns": ["SBQQ__ARR__c", "SBQQ__ACV__c", "SBQQ__NetAmount__c", "SBQQ__QuotedAmount__c"]
        },
        "closeDate": {
          "required": true,
          "description": "Expected close date used for time filtering.",
          "preferredFields": ["CloseDate"],
          "labelHints": ["Close Date"]
        },
        "stage": {
          "required": true,
          "description": "Stage for open/closed determination and grouping.",
          "preferredFields": ["StageName"],
          "labelHints": ["Stage"]
        },
        "probability": {
          "required": false,
          "description": "Probability for weighted pipeline.",
          "preferredFields": ["Probability"],
          "labelHints": ["Probability", "Stage %"]
        },
        "isClosed": {
          "required": true,
          "description": "Closed flag for open pipeline filtering.",
          "preferredFields": ["IsClosed"],
          "labelHints": ["Closed"]
        }
      },
      "recommendedFilters": [
        { "role": "isClosed", "operator": "equals", "value": "false" }
      ],
      "highRiskPatterns": [
        "Using CreatedDate instead of CloseDate for time filtering",
        "Using multi-year TCV without annualization",
        "Including Closed Won or Closed Lost in pipeline totals"
      ]
    },
    "pipeline.tcv": {
