  "metricCpqPatterns": {
    "_description": "CPQ-specific patterns for metric-definitions.json enhancement",
    "revenue_metrics": {
      "amount": ["SBQQ__NetAmount__c", "SBQQ__CustomerAmount__c", "SBQQ__QuotedAmount__c"],
      "arr": ["SBQQ__ARR__c", "SBQQ__ACV__c"],
      "mrr": ["SBQQ__MRR__c"],
