  "detectionQueries": {
    "_description": "SOQL queries to detect CPQ installation and configuration",
    "hasCpq": "SELECT COUNT() FROM EntityDefinition WHERE QualifiedApiName = 'SBQQ__Quote__c'",
    "hasCpqData": "SELECT COUNT() FROM SBQQ__Quote__c LIMIT 1",
    "cpqVersion": "SELECT SBQQ__Version__c FROM SBQQ__Setting__c LIMIT 1",
    "hasNativeQuote": "SELECT COUNT() FROM Quote LIMIT 1",
    "quotingSystemType": "SELECT (SELECT COUNT() FROM SBQQ__Quote__c LIMIT 1) cpqCount, (SELECT COUNT() FROM Quote LIMIT 1) nativeCount FROM Account LIMIT 1"
  }
