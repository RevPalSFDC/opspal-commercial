  "reportFieldMappings": {
    "_description": "Field mappings specifically for Analytics API report tokens",
    "QUOTE_AMOUNT": {
      "native": ["QUOTE.TOTAL_PRICE", "QUOTE.GRAND_TOTAL"],
      "cpq": ["SBQQ__Quote__c.SBQQ__NetAmount__c", "SBQQ__Quote__c.SBQQ__CustomerAmount__c"]
