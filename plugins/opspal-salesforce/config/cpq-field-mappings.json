    "QUOTE_DISCOUNT": {
      "native": ["QUOTE.DISCOUNT"],
      "cpq": ["SBQQ__Quote__c.SBQQ__CustomerDiscount__c", "SBQQ__Quote__c.SBQQ__AverageCustomerDiscount__c"]
