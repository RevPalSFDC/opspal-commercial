    "OPPORTUNITY_AMOUNT": {
      "native": ["OPPORTUNITY.AMOUNT", "AMOUNT"],
      "cpq": ["SBQQ__QuotedAmount__c", "SBQQ__NetAmount__c", "OPPORTUNITY.AMOUNT"]
