          "object": "Opportunity",
          "filter": "CloseDate > Original_Close_Date__c AND IsClosed = false",
          "metric": "COUNT and SUM(Amount)",
          "context_hints": []
        }
      ]
    },
    "conversion_rate": {
      "category": "marketing",
      "disambiguation_required": true,
      "interpretations": [
        {
          "label": "Lead conversion rate (converted / total leads)",
          "object": "Lead",
          "filter": "All leads in period",
          "metric": "COUNT(Converted) / COUNT(Total)",
