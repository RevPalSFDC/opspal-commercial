          "label": "Forecast accuracy (forecast vs actual, by period)",
          "object": "Opportunity",
          "filter": "IsClosed = true",
          "metric": "1 - ABS(Forecast - Actual) / Actual",
          "context_hints": []
        }
      ]
    },
    "velocity": {
      "category": "sales",
      "disambiguation_required": true,
      "interpretations": [
        {
          "label": "Pipeline velocity (# opps * win rate * avg deal / cycle)",
          "object": "Opportunity",
          "filter": "IsClosed = false",
          "metric": "Composite: count * win_rate * avg_deal / avg_cycle",
          "context_hints": ["pipeline", "sales"]
        },
        {
          "label": "Deal velocity (time in each stage)",
          "object": "Opportunity",
          "filter": "Stage history analysis",
          "metric": "AVG(days per stage)",
          "context_hints": ["stage", "deal", "movement"]
        }
      ]
    },
    "slipped": {
      "category": "sales",
      "disambiguation_required": false,
      "interpretations": [
