#!/bin/bash

##############################################################################
# test-auto-fix.sh - Comprehensive Test Suite for Auto-Fix System
##############################################################################
# Tests all components of the autonomous error resolution framework
##############################################################################

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Test counters
TESTS_RUN=0
TESTS_PASSED=0
TESTS_FAILED=0
TESTS_SKIPPED=0

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Test files
TEST_DIR="${SCRIPT_DIR}/test_auto_fix_$$"
TEST_RESULTS="${SCRIPT_DIR}/test-auto-fix-results-$(date +%Y%m%d-%H%M%S).log"

# Components to test
AUTO_FIX_ENGINE="${SCRIPT_DIR}/auto-fix-engine.py"
PREVENTION_GUARD="${SCRIPT_DIR}/error-prevention-guard.sh"
SMART_WRAPPER="${SCRIPT_DIR}/smart-operation-wrapper.py"
AGENT_RESOLVER="${SCRIPT_DIR}/agent-auto-resolver.sh"

##############################################################################
# Test Infrastructure
##############################################################################

setup_test_environment() {
    echo -e "${CYAN}Setting up test environment...${NC}"
    
    # Create test directory
    mkdir -p "$TEST_DIR"
    
    # Create test files
    create_test_files
    
    echo -e "${GREEN}Test environment ready${NC}"
}

cleanup_test_environment() {
    echo -e "${CYAN}Cleaning up test environment...${NC}"
    
    # Remove test directory
    rm -rf "$TEST_DIR"
    
    # Remove test databases
    rm -f "${SCRIPT_DIR}/.test_*.db"
    
    echo -e "${GREEN}Cleanup complete${NC}"
}

create_test_files() {
    # Create CSV with LF line endings
    printf "Id,Name,Status\n001,Test1,Active\n002,Test2,Inactive" > "${TEST_DIR}/test_lf.csv"
    
    # Create CSV with CRLF line endings
    printf "Id,Name,Status\r\n001,Test1,Active\r\n002,Test2,Inactive\r\n" > "${TEST_DIR}/test_crlf.csv"
    
    # Create CSV with BOM
    printf "\xef\xbb\xbfId,Name,Status\n001,Test1,Active\n002,Test2,Inactive" > "${TEST_DIR}/test_bom.csv"
    
    # Create CSV with special characters in headers
    echo "Id,Name@#$,Status!" > "${TEST_DIR}/test_special_chars.csv"
    echo "001,Test1,Active" >> "${TEST_DIR}/test_special_chars.csv"
    
    # Create large CSV for chunking tests
    echo "Id,Name,Status" > "${TEST_DIR}/test_large.csv"
    for i in {1..15000}; do
        echo "$(printf '%06d' $i),Test$i,Active" >> "${TEST_DIR}/test_large.csv"
    done
    
    # Create malformed CSV
    echo "Id,Name,Status" > "${TEST_DIR}/test_malformed.csv"
    echo "001,\"Test" >> "${TEST_DIR}/test_malformed.csv"
    echo "002,Test2,Inactive,Extra" >> "${TEST_DIR}/test_malformed.csv"
    
    # Create empty CSV
    touch "${TEST_DIR}/test_empty.csv"
}

##############################################################################
# Test Functions
##############################################################################

run_test() {
    local test_name="$1"
    local test_command="$2"
    local expected_result="${3:-0}"
    
    ((TESTS_RUN++))
    echo -e "${BLUE}TEST ${TESTS_RUN}: ${test_name}${NC}"
    
    # Run test and capture result
    set +e
    eval "$test_command" >> "$TEST_RESULTS" 2>&1
    local result=$?
    set -e
    
    # Check result
    if [[ $result -eq $expected_result ]]; then
        echo -e "${GREEN}  ✓ PASSED${NC}"
        ((TESTS_PASSED++))
        echo "PASS: $test_name" >> "$TEST_RESULTS"
        return 0
    else
        echo -e "${RED}  ✗ FAILED (expected $expected_result, got $result)${NC}"
        ((TESTS_FAILED++))
        echo "FAIL: $test_name (expected $expected_result, got $result)" >> "$TEST_RESULTS"
        return 1
    fi
}

skip_test() {
    local test_name="$1"
    local reason="$2"
    
    ((TESTS_SKIPPED++))
    echo -e "${YELLOW}SKIP: ${test_name} - ${reason}${NC}"
    echo "SKIP: $test_name - $reason" >> "$TEST_RESULTS"
}

##############################################################################
# Auto-Fix Engine Tests
##############################################################################

test_auto_fix_engine() {
    echo -e "\n${CYAN}Testing Auto-Fix Engine...${NC}"
    
    # Test line ending detection and fix
    run_test "Line ending detection" \
        "python3 ${AUTO_FIX_ENGINE} 'LineEnding is invalid on user data' \
         --file ${TEST_DIR}/test_lf.csv --auto"
    
    # Test CSV format fixing
    run_test "CSV format validation" \
        "python3 ${AUTO_FIX_ENGINE} 'Check that the provided CSV file is valid' \
         --file ${TEST_DIR}/test_malformed.csv --auto"
    
    # Test field name cleaning
    run_test "Field name cleaning" \
        "python3 ${AUTO_FIX_ENGINE} 'Field Name@#$ not found' \
         --file ${TEST_DIR}/test_special_chars.csv --auto"
    
    # Test confidence threshold
    run_test "Confidence threshold enforcement" \
        "python3 ${AUTO_FIX_ENGINE} 'Generic error' \
         --confidence 99" \
        1  # Should fail due to low confidence
    
    # Test rollback capability
    if [[ -f "${TEST_DIR}/test_lf.csv.backup."* ]]; then
        run_test "Backup creation" "ls ${TEST_DIR}/test_lf.csv.backup.*"
    else
        skip_test "Backup creation" "No backup file found"
    fi
}

##############################################################################
# Prevention Guard Tests
##############################################################################

test_prevention_guard() {
    echo -e "\n${CYAN}Testing Prevention Guard...${NC}"
    
    # Test CSV prevention
    run_test "CSV line ending prevention" \
        "${PREVENTION_GUARD} -n sf data upsert bulk \
         --sobject Account --file ${TEST_DIR}/test_lf.csv"
    
    # Test BOM removal
    run_test "BOM removal prevention" \
        "${PREVENTION_GUARD} -n sf data import \
         --file ${TEST_DIR}/test_bom.csv"
    
    # Test large file detection
    run_test "Large file warning" \
        "${PREVENTION_GUARD} -n sf data upsert bulk \
         --sobject Account --file ${TEST_DIR}/test_large.csv"
    
    # Test SOQL query fixing
    run_test "SOQL query validation" \
        "${PREVENTION_GUARD} -n sf data query \
         --query 'select id from account'"

    # Test CustomField MasterLabel rewrite and tooling flag injection
    run_test "CustomField query normalization" \
        "output=\$(EXECUTE_COMMAND=false ${PREVENTION_GUARD} sf data query \
            --query 'SELECT DeveloperName, MasterLabel FROM CustomField WHERE CreatedBy.Name LIKE \'%Chris%\''); \
         echo \"\$output\" | grep -q 'DeveloperName, Label FROM CustomField' && \
         echo \"\$output\" | grep -q '--use-tooling-api'"

    # Test dry run mode
    run_test "Dry run mode" \
        "${PREVENTION_GUARD} -n -m conservative \
         sf data import --file ${TEST_DIR}/test_special_chars.csv"
}

##############################################################################
# Smart Wrapper Tests
##############################################################################

test_smart_wrapper() {
    echo -e "\n${CYAN}Testing Smart Operation Wrapper...${NC}"
    
    # Test retry logic
    run_test "Retry on failure" \
        "python3 ${SMART_WRAPPER} --max-retries 2 \
         --retry-strategy linear \
         echo 'test'"
    
    # Test timeout handling
    run_test "Timeout detection" \
        "timeout 1 python3 ${SMART_WRAPPER} --timeout 5 \
         sleep 10" \
        124  # Timeout exit code
    
    # Test auto-fix integration
    run_test "Auto-fix integration" \
        "python3 ${SMART_WRAPPER} --no-auto-fix \
         false" \
        1  # Should fail without auto-fix
    
    # Test statistics collection
    run_test "Statistics generation" \
        "python3 ${SMART_WRAPPER} --stats \
         echo 'test'"
}

##############################################################################
# Agent Resolver Tests
##############################################################################

test_agent_resolver() {
    echo -e "\n${CYAN}Testing Agent Auto-Resolver...${NC}"
    
    # Source the resolver
    source "$AGENT_RESOLVER"
    
    # Set test agent context
    export AGENT_NAME="test-agent"
    export RESOLUTION_MODE="balanced"
    export CONFIDENCE_THRESHOLD="85"
    
    # Test prevention application
    local prevented_cmd=$(agent_pre_operation "data_import" \
        sf data import --file "${TEST_DIR}/test_lf.csv")
    
    if [[ -n "$prevented_cmd" ]]; then
        run_test "Agent prevention integration" "echo 'Prevention applied'"
    else
        skip_test "Agent prevention integration" "No prevention applied"
    fi
    
    # Test error handling
    run_test "Agent error handling" \
        "agent_handle_error 'Test error' 'test command' '{}'" \
        1  # Should return 1 for unresolved error
    
    # Test statistics
    show_statistics > /dev/null 2>&1
    run_test "Statistics generation" "echo 'Stats generated'"
}

##############################################################################
# Integration Tests
##############################################################################

test_integration() {
    echo -e "\n${CYAN}Testing Full Integration...${NC}"
    
    # Test end-to-end CSV import with auto-fix
    local test_file="${TEST_DIR}/integration_test.csv"
    
    # Create problematic CSV
    printf "Id,Name@,Status!\r\n001,Test,Active" > "$test_file"
    
    # Test with all components
    run_test "End-to-end auto-fix" \
        "${PREVENTION_GUARD} -a python3 ${SMART_WRAPPER} \
         --confidence 85 echo 'Simulated import of $test_file'"
    
    # Test learning system
    if [[ -f "${SCRIPT_DIR}/.resolution_learning.db" ]]; then
        run_test "Learning database creation" \
            "sqlite3 ${SCRIPT_DIR}/.resolution_learning.db 'SELECT COUNT(*) FROM resolutions'"
    else
        skip_test "Learning database" "Database not created"
    fi
}

##############################################################################
# Error Scenario Tests
##############################################################################

test_error_scenarios() {
    echo -e "\n${CYAN}Testing Error Scenarios...${NC}"
    
    # Test specific error patterns
    local errors=(
        "LineEnding is invalid on user data. Current LineEnding setting is LF"
        "Job finished successfully but it didn't process any record"
        "Check that the provided CSV file is valid"
        "Field Name__c not found"
        "Command timed out after 2m"
    )
    
    for error in "${errors[@]}"; do
        run_test "Error pattern: ${error:0:30}..." \
            "python3 ${AUTO_FIX_ENGINE} '$error' \
             --file ${TEST_DIR}/test_lf.csv"
    done
}

##############################################################################
# Performance Tests
##############################################################################

test_performance() {
    echo -e "\n${CYAN}Testing Performance...${NC}"
    
    # Test large file handling
    local start_time=$(date +%s)
    
    run_test "Large file processing" \
        "${PREVENTION_GUARD} -n echo 'Processing ${TEST_DIR}/test_large.csv'"
    
    local end_time=$(date +%s)
    local duration=$((end_time - start_time))
    
    if [[ $duration -lt 10 ]]; then
        echo -e "${GREEN}  Performance: Processed in ${duration}s${NC}"
    else
        echo -e "${YELLOW}  Performance: Took ${duration}s (slow)${NC}"
    fi
    
    # Test parallel processing
    if command -v parallel &> /dev/null; then
        run_test "Parallel fix execution" \
            "echo '${TEST_DIR}/test_'*.csv | \
             xargs -n1 -P4 python3 ${AUTO_FIX_ENGINE} 'Test error' --file"
    else
        skip_test "Parallel execution" "GNU parallel not installed"
    fi
}

##############################################################################
# Negative Tests
##############################################################################

test_negative_cases() {
    echo -e "\n${CYAN}Testing Negative Cases...${NC}"
    
    # Test with non-existent file
    run_test "Non-existent file handling" \
        "python3 ${AUTO_FIX_ENGINE} 'Error' \
         --file /nonexistent/file.csv" \
        1  # Should fail
    
    # Test with invalid confidence
    run_test "Invalid confidence value" \
        "python3 ${AUTO_FIX_ENGINE} 'Error' \
         --confidence 150" \
        1  # Should fail
    
    # Test with empty error
    run_test "Empty error handling" \
        "python3 ${AUTO_FIX_ENGINE} ''" \
        1  # Should fail
    
    # Test permission errors (should not auto-fix)
    run_test "Permission error non-fix" \
        "python3 ${AUTO_FIX_ENGINE} 'INSUFFICIENT_ACCESS' --auto" \
        1  # Should not auto-fix
}

##############################################################################
# Report Generation
##############################################################################

generate_report() {
    echo -e "\n${CYAN}========================================${NC}"
    echo -e "${CYAN}     Auto-Fix Test Results Summary${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo -e "Tests Run:     ${BLUE}$TESTS_RUN${NC}"
    echo -e "Tests Passed:  ${GREEN}$TESTS_PASSED${NC}"
    echo -e "Tests Failed:  ${RED}$TESTS_FAILED${NC}"
    echo -e "Tests Skipped: ${YELLOW}$TESTS_SKIPPED${NC}"
    
    if [[ $TESTS_FAILED -eq 0 ]]; then
        echo -e "\n${GREEN}✓ All tests passed!${NC}"
        echo "SUCCESS" > "${SCRIPT_DIR}/test-auto-fix-status.txt"
        return 0
    else
        echo -e "\n${RED}✗ Some tests failed. Check $TEST_RESULTS for details.${NC}"
        echo "FAILURE" > "${SCRIPT_DIR}/test-auto-fix-status.txt"
        return 1
    fi
}

##############################################################################
# Main Test Execution
##############################################################################

main() {
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}      Auto-Fix System Test Suite${NC}"
    echo -e "${CYAN}========================================${NC}"
    
    # Initialize test results
    echo "Test Execution Started: $(date)" > "$TEST_RESULTS"
    echo "======================================" >> "$TEST_RESULTS"
    
    # Setup
    setup_test_environment
    
    # Check if running specific test suite
    if [[ $# -gt 0 ]]; then
        case "$1" in
            engine)
                test_auto_fix_engine
                ;;
            prevention)
                test_prevention_guard
                ;;
            wrapper)
                test_smart_wrapper
                ;;
            resolver)
                test_agent_resolver
                ;;
            integration)
                test_integration
                ;;
            errors)
                test_error_scenarios
                ;;
            performance)
                test_performance
                ;;
            negative)
                test_negative_cases
                ;;
            all|*)
                # Run all tests
                test_auto_fix_engine
                test_prevention_guard
                test_smart_wrapper
                test_agent_resolver
                test_integration
                test_error_scenarios
                test_negative_cases
                
                # Only run performance tests if explicitly requested
                if [[ "$1" == "all" ]]; then
                    test_performance
                fi
                ;;
        esac
    else
        # Default: run all tests except performance
        test_auto_fix_engine
        test_prevention_guard
        test_smart_wrapper
        test_agent_resolver
        test_integration
        test_error_scenarios
        test_negative_cases
    fi
    
    # Cleanup
    cleanup_test_environment
    
    # Generate report
    generate_report
    
    # Exit with appropriate code
    exit $?
}

# Handle script arguments
case "${1:-}" in
    -h|--help)
        echo "Usage: $0 [test-suite]"
        echo ""
        echo "Test Suites:"
        echo "  engine       - Test auto-fix engine"
        echo "  prevention   - Test prevention guard"
        echo "  wrapper      - Test smart wrapper"
        echo "  resolver     - Test agent resolver"
        echo "  integration  - Test full integration"
        echo "  errors       - Test error scenarios"
        echo "  performance  - Test performance"
        echo "  negative     - Test negative cases"
        echo "  all          - Run all tests"
        echo ""
        echo "If no suite specified, runs all tests except performance"
        exit 0
        ;;
    *)
        main "$@"
        ;;
esac
