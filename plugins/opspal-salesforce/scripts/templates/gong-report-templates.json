  "templates": {
    "last_gong_call_date": {
      "templateId": "gong_last_call_date_v2",
      "name": "Last Gong Call Date by Opportunity",
      "description": "Shows the most recent Gong call date for each opportunity using MAX aggregation",
      "reportType": "Gong__Opportunities_with_Gong_Conversations_and_contacts",
      "format": "SUMMARY",
      "requiredFields": [
        "OPPORTUNITY.ID",
        "OPPORTUNITY.NAME", 
        "GONG__GONG_CALL__C.GONG__CALL_START__C"
      ],
      "lastVerifiedChecksum": "a3f2c89d12ef",
      "metadata": {
        "reportFormat": "SUMMARY",
        "groupingsDown": [
          {
            "name": "OPPORTUNITY.ID",
            "sortOrder": "ASC",
            "dateGranularity": null
          }
        ],
        "detailColumns": [
          "OPPORTUNITY.NAME",
          "OPPORTUNITY.STAGE_NAME",
          "OPPORTUNITY.CLOSE_DATE",
          "GONG__GONG_CALL__C.GONG__CALL_START__C",
          "GONG__GONG_CALL__C.GONG__CALL_DURATION__C"
        ],
        "aggregates": [
          {
            "name": "mx!GONG__GONG_CALL__C.GONG__CALL_START__C",
            "label": "Last Call Date"
          }
        ],
        "standardDateFilter": {
          "column": "OPPORTUNITY.CLOSE_DATE",
          "durationValue": "THIS_QUARTER"
        }
      }
    },
    
    "calls_last_14_days": {
      "name": "Gong Calls Last 14 Days",
      "description": "Count of Gong calls per opportunity in the last 14 days",
      "reportType": "Gong__Opportunities_with_Gong_Conversations_and_contacts",
      "format": "SUMMARY",
      "metadata": {
        "reportFormat": "SUMMARY",
        "groupingsDown": [
          {
            "name": "OPPORTUNITY.NAME",
            "sortOrder": "ASC"
          }
        ],
        "detailColumns": [
          "OPPORTUNITY.STAGE_NAME",
          "OPPORTUNITY.AMOUNT",
          "GONG__GONG_CALL__C.GONG__CALL_START__C",
          "GONG__GONG_CALL__C.NAME"
        ],
        "aggregates": [
          {
            "name": "RowCount",
            "label": "Call Count"
          }
        ],
        "reportFilters": [
          {
            "column": "GONG__GONG_CALL__C.GONG__CALL_START__C",
            "operator": "LAST_N_DAYS",
            "value": "${DAYS:=14}"
          },
          {
            "column": "OPPORTUNITY.STAGE_NAME",
            "operator": "NOT_EQUAL",
            "value": "Closed Won,Closed Lost"
          }
        ]
      }
    },
    
    "calls_last_30_days": {
