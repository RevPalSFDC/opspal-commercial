  "dashboards": {
    "momentum_rag": {
      "name": "Opportunity Momentum RAG Dashboard",
      "description": "Red-Amber-Green dashboard showing opportunity health",
      "components": [
        {
          "name": "Red Opportunities",
          "sourceReport": "single_threaded_opportunities",
          "componentType": "GAUGE",
          "filters": [
            {
              "field": "Unique Contacts",
              "operator": "LESS_THAN",
              "value": "3"
            },
            {
              "field": "Call Count",
              "operator": "EQUALS",
              "value": "0"
            }
          ],
          "color": "#FF0000"
        },
        {
          "name": "Amber Opportunities",
          "sourceReport": "calls_last_14_days",
          "componentType": "GAUGE",
          "filters": [
            {
              "field": "Call Count",
              "operator": "GREATER_THAN",
              "value": "0"
            },
            {
              "field": "Call Count",
              "operator": "LESS_THAN",
              "value": "3"
            }
          ],
          "color": "#FFA500"
        },
        {
          "name": "Green Opportunities",
          "sourceReport": "vp_plus_engagement",
          "componentType": "GAUGE",
          "filters": [
            {
              "field": "Call Count",
              "operator": "GREATER_THAN_EQUAL",
              "value": "3"
            },
            {
              "field": "Has_Executive_Engagement",
              "operator": "EQUALS",
              "value": "1"
            }
          ],
          "color": "#00FF00"
        }
      ]
    }
  },
  
  "formulaLibrary": {
    "daysSinceLastActivity": {
      "formula": "TODAY() - MAX(Activity.ActivityDate)",
      "dataType": "Number",
      "description": "Calculate days since last activity"
    },
    "coverageScore": {
      "formula": "IF(COUNT(Gong__Gong_Call__c.Id) >= 5, 100, (COUNT(Gong__Gong_Call__c.Id) / 5) * 100)",
      "dataType": "Percent",
      "description": "Coverage score based on call frequency"
    },
    "threadingIndex": {
      "formula": "COUNT_DISTINCT(Contact.Email) * IF(MAX(IF(CONTAINS(Contact.Title, \"VP\"), 1, 0)) = 1, 1.5, 1)",
      "dataType": "Number",
      "description": "Multi-threading score with executive weighting"
    },
    "riskScore": {
      "formula": "(TODAY() - MAX(Activity.ActivityDate)) * IF(COUNT_DISTINCT(Contact.Email) < 3, 2, 1)",
      "dataType": "Number",
      "description": "Risk score based on activity recency and threading"
    },
    "momentumIndicator": {
      "formula": "IF(COUNT(Gong__Gong_Call__c.Id) > PREVIOUS_COUNT(Gong__Gong_Call__c.Id), \"Increasing\", IF(COUNT(Gong__Gong_Call__c.Id) < PREVIOUS_COUNT(Gong__Gong_Call__c.Id), \"Decreasing\", \"Stable\"))",
      "dataType": "Text",
      "description": "Trend indicator for call activity"
    }
  },
  
  "dateRangePresets": {
