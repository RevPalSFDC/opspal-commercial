    "unique_external_participants": {
      "name": "Unique External Participants Last 30 Days",
      "description": "Count of unique external participants per opportunity using COUNT_DISTINCT",
      "reportType": "Gong__Opportunities_with_Gong_Conversations_and_contacts",
      "format": "SUMMARY",
      "metadata": {
        "reportFormat": "SUMMARY",
        "groupingsDown": [
          {
            "name": "OPPORTUNITY.NAME",
            "sortOrder": "ASC"
          }
        ],
        "detailColumns": [
          "OPPORTUNITY.STAGE_NAME",
          "CONTACT.EMAIL",
          "CONTACT.ACCOUNT_NAME",
          "GONG__GONG_CALL__C.GONG__CALL_START__C"
        ],
        "aggregates": [
          {
            "name": "u!CONTACT.EMAIL",
            "label": "Unique Participants"
          }
        ],
        "reportFilters": [
          {
            "column": "GONG__GONG_CALL__C.GONG__CALL_START__C",
            "operator": "LAST_N_DAYS",
            "value": "30"
          },
          {
            "column": "CONTACT.ACCOUNT_NAME",
            "operator": "NOT_EQUAL",
            "value": "[Your Company Name]"
          }
        ]
      }
    },
    
    "vp_plus_engagement": {
      "name": "VP+ Executive Engagement",
      "description": "Tracks executive-level engagement using row-level and summary formulas",
      "reportType": "Gong__Opportunities_with_Gong_Conversations_and_contacts",
      "format": "SUMMARY",
      "metadata": {
        "reportFormat": "SUMMARY",
        "groupingsDown": [
          {
            "name": "OPPORTUNITY.NAME",
            "sortOrder": "ASC"
          }
        ],
        "detailColumns": [
          "CONTACT.NAME",
          "CONTACT.TITLE",
          "GONG__GONG_CALL__C.GONG__CALL_START__C"
        ],
        "reportFilters": [
          {
            "column": "GONG__GONG_CALL__C.GONG__CALL_START__C",
            "operator": "LAST_N_DAYS",
            "value": "30"
          }
        ]
      },
      "formulas": {
        "rowLevel": {
          "name": "Is_Executive",
          "formula": "IF(CONTAINS(Contact.Title, \"VP\") || CONTAINS(Contact.Title, \"Chief\") || CONTAINS(Contact.Title, \"President\") || CONTAINS(Contact.Title, \"Director\"), 1, 0)",
          "dataType": "Number",
          "description": "Flags executive-level contacts"
        },
        "summary": {
          "name": "Has_Executive_Engagement",
          "formula": "MAX(Is_Executive)",
          "dataType": "Number",
          "description": "1 if any executive engaged, 0 otherwise"
        }
      }
    },
    
    "next_meeting_scheduled": {
      "name": "Next Meeting Scheduled Indicator",
      "description": "Shows opportunities with future meetings scheduled",
      "reportType": "Opportunities_with_Activities",
      "format": "SUMMARY",
      "metadata": {
        "reportFormat": "SUMMARY",
        "groupingsDown": [
          {
            "name": "OPPORTUNITY.NAME",
            "sortOrder": "ASC"
          }
        ],
        "detailColumns": [
          "ACTIVITY.SUBJECT",
          "ACTIVITY.DUE_DATE",
          "ACTIVITY.STATUS"
        ],
        "aggregates": [
          {
            "name": "RowCount",
            "label": "Future Meetings"
          }
        ],
        "reportFilters": [
          {
            "column": "ACTIVITY.DUE_DATE",
            "operator": "GREATER_THAN",
            "value": "TODAY"
          },
          {
            "column": "ACTIVITY.TASK_SUBTYPE",
            "operator": "EQUALS",
            "value": "Event"
          }
        ]
      }
    },
    
    "single_threaded_opportunities": {
      "name": "Single-Threaded Opportunities",
      "description": "Identifies opportunities with fewer than 3 unique contacts engaged",
      "reportType": "Gong__Opportunities_with_Gong_Conversations_and_contacts",
      "format": "SUMMARY",
      "metadata": {
        "reportFormat": "SUMMARY",
        "groupingsDown": [
          {
            "name": "OPPORTUNITY.NAME",
            "sortOrder": "ASC"
          }
        ],
        "detailColumns": [
          "OPPORTUNITY.STAGE_NAME",
          "OPPORTUNITY.AMOUNT",
          "CONTACT.EMAIL"
        ],
        "aggregates": [
          {
            "name": "u!CONTACT.EMAIL",
            "label": "Unique Contacts"
          }
        ],
        "reportFilters": [
          {
            "column": "GONG__GONG_CALL__C.GONG__CALL_START__C",
            "operator": "LAST_N_DAYS",
            "value": "30"
          }
        ],
        "summaryFilters": [
          {
            "aggregate": "u!CONTACT.EMAIL",
            "operator": "LESS_THAN",
            "value": "3"
          }
        ]
      }
    },
    
