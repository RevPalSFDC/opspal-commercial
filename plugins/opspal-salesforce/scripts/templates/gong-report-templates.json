      "reportType": "Gong__Opportunities_with_Gong_Conversations_and_contacts",
      "format": "SUMMARY",
      "metadata": {
        "reportFormat": "SUMMARY",
        "groupingsDown": [
          {
            "name": "OPPORTUNITY.NAME",
