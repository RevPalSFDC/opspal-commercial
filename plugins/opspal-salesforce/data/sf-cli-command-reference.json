{
  "version": "3.0.0",
  "lastUpdated": "2025-12-28",
  "description": "Salesforce CLI command reference for validation (Expanded with 40+ commands)",
  "commands": {
    "sf data query": {
      "valid": true,
      "flags": {
        "required": [],
        "optional": [
          "--query",
          "-q",
          "--use-tooling-api",
          "--target-org",
          "-o",
          "--api-version",
          "--json",
          "--result-format"
        ]
      },
      "description": "Query data using SOQL",
      "examples": [
        "sf data query --query \"SELECT Id FROM Account\" --target-org myorg",
        "sf data query -q \"SELECT Id FROM Contact\" -o myorg --use-tooling-api"
      ]
    },
    "sf data export": {
      "valid": false,
      "reason": "Invalid command. Use 'sf data query' instead.",
      "replacement": "sf data query",
      "description": "This command does not exist in SF CLI v2.x"
    },
    "sf data import": {
      "valid": true,
      "flags": {
        "required": ["--sobject"],
        "optional": [
          "--file",
          "-f",
          "--target-org",
          "-o",
          "--json",
          "--wait"
        ]
      },
      "description": "Import data from CSV file",
      "examples": [
        "sf data import tree --plan plan.json --target-org myorg",
        "sf data import bulk --sobject Account --file accounts.csv -o myorg"
      ]
    },
    "sf data upsert": {
      "valid": true,
      "flags": {
        "required": ["--sobject", "--external-id"],
        "optional": [
          "--file",
          "-f",
          "--target-org",
          "-o",
          "--json",
          "--wait"
        ]
      },
      "description": "Upsert data using external ID",
      "examples": [
        "sf data upsert bulk --sobject Account --external-id External_Id__c --file accounts.csv -o myorg"
      ]
    },
