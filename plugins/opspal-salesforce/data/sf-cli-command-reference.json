    "sf sobject create field": {
      "valid": false,
      "reason": "Invalid command. SF CLI has no 'sf sobject create field'. Use metadata deploy with CustomField XML.",
      "replacement": "sf project deploy start",
      "description": "This command does not exist in SF CLI v2.x. Create CustomField metadata XML and deploy with 'sf project deploy start'."
    },
    "sf sobject create": {
      "valid": false,
      "reason": "Invalid command. SF CLI has no 'sf sobject create'. Use metadata deploy with CustomObject XML.",
      "replacement": "sf project deploy start",
      "description": "This command does not exist in SF CLI v2.x. Create CustomObject metadata XML and deploy with 'sf project deploy start'."
    },
    "sf sobject create record": {
      "valid": false,
      "reason": "Invalid command. The correct command for creating records is 'sf data create record'.",
      "replacement": "sf data create record",
      "description": "Common confusion between sobject (metadata) and data (records) namespaces."
    },
    "sf sobject update": {
      "valid": false,
      "reason": "Invalid command. To update records use 'sf data update record'. To update metadata use 'sf project deploy start'.",
      "replacement": "sf data update record",
      "description": "Common confusion between sobject (metadata) and data (records) namespaces."
    },
    "sf sobject delete": {
      "valid": false,
      "reason": "Invalid command. To delete records use 'sf data delete record'. To remove metadata use 'sf project deploy start' with destructiveChanges.",
      "replacement": "sf data delete record",
      "description": "Common confusion between sobject (metadata) and data (records) namespaces."
    }
