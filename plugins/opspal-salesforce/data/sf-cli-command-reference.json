  "commonErrors": [
    {
      "error": "sf data export",
      "correction": "sf data query",
      "explanation": "'sf data export' is not a valid command. Use 'sf data query' to query data."
    },
    {
      "error": "--source-path",
      "correction": "--source-dir or -d",
      "explanation": "Flag --source-path was renamed to --source-dir in SF CLI v2.x"
    },
    {
      "error": "sf sobject create field",
      "correction": "sf project deploy start",
      "explanation": "'sf sobject create field' does not exist. Create CustomField metadata XML and deploy with 'sf project deploy start -d <source-dir>'."
    },
    {
      "error": "sf sobject create",
      "correction": "sf project deploy start",
      "explanation": "'sf sobject create' does not exist for metadata. Use 'sf data create record' for records, or deploy CustomObject XML with 'sf project deploy start'."
    }
  ]
}
