{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-marketo.sh",
            "timeout": 10000,
            "description": "Load Marketo instance context and validate authentication"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-marketo-api.sh",
            "timeout": 8000,
            "description": "Detect direct Marketo API curl calls and route mutating work through approved Marketo specialists"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/universal-agent-governance.sh",
            "timeout": 8000,
            "description": "Universal agent governance for Marketo bulk, sync, and destructive workflows"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-intelligence-analysis.sh",
            "timeout": 8000,
            "description": "Validate observability export freshness before Marketo analysis agents execute"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__campaign_activate",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-campaign-activation.sh",
            "timeout": 10000,
            "description": "Validate campaignId, check API rate limits, and enforce deactivation cooldown before campaign activation"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__campaign_clone",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-campaign-clone.sh",
            "timeout": 30000,
            "description": "Validate campaign clone source, name, and destination before execution"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__campaign_delete",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-campaign-delete.sh",
            "timeout": 30000,
            "description": "Validate campaign deletion safety before execution"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__lead_create|mcp__marketo__lead_update|mcp__marketo__lead_delete",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bulk-operation.sh",
            "timeout": 30000,
            "description": "Validate bulk lead operations"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__lead_merge",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-lead-merge.sh",
            "timeout": 30000,
            "description": "Validate lead merge operation"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__program_clone",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-orchestration.sh",
            "timeout": 30000,
            "description": "Validate Marketo program clone orchestration inputs before execution"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__bulk_lead_export_create|mcp__marketo__bulk_activity_export_create|mcp__marketo__bulk_program_member_export_create",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bulk-export.sh",
            "timeout": 30000,
            "description": "Validate bulk export date ranges, activity types, and quota before execution"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-observability-extract.sh",
            "timeout": 30000,
            "description": "Validate quota and date range before bulk export"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__marketo__campaign_create|mcp__marketo__campaign_clone",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-campaign-create.sh",
            "timeout": 15000,
            "description": "Verify Marketo campaign create and clone results"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__bulk_lead_import_status",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-bulk-import.sh",
            "timeout": 15000,
            "description": "Summarize completed Marketo bulk import results"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-instance-authentication.sh",
            "timeout": 30000,
            "description": "Auto-detect instance customizations after authentication"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-operation-verification.sh",
            "timeout": 15000,
            "description": "Verify operation success and capture metrics"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/api-limit-monitor.sh",
            "timeout": 10000,
            "description": "Track API usage and warn on thresholds"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__sync_*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sync-error-monitor.sh",
            "timeout": 15000,
            "description": "Monitor Salesforce sync errors"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__bulk_lead_export_status|mcp__marketo__bulk_activity_export_status|mcp__marketo__bulk_program_member_export_status",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-extract-complete.sh",
            "timeout": 30000,
            "description": "Trigger normalization and analysis after export completes"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__bulk_*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/observability-quota-monitor.sh",
            "timeout": 10000,
            "description": "Monitor bulk export quota usage and alert on thresholds"
          }
        ]
      },
      {
        "matcher": "mcp__marketo__campaign_*|mcp__marketo__lead_activities",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/campaign-diagnostic-reminder.sh",
            "timeout": 10000,
            "description": "Suggest /diagnose-campaign when campaign issues detected"
          }
        ]
      }
    ]
  }
}
